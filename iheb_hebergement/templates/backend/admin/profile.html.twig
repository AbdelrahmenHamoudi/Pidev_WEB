{% extends 'backend/baseend.html.twig' %}

{% block title %}Profil Admin - RE7LA Admin{% endblock %}

{% block breadcrumb %}Profil{% endblock %}
{% block page_title %}Mon Profil{% endblock %}

{% block body %}
<!-- Profile Header -->
<div style="background:linear-gradient(135deg,#1ABC9C 0%,#16a085 50%,#2C3E50 100%);border-radius:20px;padding:40px;color:#fff;position:relative;overflow:hidden;margin-bottom:30px;">
  <div style="position:absolute;top:-50px;right:-50px;width:200px;height:200px;background:rgba(255,255,255,0.1);border-radius:50%;"></div>
  <div style="position:absolute;bottom:-30px;left:-30px;width:150px;height:150px;background:rgba(255,255,255,0.05);border-radius:50%;"></div>
  
  <div style="display:flex;align-items:center;justify-content:space-between;position:relative;z-index:1;">
    <div style="display:flex;align-items:center;gap:24px;">
      <div style="width:120px;height:120px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 10px 30px rgba(0,0,0,0.2);border:4px solid rgba(255,255,255,0.2);">
        <i class="fas fa-user-shield" style="font-size:48px;color:#1ABC9C;"></i>
      </div>
      <div>
        <h1 style="font-size:28px;font-weight:700;margin-bottom:8px;">Administrateur RE7LA</h1>
        <p style="font-size:16px;opacity:0.9;margin-bottom:4px;"><i class="fas fa-envelope" style="margin-right:8px;"></i>admin@re7la.ma</p>
        <p style="font-size:14px;opacity:0.8;"><i class="fas fa-shield-alt" style="margin-right:8px;"></i>Super Administrateur</p>
      </div>
    </div>
    <button onclick="document.getElementById('editForm').scrollIntoView({behavior: 'smooth'})" style="background:#fff;color:#1ABC9C;border:none;padding:12px 24px;border-radius:12px;font-weight:600;cursor:pointer;transition:all 0.3s;display:flex;align-items:center;gap:8px;">
      <i class="fas fa-edit"></i>
      Modifier
    </button>
  </div>
</div>

<div style="display:grid;grid-template-columns:1fr 2fr;gap:24px;">
  <!-- Left Column - Info Cards -->
  <div style="display:flex;flex-direction:column;gap:24px;">
    <!-- Personal Info Card -->
    <div style="background:#fff;border-radius:20px;padding:24px;box-shadow:0 4px 20px rgba(0,0,0,0.08);border:1px solid #f0f2f5;">
      <h3 style="font-size:18px;font-weight:700;color:#2C3E50;margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid #f0f2f5;display:flex;align-items:center;gap:8px;">
        <i class="fas fa-user" style="color:#1ABC9C;"></i>
        Informations Personnelles
      </h3>
      
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="width:40px;height:40px;background:rgba(26,188,156,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-id-card" style="color:#1ABC9C;font-size:16px;"></i>
          </div>
          <div>
            <div style="font-size:12px;color:#64748b;">Nom complet</div>
            <div style="font-weight:600;color:#2C3E50;">Administrateur RE7LA</div>
          </div>
        </div>
        
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="width:40px;height:40px;background:rgba(243,156,18,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-envelope" style="color:#F39C12;font-size:16px;"></i>
          </div>
          <div>
            <div style="font-size:12px;color:#64748b;">Email</div>
            <div style="font-weight:600;color:#2C3E50;">admin@re7la.ma</div>
          </div>
        </div>
        
        <div style="display:flex;align-items-center;gap:12px;">
          <div style="width:40px;height:40px;background:rgba(239,68,68,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-phone" style="color:#ef4444;font-size:16px;"></i>
          </div>
          <div>
            <div style="font-size:12px;color:#64748b;">Téléphone</div>
            <div style="font-weight:600;color:#2C3E50;">+212 6XX-XXXXXX</div>
          </div>
        </div>
        
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="width:40px;height:40px;background:rgba(139,92,246,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-map-marker-alt" style="color:#8b5cf6;font-size:16px;"></i>
          </div>
          <div>
            <div style="font-size:12px;color:#64748b;">Localisation</div>
            <div style="font-weight:600;color:#2C3E50;">Casablanca, Maroc</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Security Card -->
    <div style="background:#fff;border-radius:20px;padding:24px;box-shadow:0 4px 20px rgba(0,0,0,0.08);border:1px solid #f0f2f5;">
      <h3 style="font-size:18px;font-weight:700;color:#2C3E50;margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid #f0f2f5;display:flex;align-items:center;gap:8px;">
        <i class="fas fa-shield-alt" style="color:#1ABC9C;"></i>
        Sécurité
      </h3>
      
      <div style="display:flex;flex-direction:column;gap:16px;">
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="width:40px;height:40px;background:rgba(34,197,94,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-check-circle" style="color:#22c55e;font-size:16px;"></i>
          </div>
          <div style="flex:1;">
            <div style="font-size:12px;color:#64748b;">Statut du compte</div>
            <div style="font-weight:600;color:#2C3E50;">Actif</div>
          </div>
          <span style="background:rgba(34,197,94,0.15);color:#22c55e;padding:4px 12px;border-radius:20px;font-size:11px;font-weight:600;">Vérifié</span>
        </div>
        
        <div style="display:flex;align-items:center;gap:12px;">
          <div style="width:40px;height:40px;background:rgba(59,130,246,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-clock" style="color:#3b82f6;font-size:16px;"></i>
          </div>
          <div>
            <div style="font-size:12px;color:#64748b;">Dernière connexion</div>
            <div style="font-weight:600;color:#2C3E50;">Aujourd'hui, 14:32</div>
          </div>
        </div>
        
        <div style="display:flex;align-items-center;gap:12px;">
          <div style="width:40px;height:40px;background:rgba(239,68,68,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-fingerprint" style="color:#ef4444;font-size:16px;"></i>
          </div>
          <div style="flex:1;">
            <div style="font-size:12px;color:#64748b;">Authentification 2FA</div>
            <div style="font-weight:600;color:#2C3E50;">Désactivée</div>
          </div>
          <button style="background:linear-gradient(135deg,#1ABC9C,#16a085);color:#fff;border:none;padding:6px 12px;border-radius:8px;font-size:11px;font-weight:500;cursor:pointer;">Activer</button>
        </div>
      </div>
    </div>

    <!-- Quick Stats -->
    <div style="background:#fff;border-radius:20px;padding:24px;box-shadow:0 4px 20px rgba(0,0,0,0.08);border:1px solid #f0f2f5;">
      <h3 style="font-size:18px;font-weight:700;color:#2C3E50;margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid #f0f2f5;display:flex;align-items:center;gap:8px;">
        <i class="fas fa-chart-line" style="color:#1ABC9C;"></i>
        Activité
      </h3>
      
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div style="text-align:center;padding:16px;background:rgba(26,188,156,0.05);border-radius:12px;">
          <div style="font-size:24px;font-weight:700;color:#1ABC9C;">142</div>
          <div style="font-size:12px;color:#64748b;">Réservations</div>
        </div>
        <div style="text-align:center;padding:16px;background:rgba(243,156,18,0.05);border-radius:12px;">
          <div style="font-size:24px;font-weight:700;color:#F39C12;">36</div>
          <div style="font-size:12px;color:#64748b;">Hébergements</div>
        </div>
        <div style="text-align:center;padding:16px;background:rgba(34,197,94,0.05);border-radius:12px;">
          <div style="font-size:24px;font-weight:700;color:#22c55e;">89%</div>
          <div style="font-size:12px;color:#64748b;">Satisfaction</div>
        </div>
        <div style="text-align:center;padding:16px;background:rgba(139,92,246,0.05);border-radius:12px;">
          <div style="font-size:24px;font-weight:700;color:#8b5cf6;">24/7</div>
          <div style="font-size:12px;color:#64748b;">Disponibilité</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Right Column - Edit Form -->
  <div>
    <div style="background:#fff;border-radius:20px;padding:32px;box-shadow:0 4px 20px rgba(0,0,0,0.08);border:1px solid #f0f2f5;" id="editForm">
      <h3 style="font-size:20px;font-weight:700;color:#2C3E50;margin-bottom:24px;display:flex;align-items:center;gap:8px;">
        <i class="fas fa-user-edit" style="color:#1ABC9C;"></i>
        Modifier le profil
      </h3>
      
      <form>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px;margin-bottom:24px;">
          <div>
            <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:14px;">Prénom</label>
            <input type="text" value="Administrateur" style="width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#f8fafc;">
          </div>
          <div>
            <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:14px;">Nom</label>
            <input type="text" value="RE7LA" style="width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#f8fafc;">
          </div>
          <div>
            <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:14px;">Email</label>
            <input type="email" value="admin@re7la.ma" style="width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#f8fafc;">
          </div>
          <div>
            <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:14px;">Téléphone</label>
            <input type="tel" value="+212 6XX-XXXXXX" style="width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#f8fafc;">
          </div>
          <div style="grid-column:1/-1;">
            <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:14px;">Adresse</label>
            <input type="text" value="Casablanca, Maroc" style="width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#f8fafc;">
          </div>
          <div style="grid-column:1/-1;">
            <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:14px;">Bio</label>
            <textarea rows="3" style="width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#f8fafc;min-height:80px;resize:vertical;">Administrateur principal de la plateforme RE7LA.</textarea>
          </div>
        </div>

        <div style="padding:20px 0;border-top:1px solid #f0f2f5;border-bottom:1px solid #f0f2f5;margin:24px 0;">
          <h4 style="font-size:16px;font-weight:700;color:#2C3E50;margin-bottom:16px;display:flex;align-items:center;gap:8px;">
            <i class="fas fa-lock" style="color:#ef4444;"></i>
            Changer le mot de passe
          </h4>
          
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px;">
            <div>
              <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:14px;">Mot de passe actuel</label>
              <input type="password" placeholder="••••••••" style="width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#f8fafc;">
            </div>
            <div>
              <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:14px;">Nouveau mot de passe</label>
              <input type="password" placeholder="••••••••" style="width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#f8fafc;">
            </div>
            <div>
              <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:14px;">Confirmer le mot de passe</label>
              <input type="password" placeholder="••••••••" style="width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#f8fafc;">
            </div>
          </div>
        </div>

        <div style="display:flex;gap:12px;">
          <button type="button" style="background:#fff;color:#64748b;border:2px solid #e8ecf0;padding:12px 24px;border-radius:12px;font-weight:500;cursor:pointer;transition:all 0.3s;">
            Annuler
          </button>
          <button type="submit" style="background:linear-gradient(135deg,#1ABC9C,#16a085);color:#fff;border:none;padding:12px 24px;border-radius:12px;font-weight:500;cursor:pointer;transition:all 0.3s;display:flex;align-items:center;gap:8px;">
            <i class="fas fa-save"></i>
            Enregistrer les modifications
          </button>
        </div>
      </form>
    </div>

    <!-- Recent Activity -->
    <div style="background:#fff;border-radius:20px;padding:32px;box-shadow:0 4px 20px rgba(0,0,0,0.08);border:1px solid #f0f2f5;margin-top:24px;">
      <h3 style="font-size:20px;font-weight:700;color:#2C3E50;margin-bottom:24px;display:flex;align-items:center;gap:8px;">
        <i class="fas fa-history" style="color:#1ABC9C;"></i>
        Activité récente
      </h3>
      
      <div style="display:flex;flex-direction:column;gap:12px;">
        <div style="display:flex;align-items:center;gap:12px;padding:16px;background:#f8fafc;border-radius:12px;">
          <div style="width:8px;height:8px;background:#22c55e;border-radius:50%;"></div>
          <div style="flex:1;">
            <div style="font-weight:600;color:#2C3E50;">Connexion réussie</div>
            <div style="font-size:12px;color:#64748b;">Aujourd'hui, 14:32</div>
          </div>
        </div>
        
        <div style="display:flex;align-items-center;gap:12px;padding:16px;background:#f8fafc;border-radius:12px;">
          <div style="width:8px;height:8px;background:#1ABC9C;border-radius:50%;"></div>
          <div style="flex:1;">
            <div style="font-weight:600;color:#2C3E50;">Modification du profil</div>
            <div style="font-size:12px;color:#64748b;">Hier, 16:45</div>
          </div>
        </div>
        
        <div style="display:flex;align-items-center;gap:12px;padding:16px;background:#f8fafc;border-radius:12px;">
          <div style="width:8px;height:8px;background:#1ABC9C;border-radius:50%;"></div>
          <div style="flex:1;">
            <div style="font-weight:600;color:#2C3E50;">Nouvelle réservation créée</div>
            <div style="font-size:12px;color:#64748b;">Hier, 10:22</div>
          </div>
        </div>
        
        <div style="display:flex;align-items-center;gap:12px;padding:16px;background:#f8fafc;border-radius:12px;">
          <div style="width:8px;height:8px;background:#ef4444;border-radius:50%;"></div>
          <div style="flex:1;">
            <div style="font-weight:600;color:#2C3E50;">Tentative de connexion échouée</div>
            <div style="font-size:12px;color:#64748b;">Il y a 3 jours</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  input:focus, textarea:focus {
    outline: none;
    border-color: #1ABC9C !important;
    background: #fff !important;
    box-shadow: 0 0 0 3px rgba(26,188,156,0.1) !important;
  }
  
  button:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(26,188,156,0.3);
  }
  
  .activity-item:hover {
    background: rgba(26,188,156,0.05) !important;
  }
</style>
{% endblock %}
