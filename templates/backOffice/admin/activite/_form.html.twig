<style>
:root {
  --orange: #F39C12;
  --yellow: #F7DC6F;
  --dark:   #2C3E50;
  --teal:   #1ABC9C;
  --bg:     #1e2d3d;
  --bg2:    #243447;
  --bg3:    #2d4059;
  --border: rgba(255,255,255,0.08);
  --text:   #e8edf2;
  --muted:  #8fa3b8;
}

@keyframes fadeUp   { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
@keyframes glow     { 0%,100%{box-shadow:0 0 0 0 rgba(26,188,156,0)} 50%{box-shadow:0 0 20px 4px rgba(26,188,156,0.18)} }
@keyframes shimmer  { 0%{background-position:-600px 0} 100%{background-position:600px 0} }
@keyframes badgePop { 0%{transform:scale(0)} 60%{transform:scale(1.15)} 100%{transform:scale(1)} }
@keyframes float    { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-5px)} }
@keyframes gradientShift { 0%{background-position:0% 50%} 50%{background-position:100% 50%} 100%{background-position:0% 50%} }
@keyframes ripple   { 0%{transform:scale(0);opacity:1} 100%{transform:scale(4);opacity:0} }

.r7f-wrap {
  max-width: 820px;
  font-family: 'Segoe UI', system-ui, sans-serif;
}

/* ── Page header ── */
.r7f-header {
  background: linear-gradient(135deg, var(--dark) 0%, #1a2d40 60%, #0f3d35 100%);
  background-size: 200% 200%;
  animation: gradientShift 8s ease infinite;
  border-radius: 20px;
  padding: 32px 36px;
  margin-bottom: 24px;
  position: relative;
  overflow: hidden;
  animation: fadeUp 0.6s ease both, gradientShift 8s ease infinite;
}
.r7f-header::before {
  content: '';
  position: absolute; top: -40px; right: -40px;
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(26,188,156,0.15) 0%, transparent 70%);
  border-radius: 50%;
}
.r7f-header::after {
  content: '';
  position: absolute; bottom: -30px; left: 200px;
  width: 150px; height: 150px;
  background: radial-gradient(circle, rgba(243,156,18,0.1) 0%, transparent 70%);
  border-radius: 50%;
}
.r7f-header-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(26,188,156,0.2);
  border: 1px solid rgba(26,188,156,0.4);
  color: #1ABC9C; font-size: 10px; font-weight: 700;
  padding: 5px 14px; border-radius: 20px;
  margin-bottom: 10px;
  letter-spacing: 1px; text-transform: uppercase;
  animation: badgePop 0.5s 0.3s ease both;
}
.r7f-header h2 {
  font-size: 1.7rem; font-weight: 800; color: white;
  margin: 0 0 6px; line-height: 1.2;
}
.r7f-header p { font-size: 13px; color: rgba(255,255,255,0.55); margin: 0; }

/* ── Error box ── */
.r7f-errors {
  background: rgba(239,68,68,0.12);
  border: 1.5px solid rgba(239,68,68,0.3);
  color: #fca5a5;
  padding: 14px 18px; border-radius: 14px;
  margin-bottom: 20px; font-size: 13px;
  animation: fadeUp 0.4s ease both;
}
.r7f-errors ul { margin: 8px 0 0 16px; }

/* ── Section cards ── */
.r7f-card {
  background: var(--bg2);
  border: 1.5px solid var(--border);
  border-radius: 20px;
  padding: 28px 32px;
  margin-bottom: 20px;
  position: relative; overflow: hidden;
  animation: fadeUp 0.6s ease both;
  transition: border-color 0.3s;
}
.r7f-card:hover { border-color: rgba(26,188,156,0.25); }
.r7f-card::before {
  content: '';
  position: absolute; top: 0; left: 0;
  width: 4px; height: 100%;
  background: linear-gradient(180deg, var(--teal), var(--orange));
  border-radius: 4px 0 0 4px;
}

.r7f-card-title {
  font-size: 13px; font-weight: 700; color: var(--text);
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 4px;
}
.r7f-card-title .icon {
  width: 32px; height: 32px; border-radius: 10px;
  background: rgba(26,188,156,0.15);
  display: flex; align-items: center; justify-content: center;
}
.r7f-card-sub { font-size: 11px; color: var(--muted); margin-bottom: 22px; padding-left: 42px; }

/* ── Grid ── */
.r7f-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18px;
}
.r7f-full { grid-column: 1 / -1; }

/* ── Labels ── */
.r7f-label {
  display: block;
  font-size: 11px; font-weight: 700;
  color: var(--muted);
  margin-bottom: 7px;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

/* ── Inputs ── */
.r7f-input, .r7f-textarea {
  width: 100%;
  background: var(--bg3);
  border: 1.5px solid rgba(255,255,255,0.07);
  border-radius: 12px;
  color: var(--text);
  font-size: 13px;
  padding: 11px 15px;
  outline: none;
  transition: all 0.25s;
  font-family: inherit;
  box-sizing: border-box;
}
.r7f-input::placeholder, .r7f-textarea::placeholder { color: rgba(255,255,255,0.2); }
.r7f-input:focus, .r7f-textarea:focus {
  border-color: var(--teal);
  background: #32505e;
  box-shadow: 0 0 0 3px rgba(26,188,156,0.12);
}
.r7f-input:hover, .r7f-textarea:hover { border-color: rgba(255,255,255,0.15); }
.r7f-textarea { resize: vertical; min-height: 100px; line-height: 1.6; }

/* Force les widgets Twig à hériter du style */
.r7f-field input,
.r7f-field textarea,
.r7f-field select {
  width: 100%;
  background: var(--bg3);
  border: 1.5px solid rgba(255,255,255,0.07);
  border-radius: 12px;
  color: var(--text);
  font-size: 13px;
  padding: 11px 15px;
  outline: none;
  transition: all 0.25s;
  font-family: inherit;
  box-sizing: border-box;
}
.r7f-field input:focus,
.r7f-field textarea:focus,
.r7f-field select:focus {
  border-color: var(--teal);
  background: #32505e;
  box-shadow: 0 0 0 3px rgba(26,188,156,0.12);
}
.r7f-field .form-error,
.r7f-field ul.form-errors,
.r7f-field ul li {
  color: #fca5a5; font-size: 11px; margin-top: 5px; list-style: none; padding: 0;
}

/* ── Upload zone ── */
.r7f-upload-zone {
  border: 2px dashed rgba(26,188,156,0.3);
  border-radius: 14px;
  background: rgba(26,188,156,0.04);
  padding: 20px;
  transition: all 0.3s;
  cursor: pointer;
}
.r7f-upload-zone:hover {
  border-color: var(--teal);
  background: rgba(26,188,156,0.08);
  animation: glow 1.5s ease-in-out infinite;
}
.r7f-upload-zone input[type="file"] {
  width: 100%;
  background: transparent;
  border: none;
  color: var(--muted);
  font-size: 12px;
  cursor: pointer;
  outline: none;
}
.r7f-upload-hint {
  font-size: 11px; color: var(--muted);
  margin-top: 8px; display: flex; align-items: center; gap: 6px;
}

/* ── Preview image ── */
.r7f-preview-row { display: flex; gap: 14px; align-items: center; margin-bottom: 12px; flex-wrap: wrap; }
.r7f-preview-img {
  height: 72px; border-radius: 12px; object-fit: cover;
  border: 2px solid rgba(26,188,156,0.3);
  animation: fadeUp 0.4s ease;
}
.r7f-preview-tag {
  background: rgba(26,188,156,0.15);
  border: 1px solid rgba(26,188,156,0.3);
  color: var(--teal); font-size: 10px; font-weight: 700;
  padding: 4px 10px; border-radius: 20px;
}

/* ── Stat chips ── */
.r7f-chips { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 6px; }
.r7f-chip {
  background: rgba(243,156,18,0.1);
  border: 1px solid rgba(243,156,18,0.25);
  color: var(--yellow); font-size: 10px; font-weight: 700;
  padding: 4px 12px; border-radius: 20px;
  letter-spacing: 0.5px;
}

/* ── Progress bar ── */
.r7f-progress-bar {
  height: 3px; background: rgba(255,255,255,0.06);
  border-radius: 3px; margin: 20px 0 0;
  overflow: hidden;
}
.r7f-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--teal), var(--orange));
  border-radius: 3px;
  transition: width 0.4s ease;
}

/* ── Buttons ── */
.r7f-actions { display: flex; gap: 12px; margin-top: 6px; }

.r7f-btn-primary {
  display: inline-flex; align-items: center; gap: 8px;
  background: linear-gradient(135deg, var(--orange), #e67e22);
  background-size: 200% 200%;
  color: white; border: none;
  padding: 13px 32px; border-radius: 50px;
  font-size: 13px; font-weight: 700;
  cursor: pointer; transition: all 0.3s;
  position: relative; overflow: hidden;
  letter-spacing: 0.3px;
}
.r7f-btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(243,156,18,0.35);
  animation: gradientShift 2s ease infinite;
}
.r7f-btn-primary:active { transform: scale(0.97); }

.r7f-btn-cancel {
  display: inline-flex; align-items: center; gap: 8px;
  background: rgba(255,255,255,0.05);
  border: 1.5px solid rgba(255,255,255,0.1);
  color: var(--muted);
  padding: 13px 24px; border-radius: 50px;
  font-size: 13px; font-weight: 600;
  text-decoration: none; transition: all 0.25s;
}
.r7f-btn-cancel:hover {
  background: rgba(255,255,255,0.08);
  border-color: rgba(255,255,255,0.2);
  color: var(--text);
}

.r7f-ripple {
  position: absolute; border-radius: 50%;
  background: rgba(255,255,255,0.25);
  width: 20px; height: 20px;
  animation: ripple 0.6s linear;
  pointer-events: none;
}

/* ── Tip box ── */
.r7f-tip {
  background: rgba(247,220,111,0.07);
  border: 1px solid rgba(247,220,111,0.2);
  border-radius: 14px;
  padding: 14px 18px;
  font-size: 12px; color: rgba(247,220,111,0.8);
  display: flex; gap: 10px; align-items: flex-start;
  margin-bottom: 20px;
  animation: fadeUp 0.6s 0.5s ease both;
}
</style>

<div class="r7f-wrap">

  {# ── Page header ── #}
  <div class="r7f-header">
    <div class="r7f-header-badge">
      <svg width="8" height="8" viewBox="0 0 8 8"><circle cx="4" cy="4" r="4" fill="#1ABC9C"/></svg>
      RE7LA — Gestion des activités
    </div>
    <h2>
      {% if activite.idActivite %}
        Modifier l'activité
      {% else %}
        Créer une nouvelle activité
      {% endif %}
    </h2>
    <p>Remplissez les informations ci-dessous pour publier votre activité</p>
  </div>

  {# ── Tip ── #}
  <div class="r7f-tip">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#F7DC6F" stroke-width="2" style="flex-shrink:0;margin-top:1px;"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
    <span>Une bonne description et une image attrayante augmentent significativement le taux de réservation de votre activité.</span>
  </div>

  {# ── Erreurs de validation ── #}
  {% if form.vars.errors|length > 0 %}
  <div class="r7f-errors">
    <strong>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="vertical-align:-2px;margin-right:4px;"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><path d="M12 9v4M12 17h.01"/></svg>
      Veuillez corriger les erreurs suivantes :
    </strong>
    <ul>
      {% for error in form.vars.errors %}
        <li>{{ error.message }}</li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}

  {{ form_start(form, {attr: {enctype: 'multipart/form-data', id: 'r7f-form'}}) }}

  {# ── Card 1 : Informations générales ── #}
  <div class="r7f-card" style="animation-delay:0.1s;">
    <div class="r7f-card-title">
      <div class="icon">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#1ABC9C" stroke-width="2.2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      </div>
      Informations générales
    </div>
    <div class="r7f-card-sub">Nom, description et localisation de l'activité</div>

    <div class="r7f-grid">

      {# Nom #}
      <div class="r7f-full r7f-field">
        {{ form_label(form.nomA, 'Nom de l\'activité', {label_attr: {class: 'r7f-label'}}) }}
        {{ form_widget(form.nomA, {attr: {class: 'r7f-input', placeholder: 'Ex : Randonnée à Aïn Draham'}}) }}
        {{ form_errors(form.nomA) }}
      </div>

      {# Description #}
      <div class="r7f-full r7f-field">
        {{ form_label(form.descriptionA, 'Description', {label_attr: {class: 'r7f-label'}}) }}
        {{ form_widget(form.descriptionA, {attr: {class: 'r7f-textarea', placeholder: 'Décrivez l\'activité, ce que les participants vivront...', rows: 4}}) }}
        {{ form_errors(form.descriptionA) }}
      </div>

      {# Lieu #}
      <div class="r7f-field">
        {{ form_label(form.lieu, 'Lieu', {label_attr: {class: 'r7f-label'}}) }}
        {{ form_widget(form.lieu, {attr: {class: 'r7f-input', placeholder: 'Ex : Aïn Draham, Jendouba'}}) }}
        {{ form_errors(form.lieu) }}
      </div>

      {# Vide pour équilibre #}
      <div></div>

    </div>
  </div>

  {# ── Card 2 : Tarif & Capacité ── #}
  <div class="r7f-card" style="animation-delay:0.2s;">
    <div class="r7f-card-title">
      <div class="icon" style="background:rgba(243,156,18,0.15);">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#F39C12" stroke-width="2.2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
      </div>
      Tarif &amp; Capacité
    </div>
    <div class="r7f-card-sub">Définissez le prix et le nombre de places disponibles</div>

    <div class="r7f-grid">

      {# Prix #}
      <div class="r7f-field">
        {{ form_label(form.prixParPersonne, 'Prix par personne (DT)', {label_attr: {class: 'r7f-label'}}) }}
        <div style="position:relative;">
          {{ form_widget(form.prixParPersonne, {attr: {class: 'r7f-input', placeholder: '0', style: 'padding-right:44px;'}}) }}
          <span style="position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:11px;font-weight:700;color:var(--teal);">DT</span>
        </div>
        {{ form_errors(form.prixParPersonne) }}
      </div>

      {# Capacité #}
      <div class="r7f-field">
        {{ form_label(form.capaciteMax, 'Capacité maximale', {label_attr: {class: 'r7f-label'}}) }}
        <div style="position:relative;">
          {{ form_widget(form.capaciteMax, {attr: {class: 'r7f-input', placeholder: '20', style: 'padding-right:54px;'}}) }}
          <span style="position:absolute;right:14px;top:50%;transform:translateY(-50%);font-size:11px;font-weight:700;color:var(--muted);">pers.</span>
        </div>
        {{ form_errors(form.capaciteMax) }}
      </div>

    </div>

    <div class="r7f-chips" style="margin-top:16px;">
      <span class="r7f-chip">💡 Prix recommandé : 50–300 DT</span>
      <span class="r7f-chip">👥 Groupe idéal : 8–20 pers.</span>
    </div>
  </div>
{# ── Card 3 : Type & Statut ── #}
<div class="r7f-card" style="animation-delay:0.25s;">
  <div class="r7f-card-title">
    <div class="icon" style="background:rgba(26,188,156,0.15);">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#1ABC9C" stroke-width="2.2">
        <circle cx="12" cy="12" r="10"/>
        <path d="M8 12l2 2 4-4"/>
      </svg>
    </div>
    Type & Statut
  </div>
  <div class="r7f-card-sub">Définissez la catégorie et la disponibilité</div>

  <div class="r7f-grid">

    {# Type #}
    <div class="r7f-field">
      {{ form_label(form.type, "Type d'activité", {label_attr: {class: 'r7f-label'}}) }}
      {{ form_widget(form.type, {attr: {class: 'r7f-input'}}) }}
      {{ form_errors(form.type) }}
    </div>

    {# Statut #}
    <div class="r7f-field">
      {{ form_label(form.statut, "Statut", {label_attr: {class: 'r7f-label'}}) }}
      {{ form_widget(form.statut, {attr: {class: 'r7f-input'}}) }}
      {{ form_errors(form.statut) }}
    </div>

  </div>
</div>
  {# ── Card 3 : Image ── #}
  <div class="r7f-card" style="animation-delay:0.3s;">
    <div class="r7f-card-title">
      <div class="icon" style="background:rgba(247,220,111,0.12);">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#F7DC6F" stroke-width="2.2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
      </div>
      Photo de l'activité
    </div>
    <div class="r7f-card-sub">Une belle photo augmente les réservations</div>

    {# Prévisualisations #}
    <div class="r7f-preview-row">
      {% if activite.image %}
        <img src="{{ asset('uploads/activites/' ~ activite.image) }}"
             class="r7f-preview-img" alt="Image actuelle">
        <span class="r7f-preview-tag">Photo actuelle</span>
      {% endif %}
      <img id="r7f-preview" src="#" alt="Aperçu" class="r7f-preview-img" style="display:none;">
      <span id="r7f-preview-tag" class="r7f-preview-tag" style="display:none;background:rgba(243,156,18,0.15);border-color:rgba(243,156,18,0.3);color:var(--orange);">Nouvelle photo</span>
    </div>

    {# Zone upload #}
    <div class="r7f-upload-zone" onclick="document.getElementById('r7f-file-input').click();">
      <div style="display:flex;align-items:center;gap:12px;margin-bottom:10px;">
        <div style="width:40px;height:40px;border-radius:12px;background:rgba(26,188,156,0.12);display:flex;align-items:center;justify-content:center;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1ABC9C" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        </div>
        <div>
          <div style="font-size:13px;font-weight:600;color:var(--text);">Glissez une image ou cliquez pour parcourir</div>
          <div style="font-size:11px;color:var(--muted);">JPG, PNG — max 2 Mo</div>
        </div>
      </div>
      <div class="r7f-field" style="pointer-events:none;opacity:0;height:0;overflow:hidden;">
        {{ form_widget(form.imageFile, {attr: {id: 'r7f-file-input', accept: 'image/*', onchange: 'r7fPreview(event)', style: 'pointer-events:all;opacity:1;'}}) }}
      </div>
      {# Vrai input file visible #}
      <input type="file" id="r7f-file-trigger" accept="image/*" onchange="r7fPreview(event)"
             style="display:none;">
    </div>
    <div class="r7f-upload-hint">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
      Format paysage recommandé (16:9) pour un meilleur rendu
    </div>
    {{ form_errors(form.imageFile) }}
  </div>

  {# ── Barre de progression simulée ── #}
  <div style="margin-bottom:20px;">
    <div style="display:flex;justify-content:space-between;font-size:11px;color:var(--muted);margin-bottom:6px;">
      <span>Complétion du formulaire</span>
      <span id="r7f-pct">0%</span>
    </div>
    <div class="r7f-progress-bar">
      <div class="r7f-progress-fill" id="r7f-fill" style="width:0%;"></div>
    </div>
  </div>

  {# ── Boutons ── #}
  <div class="r7f-actions">
    <button type="submit" class="r7f-btn-primary" id="r7f-submit">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v14a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
      {{ activite.idActivite ? 'Enregistrer les modifications' : 'Créer l\'activité' }}
    </button>
    <a href="{{ path('activite_index') }}" class="r7f-btn-cancel">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6L6 18M6 6l12 12"/></svg>
      Annuler
    </a>
  </div>

  {{ form_end(form) }}

</div>

<script>
/* ── Aperçu image ── */
function r7fPreview(e) {
  var file = e.target.files[0];
  if (!file) return;
  var reader = new FileReader();
  reader.onload = function(ev) {
    var img = document.getElementById('r7f-preview');
    var tag = document.getElementById('r7f-preview-tag');
    img.src = ev.target.result;
    img.style.display = 'block';
    tag.style.display = 'inline-block';
  };
  reader.readAsDataURL(file);
  updateProgress();
}

/* ── Clic zone upload → déclenche le vrai input Symfony ── */
document.querySelector('.r7f-upload-zone').addEventListener('click', function(e) {
  e.stopPropagation();
  var realInput = document.getElementById('r7f-file-input') ||
                  document.querySelector('input[type="file"]');
  if (realInput) realInput.click();
});

/* ── Drag & drop ── */
var zone = document.querySelector('.r7f-upload-zone');
zone.addEventListener('dragover', function(e) { e.preventDefault(); zone.style.borderColor = '#1ABC9C'; });
zone.addEventListener('dragleave', function()  { zone.style.borderColor = 'rgba(26,188,156,0.3)'; });
zone.addEventListener('drop', function(e) {
  e.preventDefault();
  zone.style.borderColor = 'rgba(26,188,156,0.3)';
  var file = e.dataTransfer.files[0];
  if (file && file.type.startsWith('image/')) {
    var realInput = document.getElementById('r7f-file-input') ||
                    document.querySelector('input[type="file"]');
    if (realInput) {
      var dt = new DataTransfer();
      dt.items.add(file);
      realInput.files = dt.files;
      r7fPreview({ target: realInput });
    }
  }
});

/* ── Barre de progression ── */
function updateProgress() {
  var inputs = document.querySelectorAll('#r7f-form input:not([type=hidden]):not([type=file]), #r7f-form textarea');
  var filled = 0;
  inputs.forEach(function(el) { if (el.value.trim() !== '') filled++; });
  var fileInput = document.getElementById('r7f-file-input') || document.querySelector('input[type="file"]');
  var hasFile = fileInput && fileInput.files && fileInput.files.length > 0;
  var total = inputs.length + 1;
  var pct = Math.round(((filled + (hasFile ? 1 : 0)) / total) * 100);
  document.getElementById('r7f-fill').style.width = pct + '%';
  document.getElementById('r7f-pct').textContent = pct + '%';
}
document.querySelectorAll('#r7f-form input, #r7f-form textarea').forEach(function(el) {
  el.addEventListener('input', updateProgress);
});
updateProgress();

/* ── Ripple sur bouton submit ── */
document.getElementById('r7f-submit').addEventListener('click', function(e) {
  var rect = this.getBoundingClientRect();
  var r = document.createElement('span');
  r.className = 'r7f-ripple';
  r.style.left = (e.clientX - rect.left - 10) + 'px';
  r.style.top  = (e.clientY - rect.top  - 10) + 'px';
  this.appendChild(r);
  setTimeout(function() { r.remove(); }, 600);
});
</script>
