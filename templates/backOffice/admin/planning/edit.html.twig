{% extends 'backend/baseend.html.twig' %}

{% block title %}RE7LA Admin — Modifier Planning{% endblock %}
{% block breadcrumb %}Activités / Plannings / Modifier{% endblock %}
{% block page_title %}Modifier le planning{% endblock %}

{% block body %}

<div class="card" style="max-width:600px;margin:0 auto;">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;">
        <div>
            <div class="card-title">Modifier le planning</div>
            <div class="card-sub">Modifiez les informations du planning</div>
        </div>
        <a href="{{ path('planning_index', {idActivite: planning.activite.idActivite}) }}"
           style="background:#f0f2f5;color:#64748b;padding:10px 16px;border-radius:10px;
                  font-size:13px;font-weight:600;text-decoration:none;">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
    </div>

    {{ form_start(form) }}

    <div style="display:flex;flex-direction:column;gap:16px;">

        <div>
            {{ form_label(form.activite) }}
            {{ form_widget(form.activite, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.activite) }}
        </div>

        <div>
            {{ form_label(form.datePlanning) }}
            {{ form_widget(form.datePlanning, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.datePlanning) }}
        </div>

        <div style="display:flex;gap:16px;">
            <div style="flex:1;">
                {{ form_label(form.heureDebut) }}
                {{ form_widget(form.heureDebut, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.heureDebut) }}
            </div>
            <div style="flex:1;">
                {{ form_label(form.heureFin) }}
                {{ form_widget(form.heureFin, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.heureFin) }}
            </div>
        </div>

        <div>
            {{ form_label(form.nbPlacesRestantes) }}
            {{ form_widget(form.nbPlacesRestantes, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.nbPlacesRestantes) }}
        </div>

        <div>
            {{ form_label(form.etat) }}
            {{ form_widget(form.etat, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.etat) }}
        </div>

    </div>

    <div style="display:flex;gap:10px;margin-top:24px;">
        <button type="submit"
                style="background:linear-gradient(135deg,#F7B731,#E6C050);color:#fff;
                       padding:10px 24px;border-radius:10px;border:none;
                       font-size:13px;font-weight:600;cursor:pointer;">
            <i class="fas fa-save"></i> Enregistrer
        </button>
        <a href="{{ path('planning_index', {idActivite: planning.activite.idActivite}) }}"
           style="background:#f0f2f5;color:#64748b;padding:10px 16px;border-radius:10px;
                  font-size:13px;font-weight:600;text-decoration:none;">
            Annuler
        </a>
    </div>

    {{ form_end(form) }}

</div>

{% endblock %}
