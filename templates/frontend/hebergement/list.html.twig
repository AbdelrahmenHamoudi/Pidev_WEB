{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}Nos Hébergements - RE7LA{% endblock %}

{% block body %}
<section class="py-5" style="background: #f8f9fa; min-height: 100vh;">
    <div class="container">
        <!-- Header -->
        <div class="text-center mb-5">
            <h2 style="font-weight: 700; color: #2c3e50;">
                <span style="color: #87CEEB;">Nos</span> Hébergements
            </h2>
            <p style="color: #777;">Découvrez nos meilleures offres d'hébergement</p>
        </div>

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 15px; border: none; background: rgba(147, 197, 114, 0.15); color: #5a9e3b;">
                <i class="bx bx-check-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 15px; border: none; background: rgba(231, 76, 60, 0.15); color: #c0392b;">
                <i class="bx bx-error-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <!-- Grid -->
        <div class="row g-4">
            {% for hebergement in hebergements %}
            <div class="col-md-6 col-lg-4">
                <div class="card border-0 overflow-hidden" style="border-radius: 25px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); transition: all 0.3s ease;">
                    <div class="position-relative">
                        {% set firstImage = hebergement.images|length > 0 ? hebergement.images[0].filename : hebergement.image %}
                        {% if firstImage %}
                            <img src="{{ asset(firstImage) }}" class="w-100" style="height: 250px; object-fit: cover;" alt="{{ hebergement.titre }}">
                        {% else %}
                            <div class="w-100 d-flex align-items-center justify-content-center" style="height: 250px; background: linear-gradient(135deg, #87CEEB, #93C572);">
                                <i class="bx bx-building-house" style="font-size: 5rem; color: white;"></i>
                            </div>
                        {% endif %}
                        <span style="position: absolute; top: 20px; left: 20px; background: linear-gradient(135deg, #87CEEB, #93C572); color: white; padding: 8px 20px; border-radius: 25px; font-weight: 600; font-size: 0.85rem;">
                            {{ hebergement.typeHebergement }}
                        </span>
                        <span style="position: absolute; top: 20px; right: 20px; background: rgba(255,255,255,0.9); padding: 8px 15px; border-radius: 25px; font-weight: 700; color: #87CEEB;">
                            {{ hebergement.prixParNuit }} DT<span style="font-size: 0.75rem; color: #999;">/nuit</span>
                        </span>
                    </div>
                    <div class="card-body p-4">
                        <h5 style="font-weight: 700; color: #2c3e50; margin-bottom: 10px;">{{ hebergement.titre }}</h5>
                        <p style="color: #777; font-size: 0.95rem; margin-bottom: 20px;">
                            {{ hebergement.descHebergement|slice(0, 80) }}{% if hebergement.descHebergement|length > 80 %}...{% endif %}
                        </p>
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <span style="color: #666;">
                                <i class="bx bx-user" style="color: #87CEEB;"></i> {{ hebergement.capacite }} personnes
                            </span>
                            <span style="color: #666;">
                                <i class="bx bx-calendar-check" style="color: #93C572;"></i> Disponible
                            </span>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="{{ path('app_hebergement_detail', {id: hebergement.id}) }}" class="btn w-50" style="background: rgba(135, 206, 235, 0.15); color: #87CEEB; border-radius: 50px; font-weight: 600;">
                                Voir détails
                            </a>
                            <a href="{{ path('app_reservation_new', {hebergementId: hebergement.id}) }}" class="btn w-50" style="background: linear-gradient(135deg, #87CEEB, #93C572); color: white; border-radius: 50px; font-weight: 600;">
                                Réserver
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="col-12 text-center py-5">
                <i class="bx bx-building-house" style="font-size: 5rem; color: #ddd; margin-bottom: 20px;"></i>
                <h4 style="color: #2c3e50; font-weight: 600;">Aucun hébergement disponible</h4>
                <p style="color: #777;">Revenez plus tard pour découvrir nos nouvelles offres</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endblock %}
