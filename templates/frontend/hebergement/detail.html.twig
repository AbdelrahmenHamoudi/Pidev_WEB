                            <div class="col-md-6">
                                <div class="p-3 rounded-4 h-100" style="background: rgba(255,255,255,0.02);">
                                    <div class="small opacity-50 text-uppercase mb-2" style="font-size: 0.65rem;"><i class="bx bx-volume-full me-1"></i>Niveau sonore</div>
                                    <p class="mb-0 small" id="resBruit">Chargement...</p>
                                </div>
                            </div>

                            <!-- Analysis Row -->
                            <div class="col-md-6">
                                <div class="p-3 rounded-4" style="background: rgba(135, 206, 235, 0.05); border: 1px solid rgba(135, 206, 235, 0.1);">
                                    <div class="small fw-bold text-uppercase mb-2" style="color: #87CEEB; font-size: 0.65rem;"><i class="bx bx-time-five me-1"></i>Meilleure période de visite</div>
                                    <p class="mb-0 small" id="resTime">Chargement...</p>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 rounded-4" style="background: rgba(147, 197, 114, 0.05); border: 1px solid rgba(147, 197, 114, 0.1);">
