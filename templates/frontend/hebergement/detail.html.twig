<!-- Lightbox -->
<div id="lightbox" class="lightbox" onclick="closeLightbox(event)">
    <span class="position-absolute top-0 end-0 p-4 text-white fs-1 cursor-pointer" onclick="closeLightbox()">&times;</span>
    <img id="lightbox-img" src="" alt="Gallery Full">
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
const images = [
    {% for image in hebergement.images %}
        '{{ asset(image.filename) }}'{% if not loop.last %},{% endif %}
    {% endfor %}
];
let currentIdx = 0;

function openLightbox(index) {
    if (images.length === 0) return;
    currentIdx = index;
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    lightboxImg.src = images[index];
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden';
}

function closeLightbox(e) {
    if (e && e.target !== e.currentTarget) return;
    document.getElementById('lightbox').classList.remove('active');
    document.body.style.overflow = 'auto';
}

// Leaflet Implementation
document.addEventListener('DOMContentLoaded', function() {
    {% if safetyData.success and safetyData.coords %}
        const lat = {{ safetyData.coords.lat }};
        const lon = {{ safetyData.coords.lon }};
        const map = L.map('safeMap').setView([lat, lon], 14);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

        const createIcon = (iconName, color, size = 24) => L.divIcon({
            html: `<i class="bx ${iconName}" style="font-size: ${size}px; color: ${color};"></i>`,
            className: 'custom-map-icon',
            iconSize: [size, size],
            iconAnchor: [size/2, size/2]
        });

        // Accommodation
        L.marker([lat, lon], {icon: createIcon('bxs-home-circle', '#4F46E5', 36)}).addTo(map)
            .bindPopup('<b>{{ hebergement.titre }}</b>').openPopup();

        // Safety Radius
        L.circle([lat, lon], {
            color: '{{ safetyData.color }}',
            fillColor: '{{ safetyData.color }}',
            fillOpacity: 0.1,
            radius: 800
        }).addTo(map);

        // POIs
        {% for p in safetyData.details.police %}
            L.marker([{{ p.lat }}, {{ p.lon }}], {icon: createIcon('bxs-shield', '#3b82f6')}).addTo(map);
        {% endfor %}
        {% for h in safetyData.details.hospitals %}
            L.marker([{{ h.lat }}, {{ h.lon }}], {icon: createIcon('bxs-plus-medical', '#ef4444')}).addTo(map);
        {% endfor %}
        {% for a in safetyData.details.activity %}
            L.marker([{{ a.lat }}, {{ a.lon }}], {icon: createIcon('bxs-coffee', '#f59e0b', 20)}).addTo(map);
        {% endfor %}
    {% endif %}
});

// Digital Twin JS logic
let selectedProfile = 'calme';
document.querySelectorAll('.profile-pill').forEach(pill => {
    pill.addEventListener('click', () => {
        document.querySelectorAll('.profile-pill').forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
        selectedProfile = pill.dataset.profile;
    });
});

async function runSimulation() {
    const btn = document.getElementById('btnSimulate');
    const loader = document.getElementById('simLoader');
    const result = document.getElementById('simulationResult');

    btn.disabled = true;
    btn.style.opacity = '0.5';
    loader.style.display = 'flex';
    result.classList.remove('active');

    try {
        const response = await fetch('{{ path('app_hebergement_simulate', {id: hebergement.id}) }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                profile: selectedProfile,
                budget: '{{ hebergement.prixParNuit }} (DT)',
                noise: selectedProfile === 'calme' ? 'faible' : 'moyen',
                crowd: selectedProfile === 'festif' ? 'élevé' : 'moyen'
            })
        });

        const data = await response.json();

        if (data.error) {
            alert("Erreur de simulation : " + data.error);
        } else {
            // Helper to handle mixed data types (strings vs objects/arrays)
            const safeText = (val) => {
                if (typeof val === 'object' && val !== null) {
                    return JSON.stringify(val).replace(/["{}\[\]]/g, ' ').trim();
                }
                return val || 'Donnée non disponible';
            };

            // Fill result using new JSON keys and defensive helper
            document.getElementById('resScore').innerText = data.score;
            document.getElementById('resLoc').innerText = safeText(data.localisation);
            document.getElementById('resProfile').innerText = selectedProfile.charAt(0).toUpperCase() + selectedProfile.slice(1);
            
            document.getElementById('resAmbiance').innerText = safeText(data.ambiance);
            document.getElementById('resMeteo').innerText = safeText(data.meteo);
            document.getElementById('resTemp').innerText = safeText(data.temperature);
            document.getElementById('resVent').innerText = safeText(data.vent);
            
            document.getElementById('resAffluence').innerText = safeText(data.affluence);
            document.getElementById('resBruit').innerText = safeText(data.bruit);
            document.getElementById('resTime').innerText = safeText(data.visite);
            document.getElementById('resFuture').innerText = safeText(data.previsions);
            document.getElementById('resAdapt').innerText = safeText(data.analyse);
            document.getElementById('resRec').innerText = safeText(data.recommandation);

            result.classList.add('active');
            result.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    } catch (err) {
        console.error(err);
        alert("Erreur de connexion au service d'IA.");
    } finally {
        btn.disabled = false;
        btn.style.opacity = '1';
        loader.style.display = 'none';
    }
}




</script>
{% endblock %}
