                                    <p class="mb-0 small" id="resFuture">Chargement...</p>
                                </div>
                            </div>

                            <div class="col-12">
                                <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px dotted rgba(255,255,255,0.1);">
