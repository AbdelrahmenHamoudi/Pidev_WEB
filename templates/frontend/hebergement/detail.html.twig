                <div class="d-flex flex-wrap gap-3" id="profileContainer">
                    <div class="profile-pill active" data-profile="calme"><i class="bx bx-leaf"></i>Calme</div>
                    <div class="profile-pill" data-profile="festif"><i class="bx bx-party"></i>Festif</div>
                    <div class="profile-pill" data-profile="business"><i class="bx bx-briefcase"></i>Business</div>
                    <div class="profile-pill" data-profile="famille"><i class="bx bx-home-heart"></i>Famille</div>
                    <div class="profile-pill" data-profile="aventure"><i class="bx bx-map-pin"></i>Aventure</div>
                </div>
            </div>

            <div id="simulationResult" class="simulation-result-card">
                <div class="row g-5">
                    <div class="col-lg-3">
                        <div class="h-100 d-flex flex-column align-items-center justify-content-center text-center p-4 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
                            <div class="score-circle mb-3" style="border-color: #87CEEB;">
                                <div class="val text-white" id="resScore">--</div>
                                <div class="label">Score /10</div>
                            </div>
                            <h5 class="mb-1 text-white" id="resLoc">Localisation</h5>
                            <p class="small opacity-50 mb-0" id="resProfile">Profil voyageur</p>
                        </div>
                    </div>
                    <div class="col-lg-9">
                        <div class="row g-3">
                            <!-- Ambiance Row (v3) -->
                            <div class="col-12">
                                <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.03); border-left: 3px solid #87CEEB;">
                                    <div class="small opacity-50 text-uppercase mb-1" style="font-size: 0.65rem;"><i class="bx bx-world me-1"></i>Ambiance générale</div>
                                    <p class="mb-0 small" id="resAmbiance">Chargement...</p>
                                </div>
                            </div>

                            <!-- Weather Row -->
                            <div class="col-md-4">
                                <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
                                    <div class="small opacity-50 text-uppercase mb-1" style="font-size: 0.65rem;"><i class="bx bx-cloud-light-rain me-1"></i>Conditions</div>
                                    <p class="mb-0 small fw-bold" id="resMeteo">Chargement...</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
                                    <div class="small opacity-50 text-uppercase mb-1" style="font-size: 0.65rem;"><i class="bx bx-thermometer me-1"></i>Température</div>
                                    <p class="mb-0 small fw-bold" id="resTemp">--</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="p-3 rounded-4" style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);">
                                    <div class="small opacity-50 text-uppercase mb-1" style="font-size: 0.65rem;"><i class="bx bx-wind me-1"></i>Vitesse du Vent</div>
                                    <p class="mb-0 small fw-bold" id="resVent">--</p>
                                </div>
                            </div>
                            
                            <!-- Context Row -->
                            <div class="col-md-6">
                                <div class="p-3 rounded-4 h-100" style="background: rgba(255,255,255,0.02);">
                                    <div class="small opacity-50 text-uppercase mb-2" style="font-size: 0.65rem;"><i class="bx bx-group me-1"></i>Niveau d’affluence</div>
                                    <p class="mb-0 small" id="resAffluence">Chargement...</p>
                                </div>
