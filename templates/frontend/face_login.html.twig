{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}Face ID - Connexion - RE7LA{% endblock %}

{% block extra_styles %}
<style>
    .face-login-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 120px 20px 60px;
        background:
            radial-gradient(circle at 10% 20%, rgba(26, 188, 156, 0.40), transparent 22%),
            radial-gradient(circle at 88% 14%, rgba(243, 156, 18, 0.42), transparent 24%),
            linear-gradient(135deg, #fff0cc 0%, #fffaf1 32%, #e6fbf6 68%, #fff2d9 100%);
    }

    .face-card {
        background: rgba(255,255,255,0.95);
        backdrop-filter: blur(20px);
        border-radius: 32px;
        padding: 40px;
        max-width: 520px;
        width: 100%;
        box-shadow: 0 35px 80px rgba(44, 62, 80, 0.18);
        border: 1px solid rgba(255,255,255,0.75);
        text-align: center;
    }

    .face-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 20px;
        background: linear-gradient(135deg, rgba(139,92,246,0.15), rgba(124,58,237,0.15));
        border-radius: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 36px;
    }

    .face-card h1 {
        font-size: 28px;
        font-weight: 900;
        color: #2C3E50;
        margin-bottom: 8px;
    }

    .face-card .subtitle {
        color: #6b7280;
        font-size: 14px;
        margin-bottom: 24px;
    }

    .camera-container {
        position: relative;
        width: 100%;
        border-radius: 20px;
        overflow: hidden;
        background: #000;
        margin-bottom: 20px;
    }

    .camera-container video {
        width: 100%;
        height: 320px;
        object-fit: cover;
        transform: scaleX(-1);
    }

    .camera-container canvas {
        display: none;
    }

    .camera-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        pointer-events: none;
    }

    .face-guide {
        width: 200px;
        height: 260px;
        border: 3px dashed rgba(26,188,156,0.6);
        border-radius: 50%;
        animation: pulse-guide 2s ease-in-out infinite;
    }

    @keyframes pulse-guide {
        0%, 100% { border-color: rgba(26,188,156,0.4); transform: scale(1); }
        50% { border-color: rgba(26,188,156,0.8); transform: scale(1.02); }
    }

    .status-bar {
        padding: 12px 16px;
        border-radius: 14px;
        margin-bottom: 20px;
        font-weight: 600;
        font-size: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .status-ready {
        background: rgba(34,197,94,0.1);
        color: #16a34a;
    }

    .status-offline {
        background: rgba(239,68,68,0.1);
        color: #dc2626;
    }

    .status-scanning {
        background: rgba(59,130,246,0.1);
        color: #2563eb;
    }

    .status-success {
        background: rgba(34,197,94,0.15);
        color: #15803d;
    }

    .status-error {
        background: rgba(239,68,68,0.1);
        color: #dc2626;
    }

    .btn-scan {
        width: 100%;
        height: 56px;
        border: none;
        border-radius: 18px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 800;
        color: white;
        background: linear-gradient(135deg, #8b5cf6, #7c3aed);
        box-shadow: 0 12px 30px rgba(139,92,246,0.35);
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .btn-scan:hover:not(:disabled) {
        transform: translateY(-3px);
        box-shadow: 0 16px 40px rgba(139,92,246,0.4);
    }

    .btn-scan:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .face-links {
        margin-top: 24px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .face-links a {
        color: #6b7280;
        text-decoration: none;
        font-size: 14px;
        font-weight: 600;
        transition: color 0.2s;
    }

    .face-links a:hover {
        color: #F39C12;
    }

    .confidence-bar {
        display: none;
        margin-top: 12px;
        padding: 10px 16px;
        background: rgba(34,197,94,0.08);
        border-radius: 12px;
    }

    .confidence-bar .bar {
        height: 6px;
        border-radius: 3px;
        background: #e5e7eb;
        overflow: hidden;
        margin-top: 6px;
    }

    .confidence-bar .bar-fill {
        height: 100%;
        border-radius: 3px;
        background: linear-gradient(90deg, #22c55e, #16a34a);
        transition: width 0.5s ease;
    }

    @keyframes spin {
        to { transform: rotate(360deg); }
    }

    .spinner {
        width: 20px;
        height: 20px;
        border: 3px solid rgba(255,255,255,0.3);
        border-top-color: white;
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
    }
</style>
{% endblock %}

{% block body %}
<section class="face-login-page">
    <div class="face-card">
        <div class="face-icon">📷</div>
        <h1>Face ID</h1>
        <p class="subtitle">Connectez-vous avec votre visage en un instant</p>

        <div id="statusBar" class="status-bar {% if serverOnline %}status-ready{% else %}status-offline{% endif %}">
            {% if serverOnline %}
                <i class="fas fa-check-circle"></i>
                <span>Serveur Face ID en ligne — Caméra prête</span>
            {% else %}
                <i class="fas fa-times-circle"></i>
                <span>Serveur Face ID hors ligne — Veuillez réessayer plus tard</span>
            {% endif %}
        </div>

        <div class="camera-container">
            <video id="videoFeed" autoplay playsinline></video>
            <canvas id="captureCanvas"></canvas>
            <div class="camera-overlay">
                <div class="face-guide"></div>
            </div>
        </div>

        <div id="confidenceBar" class="confidence-bar">
            <div style="display:flex;justify-content:space-between;font-size:13px;">
                <span style="color:#2C3E50;font-weight:600;">Confiance</span>
                <span id="confidenceValue" style="color:#16a34a;font-weight:700;">0%</span>
            </div>
            <div class="bar">
                <div id="confidenceFill" class="bar-fill" style="width:0%"></div>
            </div>
        </div>

        <button id="btnScan" class="btn-scan" {% if not serverOnline %}disabled{% endif %}>
            <i class="fas fa-camera"></i>
            Scanner mon visage
        </button>

        <div class="face-links">
            <a href="{{ path('app_login') }}">
                <i class="fas fa-arrow-left"></i>
                Retour à la connexion classique
            </a>
        </div>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', async function() {
    const video = document.getElementById('videoFeed');
    const canvas = document.getElementById('captureCanvas');
    const btnScan = document.getElementById('btnScan');
    const statusBar = document.getElementById('statusBar');
    const confidenceBar = document.getElementById('confidenceBar');
    const confidenceValue = document.getElementById('confidenceValue');
    const confidenceFill = document.getElementById('confidenceFill');

    // Demarrer la camera
    try {
        const stream = await navigator.mediaDevices.getUserMedia({
            video: { width: 640, height: 480, facingMode: 'user' }
        });
        video.srcObject = stream;
    } catch (err) {
        setStatus('Impossible d\'accéder à la caméra. Vérifiez les permissions.', 'error');
        btnScan.disabled = true;
        return;
    }

    function setStatus(message, type) {
        statusBar.className = 'status-bar status-' + type;
        let icon = 'fa-info-circle';
        if (type === 'ready') icon = 'fa-check-circle';
        if (type === 'offline' || type === 'error') icon = 'fa-times-circle';
        if (type === 'scanning') icon = 'fa-spinner fa-spin';
        if (type === 'success') icon = 'fa-check-circle';
        statusBar.innerHTML = '<i class="fas ' + icon + '"></i><span>' + message + '</span>';
    }

    function captureImage() {
        canvas.width = video.videoWidth;
        canvas.height = video.videoHeight;
        const ctx = canvas.getContext('2d');
        ctx.translate(canvas.width, 0);
        ctx.scale(-1, 1);
        ctx.drawImage(video, 0, 0);
        return canvas.toDataURL('image/jpeg', 0.85);
    }

    btnScan.addEventListener('click', async function() {
        btnScan.disabled = true;
        btnScan.innerHTML = '<div class="spinner"></div> Analyse en cours...';
        setStatus('Scan du visage en cours...', 'scanning');

        const imageBase64 = captureImage();

        try {
            const response = await fetch('{{ path("app_face_login_attempt") }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ image: imageBase64 })
            });

            const result = await response.json();

            if (result.success) {
                setStatus('Bienvenue ' + result.user + ' !', 'success');

                // Afficher la confiance
                if (result.confidence) {
                    confidenceBar.style.display = 'block';
                    confidenceValue.textContent = result.confidence + '%';
                    confidenceFill.style.width = result.confidence + '%';
                }

                btnScan.innerHTML = '<i class="fas fa-check"></i> Connexion réussie !';
                btnScan.style.background = 'linear-gradient(135deg, #22c55e, #16a34a)';

                // Rediriger apres 1.5s
                setTimeout(() => {
                    window.location.href = result.redirectUrl || '/';
                }, 1500);

            } else {
                setStatus(result.message || 'Visage non reconnu', 'error');
                btnScan.disabled = false;
                btnScan.innerHTML = '<i class="fas fa-camera"></i> Réessayer';
            }

        } catch (err) {
            setStatus('Erreur de communication avec le serveur', 'error');
            btnScan.disabled = false;
            btnScan.innerHTML = '<i class="fas fa-camera"></i> Réessayer';
        }
    });
});
</script>
{% endblock %}