{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}Codes de secours - RE7LA{% endblock %}

{% block extra_styles %}
<style>
    .backup-section {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 120px 20px 60px;
        background:
            radial-gradient(circle at 10% 20%, rgba(26, 188, 156, 0.30), transparent 22%),
            linear-gradient(135deg, #fff0cc 0%, #fffaf1 32%, #e6fbf6 68%, #fff2d9 100%);
    }

    .backup-card {
        width: 100%;
        max-width: 520px;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-radius: 28px;
        padding: 48px 40px;
        box-shadow: 0 35px 80px rgba(44, 62, 80, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.75);
        text-align: center;
    }

    .success-icon {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, rgba(34, 197, 94, 0.15), rgba(22, 163, 74, 0.25));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
        font-size: 36px;
        color: #22c55e;
    }

    .backup-card h1 {
        font-size: 1.6rem;
        font-weight: 900;
        color: #2C3E50;
        margin-bottom: 10px;
    }

    .warning-box {
        background: linear-gradient(135deg, #fffbeb, #fef3c7);
        border: 1px solid rgba(245, 158, 11, 0.25);
        border-radius: 14px;
        padding: 16px;
        margin-bottom: 24px;
        text-align: left;
    }

    .warning-box p {
        color: #92400e;
        font-size: 13px;
        font-weight: 600;
        margin: 0;
        line-height: 1.6;
    }

    .codes-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 24px;
    }

    .codes-grid .code-item {
        background: #f8fafc;
        border: 2px solid #e8ecf0;
        border-radius: 12px;
        padding: 12px;
        font-family: monospace;
        font-size: 16px;
        font-weight: 800;
        color: #2C3E50;
        letter-spacing: 2px;
    }

    .btn-copy {
        width: 100%;
        height: 52px;
        border: 2px solid #e8ecf0;
        border-radius: 16px;
        cursor: pointer;
        font-size: 14px;
        font-weight: 700;
        color: #2C3E50;
        background: #fff;
        transition: all 0.3s ease;
        margin-bottom: 12px;
    }

    .btn-copy:hover {
        border-color: #1ABC9C;
        color: #1ABC9C;
    }

    .btn-done {
        width: 100%;
        height: 52px;
        border: none;
        border-radius: 16px;
        cursor: pointer;
        font-size: 15px;
        font-weight: 800;
        color: white;
        background: linear-gradient(135deg, #1ABC9C, #16a085);
        box-shadow: 0 14px 28px rgba(26, 188, 156, 0.28);
        transition: all 0.3s ease;
    }

    .btn-done:hover {
        transform: translateY(-2px);
    }
</style>
{% endblock %}

{% block body %}
<section class="backup-section">
    <div class="backup-card" data-aos="zoom-in-up">
        <div class="success-icon">
            <i class="fas fa-check"></i>
        </div>

        <h1>2FA Activee !</h1>
        <p style="color:#6b7280;font-size:14px;margin-bottom:20px;">
            Sauvegardez ces codes de secours dans un endroit sur.
            Ils vous permettront de vous connecter si vous perdez votre telephone.
        </p>

        <div class="warning-box">
            <p>
                <i class="fas fa-exclamation-triangle" style="color:#f59e0b;margin-right:6px;"></i>
                <strong>Attention :</strong> Chaque code ne peut etre utilise qu'une seule fois.
                Ces codes ne seront plus affiches apres cette page.
            </p>
        </div>

        <div class="codes-grid" id="codesGrid">
            {% for code in backupCodes %}
                <div class="code-item">{{ code }}</div>
            {% endfor %}
        </div>

        <button class="btn-copy" id="copyBtn" onclick="copyBackupCodes()">
            <i class="fas fa-copy me-2"></i>
            Copier les codes
        </button>

        <a href="{{ path('app_user_profile') }}" class="btn-done" style="display:flex;align-items:center;justify-content:center;text-decoration:none;">
            <i class="fas fa-check-circle me-2"></i>
            J'ai sauvegarde mes codes
        </a>
    </div>
</section>

<script>
function copyBackupCodes() {
    const codes = [];
    document.querySelectorAll('.code-item').forEach(el => {
        codes.push(el.textContent.trim());
    });

    const text = "RE7LA - Codes de secours 2FA\n\n" + codes.join('\n');

    navigator.clipboard.writeText(text).then(() => {
        const btn = document.getElementById('copyBtn');
        btn.innerHTML = '<i class="fas fa-check me-2"></i> Codes copies !';
        btn.style.borderColor = '#22c55e';
        btn.style.color = '#22c55e';

        setTimeout(() => {
            btn.innerHTML = '<i class="fas fa-copy me-2"></i> Copier les codes';
            btn.style.borderColor = '#e8ecf0';
            btn.style.color = '#2C3E50';
        }, 3000);
    });
}
</script>
{% endblock %}