{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}Activer la 2FA - RE7LA{% endblock %}

{% block extra_styles %}
<style>
    .setup-section {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 120px 20px 60px;
        background:
            radial-gradient(circle at 10% 20%, rgba(26, 188, 156, 0.30), transparent 22%),
            radial-gradient(circle at 88% 14%, rgba(243, 156, 18, 0.32), transparent 24%),
            linear-gradient(135deg, #fff0cc 0%, #fffaf1 32%, #e6fbf6 68%, #fff2d9 100%);
    }

    .setup-card {
        width: 100%;
        max-width: 520px;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-radius: 28px;
        padding: 48px 40px;
        box-shadow: 0 35px 80px rgba(44, 62, 80, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.75);
        text-align: center;
    }

    .setup-card h1 {
        font-size: 1.8rem;
        font-weight: 900;
        color: #2C3E50;
        margin-bottom: 10px;
    }

    .setup-card p {
        color: #6b7280;
        font-size: 14px;
        line-height: 1.7;
        margin-bottom: 24px;
    }

    .qr-container {
        background: #fff;
        border-radius: 20px;
        padding: 24px;
        display: inline-block;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
        margin-bottom: 20px;
    }

    .qr-container img {
        display: block;
        border-radius: 8px;
    }

    .secret-display {
        background: #f8fafc;
        border: 2px dashed #e8ecf0;
        border-radius: 14px;
        padding: 14px;
        margin-bottom: 28px;
        word-break: break-all;
    }

    .secret-display code {
        font-size: 15px;
        font-weight: 800;
        color: #2C3E50;
        letter-spacing: 2px;
        word-break: break-all;
    }

    .setup-alert {
        background: linear-gradient(135deg, rgba(255, 236, 232, 0.96), rgba(255, 224, 214, 0.96));
        border: 1px solid rgba(231, 76, 60, 0.18);
        color: #c0392b;
        padding: 14px 16px;
        border-radius: 14px;
        margin-bottom: 20px;
        font-size: 14px;
        font-weight: 600;
    }

    .verify-input {
        width: 100%;
        height: 62px;
        border: 2px solid #e8ecf0;
        border-radius: 18px;
        text-align: center;
        font-size: 24px;
        font-weight: 800;
        color: #2C3E50;
        background: #f8fafc;
        outline: none;
        letter-spacing: 8px;
        margin-bottom: 20px;
    }

    .verify-input:focus {
        border-color: #1ABC9C;
        box-shadow: 0 0 0 4px rgba(26, 188, 156, 0.15);
        background: #fff;
    }

    .btn-activate {
        width: 100%;
        height: 56px;
        border: none;
        border-radius: 18px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 800;
        color: white;
        background: linear-gradient(135deg, #1ABC9C, #16a085);
        box-shadow: 0 16px 30px rgba(26, 188, 156, 0.30);
        transition: all 0.3s ease;
    }

    .btn-activate:hover {
        transform: translateY(-2px);
    }

    .steps-list {
        text-align: left;
        margin-bottom: 28px;
        list-style: none;
        padding: 0;
    }

    .steps-list li {
        padding: 8px 0;
        font-size: 14px;
        color: #4b5563;
        display: flex;
        align-items: flex-start;
        gap: 10px;
    }

    .step-num {
        width: 26px;
        height: 26px;
        min-width: 26px;
        background: linear-gradient(135deg, #1ABC9C, #16a085);
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 800;
    }
</style>
{% endblock %}

{% block body %}
<section class="setup-section">
    <div class="setup-card" data-aos="zoom-in-up">
        <h1><i class="fas fa-shield-alt" style="color:#1ABC9C;margin-right:8px;"></i> Activer la 2FA</h1>
        <p>Securisez votre compte avec Google Authenticator</p>

        <ol class="steps-list">
            <li>
                <span class="step-num">1</span>
                Installez <strong>Google Authenticator</strong> sur votre telephone
            </li>
            <li>
                <span class="step-num">2</span>
                Scannez le QR code ci-dessous avec l'application
            </li>
            <li>
                <span class="step-num">3</span>
                Entrez le code a 6 chiffres affiche dans l'application
            </li>
        </ol>

        <div class="qr-container">
            <img src="{{ qrCodeDataUri }}" alt="QR Code 2FA">
        </div>

        <div class="secret-display">
            <small style="color:#6b7280;font-size:11px;display:block;margin-bottom:6px;">Cle manuelle :</small>
            <code>{{ secret }}</code>
        </div>

        {% if error %}
            <div class="setup-alert">
                <i class="fas fa-exclamation-circle me-2"></i>
                {{ error }}
            </div>
        {% endif %}

        <form method="post">
            <input type="hidden" name="secret" value="{{ secret }}">
            <input type="text" name="code" class="verify-input" placeholder="000000" maxlength="6" inputmode="numeric" autocomplete="off" autofocus required>
            <button type="submit" class="btn-activate">
                <i class="fas fa-check-circle me-2"></i>
                Activer la 2FA
            </button>
        </form>

        <div style="margin-top:20px;">
            <a href="{{ path('app_user_profile') }}" style="color:#6b7280;font-size:13px;text-decoration:none;">
                <i class="fas fa-arrow-left me-1"></i> Retour au profil
            </a>
        </div>
    </div>
</section>
{% endblock %}