<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="keywords" content="voyage, reservation, travel, maroc, hotels, excursions">
    <meta name="description" content="RE7LA - Votre agence de voyage pour des expériences uniques au Maroc">

    <title>{% block title %}RE7LA - Voyagez Autrement{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>
        :root {
            --bleu-ceil: #87CEEB;
            --bleu-ceil-dark: #5dade2;
            --rouge: #e74c3c;
            --vert-pistache: #93C572;
            --vert-pistache-dark: #7cb342;
            --dark: #2c3e50;
            --light: #f8f9fa;
            --navbar-height: 96px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Poppins', sans-serif; overflow-x: hidden; background: var(--light); }

        .navbar-re7la {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
            border-bottom: 1px solid rgba(255, 255, 255, 0.3);
            padding: 15px 0;
            transition: all 0.3s ease;
            min-height: var(--navbar-height);
            display: flex;
            align-items: center;
            z-index: 1100;
        }

        .navbar-re7la.scrolled { background: rgba(255, 255, 255, 0.95); padding: 10px 0; }

        .navbar-brand {
            font-weight: 800;
            font-size: 2rem;
            background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .navbar-brand span { color: var(--rouge); -webkit-text-fill-color: var(--rouge); }

        .nav-link {
            font-weight: 500;
            color: var(--dark) !important;
            margin: 0 10px;
            position: relative;
            transition: all 0.3s ease;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--bleu-ceil), var(--vert-pistache));
            transition: width 0.3s ease;
            border-radius: 2px;
        }

        .nav-link:hover::after, .nav-link.active::after { width: 100%; }

        .btn-nav {
            background: linear-gradient(135deg, var(--bleu-ceil), var(--bleu-ceil-dark));
            color: white !important;
            padding: 10px 25px !important;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

        .btn-nav:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(135, 206, 235, 0.4); }

        .btn-nav-outline {
            background: white;
            color: var(--dark) !important;
            padding: 10px 22px !important;
            border-radius: 50px;
            font-weight: 600;
            border: 1px solid rgba(44, 62, 80, 0.12);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            transition: all 0.3s ease;
        }

        .btn-nav-outline:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(44, 62, 80, 0.08); }

        .account-dropdown { position: relative; }

        .account-btn {
            border: none;
            background: white;
            border-radius: 999px;
            padding: 7px 14px 7px 8px;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: 0 10px 25px rgba(44, 62, 80, 0.08);
            font-weight: 600;
            color: var(--dark);
            transition: all 0.3s ease;
        }

        .account-btn:hover { transform: translateY(-2px); }

        .account-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            overflow: hidden;
            background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache));
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 13px;
            font-weight: 700;
        }

        .account-avatar img { width: 100%; height: 100%; object-fit: cover; }

        .account-menu {
            position: absolute;
            top: calc(100% + 12px);
            right: 0;
            min-width: 260px;
            background: white;
            border-radius: 18px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.12);
            border: 1px solid rgba(0,0,0,0.05);
            padding: 10px;
            display: none;
            z-index: 1200;
        }

        .account-menu.show { display: block; }

        .account-menu-header { padding: 10px 12px 12px; border-bottom: 1px solid #f1f5f9; margin-bottom: 8px; }
        .account-menu-header strong { display: block; color: var(--dark); font-size: 14px; }
        .account-menu-header span { display: block; color: #64748b; font-size: 12px; margin-top: 2px; word-break: break-word; }

        .account-menu a, .account-menu button {
            width: 100%;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 14px;
            border-radius: 12px;
            text-decoration: none;
            color: #334155;
            font-weight: 600;
            font-size: 14px;
            background: transparent;
            border: none;
            text-align: left;
            transition: all 0.2s ease;
        }

        .account-menu a:hover, .account-menu button:hover { background: #f8fafc; color: var(--bleu-ceil-dark); }
        .delete-account-btn { color: #dc2626 !important; }
        .delete-account-btn:hover { background: #fef2f2 !important; color: #b91c1c !important; }

        main.site-main { padding-top: calc(var(--navbar-height) + 24px); }

        .hero-section {
            min-height: calc(100vh - var(--navbar-height));
            background: linear-gradient(135deg, rgba(135, 206, 235, 0.1), rgba(147, 197, 114, 0.1));
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
        }

        .hero-bg {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: url('https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?ixlib=rb-4.0.3') center/cover;
            opacity: 0.15;
        }

        .hero-content { position: relative; z-index: 2; }
        .hero-title { font-size: 4.5rem; font-weight: 800; line-height: 1.1; margin-bottom: 20px; }

        .hero-title .gradient-text {
            background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache), var(--rouge));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-subtitle { font-size: 1.3rem; color: #666; margin-bottom: 40px; font-weight: 400; }

        .booking-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(20px);
            border-radius: 30px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.5);
        }

        .booking-card h3 { color: var(--dark); font-weight: 700; margin-bottom: 30px; text-align: center; }

        .form-control-re7la {
            border: 2px solid #e0e0e0;
            border-radius: 15px;
            padding: 15px 20px;
            font-size: 15px;
            transition: all 0.3s ease;
            background: white;
        }

        .form-control-re7la:focus { border-color: var(--bleu-ceil); box-shadow: 0 0 0 4px rgba(135, 206, 235, 0.2); }

        .btn-rechercher {
            background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache));
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 16px;
            width: 100%;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-rechercher:hover { transform: translateY(-3px); box-shadow: 0 15px 40px rgba(135, 206, 235, 0.4); }

        .floating-shape { position: absolute; border-radius: 50%; opacity: 0.1; animation: float 20s infinite ease-in-out; }
        .shape-1 { width: 400px; height: 400px; background: var(--bleu-ceil); top: -200px; right: -100px; animation-delay: 0s; }
        .shape-2 { width: 300px; height: 300px; background: var(--vert-pistache); bottom: -150px; left: -100px; animation-delay: 5s; }
        .shape-3 { width: 200px; height: 200px; background: var(--rouge); top: 50%; left: 10%; animation-delay: 10s; }

        @keyframes float {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            33% { transform: translate(30px, -30px) rotate(120deg); }
            66% { transform: translate(-20px, 20px) rotate(240deg); }
        }

        @media (max-width: 991px) {
            :root { --navbar-height: 88px; }
            .navbar-re7la { padding: 12px 0; }
            .account-menu { right: 0; min-width: 240px; }
            main.site-main { padding-top: calc(var(--navbar-height) + 18px); }
        }

        {% block extra_styles %}{% endblock %}
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-re7la fixed-top">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">RE<span>7</span>LA</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}" href="{{ path('app_home') }}">Accueil</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#services">Services</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'activite_index_front' ? 'active' : '' }}" href="{{ path('activite_index_front') }}">Activités</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') == 'app_hebergements_search' ? 'active' : '' }}" href="{{ path('app_hebergements_search') }}">Réservation</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_trajet' ? 'active' : '' }}" href="{{ path('app_trajet') }}">Mes Trajets</a>
                    </li>
                    {% if app.session.get('user_id') or app.user %}
                       
                        {% if app.session.get('user_id') or app.user %}
    <li class="nav-item">
        <a class="nav-link {{ app.request.attributes.get('_route') == 'app_reservations_list' ? 'active' : '' }}" href="{{ path('app_reservations_list') }}">Mes Voyages</a>
    </li>
    {# ── AJOUTER CES LIGNES ── #}
    
{% endif %}
                    {% endif %}
                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') starts with 'app_promotions' ? 'active' : '' }}" href="{{ path('app_promotions_list') }}">Promotions</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link nav-link-communaute {{ app.request.attributes.get('_route') starts with 'app_communaute' ? 'active' : '' }}" href="{{ path('app_communaute_index') }}">Communauté</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#contact">Contact</a>
                    </li>

                    {% if app.user %}
                        <li class="nav-item ms-lg-3">
                            <div class="account-dropdown">
                                <button type="button" class="account-btn" id="accountDropdownBtn">
                                    <span class="account-avatar">
                                        {% if app.user.image %}
                                            <img src="{{ asset('uploads/profiles/' ~ app.user.image) }}" alt="Avatar">
                                        {% else %}
                                            {{ app.user.prenom|slice(0,1)|upper }}{{ app.user.nom|slice(0,1)|upper }}
                                        {% endif %}
                                    </span>
                                    <span>{{ app.user.prenom }}</span>
                                    <i class="fas fa-chevron-down"></i>
                                </button>

                                <div class="account-menu" id="accountDropdownMenu">
                                    <div class="account-menu-header">
                                        <strong>{{ app.user.prenom }} {{ app.user.nom }}</strong>
                                        <span>{{ app.user.e_mail }}</span>
                                    </div>

                                    <a href="{{ path('app_user_profile') }}">
                                        <i class="fas fa-user"></i>
                                        Mon profil
                                    </a>

                                    {% if app.user and app.user.role == 'admin' %}
                                    <a href="{{ path('app_admin') }}">
                                        <i class="fas fa-user-shield"></i>
                                        Administration
                                    </a>
                                    {% endif %}

                                    <a href="{{ path('app_user_profile_edit') }}">
                                        <i class="fas fa-user-edit"></i>
                                        Modifier mon compte
                                    </a>

                                    <form method="post" action="{{ path('app_user_account_delete') }}" onsubmit="return confirm('Voulez-vous vraiment supprimer votre compte ? Cette action est irréversible.');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
                                        <button type="submit" class="delete-account-btn">
                                            <i class="fas fa-trash-alt"></i>
                                            Supprimer mon compte
                                        </button>
                                    </form>

                                    <a href="{{ path('app_logout') }}">
                                        <i class="fas fa-sign-out-alt"></i>
                                        Déconnexion
                                    </a>
                                </div>
                            </div>
                        </li>
                    {% else %}
                        <li class="nav-item ms-lg-3">
                            <div style="display:flex;align-items:center;gap:10px;">
                                <a class="btn-nav-outline" href="{{ path('app_login') }}">
                                    <i class="fas fa-user me-2"></i>Connexion
                                </a>
                                <a class="btn-nav" href="{{ path('app_register') }}">
                                    <i class="fas fa-user-plus me-2"></i>Inscription
                                </a>
                            </div>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    <main class="site-main">
        {% block body %}{% endblock %}
    </main>

    <footer style="background: var(--dark); color: white; padding: 60px 0 30px; margin-top: 100px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <h3 style="font-weight: 800; margin-bottom: 20px;">RE<span style="color: var(--rouge);">7</span>LA</h3>
                    <p style="color: #aaa; line-height: 1.8;">Votre partenaire de confiance pour des voyages inoubliables au Maroc. Découvrez des expériences uniques et authentiques.</p>
                </div>
                <div class="col-lg-2 col-md-4 mb-4">
                    <h5 style="font-weight: 600; margin-bottom: 20px; color: var(--vert-pistache);">Liens rapides</h5>
                    <ul style="list-style: none; padding: 0;">
                        <li style="margin-bottom: 10px;"><a href="{{ path('app_home') }}" style="color: #aaa; text-decoration: none;">Accueil</a></li>

                        <li style="margin-bottom: 10px;"><a href="#" style="color: #aaa; text-decoration: none;">Services</a></li>
                        <li style="margin-bottom: 10px;"><a href="#" style="color: #aaa; text-decoration: none;">Contact</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4 mb-4">
                    <h5 style="font-weight: 600; margin-bottom: 20px; color: var(--vert-pistache);">Contact</h5>
                    <ul style="list-style: none; padding: 0; color: #aaa;">
                        <li style="margin-bottom: 10px;"><i class="fas fa-map-marker-alt me-2" style="color: var(--rouge);"></i> Casablanca, Maroc</li>
                        <li style="margin-bottom: 10px;"><i class="fas fa-phone me-2" style="color: var(--rouge);"></i> +212 5XX-XXXXXX</li>
                        <li style="margin-bottom: 10px;"><i class="fas fa-envelope me-2" style="color: var(--rouge);"></i> contact@re7la.ma</li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4 mb-4">
                    <h5 style="font-weight: 600; margin-bottom: 20px; color: var(--vert-pistache);">Newsletter</h5>
                    <p style="color: #aaa; font-size: 0.9rem;">Abonnez-vous pour recevoir nos offres exclusives.</p>
                </div>
            </div>
            <hr style="border-color: #444; margin: 40px 0 20px;">
            <div class="text-center" style="color: #777;">
                <p>&copy; 2024 RE7LA. Tous droits réservés.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

    <script>
        AOS.init({ duration: 1000, once: true });

        window.addEventListener('scroll', function() {
            const navbar = document.querySelector('.navbar-re7la');
            if (window.scrollY > 50) { navbar.classList.add('scrolled'); }
            else { navbar.classList.remove('scrolled'); }
        });

        document.addEventListener('DOMContentLoaded', function () {
            const btn = document.getElementById('accountDropdownBtn');
            const menu = document.getElementById('accountDropdownMenu');
            if (btn && menu) {
                btn.addEventListener('click', function (e) { e.stopPropagation(); menu.classList.toggle('show'); });
                document.addEventListener('click', function () { menu.classList.remove('show'); });
            }
        });
    </script>

    {% block javascripts %}{% endblock %}
</body>
</html>
