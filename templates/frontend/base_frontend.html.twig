<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="keywords" content="voyage, reservation, travel, maroc, hotels, excursions">
    <meta name="description" content="RE7LA - Votre agence de voyage pour des expériences uniques au Maroc">

    <title>{% block title %}RE7LA - Voyagez Autrement{% endblock %}</title>
    <link rel="icon" type="image/png" href="{{ asset('images/re7la-logo.png') }}">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- AOS Animation -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    
    <style>
        :root {
            --bleu-ceil: #87CEEB;
            --bleu-ceil-dark: #5dade2;
            --rouge: #e74c3c;
            --vert-pistache: #93C572;
            --vert-pistache-dark: #7cb342;
            --dark: #2c3e50;
            --light: #f8f9fa;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            overflow-x: hidden;
            background: var(--light);
        }

        /* ========== NAVBAR GLASSMORPHISM ========== */
        .navbar-re7la {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
            border-bottom: 1px solid rgba(255, 255, 255, 0.3);
            padding: 15px 0;
            transition: all 0.3s ease;
        }

        .navbar-re7la.scrolled {
            background: rgba(255, 255, 255, 0.95);
            padding: 10px 0;
        }

        .navbar-brand {
            display: flex;
            align-items: center;
            text-decoration: none;
            padding: 4px 0;
        }

        .navbar-brand-logo {
            height: 56px;
            width: auto;
            max-width: 200px;
            object-fit: contain;
            display: block;
        }

        .nav-link {
            font-weight: 500;
            color: var(--dark) !important;
            margin: 0 10px;
            position: relative;
            transition: all 0.3s ease;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 3px;
            background: linear-gradient(90deg, var(--bleu-ceil), var(--vert-pistache));
            transition: width 0.3s ease;
            border-radius: 2px;
        }

        .nav-link:hover::after,
        .nav-link.active::after {
            width: 100%;
        }

        .btn-nav {
            background: linear-gradient(135deg, var(--bleu-ceil), var(--bleu-ceil-dark));
            color: white !important;
            padding: 10px 25px !important;
            border-radius: 50px;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
        }

        .btn-nav:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(135, 206, 235, 0.4);
        }

        /* ========== HERO SECTION ========== */
        .hero-section {
            min-height: 100vh;
            background: linear-gradient(135deg, rgba(135, 206, 235, 0.1), rgba(147, 197, 114, 0.1));
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
        }

        .hero-bg {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: url('https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?ixlib=rb-4.0.3') center/cover;
            opacity: 0.15;
        }

        .hero-content {
            position: relative;
            z-index: 2;
        }

        .hero-title {
            font-size: 4.5rem;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 20px;
        }

        .hero-title .gradient-text {
            background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache), var(--rouge));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero-subtitle {
            font-size: 1.3rem;
            color: #666;
            margin-bottom: 40px;
            font-weight: 400;
        }

        /* ========== BOOKING FORM ========== */
        .booking-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(20px);
            border-radius: 30px;
            padding: 40px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.5);
        }

        .booking-card h3 {
            color: var(--dark);
            font-weight: 700;
            margin-bottom: 30px;
            text-align: center;
        }

        .form-control-re7la {
            border: 2px solid #e0e0e0;
            border-radius: 15px;
            padding: 15px 20px;
            font-size: 15px;
            transition: all 0.3s ease;
            background: white;
        }

        .form-control-re7la:focus {
            border-color: var(--bleu-ceil);
            box-shadow: 0 0 0 4px rgba(135, 206, 235, 0.2);
        }

        .btn-rechercher {
            background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache));
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 16px;
            width: 100%;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-rechercher:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(135, 206, 235, 0.4);
        }

        /* ========== FLOATING SHAPES ========== */
        .floating-shape {
            position: absolute;
            border-radius: 50%;
            opacity: 0.1;
            animation: float 20s infinite ease-in-out;
        }

        .shape-1 {
            width: 400px;
            height: 400px;
            background: var(--bleu-ceil);
            top: -200px;
            right: -100px;
            animation-delay: 0s;
        }

        .shape-2 {
            width: 300px;
            height: 300px;
            background: var(--vert-pistache);
            bottom: -150px;
            left: -100px;
            animation-delay: 5s;
        }

        .shape-3 {
            width: 200px;
            height: 200px;
            background: var(--rouge);
            top: 50%;
            left: 10%;
            animation-delay: 10s;
        }

        @keyframes float {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            33% { transform: translate(30px, -30px) rotate(120deg); }
            66% { transform: translate(-20px, 20px) rotate(240deg); }
        }

        {% block extra_styles %}{% endblock %}
    </style>
    
    {% block stylesheets %}{% endblock %}
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-re7la fixed-top">
        <div class="container">
            <a class="navbar-brand" href="{{ path('app_home') }}">
                <img src="{{ asset('images/re7la-logo.png') }}" alt="RE7LA" class="navbar-brand-logo">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_home') }}">Accueil</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_trajet') }}">Mes trajets</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_voiture_guide') }}">Guide Flotte</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#destinations">Destinations</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#services">Services</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#contact">Contact</a>
                    </li>
                    <li class="nav-item ms-lg-3">
                        <a class="nav-link btn-nav" href="{{ path('app_login') }}">
                            <i class="fas fa-user me-2"></i>Connexion
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main>
        {% block body %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer style="background: var(--dark); color: white; padding: 60px 0 30px; margin-top: 100px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <img src="{{ asset('images/re7la-logo.png') }}" alt="RE7LA" style="height: 64px; width: auto; object-fit: contain; margin-bottom: 20px; display: block;">
                    <p style="color: #aaa; line-height: 1.8;">Votre partenaire de confiance pour des voyages inoubliables au Maroc. Découvrez des expériences uniques et authentiques.</p>
                    <div style="margin-top: 20px;">
                        <a href="#" style="color: var(--bleu-ceil); margin-right: 15px; font-size: 1.3rem;"><i class="fab fa-facebook"></i></a>
                        <a href="#" style="color: var(--bleu-ceil); margin-right: 15px; font-size: 1.3rem;"><i class="fab fa-instagram"></i></a>
                        <a href="#" style="color: var(--bleu-ceil); margin-right: 15px; font-size: 1.3rem;"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4 mb-4">
                    <h5 style="font-weight: 600; margin-bottom: 20px; color: var(--vert-pistache);">Liens rapides</h5>
                    <ul style="list-style: none; padding: 0;">
                        <li style="margin-bottom: 10px;"><a href="{{ path('app_home') }}" style="color: #aaa; text-decoration: none;">Accueil</a></li>
                        <li style="margin-bottom: 10px;"><a href="#" style="color: #aaa; text-decoration: none;">Destinations</a></li>
                        <li style="margin-bottom: 10px;"><a href="#" style="color: #aaa; text-decoration: none;">Services</a></li>
                        <li style="margin-bottom: 10px;"><a href="#" style="color: #aaa; text-decoration: none;">Contact</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4 mb-4">
                    <h5 style="font-weight: 600; margin-bottom: 20px; color: var(--vert-pistache);">Contact</h5>
                    <ul style="list-style: none; padding: 0; color: #aaa;">
                        <li style="margin-bottom: 10px;"><i class="fas fa-map-marker-alt me-2" style="color: var(--rouge);"></i> Casablanca, Maroc</li>
                        <li style="margin-bottom: 10px;"><i class="fas fa-phone me-2" style="color: var(--rouge);"></i> +212 5XX-XXXXXX</li>
                        <li style="margin-bottom: 10px;"><i class="fas fa-envelope me-2" style="color: var(--rouge);"></i> contact@re7la.ma</li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4 mb-4">
                    <h5 style="font-weight: 600; margin-bottom: 20px; color: var(--vert-pistache);">Newsletter</h5>
                    <p style="color: #aaa; font-size: 0.9rem;">Abonnez-vous pour recevoir nos offres exclusives.</p>
                    <div class="input-group mt-3">
                        <input type="email" class="form-control" placeholder="Votre email" style="border-radius: 25px 0 0 25px; border: none;">
                        <button class="btn" style="background: var(--bleu-ceil); color: white; border-radius: 0 25px 25px 0;">
                            <i class="fas fa-paper-plane"></i>
                        </button>
                    </div>
                </div>
            </div>
            <hr style="border-color: #444; margin: 40px 0 20px;">
            <div class="text-center" style="color: #777;">
                <p>&copy; 2024 RE7LA. Tous droits réservés.</p>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- AOS Animation -->
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    
    <script>
        // Initialize AOS
        AOS.init({
            duration: 1000,
            once: true
        });

        // Navbar scroll effect
        window.addEventListener('scroll', function() {
            const navbar = document.querySelector('.navbar-re7la');
            if (window.scrollY > 50) {
                navbar.classList.add('scrolled');
            } else {
                navbar.classList.remove('scrolled');
            }
        });
    </script>

    {% block javascripts %}{% endblock %}
</body>
</html>
