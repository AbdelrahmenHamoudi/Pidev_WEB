    <main class="site-main">
        {% block flashes %}
            <div class="container mt-3">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'error' ? 'danger' : (label == 'success' ? 'success' : 'info') }} alert-dismissible fade show rounded-4 shadow-sm border-0" role="alert">
                            <div class="d-flex align-items-center">
                                <div class="alert-icon me-3">
                                    {% if label == 'success' %}
                                        <i class="fas fa-check-circle fs-4"></i>
                                    {% elseif label == 'error' %}
                                        <i class="fas fa-exclamation-circle fs-4"></i>
                                    {% else %}
                                        <i class="fas fa-info-circle fs-4"></i>
                                    {% endif %}
                                </div>
                                <div class="alert-content">
                                    {{ message }}
                                </div>
                            </div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
        {% endblock %}
        {% block body %}{% endblock %}
    </main>

    <footer style="background: var(--dark); color: white; padding: 60px 0 30px; margin-top: 100px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <h3 style="font-weight: 800; margin-bottom: 20px;">RE<span style="color: var(--rouge);">7</span>LA</h3>
                    <p style="color: #aaa; line-height: 1.8;">Votre partenaire de confiance pour des voyages inoubliables au Maroc. Découvrez des expériences uniques et authentiques.</p>
                </div>
                <div class="col-lg-2 col-md-4 mb-4">
                    <h5 style="font-weight: 600; margin-bottom: 20px; color: var(--vert-pistache);">Liens rapides</h5>
                    <ul style="list-style: none; padding: 0;">
                        <li style="margin-bottom: 10px;"><a href="{{ path('app_home') }}" style="color: #aaa; text-decoration: none;">Accueil</a></li>
                        <li style="margin-bottom: 10px;"><a href="#" style="color: #aaa; text-decoration: none;">Services</a></li>
                        <li style="margin-bottom: 10px;"><a href="#" style="color: #aaa; text-decoration: none;">Contact</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4 mb-4">
                    <h5 style="font-weight: 600; margin-bottom: 20px; color: var(--vert-pistache);">Contact</h5>
                    <ul style="list-style: none; padding: 0; color: #aaa;">
                        <li style="margin-bottom: 10px;"><i class="fas fa-map-marker-alt me-2" style="color: var(--rouge);"></i> Casablanca, Maroc</li>
                        <li style="margin-bottom: 10px;"><i class="fas fa-phone me-2" style="color: var(--rouge);"></i> +212 5XX-XXXXXX</li>
                        <li style="margin-bottom: 10px;"><i class="fas fa-envelope me-2" style="color: var(--rouge);"></i> contact@re7la.ma</li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4 mb-4">
                    <h5 style="font-weight: 600; margin-bottom: 20px; color: var(--vert-pistache);">Newsletter</h5>
                    <p style="color: #aaa; font-size: 0.9rem;">Abonnez-vous pour recevoir nos offres exclusives.</p>
                </div>
            </div>
            <hr style="border-color: #444; margin: 40px 0 20px;">
            <div class="text-center" style="color: #777;">
                <p>&copy; 2024 RE7LA. Tous droits réservés.</p>
            </div>
        </div>
    </footer>

    <!-- Favorites Offcanvas Sidebar -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="favoritesSidebar" aria-labelledby="favoritesSidebarLabel" style="border-radius: 30px 0 0 30px; width: 400px; border-left: none; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(20px);">
        <div class="offcanvas-header border-bottom py-4 px-4">
            <h5 class="offcanvas-title fw-bold" id="favoritesSidebarLabel" style="font-size: 1.5rem;">
                <i class="fas fa-heart text-danger me-2"></i> Favoris
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body p-4">
            <div id="favoritesList" class="d-flex flex-column gap-3">
                <div class="text-center py-5 text-muted empty-fav-msg">
                    <i class="fas fa-heart-broken fa-3x mb-3 opacity-25"></i>
                    <p>Aucun favori pour le moment.</p>
                </div>
            </div>
        </div>
        <div class="offcanvas-footer p-4 border-top">
            <a href="{{ path('app_hebergements_search') }}" class="btn w-100 py-3 rounded-pill" style="background: var(--bleu-ceil); color: white; font-weight: 600;">Découvrir plus</a>
        </div>
    </div>

    <!-- Localization Modal -->
    <div class="modal fade" id="localizationModal" tabindex="-1" aria-labelledby="localizationModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content modal-premium shadow-lg">
                <div class="modal-header border-0 pb-0">
                    <h4 class="fw-bold mb-0 ms-2 mt-3">Langue et Devise</h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="row">
                        <div class="col-md-6 border-end">
                            <h6 class="text-uppercase fw-bold text-muted small mb-4 ms-2">Langue</h6>
                            <div class="row g-2">
                                <div class="col-12">
                                    <a href="{{ path('app_change_locale', {locale: 'fr'}) }}" class="loc-option {{ app.request.locale == 'fr' ? 'active' : '' }}">
                                        <img src="https://flagcdn.com/w40/fr.png" class="loc-flag" alt="FR">
                                        <div class="flex-grow-1"><div class="fw-bold">Français</div></div>
                                        {% if app.request.locale == 'fr' %}<i class="fas fa-check-circle text-success"></i>{% endif %}
                                    </a>
                                </div>
                                <div class="col-12">
                                    <a href="{{ path('app_change_locale', {locale: 'en'}) }}" class="loc-option {{ app.request.locale == 'en' ? 'active' : '' }}">
                                        <img src="https://flagcdn.com/w40/us.png" class="loc-flag" alt="US">
                                        <div class="flex-grow-1"><div class="fw-bold">English</div></div>
                                        {% if app.request.locale == 'en' %}<i class="fas fa-check-circle text-success"></i>{% endif %}
                                    </a>
                                </div>
                                <div class="col-12">
                                    <a href="{{ path('app_change_locale', {locale: 'ar'}) }}" class="loc-option {{ app.request.locale == 'ar' ? 'active' : '' }}">
                                        <img src="https://flagcdn.com/w40/tn.png" class="loc-flag" alt="TN">
                                        <div class="flex-grow-1"><div class="fw-bold">العربية</div></div>
                                        {% if app.request.locale == 'ar' %}<i class="fas fa-check-circle text-success"></i>{% endif %}
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-uppercase fw-bold text-muted small mb-4 ms-2">Devise</h6>
                            <div class="row g-2">
                                <div class="col-12">
                                    <a href="{{ path('app_change_currency', {currency: 'TND'}) }}" class="loc-option {{ current_currency == 'TND' ? 'active' : '' }}">
                                        <div class="loc-flag d-flex align-items-center justify-content-center bg-light fw-bold text-dark" style="font-size: 0.7rem;">DT</div>
                                        <div class="flex-grow-1"><div class="fw-bold">Dinar Tunisien</div></div>
                                        {% if current_currency == 'TND' %}<i class="fas fa-check-circle text-success"></i>{% endif %}
                                    </a>
                                </div>
                                <div class="col-12">
                                    <a href="{{ path('app_change_currency', {currency: 'EUR'}) }}" class="loc-option {{ current_currency == 'EUR' ? 'active' : '' }}">
                                        <div class="loc-flag d-flex align-items-center justify-content-center bg-light fw-bold text-dark">€</div>
                                        <div class="flex-grow-1"><div class="fw-bold">Euro</div></div>
                                        {% if current_currency == 'EUR' %}<i class="fas fa-check-circle text-success"></i>{% endif %}
                                    </a>
                                </div>
                                <div class="col-12">
                                    <a href="{{ path('app_change_currency', {currency: 'USD'}) }}" class="loc-option {{ current_currency == 'USD' ? 'active' : '' }}">
                                        <div class="loc-flag d-flex align-items-center justify-content-center bg-light fw-bold text-dark">$</div>
                                        <div class="flex-grow-1"><div class="fw-bold">Dollar Américain</div></div>
                                        {% if current_currency == 'USD' %}<i class="fas fa-check-circle text-success"></i>{% endif %}
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

    <script>
        AOS.init({ duration: 1000, once: true });

        // Favorites Logic
        const FAV_STORAGE_KEY = 're7la_favorites';
        function getFavorites() { return JSON.parse(localStorage.getItem(FAV_STORAGE_KEY) || '[]'); }
        function saveFavorites(favorites) {
            localStorage.setItem(FAV_STORAGE_KEY, JSON.stringify(favorites));
            renderFavorites();
            updateUIHeartIcons();
        }
        function toggleFavorite(hotel) {
            let favorites = getFavorites();
            const index = favorites.findIndex(item => item.id == hotel.id);
            if (index > -1) { favorites.splice(index, 1); } 
            else { 
                favorites.push(hotel);
                const sidebar = new bootstrap.Offcanvas(document.getElementById('favoritesSidebar'));
                sidebar.show();
            }
            saveFavorites(favorites);
        }
        function renderFavorites() {
            const container = document.getElementById('favoritesList');
            const favorites = getFavorites();
            if (favorites.length === 0) {
                container.innerHTML = `<div class="text-center py-5 text-muted empty-fav-msg"><i class="fas fa-heart-broken fa-3x mb-3 opacity-25"></i><p>Aucun favori.</p></div>`;
                return;
            }
            container.innerHTML = favorites.map(hotel => `
                <div class="fav-item-card">
                    <img src="${hotel.image}" class="fav-item-img" alt="${hotel.title}">
                    <div class="fav-item-info">
                        <div class="fav-item-title">${hotel.title}</div>
                        <div class="fav-item-price">${hotel.price} DT</div>
                        <a href="/reservation/details/${hotel.id}" class="btn btn-sm p-0 text-primary fw-bold mt-1" style="font-size: 0.75rem;">Voir plus</a>
                    </div>
                    <div class="fav-remove-btn" onclick="toggleFavorite({id: '${hotel.id}'})"><i class="fas fa-times"></i></div>
                </div>
            `).join('');
        }
        function updateUIHeartIcons() {
            const favorites = getFavorites();
            const ids = favorites.map(f => f.id);
            document.querySelectorAll('.fav-btn').forEach(btn => {
                const id = btn.dataset.id;
                const heart = btn.querySelector('i');
                if (ids.includes(id)) {
                    heart.classList.remove('far'); heart.classList.add('fas'); btn.style.color = '#ef4444';
                } else {
                    heart.classList.remove('fas'); heart.classList.add('far'); btn.style.color = '#94a3b8';
                }
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            renderFavorites(); updateUIHeartIcons();
            const observer = new MutationObserver(updateUIHeartIcons);
            observer.observe(document.body, { childList: true, subtree: true });
            document.addEventListener('click', (e) => {
                const favBtn = e.target.closest('.fav-btn');
                if (favBtn) { toggleFavorite({ id: favBtn.dataset.id, title: favBtn.dataset.title, image: favBtn.dataset.image, price: favBtn.dataset.price }); }
            });
        });

        window.addEventListener('scroll', function() {
            const navbar = document.querySelector('.navbar-re7la');
            if (window.scrollY > 50) { navbar.classList.add('scrolled'); }
            else { navbar.classList.remove('scrolled'); }
        });

        document.addEventListener('DOMContentLoaded', function () {
            const btn = document.getElementById('accountDropdownBtn');
            const menu = document.getElementById('accountDropdownMenu');
            if (btn && menu) {
                btn.addEventListener('click', function (e) { e.stopPropagation(); menu.classList.toggle('show'); });
                document.addEventListener('click', function () { menu.classList.remove('show'); });
            }
        });
    </script>
    {% block javascripts %}{% endblock %}
</body>
</html>
