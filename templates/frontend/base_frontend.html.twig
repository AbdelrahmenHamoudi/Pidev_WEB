    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

    <script>
        AOS.init({ duration: 1000, once: true });

        // Favorites Logic
        const FAV_STORAGE_KEY = 're7la_favorites';
        function getFavorites() { return JSON.parse(localStorage.getItem(FAV_STORAGE_KEY) || '[]'); }
        function saveFavorites(favorites) {
            localStorage.setItem(FAV_STORAGE_KEY, JSON.stringify(favorites));
            renderFavorites();
            updateUIHeartIcons();
        }
        function toggleFavorite(hotel) {
            let favorites = getFavorites();
            const index = favorites.findIndex(item => item.id == hotel.id);
            if (index > -1) { favorites.splice(index, 1); } 
            else { 
                favorites.push(hotel);
                const sidebar = new bootstrap.Offcanvas(document.getElementById('favoritesSidebar'));
                sidebar.show();
            }
            saveFavorites(favorites);
        }
        function renderFavorites() {
            const container = document.getElementById('favoritesList');
            const favorites = getFavorites();
            if (favorites.length === 0) {
                container.innerHTML = `<div class="text-center py-5 text-muted empty-fav-msg"><i class="fas fa-heart-broken fa-3x mb-3 opacity-25"></i><p>Aucun favori.</p></div>`;
                return;
            }
            container.innerHTML = favorites.map(hotel => `
                <div class="fav-item-card">
                    <img src="${hotel.image}" class="fav-item-img" alt="${hotel.title}">
                    <div class="fav-item-info">
                        <div class="fav-item-title">${hotel.title}</div>
                        <div class="fav-item-price">${hotel.price} DT</div>
                        <a href="/reservation/details/${hotel.id}" class="btn btn-sm p-0 text-primary fw-bold mt-1" style="font-size: 0.75rem;">Voir plus</a>
                    </div>
                    <div class="fav-remove-btn" onclick="toggleFavorite({id: '${hotel.id}'})"><i class="fas fa-times"></i></div>
                </div>
            `).join('');
        }
        function updateUIHeartIcons() {
            const favorites = getFavorites();
            const ids = favorites.map(f => f.id);
            document.querySelectorAll('.fav-btn').forEach(btn => {
                const id = btn.dataset.id;
                const heart = btn.querySelector('i');
                if (ids.includes(id)) {
                    heart.classList.remove('far'); heart.classList.add('fas'); btn.style.color = '#ef4444';
                } else {
                    heart.classList.remove('fas'); heart.classList.add('far'); btn.style.color = '#94a3b8';
                }
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            renderFavorites(); updateUIHeartIcons();
            const observer = new MutationObserver(updateUIHeartIcons);
            observer.observe(document.body, { childList: true, subtree: true });
            document.addEventListener('click', (e) => {
                const favBtn = e.target.closest('.fav-btn');
                if (favBtn) { toggleFavorite({ id: favBtn.dataset.id, title: favBtn.dataset.title, image: favBtn.dataset.image, price: favBtn.dataset.price }); }
            });
        });

        window.addEventListener('scroll', function() {
            const navbar = document.querySelector('.navbar-re7la');
            if (window.scrollY > 50) { navbar.classList.add('scrolled'); }
            else { navbar.classList.remove('scrolled'); }
        });

        document.addEventListener('DOMContentLoaded', function () {
            const btn = document.getElementById('accountDropdownBtn');
            const menu = document.getElementById('accountDropdownMenu');
            if (btn && menu) {
                btn.addEventListener('click', function (e) { e.stopPropagation(); menu.classList.toggle('show'); });
                document.addEventListener('click', function () { menu.classList.remove('show'); });
            }
        });
    </script>
