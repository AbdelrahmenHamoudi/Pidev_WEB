{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}Mes Réservations - RE7LA{% endblock %}

{% block body %}
<section class="py-5" style="background: #f8f9fa; min-height: 100vh;">
    <div class="container">
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h2 style="font-weight: 700; color: #2c3e50;">
                    <span style="color: #87CEEB;">Mes</span> Réservations
                </h2>
                <p style="color: #777;">Gérez vos réservations d'hébergement</p>
            </div>
            <a href="{{ path('app_hebergements_search') }}" class="btn" style="background: linear-gradient(135deg, #87CEEB, #93C572); color: white; border-radius: 50px; padding: 12px 30px; font-weight: 600;">
                <i class="bx bx-plus me-2"></i>Nouvelle réservation
            </a>
        </div>

        <!-- Flash Messages -->
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 15px; border: none; background: rgba(147, 197, 114, 0.15); color: #5a9e3b;">
                <i class="bx bx-check-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 15px; border: none; background: rgba(231, 76, 60, 0.15); color: #c0392b;">
                <i class="bx bx-error-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}

        <!-- Reservations List -->
        {% if reservations|length > 0 %}
            <div class="row g-4">
                {% for reservation in reservations %}
                <div class="col-md-6 col-lg-4">
                    <div class="card border-0" style="border-radius: 25px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); overflow: hidden;">
                        <div class="position-relative">
                            {% set imgName = reservation.hebergement.image|split('/')|last|split('\\')|last %}
                            {% if imgName and '.' in imgName %}
                                <img src="{{ asset('uploads/hebergements/' ~ imgName) }}" class="w-100" style="height: 200px; object-fit: cover;" alt="{{ reservation.hebergement.titre }}" onerror="this.src='https://images.unsplash.com/photo-1566073771259-6a8506099945?w=200';">
                            {% else %}
                                <div class="w-100 d-flex align-items-center justify-content-center" style="height: 200px; background: linear-gradient(135deg, #87CEEB, #93C572);">
                                    <i class="bx bx-building-house" style="font-size: 4rem; color: white;"></i>
                                </div>
                            {% endif %}
                            <span class="badge-status statut-{{ reservation.statut_r|lower|replace({' ': '-'}) }}" style="position: absolute; top: 15px; right: 15px; padding: 8px 15px; border-radius: 25px; font-weight: 600; font-size: 0.8rem;">
                                {{ reservation.statut_r }}
                            </span>
                        </div>
                        <div class="card-body p-4">
                            <h5 style="font-weight: 700; color: #2c3e50; margin-bottom: 5px;">{{ reservation.hebergement.titre }}</h5>
                            <p style="color: #87CEEB; font-size: 0.9rem; margin-bottom: 15px;">
                                <i class="bx bx-tag me-1"></i>{{ reservation.hebergement.typeHebergement }}
                            </p>
                            
                            <div style="background: #f8f9fa; border-radius: 15px; padding: 15px; margin-bottom: 20px;">
                                <div class="d-flex justify-content-between mb-2">
                                    <span style="color: #777;"><i class="bx bx-calendar me-1"></i>Arrivée</span>
                                    <span style="font-weight: 600; color: #2c3e50;">{{ reservation.dateDebutR|date('d/m/Y') }}</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span style="color: #777;"><i class="bx bx-calendar me-1"></i>Départ</span>
                                    <span style="font-weight: 600; color: #2c3e50;">{{ reservation.dateFinR|date('d/m/Y') }}</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span style="color: #777;"><i class="bx bx-moon me-1"></i>Nuits</span>
                                    <span style="font-weight: 600; color: #2c3e50;">{{ ((reservation.dateFinR|date('U') - reservation.dateDebutR|date('U')) / 86400)|default(1) }}</span>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span style="color: #777;">Total</span>
                                <span style="font-weight: 700; color: #87CEEB; font-size: 1.3rem;">{{ reservation.hebergement ? (((reservation.dateFinR|date('U') - reservation.dateDebutR|date('U')) / 86400) * reservation.hebergement.prixParNuitNumeric)|default(0) ~ ' DT' : 'N/A' }}</span>
                            </div>

                            <div class="d-flex gap-2">
                                <a href="{{ path('app_reservation_show', {id: reservation.idReservation}) }}" class="btn flex-fill" style="background: rgba(135, 206, 235, 0.15); color: #87CEEB; border-radius: 50px; font-weight: 600;">
                                    <i class="bx bx-show me-1"></i>Voir
                                </a>
                                {% if reservation.statut_r in ['EN ATTENTE', 'PENDING'] %}
                                    <a href="{{ path('app_reservation_edit', {id: reservation.idReservation}) }}" class="btn flex-fill" style="background: rgba(243, 156, 18, 0.15); color: #f39c12; border-radius: 50px; font-weight: 600;">
                                        <i class="bx bx-edit me-1"></i>Modifier
                                    </a>
                                    <form method="post" action="{{ path('app_reservation_cancel', {id: reservation.idReservation}) }}" class="action-form" style="display: inline; flex: 1;" onsubmit="return confirm('Êtes-vous sûr de vouloir annuler cette réservation ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('cancel' ~ reservation.idReservation) }}">
                                        <button class="btn w-100" style="background: rgba(231, 76, 60, 0.15); color: #e74c3c; border-radius: 50px; font-weight: 600;">
                                            <i class="bx bx-x-circle me-1"></i>Annuler
                                        </button>
                                    </form>
                                {% endif %}
                                {% if reservation.statut_r in ['Annulée', 'EN ATTENTE', 'PENDING'] %}
                                    <form method="post" action="{{ path('app_reservation_delete', {id: reservation.idReservation}) }}" style="display: inline; flex: 1;" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette réservation ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reservation.idReservation) }}">
                                        <button class="btn w-100" style="background: rgba(149, 165, 166, 0.15); color: #95a5a6; border-radius: 50px; font-weight: 600;">
                                            <i class="bx bx-trash me-1"></i>Supprimer
                                        </button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="text-center py-5">
                <div style="background: white; border-radius: 25px; padding: 60px; box-shadow: 0 10px 40px rgba(0,0,0,0.1);">
                    <i class="bx bx-calendar-x" style="font-size: 5rem; color: #ddd; margin-bottom: 20px;"></i>
                    <h4 style="color: #2c3e50; font-weight: 600; margin-bottom: 15px;">Aucune réservation</h4>
                    <p style="color: #777; margin-bottom: 30px;">Vous n'avez pas encore de réservations. Découvrez nos hébergements et faites votre première réservation !</p>
                    <a href="{{ path('app_hebergements_search') }}" class="btn" style="background: linear-gradient(135deg, #87CEEB, #93C572); color: white; border-radius: 50px; padding: 15px 40px; font-weight: 600;">
                        <i class="bx bx-building-house me-2"></i>Parcourir les hébergements
                    </a>
                </div>
            </div>
        {% endif %}
    </div>
</section>

<style>
    .statut-confirmee { background: rgba(147, 197, 114, 0.2); color: #93C572; }
    .statut-en-attente { background: rgba(243, 156, 18, 0.2); color: #f39c12; }
    .statut-annulee { background: rgba(231, 76, 60, 0.2); color: #e74c3c; }
    .statut-pending { background: rgba(243, 156, 18, 0.2); color: #f39c12; }
</style>

<script>
document.querySelectorAll('.action-form').forEach(form => {
  form.addEventListener('submit', function() {
    const btn = this.querySelector('button');
    if (btn) {
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Traitement...';
    }
  });
});
</script>
{% endblock %}
