{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}Rechercher un hébergement - RE7LA{% endblock %}

{% block body %}
<div class="container-fluid py-5" style="background: #f8f9fa;">
    <div class="container py-4">
        
        <!-- Header & Search Bar -->
        <div class="row mb-5" style="margin-top: 80px;">
            <div class="col-12 px-0">
                <form method="get" action="{{ path('app_hebergements_search') }}" class="hero-search-container" style="margin-top: 0; max-width: 1000px; margin: 0 auto;">
                    <div class="search-input-group">
                        <span class="search-label">Où allez-vous ?</span>
                        <input type="text" name="titre" class="search-field" placeholder="Rechercher..." value="{{ current_titre }}">
                    </div>
                    <div class="search-input-group">
                        <span class="search-label">Dates</span>
                        <input type="text" name="dates" class="search-field" placeholder="Ajouter des dates" onfocus="(this.type='date')">
                    </div>
                    <div class="search-input-group">
                        <span class="search-label">Voyageurs</span>
                        <input type="number" name="capacite" min="1" class="search-field" placeholder="Personnes" value="{{ current_capacite }}">
                    </div>
                    <button type="submit" class="search-btn">
                        <i class="fas fa-search"></i>
                    </button>
                </form>
            </div>
        </div>

        <div class="row">
            <!-- Sidebar Filters -->
            <div class="col-lg-3">
                <form method="get" action="{{ path('app_hebergements_search') }}" class="filter-sidebar">
                    <div class="filter-group">
                        <h6 class="filter-title">Filtrer par nom</h6>
                        <input type="text" name="titre" class="form-control" placeholder="Hébergement..." value="{{ current_titre }}" style="border-radius: 10px; border: 1px solid #ddd;">
                    </div>

                    <div class="filter-group">
                        <h6 class="filter-title">Type d'établissement</h6>
                        <label class="filter-option">
                            <input type="radio" name="type" value="all" {{ current_type == 'all' ? 'checked' : '' }}> Tous
                        </label>
                        <label class="filter-option">
                            <input type="radio" name="type" value="Appartement" {{ current_type == 'Appartement' ? 'checked' : '' }}> Appart'hôtel
                        </label>
                        <label class="filter-option">
                            <input type="radio" name="type" value="Hôtel" {{ current_type == 'Hôtel' ? 'checked' : '' }}> Hôtel
                        </label>
                        <label class="filter-option">
                            <input type="radio" name="type" value="Maison d'hôtes" {{ current_type == "Maison d'hôtes" ? 'checked' : '' }}> Maison d'hôtes
                        </label>
                    </div>

                    <div class="filter-group">
                        <h6 class="filter-title">Capacité (personnes)</h6>
                        <select name="capacite" class="form-control" style="border-radius: 10px; border: 1px solid #ddd;">
                            <option value="">Toutes capacités</option>
                            <option value="1" {{ current_capacite == '1' ? 'selected' : '' }}>1+ personne</option>
                            <option value="2" {{ current_capacite == '2' ? 'selected' : '' }}>2+ personnes</option>
                            <option value="4" {{ current_capacite == '4' ? 'selected' : '' }}>4+ personnes</option>
                            <option value="6" {{ current_capacite == '6' ? 'selected' : '' }}>6+ personnes</option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <h6 class="filter-title">Disponibilité</h6>
                        <label class="filter-option">
                            <input type="radio" name="disponible" value="" {{ current_disponible is empty ? 'checked' : '' }}> Tous
                        </label>
                        <label class="filter-option">
                            <input type="radio" name="disponible" value="1" {{ current_disponible == '1' ? 'checked' : '' }}> Disponible
                        </label>
                        <label class="filter-option">
                            <input type="radio" name="disponible" value="0" {{ current_disponible == '0' ? 'checked' : '' }}> Indisponible
                        </label>
                    </div>

                    <button type="submit" class="btn btn-primary-modern w-100 mt-3">Appliquer les filtres</button>
                    <a href="{{ path('app_hebergements_search') }}" class="btn btn-outline-secondary w-100 mt-2" style="border-radius: 12px;">Réinitialiser</a>
                </form>
            </div>

            <!-- Results Content -->
            <div class="col-lg-9">
                <!-- Tabs -->
                <div class="results-header-tabs mb-4" data-aos="fade-up">
                    <div class="category-tabs d-flex gap-2">
                        <a href="{{ path('app_hebergements_search') }}" class="btn btn-category {{ current_type == 'all' or current_type is empty ? 'active' : '' }}">Tous les séjours</a>
                        <a href="{{ path('app_hebergements_search', {type: 'Hôtel'}) }}" class="btn btn-category {{ current_type == 'Hôtel' ? 'active' : '' }}">Hôtels</a>
                        <a href="{{ path('app_hebergements_search', {type: "Maison d'hôtes"}) }}" class="btn btn-category {{ current_type == "Maison d'hôtes" ? 'active' : '' }}">Maisons</a>
                    </div>
                </div>
                    
                    <div class="d-flex justify-content-between align-items-center mb-4" data-aos="fade-up">
                        <h4 class="mb-0 fw-bold">{{ hebergements|length }} établissements trouvés</h4>
                        <div class="dropdown">
                            <button class="btn btn-light dropdown-toggle" type="button" data-bs-toggle="dropdown" style="border-radius: 50px; padding: 10px 20px; font-weight: 600;">
                                Trier par : {{ current_sort == 'price_asc' ? 'Prix croissant' : current_sort == 'price_desc' ? 'Prix décroissant' : 'Recommandé' }}
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end" style="border-radius: 12px; border: none; box-shadow: 0 4px 20px rgba(0,0,0,0.1);">
                                <li><a class="dropdown-item" href="{{ path('app_hebergements_search', {titre: current_titre, type: current_type, capacite: current_capacite, disponible: current_disponible, sort: 'default'}) }}">Recommandé</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_hebergements_search', {titre: current_titre, type: current_type, capacite: current_capacite, disponible: current_disponible, sort: 'price_asc'}) }}">Prix : croissant</a></li>
                                <li><a class="dropdown-item" href="{{ path('app_hebergements_search', {titre: current_titre, type: current_type, capacite: current_capacite, disponible: current_disponible, sort: 'price_desc'}) }}">Prix : décroissant</a></li>
                            </ul>
                        </div>
                    </div>

                <!-- Results List -->
                <div class="search-results-list">
                    {% for hebergement in hebergements %}
                    <div class="hebergement-card-horizontal" data-type="{{ hebergement.typeHebergement }}">
                        <div class="card-image-box">
                            {% set imgName = '' %}
                            {% if hebergement.image %}
                                {% set imgName = hebergement.image|split('/')|last|split('\\')|last %}
                            {% endif %}
                            
                            {% if imgName and '.' in imgName %}
                                <img src="{{ asset('uploads/hebergements/' ~ imgName) }}" alt="{{ hebergement.titre }}" onerror="this.src='https://images.unsplash.com/photo-1566073771259-6a8506099945?w=800';">
                            {% else %}
                                <img src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?w=800" alt="{{ hebergement.titre }}">
                            {% endif %}
                            <div class="badge-favorite">
                                <i class="far fa-heart"></i>
                            </div>
                        </div>
                        <div class="card-content-box">
                            <div>
                                <div class="card-header-flex">
                                    <h4 class="card-title">{{ hebergement.titre }}</h4>
                                    <div class="text-warning">
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                        <i class="fas fa-star"></i>
                                    </div>
                                </div>
                                <div class="card-location">
                                    <i class="fas fa-map-marker-alt me-1"></i> {{ hebergement.typeHebergement }}
                                </div>
                                <div class="card-amenities">
                                    <span><i class="fas fa-wifi me-1"></i> Wifi gratuit</span>
                                    <span><i class="fas fa-swimming-pool me-1"></i> Piscine</span>
                                    <span><i class="fas fa-parking me-1"></i> Parking</span>
                                </div>
                            </div>
                            <div class="d-flex justify-content-between align-items-end">
                                <div>
                                  
                                </div>
                                <div class="card-price-box">
                                    <div class="price-value">{{ hebergement.prixParNuit }} DT</div>
                                    <div class="price-unit">pour 1 nuit, taxes incluses</div>
                                    <a href="{{ path('app_hebergement_detail', {id: hebergement.idHebergement}) }}" class="btn btn-primary-modern mt-3">Voir les disponibilités</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% else %}
                    <div class="text-center py-5">
                        <img src="https://cdni.iconscout.com/illustration/premium/thumb/not-found-4064375-3363936.png" style="width: 200px; opacity: 0.5;">
                        <h4 class="mt-4" style="color: #999;">Aucun résultat ne correspond à votre recherche</h4>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>
    <style>
        .category-tabs .btn-category {
            border-radius: 12px;
            padding: 10px 24px;
            font-weight: 600;
            border: 1px solid #eee;
            background: white;
            color: #444;
            transition: all 0.3s;
        }
        .category-tabs .btn-category.active {
            background: #87CEEB;
            color: white;
            border-color: #87CEEB;
            box-shadow: 0 4px 15px rgba(135, 206, 235, 0.3);
        }
    </style>
{% endblock %}
