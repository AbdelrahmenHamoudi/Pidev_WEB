    {% extends 'frontend/base_frontend.html.twig' %}

{% block title %}Réinitialiser le mot de passe - RE7LA{% endblock %}

{% block extra_styles %}
<style>
    .reset-section {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 120px 20px 60px;
        background: linear-gradient(135deg, #fff0cc 0%, #fffaf1 32%, #e6fbf6 68%, #fff2d9 100%);
    }
    .reset-card {
        background: white;
        max-width: 520px;
        width: 100%;
        padding: 50px 40px;
        border-radius: 28px;
        box-shadow: 0 35px 80px rgba(44, 62, 80, 0.18);
        text-align: center;
    }
    .reset-icon {
        width: 100px;
        height: 100px;
        margin: 0 auto 24px;
        border-radius: 50%;
        background: linear-gradient(135deg, #F39C12, #e67e22);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 42px;
        box-shadow: 0 20px 40px rgba(243, 156, 18, 0.3);
    }
    .reset-card h1 {
        color: #2C3E50;
        font-size: 2rem;
        font-weight: 900;
        margin-bottom: 10px;
    }
    .reset-card p {
        color: #6b7280;
        font-size: 15px;
        line-height: 1.7;
        margin-bottom: 30px;
    }
    .form-group { margin-bottom: 18px; text-align: left; }
    .input-label {
        display: block;
        margin-bottom: 10px;
        color: #2C3E50;
        font-size: 14px;
        font-weight: 800;
    }
    .form-input {
        width: 100%;
        height: 62px;
        border-radius: 18px;
        border: 2px solid rgba(44, 62, 80, 0.10);
        background: #f9fafb;
        padding: 0 20px;
        font-size: 15px;
        color: #2C3E50;
        outline: none;
        transition: all 0.25s ease;
    }
    .form-input:focus {
        border-color: #F39C12;
        background: white;
        box-shadow: 0 0 0 4px rgba(243, 156, 18, 0.14);
    }
    .code-input {
        text-align: center;
        letter-spacing: 12px;
        font-size: 26px;
        font-weight: 900;
    }
    .btn-reset {
        width: 100%;
        height: 62px;
        border: none;
        border-radius: 20px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 900;
        color: white;
        background: #F39C12;
        box-shadow: 0 18px 34px rgba(243, 156, 18, 0.34);
        transition: all 0.3s ease;
    }
    .btn-reset:hover {
        background: #e67e22;
        transform: translateY(-3px);
    }
    .alert {
        padding: 14px 16px;
        border-radius: 14px;
        margin-bottom: 20px;
        font-size: 14px;
        text-align: left;
    }
    .alert-danger {
        background: #ffecec;
        color: #c0392b;
        border: 1px solid rgba(231, 76, 60, 0.2);
    }
    .alert-success {
        background: #e5ffed;
        color: #15803d;
        border: 1px solid rgba(22, 163, 74, 0.2);
    }
</style>
{% endblock %}

{% block body %}
<section class="reset-section">
    <div class="reset-card">
        <div class="reset-icon">
            <i class="fas fa-key"></i>
        </div>

        <h1>Nouveau mot de passe</h1>
        <p>Entrez le code reçu par email et choisissez un nouveau mot de passe.</p>

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
            </div>
        {% endfor %}

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">
                <i class="fas fa-check-circle me-2"></i>{{ message }}
            </div>
        {% endfor %}

        <form method="post" action="{{ path('app_reset_password') }}">
            <div class="form-group">
                <label class="input-label">Code de vérification</label>
                <input type="text" name="code" class="form-input code-input" placeholder="000000" maxlength="6" pattern="[0-9]{6}" required>
            </div>

            <div class="form-group">
                <label class="input-label">Nouveau mot de passe</label>
                <input type="password" name="new_password" class="form-input" placeholder="Min 8 caractères" required>
            </div>

            <div class="form-group">
                <label class="input-label">Confirmer le mot de passe</label>
                <input type="password" name="confirm_password" class="form-input" placeholder="Confirmer" required>
            </div>

            <button type="submit" class="btn-reset">
                <i class="fas fa-check me-2"></i>Réinitialiser le mot de passe
            </button>
        </form>

        <p style="margin-top: 20px; font-size: 13px; color: #9ca3af;">
            Le code est valable pendant 15 minutes
        </p>
    </div>
</section>
{% endblock %}