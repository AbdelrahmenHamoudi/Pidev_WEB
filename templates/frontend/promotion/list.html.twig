{# ══════════════════════════════════════════════════════════════════════════
   PUSHER REAL-TIME NOTIFICATIONS (WebSocket API)
   When admin creates/updates a promotion, all connected users see a toast.
   
   How to get your Pusher keys:
   1. Go to https://pusher.com/channels → Sign up free
   2. Create a new app (choose "EU" cluster for Europe)
   3. Copy App ID, Key, Secret from the "App Keys" tab
   4. Set them in .env:
      PUSHER_APP_ID=your_app_id
      PUSHER_KEY=your_key  
      PUSHER_SECRET=your_secret
      PUSHER_CLUSTER=eu
   Free tier: 200,000 messages/day, 100 concurrent connections
══════════════════════════════════════════════════════════════════════════ #}

<script src="https://js.pusher.com/8.2.0/pusher.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
(function() {
    // Initialize Pusher with the public key (exposed via Twig global)
    const pusherKey = '{{ pusher_key }}';
    const pusherCluster = '{{ pusher_cluster }}';
    
    // Only connect if Pusher is configured (key is not a placeholder)
    if (pusherKey && pusherKey !== 'YOUR_PUSHER_KEY' && pusherKey.length > 5) {
        const pusher = new Pusher(pusherKey, {
            cluster: pusherCluster || 'eu'
        });
        
        const channel = pusher.subscribe('promotions');
        
        // 🎉 New promotion created by admin
        channel.bind('new-promo', function(data) {
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                title: data.message || '🎉 Nouvelle promotion disponible!',
                html: data.discount ? '<small style="color:#F7B731;font-weight:700;">-' + data.discount + '</small>' : '',
                showConfirmButton: true,
                confirmButtonText: '👀 Voir',
                confirmButtonColor: '#F7B731',
                showCancelButton: false,
                timer: 8000,
                timerProgressBar: true,
                customClass: {
                    popup: 'animate__animated animate__slideInRight'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.reload();
                }
            });
        });
        
        // 🔄 Promotion updated by admin
        channel.bind('promo-updated', function(data) {
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'info',
                title: data.message || '🔄 Une promotion a été mise à jour',
                showConfirmButton: false,
                timer: 5000,
                timerProgressBar: true,
                customClass: {
                    popup: 'animate__animated animate__slideInRight'
                }
            });
        });

        // 🧠 Smart Discount Engine: Discount Increased (Centered Dialog)
        channel.bind('smart-increase', function(data) {
            Swal.fire({
                title: '🧠 Opportunité Smart Engine !',
                html: `
                    <div style="text-align:center; padding:10px;">
                        <div style="background:rgba(26,188,156,0.1); width:70px; height:70px; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
                            <span style="font-size:32px;">🔥</span>
                        </div>
                        <h4 style="color:#2c3e50; font-weight:800; margin-bottom:10px;">${data.name}</h4>
                        <p style="color:#64748b; font-size:14px; line-height:1.6;">
                            Nous avons détecté un faible engagement sur cette offre.<br>
                            Pour vous faire plaisir, nous avons boosté la réduction à <br>
                            <span style="color:#1abc9c; font-size:24px; font-weight:900;">${data.newDiscount}</span> !
                        </p>
                    </div>
                `,
                icon: 'success',
                showCancelButton: true,
                confirmButtonColor: '#1abc9c',
                cancelButtonColor: '#94a3b8',
                confirmButtonText: '<i class="fas fa-calendar-check"></i> Réserver maintenant',
                cancelButtonText: 'Ignorer',
                customClass: {
                    popup: 'animate__animated animate__zoomIn'
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    // Open the reservation modal for this specific promotion
                    // Assuming currentPromo exists or we can find the card and click it
                    const card = document.querySelector(`.promo-card[data-promo-id="${data.id}"]`);
                    if (card) {
                        card.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        setTimeout(() => {
                            // Trigger the openReservationModal function defined in list.html.twig
                            if (typeof openReservationModal === 'function') {
                                // Find the promo data in promotionsData
                                if (promotionsData && promotionsData[data.id]) {
                                    openReservationModal(promotionsData[data.id]);
                                } else {
                                    window.location.reload(); // Fallback
                                }
                            }
                        }, 500);
                    } else {
                        window.location.reload();
                    }
                }
            });
        });
        
        console.log('✅ Pusher real-time notifications connected.');
    } else {
        console.log('ℹ️ Pusher not configured. Set PUSHER_KEY in .env to enable real-time notifications.');
    }
})();
</script>
