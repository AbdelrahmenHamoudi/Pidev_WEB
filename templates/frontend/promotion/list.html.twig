.promo-card {
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    border: 1px solid transparent;
}
.card-status-active:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(147, 197, 114, 0.25) !important;
    border-color: rgba(147, 197, 114, 0.4) !important;
}
.card-status-upcoming:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(243, 156, 18, 0.25) !important;
    border-color: rgba(243, 156, 18, 0.4) !important;
}
.card-status-expired:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(230, 57, 70, 0.15) !important;
    filter: grayscale(60%);
}

.trending-card {
    position: relative;
    overflow: hidden;
}
.trending-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 60%);
    animation: flameFlicker 3s infinite alternate ease-in-out;
    pointer-events: none;
    z-index: 0;
}
@keyframes flameFlicker {
    0% { transform: translate(0, 0) scale(1); opacity: 0.5; }
    50% { transform: translate(2%, 3%) scale(1.05); opacity: 0.8; }
    100% { transform: translate(-1%, -2%) scale(0.95); opacity: 0.6; }
}
.trending-card .card-body h6, 
.trending-card .card-body p, 
.trending-card .card-body span {
    color: #fff !important;
    position: relative;
    z-index: 1;
}
.trending-card .date-container {
    background: rgba(255, 255, 255, 0.15) !important;
}

/* Sidebar Styling */
.sidebar-modern {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    border-right: 1px solid rgba(255,255,255,0.5);
    box-shadow: 5px 0 30px rgba(0,0,0,0.02);
}
.sidebar-check {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    cursor: pointer;
    font-size: 13px;
    color: #64748b;
    font-weight: 500;
    border-radius: 10px;
    transition: all 0.3s ease;
}
.sidebar-check:hover {
    background: rgba(247, 183, 49, 0.08);
    color: #2c3e50;
    transform: translateX(4px);
}
.sidebar-check input[type="radio"], .sidebar-check input[type="checkbox"] {
    accent-color: #F7B731;
    width: 16px;
    height: 16px;
    transition: transform 0.2s;
}
.sidebar-check input:checked {
    transform: scale(1.1);
}
.sidebar-check input:checked + span {
    font-weight: 700;
    color: #2c3e50;
}

/* Animated Background */
.animated-bg {
    background: linear-gradient(-45deg, #f0f4f8, #e2e8f0, #f8fafc, #edf2f7);
    background-size: 400% 400%;
    animation: gradientBg 15s ease infinite;
    min-height: 100vh;
}
@keyframes gradientBg {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

.modal-content {
    box-shadow: 0 30px 80px rgba(0,0,0,0.2);
}
</style>

<script>
const offerDetails = JSON.parse(document.getElementById('offerDetailsData').textContent || '{}');
const packDetails  = JSON.parse(document.getElementById('packDetailsData').textContent || '{}');
const rawPromos    = JSON.parse(document.getElementById('promotionsRawData').textContent || '{}');

const promotionsData = {};
Object.values(rawPromos).forEach(p => {
    promotionsData[String(p.id)] = p;
});

// Gestionnaire pour boutons Débloquer
document.querySelectorAll('.btn-unlock').forEach(btn => {
    btn.addEventListener('click', () => {
        const promoId = btn.dataset.promoId;
        currentUnlockPromo = promotionsData[promoId];
        
        // Afficher QR si disponible
        if (currentUnlockPromo.promoCode && currentUnlockPromo.promoCode.qr_url) {
            document.getElementById('qrImage').src = currentUnlockPromo.promoCode.qr_url;
            document.getElementById('qrDisplay').style.display = 'block';
        } else {
            document.getElementById('qrDisplay').style.display = 'none';
        }
        
        document.getElementById('promoCodeInput').value = '';
        document.getElementById('codeError').style.display = 'none';
        document.getElementById('codeSuccess').style.display = 'none';
        
        new bootstrap.Modal(document.getElementById('unlockModal')).show();
    });
});

function filterPromotions() {
    const input = document.getElementById('searchInput');
    const filter = input.value.toLowerCase();
    const wrappers = document.getElementsByClassName('promo-card-wrapper');

    for (let i = 0; i < wrappers.length; i++) {
        // We look into the inner text of the card to find matches
        const text = wrappers[i].innerText.toLowerCase();
        
        if (text.includes(filter)) {
            wrappers[i].style.display = "";
        } else {
            wrappers[i].style.display = "none";
        }
    }
}

async function verifyCode() {
    const code = document.getElementById('promoCodeInput').value.trim();
    const errorDiv = document.getElementById('codeError');
    const successDiv = document.getElementById('codeSuccess');
    
    if (!code) {
        errorDiv.textContent = 'Veuillez entrer un code';
        errorDiv.style.display = 'block';
        return;
    }
    
    try {
        const response = await fetch('{{ path("promo_validate_code_ajax") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                code: code,
                promotion_id: currentUnlockPromo.id
            })
        });
        
        const data = await response.json();
        
        if (data.valid) {
            errorDiv.style.display = 'none';
            successDiv.textContent = '✅ Code validé ! Redirection...';
            successDiv.style.display = 'block';
            
            // Fermer modal et ouvrir modal réservation
            setTimeout(() => {
                bootstrap.Modal.getInstance(document.getElementById('unlockModal')).hide();
                // Ouvrir modal réservation avec le code validé
                openReservationModal(currentUnlockPromo, code);
            }, 1000);
        } else {
            successDiv.style.display = 'none';
            errorDiv.textContent = data.message || 'Code invalide';
            errorDiv.style.display = 'block';
        }
    } catch (e) {
        errorDiv.textContent = 'Erreur de connexion';
        errorDiv.style.display = 'block';
    }
}

function openReservationModal(promo, validatedCode) {
    // Stocker le code validé pour l'envoyer lors de la réservation
    promo.validatedPromoCode = validatedCode;
    
    // Ouvrir le modal de réservation normal
    currentPromo = promo;
    document.getElementById('modalTitle').textContent = promo.name;
    document.getElementById('modalSubtitle').textContent = promo.isPack 
        ? '📦 Pack - Code validé ✓' 
        : '🎫 Offre individuelle - Code validé ✓';
        
    document.getElementById('prixRecap').style.display    = 'none';
    document.getElementById('btnConfirmer').style.display  = 'none';
    document.getElementById('modalError').style.display    = 'none';
    document.getElementById('modalSuccess').style.display  = 'none';
    currentPriceData = null;
    packPriceData    = [];

    if (promo.isPack) {
        buildPackModal(promo.id, promo.startDate, promo.endDate);
    } else {
        buildIndividualModal(promo.offerType, promo.referenceId, promo.id, promo.startDate, promo.endDate);
    }
    
    new bootstrap.Modal(document.getElementById('reservationModal')).show();
}

function labelForType(type) {
    if (type === 'hebergement') return 'Hébergement';
    if (type === 'voiture') return 'Voiture';
    if (type === 'activite') return 'Activité';
    return '';
}

document.querySelectorAll('.btn-reserver').forEach(btn => {
    btn.addEventListener('click', () => {
        const promoId   = btn.dataset.promoId;
        currentPromo    = promotionsData[promoId];
        const promoStart = btn.dataset.promoStart || '';
        const promoEnd   = btn.dataset.promoEnd   || '';

        document.getElementById('modalTitle').textContent    = currentPromo.name;
        document.getElementById('modalSubtitle').textContent = currentPromo.isPack
            ? '📦 Pack — Remplissez les informations pour chaque offre'
            : '🎫 Offre individuelle — ' + labelForType(currentPromo.offerType);

        document.getElementById('prixRecap').style.display    = 'none';
        document.getElementById('btnConfirmer').style.display  = 'none';
        document.getElementById('modalError').style.display    = 'none';
        document.getElementById('modalSuccess').style.display  = 'none';
        currentPriceData = null;
        packPriceData    = [];

        if (currentPromo.isPack) {
            buildPackModal(promoId, promoStart, promoEnd);
        } else {
            buildIndividualModal(currentPromo.offerType, currentPromo.referenceId, promoId, promoStart, promoEnd);
        }

        new bootstrap.Modal(document.getElementById('reservationModal')).show();
    });
});

function buildIndividualModal(type, offerId, promoId, promoStart, promoEnd) {
    const offer = offerDetails[promoId] || {};
    const minA  = promoStart ? `min="${promoStart}"` : `min="${todayStr()}"`;
    const maxA  = promoEnd   ? `max="${promoEnd}"` : '';
    const hint  = promoStart && promoEnd
        ? `<div style="font-size:11px;color:#94a3b8;margin-top:3px;">Période : ${promoStart} → ${promoEnd}</div>` : '';
    let html = '';

    if (type === 'hebergement') {
        const prixNuit = parseFloat(offer.unitPrice) || 0;
        html = `
        <div class="offer-info mb-3" style="background:#f8f9fa;border-radius:12px;padding:14px 16px;">
            <div class="d-flex justify-content-between">
                <span style="color:#94a3b8;font-size:13px;">🏨 ${offer.label || 'Hébergement'}</span>
                <span style="font-weight:700;color:#2c3e50;">${prixNuit.toFixed(2)} DT / nuit</span>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-6">
                <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">📅 Date d'arrivée *</label>
                <input type="date" id="hebergDateDebut" class="form-control" ${minA} ${maxA}
                       onchange="onHebergDateChange(${promoId}, ${offerId})">${hint}
            </div>
            <div class="col-6">
                <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">📅 Date de départ *</label>
                <input type="date" id="hebergDateFin" class="form-control" ${minA} ${maxA}
                       onchange="onHebergDateChange(${promoId}, ${offerId})">
            </div>
        </div>
        <div id="hebergCalc" style="display:none;margin-top:14px;"></div>`;

    } else if (type === 'voiture') {
        const prixKm = parseFloat(offer.unitPrice) || 0;
        html = `
        <div class="offer-info mb-3" style="background:#f8f9fa;border-radius:12px;padding:14px 16px;">
            <div class="d-flex justify-content-between">
                <span style="color:#94a3b8;font-size:13px;">🚗 ${offer.label || 'Voiture'}</span>
                <span style="font-weight:700;color:#2c3e50;">${prixKm.toFixed(2)} DT / km</span>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-6">
                <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">🛣️ Distance (km) *</label>
                <input type="number" id="distanceKm" class="form-control" min="1" placeholder="100"
                       oninput="onVoitureChange(${promoId}, ${offerId})">
            </div>
            <div class="col-6">
                <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">📅 Date de réservation</label>
                <input type="date" id="dateVoiture" class="form-control" ${minA} ${maxA} value="${promoStart || todayStr()}">${hint}
            </div>
            <div class="col-12">
                <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">📍 Point de départ</label>
                <input type="text" id="pointDepart" class="form-control" placeholder="Ex: Tunis">
            </div>
            <div class="col-12">
                <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">📍 Point d'arrivée</label>
                <input type="text" id="pointArrivee" class="form-control" placeholder="Ex: Sousse">
            </div>
        </div>`;

    } else if (type === 'activite') {
        const prixPers = parseFloat(offer.unitPrice) || 0;
        html = `
        <div class="offer-info mb-3" style="background:#f8f9fa;border-radius:12px;padding:14px 16px;">
            <div class="d-flex justify-content-between">
                <span style="color:#94a3b8;font-size:13px;">🎯 ${offer.label || 'Activité'}</span>
                <span style="font-weight:700;color:#2c3e50;">${prixPers.toFixed(2)} DT / personne</span>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-6">
                <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">👥 Nombre de personnes *</label>
                <input type="number" id="nbPersonnesActivite" class="form-control"
                       min="1" max="${offer.maxPersons || 99}" value="1"
                       oninput="onActiviteChange(${promoId}, ${offerId})">
            </div>
            <div class="col-6">
                <label class="form-label" style="font-size:13px;font-weight:600;color:#475569;">📅 Date de l'activité *</label>
                <input type="date" id="dateActivite" class="form-control" ${minA} ${maxA} value="${promoStart || todayStr()}"
                       onchange="onActiviteChange(${promoId}, ${offerId})">${hint}
            </div>
        </div>`;
    }

    document.getElementById('modalBody').innerHTML = html;
}

let packPromoStart = '';
let packPromoEnd   = '';

function buildPackModal(promoId, promoStart, promoEnd) {
    packPromoStart = promoStart || '';
    packPromoEnd   = promoEnd   || '';
    const items = packDetails[promoId] || [];
    const minA  = promoStart ? `min="${promoStart}"` : `min="${todayStr()}"`;
    const maxA  = promoEnd   ? `max="${promoEnd}"` : '';
    const hint  = promoStart && promoEnd
        ? `<div style="font-size:11px;color:#94a3b8;margin-top:4px;">Période : ${promoStart} → ${promoEnd}</div>` : '';
    let html = `
    <div style="background:#fff3cd;border-radius:12px;padding:12px 16px;margin-bottom:16px;font-size:13px;color:#856404;">
        📦 Ce pack contient <strong>${items.length} offre(s)</strong>. Remplissez les détails pour chaque offre.
    </div>`;

    items.forEach((item, idx) => {
        const icon = item.type === 'hebergement' ? '🏨' : item.type === 'voiture' ? '🚗' : '🎯';
        html += `
        <div class="pack-item mb-3" style="border:1px solid #e8ecf0;border-radius:14px;padding:16px;"
             data-idx="${idx}" data-type="${item.type}" data-id="${item.id}">
            <div style="font-weight:700;color:#2c3e50;font-size:14px;margin-bottom:12px;">
                ${icon} ${item.label || item.type}
                <span style="float:right;font-size:12px;color:#94a3b8;font-weight:500;">
                    ${parseFloat(item.unitPrice).toFixed(2)} DT / ${item.type === 'hebergement' ? 'nuit' : item.type === 'voiture' ? 'km' : 'pers.'}
                </span>
            </div>
            ${buildPackItemFields(item, idx, minA, maxA)}
            <div id="packItemCalc_${idx}" style="margin-top:10px;display:none;"></div>
        </div>`;
    });

    document.getElementById('modalBody').innerHTML = html;
    packPriceData = new Array(items.length).fill(null);
}

function buildPackItemFields(item, idx, minA, maxA) {
    const type = item.type;
    if (type === 'hebergement') {
        return `<div class="row g-2">
            <div class="col-6">
                <label style="font-size:12px;color:#64748b;">Arrivée</label>
                <input type="date" class="form-control form-control-sm" id="pack_dateDebut_${idx}" ${minA} ${maxA}
                       onchange="onPackItemChange(${idx}, '${type}', ${item.id})">
            </div>
            <div class="col-6">
                <label style="font-size:12px;color:#64748b;">Départ</label>
                <input type="date" class="form-control form-control-sm" id="pack_dateFin_${idx}" ${minA} ${maxA}
                       onchange="onPackItemChange(${idx}, '${type}', ${item.id})">
            </div>
        </div>`;
    } else if (type === 'voiture') {
        return `<div class="row g-2">
            <div class="col-6">
                <label style="font-size:12px;color:#64748b;">🛣️ Distance (km)</label>
                <input type="number" class="form-control form-control-sm" id="pack_km_${idx}" min="1" placeholder="100"
                       oninput="onPackItemChange(${idx}, '${type}', ${item.id})">
            </div>
            <div class="col-6">
                <label style="font-size:12px;color:#64748b;">👥 Places</label>
                <input type="number" class="form-control form-control-sm" id="pack_places_${idx}" min="1" max="${item.maxPersons}" value="1">
            </div>
        </div>`;
    } else {
        return `<div class="row g-2">
            <div class="col-6">
                <label style="font-size:12px;color:#64748b;">Nb personnes</label>
                <input type="number" class="form-control form-control-sm" id="pack_nbPers_${idx}" min="1" max="${item.maxPersons}" value="1"
                       oninput="onPackItemChange(${idx}, '${type}', ${item.id})">
            </div>
            <div class="col-6">
                <label style="font-size:12px;color:#64748b;">Date</label>
                <input type="date" class="form-control form-control-sm" id="pack_date_${idx}" min="${todayStr()}" value="${todayStr()}">
            </div>
        </div>`;
    }
}

function onHebergDateChange(promoId, offerId) {
    const debut = document.getElementById('hebergDateDebut')?.value;
    const fin   = document.getElementById('hebergDateFin')?.value;
    if (!debut || !fin || fin <= debut) return;
    callPrixAjax({ type: 'hebergement', id: offerId, promotion_id: promoId, date_debut: debut, date_fin: fin })
        .then(data => {
            if (data.success) {
                currentPriceData = data.data;
                updatePrixRecap(data.data);
                document.getElementById('hebergCalc').style.display = 'block';
                document.getElementById('hebergCalc').innerHTML = calcMini(data.data);
            }
        });
}

function onVoitureChange(promoId, offerId) {
    const km = parseFloat(document.getElementById('distanceKm')?.value || 0);
    if (km <= 0) return;
    callPrixAjax({ type: 'voiture', id: offerId, promotion_id: promoId, distance_km: km })
        .then(data => { if (data.success) { currentPriceData = data.data; updatePrixRecap(data.data); } });
}

function onActiviteChange(promoId, offerId) {
    const nbPers = parseInt(document.getElementById('nbPersonnesActivite')?.value || 1);
    callPrixAjax({ type: 'activite', id: offerId, promotion_id: promoId, nb_personnes: nbPers })
        .then(data => { if (data.success) { currentPriceData = data.data; updatePrixRecap(data.data); } });
}

async function onPackItemChange(idx, type, id) {
    let payload = { type, id, promotion_id: currentPromo.id };
    if (type === 'hebergement') {
        const d = document.getElementById(`pack_dateDebut_${idx}`)?.value;
        const f = document.getElementById(`pack_dateFin_${idx}`)?.value;
        if (!d || !f || f <= d) return;
        payload.date_debut = d; payload.date_fin = f;
    } else if (type === 'voiture') {
        const km = parseFloat(document.getElementById(`pack_km_${idx}`)?.value || 0);
        if (km <= 0) return;
        payload.distance_km = km;
    } else {
        payload.nb_personnes = parseInt(document.getElementById(`pack_nbPers_${idx}`)?.value || 1);
    }
    const data = await callPrixAjax(payload);
    if (data.success) {
        packPriceData[idx] = data.data;
        document.getElementById(`packItemCalc_${idx}`).style.display = 'block';
        document.getElementById(`packItemCalc_${idx}`).innerHTML = calcMini(data.data);
        recalcPackTotal();
    }
}

function recalcPackTotal() {
    if (packPriceData.every(p => p !== null)) {
        updatePrixRecap({
            base_price:  packPriceData.reduce((s, p) => s + p.base_price, 0),
            discount:    packPriceData.reduce((s, p) => s + p.discount, 0),
            final_price: packPriceData.reduce((s, p) => s + p.final_price, 0)
        });
    }
}

async function callPrixAjax(payload) {
    try {
        const r = await fetch('{{ path("promo_prix_ajax") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        return await r.json();
    } catch { return { success: false }; }
}

function updatePrixRecap(data) {
    document.getElementById('prixRecap').style.display    = 'block';
    document.getElementById('btnConfirmer').style.display  = 'block';
    document.getElementById('recapOriginal').textContent   = data.base_price.toFixed(2) + ' DT';
    document.getElementById('recapDiscount').textContent   = '- ' + data.discount.toFixed(2) + ' DT';
    document.getElementById('recapTotal').textContent      = data.final_price.toFixed(2) + ' DT';
}

function calcMini(data) {
    return `<div style="font-size:12px;color:#64748b;">
        Base: <strong>${data.base_price.toFixed(2)} DT</strong>
        | Réduction: <strong style="color:#1ABC9C">-${data.discount.toFixed(2)} DT</strong>
        | <strong style="color:#F7B731">${data.final_price.toFixed(2)} DT</strong>
    </div>`;
}

async function confirmerReservation() {
    const btn = document.getElementById('btnConfirmer');
    btn.disabled = true;
    btn.textContent = '⏳ En cours...';
    document.getElementById('modalError').style.display   = 'none';
    document.getElementById('modalSuccess').style.display = 'none';

    let payload = { promotion_id: currentPromo.id };
    if (currentPromo.validatedPromoCode) {
        payload.promo_code = currentPromo.validatedPromoCode;
    }

    if (currentPromo.isPack) {
        const items = packDetails[currentPromo.id] || [];
        payload.pack_inputs = items.map((item, idx) => {
            const base = { type: item.type, id: item.id };
            if (item.type === 'hebergement') {
                base.date_debut = document.getElementById(`pack_dateDebut_${idx}`)?.value;
                base.date_fin   = document.getElementById(`pack_dateFin_${idx}`)?.value;
            } else if (item.type === 'voiture') {
                base.distance_km = parseFloat(document.getElementById(`pack_km_${idx}`)?.value || 0);
                base.nb_personnes = parseInt(document.getElementById(`pack_places_${idx}`)?.value || 1);
            } else {
                base.nb_personnes  = parseInt(document.getElementById(`pack_nbPers_${idx}`)?.value || 1);
                base.date_activite = document.getElementById(`pack_date_${idx}`)?.value;
            }
            return base;
        });
    } else {
        const type = currentPromo.offerType;
        if (type === 'hebergement') {
            payload.date_debut = document.getElementById('hebergDateDebut')?.value;
            payload.date_fin   = document.getElementById('hebergDateFin')?.value;
        } else if (type === 'voiture') {
            payload.distance_km      = parseFloat(document.getElementById('distanceKm')?.value || 0);
            payload.date_reservation = document.getElementById('dateVoiture')?.value;
            payload.point_depart     = document.getElementById('pointDepart')?.value || 'Non spécifié';
            payload.point_arrivee    = document.getElementById('pointArrivee')?.value || 'Non spécifié';
        } else {
            payload.nb_personnes = parseInt(document.getElementById('nbPersonnesActivite')?.value || 1);
            payload.date_activite = document.getElementById('dateActivite')?.value;
        }
    }

    try {
        const r = await fetch('{{ path("promo_reserver_ajax") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const data = await r.json();
        if (data.success) {
            document.getElementById('modalSuccess').style.display = 'block';
            document.getElementById('modalSuccess').textContent   = data.message;
            btn.style.display = 'none';
            setTimeout(() => window.location.href = '{{ path("promo_mes_reservations") }}', 1500);
        } else {
            document.getElementById('modalError').style.display = 'block';
            document.getElementById('modalError').textContent   = '❌ ' + data.error;
            btn.disabled = false;
            btn.textContent = '✅ Confirmer la réservation';
        }
    } catch {
        document.getElementById('modalError').style.display = 'block';
        document.getElementById('modalError').textContent   = '❌ Erreur réseau. Réessayez.';
        btn.disabled = false;
        btn.textContent = '✅ Confirmer la réservation';
    }
}

function todayStr() { return new Date().toISOString().slice(0, 10); }
function labelForType(type) {
    return type === 'hebergement' ? 'Hébergement' : type === 'voiture' ? 'Voiture' : type === 'activite' ? 'Activité' : type;
}

document.querySelectorAll('#sidebarForm input[type="radio"]').forEach(radio => {
    radio.addEventListener('change', () => {
        document.getElementById('hiddenNom').value = document.getElementById('searchInput')?.value || '';
        document.getElementById('sidebarForm').submit();
    });
});

// Suivi des vues au survol (une seule fois par chargement de page)
document.querySelectorAll('.promo-card').forEach(card => {
    let hovered = false;
    card.addEventListener('mouseenter', function() {
        if (!hovered) {
            hovered = true;
            const promoId = this.dataset.promoId;
            if(promoId) {
                fetch(`/promotions/${promoId}/increment-view`, { method: 'POST' }).catch(e => {});
            }
        }
    });
});
</script>
