{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}RE7LA.ai - Votre jumeau de voyage intelligent{% endblock %}

{% block body %}
<div class="re7la-ai-layout">
    <!-- Sidebar -->
    <aside class="ai-sidebar">
        <div class="sidebar-header">
            <div class="ai-logo">
                <span class="logo-text">RE7LA</span>
                <span class="logo-badge">AI</span>
            </div>
            <button class="menu-toggle"><i class="fas fa-bars"></i></button>
        </div>

        <div class="sidebar-content">
            <button class="btn-new-project">
                <i class="fas fa-plus"></i> Commencer un projet
            </button>

            <div class="no-projects mt-4">
                <p class="text-muted small">Aucun projet de voyage pour l'instant</p>
            </div>

            <div class="sidebar-card login-card mt-auto">
                <h6>Connectez-vous pour enregistrer vos discussions.</h6>
                <p class="small text-muted">Après connexion, vous pourrez retrouver vos discussions récentes ici.</p>
                <a href="{{ path('app_login') }}" class="btn btn-outline-dark btn-sm rounded-pill px-3">Connexion</a>
            </div>
        </div>

        <div class="sidebar-footer">
            <div class="footer-links">
                <div class="link-item"><i class="fas fa-flag me-2"></i> Français</div>
                <div class="link-item"><i class="fas fa-euro-sign me-2"></i> Euro</div>
                <div class="link-item"><i class="fas fa-comment-alt me-2"></i> Envoyer un commentaire</div>
                <div class="link-item small mt-2">Informations et mentions légales <i class="fas fa-chevron-right ms-1"></i></div>
            </div>
        </div>
    </aside>

    <!-- Main Chat Area -->
    <main class="ai-main">
        <header class="ai-top-bar">
            <div class="ms-auto">
                <a href="{{ path('app_login') }}" class="btn btn-dark rounded-pill px-4">Connexion</a>
            </div>
        </header>

        <div class="ai-content-center">
            <div class="ai-container">
                <div class="ai-hero-section" id="hero-section">
                    <div class="ai-sparkle">
                        <i class="fas fa-sparkles" style="color: #ff690f; font-size: 2rem;"></i>
                    </div>
                    <h1 class="ai-title">Quel est votre projet de voyage ?</h1>
                    <p class="ai-location">Vous êtes à <strong>Aéroport Intl de Tunis-Carthage</strong> <i class="fas fa-chevron-down ms-1"></i></p>
                    
                    <div class="quick-actions-grid mt-4">
                        <button class="btn-quick"><i class="fas fa-question-circle"></i> Choses à faire</button>
                        <button class="btn-quick"><i class="fas fa-plane"></i> Trouver un vol</button>
                        <button class="btn-quick"><i class="fas fa-bed"></i> Trouver un hébergement</button>
                        <button class="btn-quick"><i class="fas fa-car"></i> Trouver une voiture</button>
                        <button class="btn-quick"><i class="fas fa-satellite-dish"></i> Suivre un vol</button>
                        <button class="btn-quick"><i class="fas fa-map-marker-alt"></i> Où partir ?</button>
                        <button class="btn-quick"><i class="fas fa-calendar-alt"></i> Quand partir ?</button>
                    </div>
                </div>

                <!-- Chat History -->
                <div id="chat-history" class="chat-history d-none">
                    <!-- Messages will appear here -->
                </div>

                <!-- Persistent Input Area -->
                <div class="chat-input-container mt-4">
                    <div class="chat-input-pill shadow-lg">
                        <textarea id="chat-input" placeholder="Posez une question." rows="1"></textarea>
                        <div class="pill-actions">
                            <button class="btn-pill-icon"><i class="fas fa-plus"></i></button>
                            <div class="ms-auto d-flex align-items-center">
                                <button class="btn-pill-icon"><i class="fas fa-microphone"></i></button>
                                <button id="send-btn" class="btn-pill-send"><i class="fas fa-arrow-right"></i></button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <footer class="ai-footer">
            <p class="small text-muted text-center px-4">
                L'IA peut commettre des erreurs. En utilisant le planificateur de voyages par IA de RE7LA.ai, vous acceptez nos <a href="#">Conditions</a> et notre <a href="#">Politique de confidentialité</a>.
            </p>
        </footer>
    </main>
</div>

<style>
    /* Layout */
    .re7la-ai-layout {
        display: flex;
        height: 100vh;
        width: 100%;
        background: white;
        overflow: hidden;
        position: fixed;
        top: 0; left: 0; z-index: 1000;
        font-family: 'Outfit', sans-serif;
    }

    /* Sidebar */
    .ai-sidebar {
        width: 280px;
        border-right: 1px solid #f1f5f9;
        display: flex;
        flex-direction: column;
        padding: 24px;
        background: #fafafa;
    }

    .ai-logo {
        font-weight: 800;
        font-size: 1.4rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .logo-text { color: #ff690f; }
    .logo-badge { background: #ff690f; color: white; padding: 2px 6px; border-radius: 4px; font-size: 0.8rem; }

    .btn-new-project {
        width: 100%;
        padding: 12px;
        border: 1px solid #e2e8f0;
        background: white;
        border-radius: 50px;
        font-weight: 600;
        margin-top: 24px;
        transition: 0.3s;
    }
    .btn-new-project:hover { background: #f8fafc; }

    .sidebar-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 16px;
    }

    .footer-links {
        margin-top: 24px;
        color: #64748b;
        font-size: 0.85rem;
    }
    .link-item { margin-bottom: 12px; cursor: pointer; }
    .link-item:hover { color: #ff690f; }

    /* Main Area */
    .ai-main {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        position: relative;
    }

    .ai-top-bar {
        padding: 16px 32px;
        display: flex;
        align-items: center;
    }

    .ai-content-center {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px;
        overflow-y: auto;
    }

    .ai-container {
        max-width: 800px;
        width: 100%;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .ai-hero-section {
        text-align: center;
        padding-top: 60px;
    }

    .ai-title {
        font-size: 3.5rem;
        font-weight: 800;
        margin: 24px 0;
        color: #1e293b;
    }

    .ai-location {
        color: #475569;
        margin-bottom: 40px;
    }

    /* Chat Input */
    .chat-input-pill {
        background: white;
        border: 2px solid #ff690f;
        border-radius: 32px;
        padding: 16px 24px;
        display: flex;
        flex-direction: column;
        transition: 0.3s;
    }
    .chat-input-pill:focus-within {
        box-shadow: 0 0 0 4px rgba(255, 105, 15, 0.1);
    }

    #chat-input {
        border: none;
        outline: none;
        width: 100%;
        font-size: 1.1rem;
        resize: none;
        margin-bottom: 8px;
    }

    .pill-actions {
        display: flex;
        align-items: center;
    }

    .btn-pill-icon {
        background: transparent;
        border: none;
        color: #64748b;
        font-size: 1.2rem;
        padding: 8px;
        margin-right: 8px;
        transition: 0.2s;
    }
    .btn-pill-icon:hover { color: #1e293b; }

    .btn-pill-send {
        background: #e2e8f0;
        border: none;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        color: #94a3b8;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s;
    }
    .btn-pill-send.active {
        background: #ff690f;
        color: white;
        box-shadow: 0 4px 12px rgba(255, 105, 15, 0.3);
    }

    /* Quick Actions */
    .quick-actions-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 12px;
    }

    .btn-quick {
        background: #f1f5f9;
        border: none;
        padding: 10px 20px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.9rem;
        color: #334155;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: 0.2s;
    }
    .btn-quick:hover { background: #e2e8f0; }

    /* Messages */
    .chat-history {
        flex: 1;
        width: 100%;
        padding: 20px 0;
        overflow-y: auto;
    }
    .message {
        margin-bottom: 24px;
        display: flex;
        gap: 16px;
    }
    .message-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: #ff690f;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
    }
    .message-content {
        flex: 1;
        padding-top: 8px;
        line-height: 1.6;
        color: #334155;
    }
    .user-message .message-avatar { background: #1e293b; }

    .ai-footer { padding: 24px; }

    @keyframes navPulse {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 105, 15, 0.4); }
        70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(255, 105, 15, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 105, 15, 0); }
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const chatInput = document.getElementById('chat-input');
        const sendBtn = document.getElementById('send-btn');
        const chatHistory = document.getElementById('chat-history');
        const heroSection = document.getElementById('hero-section');
        let messages = [];

        // Configure marked for safe rendering
        marked.setOptions({
            breaks: true,
            gfm: true
        });

        // Auto-expand textarea
        chatInput.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';
            
            if (this.value.trim().length > 0) {
                sendBtn.classList.add('active');
            } else {
                sendBtn.classList.remove('active');
            }
        });

        // Quick actions interaction
        document.querySelectorAll('.btn-quick').forEach(btn => {
            btn.addEventListener('click', function() {
                const text = this.innerText.trim();
                chatInput.value = text;
                chatInput.focus();
                
                // Trigger auto-expand and active state
                chatInput.dispatchEvent(new Event('input'));
                
                // Optional: Automatically send? 
                // The user said "affiche dans la barre de recherche", so I'll just show it.
                // If they wanted to send, I'd call sendMessage().
            });
        });

        async function sendMessage() {
            const content = chatInput.value.trim();
            if (!content) return;

            // Update UI: Hide hero if first message
            if (messages.length === 0) {
                heroSection.classList.add('d-none');
                chatHistory.classList.remove('d-none');
                document.querySelector('.ai-container').style.height = '100%';
                document.querySelector('.ai-content-center').style.alignItems = 'flex-start';
            }

            // Add user message
            addMessage('user', content);
            
            // Prepare the payload for the API (only messages up to now)
            const payload = { messages: [...messages] };

            chatInput.value = '';
            chatInput.style.height = 'auto';
            sendBtn.classList.remove('active');

            // Show loading in UI (this adds to messages array too, so we use payload above)
            const loadingId = addMessage('assistant', '<div class="spinner-grow spinner-grow-sm text-warning me-2"></div> RE7LA.ai réfléchit...');

            try {
                const response = await fetch("{{ path('app_re7la_ai_chat') }}", {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();
                
                if (data.error) {
                    updateMessage(loadingId, `<div class="text-danger"><i class="fas fa-exclamation-triangle me-2"></i> ${data.error}</div>`);
                    return;
                }

                // Replace loading with real response
                updateMessage(loadingId, data.content);
                
                // Update the last message in the array with the real content
                const lastMsg = messages.find(m => m.content.includes('RE7LA.ai réfléchit...'));
                if (lastMsg) lastMsg.content = data.content;

            } catch (error) {
                updateMessage(loadingId, "Désolé, une erreur de connexion est survenue.");
            }
        }

        function scrollChat() {
            chatHistory.scrollTo({
                top: chatHistory.scrollHeight,
                behavior: 'smooth'
            });
        }

        function addMessage(role, content) {
            const id = Date.now();
            messages.push({ role, content });

            const msgDiv = document.createElement('div');
            msgDiv.className = `message ${role}-message fade-in`;
            msgDiv.id = `msg-${id}`;
            
            // Render markdown for assistant, keep plain for user or render both
            const renderedContent = role === 'assistant' ? (content.includes('Loading') ? content : marked.parse(content)) : content;

            msgDiv.innerHTML = `
                <div class="message-avatar">
                    ${role === 'user' ? 'U' : 'AI'}
                </div>
                <div class="message-content">
                    ${renderedContent}
                </div>
            `;
            chatHistory.appendChild(msgDiv);
            scrollChat();
            return id;
        }

        function updateMessage(id, content) {
            const msgDiv = document.getElementById(`msg-${id}`);
            if (msgDiv) {
                // Parse markdown for the real response
                msgDiv.querySelector('.message-content').innerHTML = marked.parse(content);
                scrollChat();
            }
        }

        sendBtn.addEventListener('click', sendMessage);
        chatInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });
    });
</script>
{% endblock %}
