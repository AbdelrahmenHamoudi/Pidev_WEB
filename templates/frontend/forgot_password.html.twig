{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}Mot de passe oublié - RE7LA{% endblock %}

{% block extra_styles %}
<style>
    :root {
        --re7la-orange: #F39C12;
        --re7la-orange-dark: #e67e22;
        --re7la-white: #FAFAFA;
        --re7la-yellow: #F7DC6F;
        --re7la-navy: #2C3E50;
        --re7la-turquoise: #1ABC9C;
        --re7la-text: #243447;
        --re7la-muted: #6b7280;
        --re7la-border: rgba(44, 62, 80, 0.10);
        --re7la-shadow: 0 35px 80px rgba(44, 62, 80, 0.18);
        --re7la-success-bg: #dff6ef;
        --re7la-success-text: #0f766e;
    }

    .auth-section {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 120px 20px 60px;
        position: relative;
        overflow: hidden;
        background:
            radial-gradient(circle at 10% 20%, rgba(26, 188, 156, 0.40), transparent 22%),
            radial-gradient(circle at 88% 14%, rgba(243, 156, 18, 0.42), transparent 24%),
            radial-gradient(circle at 85% 82%, rgba(247, 220, 111, 0.36), transparent 24%),
            radial-gradient(circle at 18% 85%, rgba(26, 188, 156, 0.22), transparent 20%),
            linear-gradient(135deg, #fff0cc 0%, #fffaf1 32%, #e6fbf6 68%, #fff2d9 100%);
    }

    .auth-section::before,
    .auth-section::after {
        content: "";
        position: absolute;
        border-radius: 50%;
        z-index: 0;
        filter: blur(10px);
        animation: floatBlob 9s ease-in-out infinite;
    }

    .auth-section::before {
        width: 440px;
        height: 440px;
        left: -120px;
        top: -120px;
        background: rgba(243, 156, 18, 0.20);
    }

    .auth-section::after {
        width: 380px;
        height: 380px;
        right: -90px;
        bottom: -120px;
        background: rgba(26, 188, 156, 0.20);
        animation-delay: 1.2s;
    }

    @keyframes floatBlob {
        0%, 100% {
            transform: translate(0, 0) scale(1);
        }
        50% {
            transform: translate(10px, -12px) scale(1.03);
        }
    }

    .auth-wrapper {
        width: 100%;
        max-width: 1180px;
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        border-radius: 36px;
        overflow: hidden;
        background: rgba(250, 250, 250, 0.80);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.75);
        box-shadow: var(--re7la-shadow);
        position: relative;
        z-index: 1;
    }

    .auth-story {
        position: relative;
        padding: 64px 58px;
        color: white;
        min-height: 720px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        overflow: hidden;
        background:
            linear-gradient(160deg, rgba(44, 62, 80, 0.96), rgba(44, 62, 80, 0.82)),
            linear-gradient(135deg, rgba(243, 156, 18, 0.28), rgba(26, 188, 156, 0.24));
    }

    .auth-story::before,
    .auth-story::after {
        content: "";
        position: absolute;
        border-radius: 50%;
        z-index: 0;
    }

    .auth-story::before {
        width: 300px;
        height: 300px;
        top: -70px;
        right: -60px;
        background: rgba(243, 156, 18, 0.22);
    }

    .auth-story::after {
        width: 240px;
        height: 240px;
        bottom: -70px;
        left: -60px;
        background: rgba(26, 188, 156, 0.18);
    }

    .story-top,
    .story-content,
    .story-bottom {
        position: relative;
        z-index: 2;
    }

    .story-brand {
        display: inline-flex;
        align-items: center;
        gap: 14px;
        padding: 14px 20px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.10);
        border: 1px solid rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(12px);
    }

    .story-brand img {
        width: 60px;
        height: 60px;
        object-fit: contain;
        background: rgba(255, 255, 255, 0.96);
        border-radius: 18px;
        padding: 5px;
    }

    .story-brand span {
        font-size: 14px;
        font-weight: 900;
        letter-spacing: 0.4px;
    }

    .story-kicker {
        display: inline-block;
        margin: 30px 0 14px;
        padding: 9px 15px;
        border-radius: 999px;
        background: rgba(247, 220, 111, 0.18);
        color: var(--re7la-yellow);
        font-size: 13px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .story-title {
        font-size: clamp(2.4rem, 4vw, 4.1rem);
        line-height: 1.03;
        font-weight: 900;
        margin-bottom: 18px;
    }

    .story-title .accent-orange {
        color: var(--re7la-orange);
    }

    .story-title .accent-yellow {
        color: var(--re7la-yellow);
    }

    .story-text {
        max-width: 530px;
        color: rgba(255, 255, 255, 0.86);
        font-size: 1.05rem;
        line-height: 1.9;
        margin-bottom: 36px;
    }

    .journey-steps {
        display: grid;
        gap: 16px;
        max-width: 540px;
    }

    .journey-step {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        padding: 18px;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.10);
        transition: transform 0.25s ease, background 0.25s ease;
    }

    .journey-step:hover {
        transform: translateY(-2px);
        background: rgba(255, 255, 255, 0.11);
    }

    .journey-step-number {
        width: 46px;
        height: 46px;
        min-width: 46px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--re7la-orange), var(--re7la-yellow));
        color: var(--re7la-navy);
        font-weight: 900;
        box-shadow: 0 12px 24px rgba(243, 156, 18, 0.30);
    }

    .journey-step h3 {
        margin: 0 0 6px;
        font-size: 15px;
        font-weight: 800;
    }

    .journey-step p {
        margin: 0;
        color: rgba(255, 255, 255, 0.78);
        font-size: 14px;
        line-height: 1.7;
    }

    .story-bottom {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        margin-top: 30px;
    }

    .trust-badge {
        padding: 15px 16px;
        border-radius: 18px;
        min-width: 155px;
        background: rgba(255, 255, 255, 0.10);
        border: 1px solid rgba(255, 255, 255, 0.10);
        transition: transform 0.25s ease;
    }

    .trust-badge:hover {
        transform: translateY(-2px);
    }

    .trust-badge strong {
        display: block;
        color: white;
        font-size: 1rem;
        margin-bottom: 4px;
    }

    .trust-badge span {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.72);
    }

    .auth-panel {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 58px 44px;
        background: linear-gradient(180deg, rgba(250, 250, 250, 0.98), rgba(250, 250, 250, 0.94));
    }

    .auth-card {
        width: 100%;
        max-width: 440px;
    }

    .auth-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .logo-box {
        width: 132px;
        height: 132px;
        margin: 0 auto 20px;
        border-radius: 34px;
        background: linear-gradient(145deg, rgba(243, 156, 18, 0.24), rgba(26, 188, 156, 0.24));
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 22px 50px rgba(44, 62, 80, 0.14);
        border: 1px solid rgba(44, 62, 80, 0.06);
        animation: logoFloat 4.5s ease-in-out infinite;
    }

    .logo-box img {
        width: 98px;
        height: 98px;
        object-fit: contain;
    }

    @keyframes logoFloat {
        0%, 100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-4px);
        }
    }

    .auth-header h1 {
        font-size: 2.1rem;
        font-weight: 900;
        color: var(--re7la-navy);
        margin-bottom: 10px;
    }

    .auth-header p {
        color: var(--re7la-muted);
        margin: 0;
        line-height: 1.8;
        font-size: 15px;
    }

    .success-message {
        display: none;
        background: linear-gradient(135deg, #dff6ef, #cbf3e8);
        border: 1px solid rgba(26, 188, 156, 0.25);
        color: var(--re7la-success-text);
        padding: 15px 16px;
        border-radius: 16px;
        margin-bottom: 18px;
        font-size: 14px;
        text-align: left;
    }

    .success-message.show {
        display: block;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .input-label {
        display: block;
        margin-bottom: 10px;
        color: var(--re7la-navy);
        font-size: 14px;
        font-weight: 800;
    }

    .input-wrap {
        position: relative;
    }

    .input-wrap .input-icon {
        position: absolute;
        top: 50%;
        left: 16px;
        transform: translateY(-50%);
        color: #7c8a9c;
        font-size: 15px;
        pointer-events: none;
    }

    .input-wrap input {
        width: 100%;
        height: 62px;
        border-radius: 20px;
        border: 1.5px solid var(--re7la-border);
        background: #ffffff;
        padding: 0 18px 0 48px;
        color: var(--re7la-text);
        font-size: 15px;
        outline: none;
        transition: all 0.25s ease;
        box-shadow: 0 10px 24px rgba(44, 62, 80, 0.04);
    }

    .input-wrap input::placeholder {
        color: #9ca3af;
    }

    .input-wrap input:focus {
        border-color: var(--re7la-orange);
        box-shadow: 0 0 0 4px rgba(243, 156, 18, 0.16);
        transform: translateY(-1px);
    }

    .helper-text {
        margin-top: 10px;
        font-size: 13px;
        line-height: 1.7;
        color: var(--re7la-muted);
    }

    .btn-auth {
        width: 100%;
        height: 62px;
        border: none;
        border-radius: 20px;
        cursor: pointer;
        font-size: 16px;
        font-weight: 900;
        color: white;
        letter-spacing: 0.3px;
        background: #F39C12;
        box-shadow: 0 18px 34px rgba(243, 156, 18, 0.34);
        transition: all 0.3s ease;
    }

    .btn-auth:hover {
        background: var(--re7la-orange-dark);
        transform: translateY(-3px) scale(1.01);
        box-shadow: 0 22px 40px rgba(243, 156, 18, 0.38);
    }

    .btn-auth:active {
        transform: translateY(0);
    }

    .btn-subtext {
        text-align: center;
        margin-top: 14px;
        color: var(--re7la-muted);
        font-size: 13px;
    }

    .auth-links {
        text-align: center;
        margin-top: 28px;
    }

    .auth-links p {
        margin-bottom: 10px;
        color: var(--re7la-muted);
        font-size: 14px;
    }

    .auth-links a {
        text-decoration: none;
        font-weight: 800;
        color: var(--re7la-navy);
        transition: color 0.2s ease;
    }

    .auth-links a:hover {
        color: var(--re7la-turquoise);
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--re7la-orange) !important;
        margin-top: 4px;
    }

    @media (max-width: 991px) {
        .auth-wrapper {
            grid-template-columns: 1fr;
            max-width: 780px;
        }

        .auth-story {
            min-height: auto;
            padding: 42px 30px;
        }

        .auth-panel {
            padding: 42px 24px;
        }
    }

    @media (max-width: 576px) {
        .auth-section {
            padding: 100px 14px 40px;
        }

        .auth-wrapper {
            border-radius: 24px;
        }

        .auth-story,
        .auth-panel {
            padding: 28px 18px;
        }

        .story-title {
            font-size: 2rem;
        }

        .auth-header h1 {
            font-size: 1.8rem;
        }

        .logo-box {
            width: 110px;
            height: 110px;
        }

        .logo-box img {
            width: 82px;
            height: 82px;
        }
    }
</style>
{% endblock %}

{% block body %}
<section class="auth-section">
    <div class="auth-wrapper" data-aos="zoom-in-up">
        <div class="auth-story">
            <div class="story-top">
                <div class="story-brand">
                    <img src="{{ asset('assets_backend/images/logo.png') }}" alt="Logo RE7LA">
                    <span>RE7LA EXPERIENCE</span>
                </div>
            </div>

            <div class="story-content">
                <span class="story-kicker">Assistance • Sécurité • Accès</span>

                <h2 class="story-title">
                    Récupérez votre <span class="accent-orange">accès</span><br>
                    en toute <span class="accent-yellow">simplicité</span>
                </h2>

                <p class="story-text">
                    Vous avez oublié votre mot de passe ? Aucun souci. Entrez votre adresse email
                    et nous vous guiderons rapidement pour réinitialiser votre accès et reprendre
                    votre aventure RE7LA en toute sérénité.
                </p>

                <div class="journey-steps">
                    <div class="journey-step">
                        <div class="journey-step-number">1</div>
                        <div>
                            <h3>Saisissez votre adresse email</h3>
                            <p>Indiquez l’adresse liée à votre compte pour lancer la procédure de récupération.</p>
                        </div>
                    </div>

                    <div class="journey-step">
                        <div class="journey-step-number">2</div>
                        <div>
                            <h3>Recevez votre lien de réinitialisation</h3>
                            <p>Un email vous sera envoyé pour sécuriser et simplifier la récupération de votre accès.</p>
                        </div>
                    </div>

                    <div class="journey-step">
                        <div class="journey-step-number">3</div>
                        <div>
                            <h3>Revenez rapidement sur RE7LA</h3>
                            <p>Réinitialisez votre mot de passe et retrouvez vos voyages, loisirs et réservations.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="story-bottom">
                <div class="trust-badge">
                    <strong>Simple</strong>
                    <span>Étapes claires</span>
                </div>
                <div class="trust-badge">
                    <strong>Sécurisé</strong>
                    <span>Récupération fiable</span>
                </div>
                <div class="trust-badge">
                    <strong>Rapide</strong>
                    <span>Retour à votre espace</span>
                </div>
            </div>
        </div>

        <div class="auth-panel">
            <div class="auth-card">
                <div class="auth-header">
                    <div class="logo-box">
                        <img src="{{ asset('assets_backend/images/logo.png') }}" alt="RE7LA Logo">
                    </div>
                    <h1>Mot de passe oublié ?</h1>
                    <p>
                        Entrez votre adresse email pour recevoir un lien de réinitialisation.
                    </p>
                </div>

                <div class="success-message" id="successMsg">
                    <i class="fas fa-check-circle me-2"></i>
                    Un email de réinitialisation a été envoyé avec succès.
                </div>

                <form method="post" action="#" id="forgotForm">
                    <div class="form-group">
                        <label for="email" class="input-label">Adresse email</label>
                        <div class="input-wrap">
                            <i class="fas fa-envelope input-icon"></i>
                            <input
                                type="email"
                                id="email"
                                name="email"
                                placeholder="exemple@email.com"
                                required
                                autocomplete="email"
                            >
                        </div>
                        <div class="helper-text">
                            Utilisez l’adresse email associée à votre compte RE7LA.
                        </div>
                    </div>

                    <button type="submit" class="btn-auth">
                        <i class="fas fa-paper-plane me-2"></i>
                        Envoyer le lien
                    </button>

                    <div class="btn-subtext">
                        Nous vous aiderons à récupérer votre accès en toute simplicité.
                    </div>
                </form>

                <div class="auth-links">
                    <p>
                        <a href="{{ path('app_login') }}" class="back-link">
                            <i class="fas fa-arrow-left"></i>
                            Retour à la connexion
                        </a>
                    </p>
                    <p>
                        <a href="{{ path('app_home') }}" class="back-link">
                            <i class="fas fa-home"></i>
                            Retour à l'accueil
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const forgotForm = document.getElementById('forgotForm');
    const successMsg = document.getElementById('successMsg');

    if (forgotForm && successMsg) {
        forgotForm.addEventListener('submit', function(e) {
            e.preventDefault();
            successMsg.classList.add('show');

            setTimeout(function() {
                successMsg.classList.remove('show');
            }, 5000);
        });
    }
});
</script>
{% endblock %}