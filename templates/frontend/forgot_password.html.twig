{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}Mot de passe oublié - RE7LA{% endblock %}

{% block extra_styles %}
<style>
    .auth-section {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, rgba(135, 206, 235, 0.1), rgba(147, 197, 114, 0.1));
        padding: 120px 20px 50px;
        position: relative;
        overflow: hidden;
    }

    .auth-shape {
        position: absolute;
        border-radius: 50%;
        opacity: 0.1;
    }

    .auth-shape-1 {
        width: 500px;
        height: 500px;
        background: var(--rouge);
        top: -250px;
        right: -250px;
    }

    .auth-shape-2 {
        width: 400px;
        height: 400px;
        background: var(--bleu-ceil);
        bottom: -200px;
        left: -200px;
    }

    .auth-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-radius: 30px;
        padding: 50px;
        box-shadow: 0 25px 80px rgba(0, 0, 0, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.5);
        width: 100%;
        max-width: 450px;
        position: relative;
        z-index: 1;
        text-align: center;
    }

    .auth-icon {
        width: 90px;
        height: 90px;
        background: linear-gradient(135deg, var(--rouge), #c0392b);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 25px;
        font-size: 2.5rem;
        color: white;
        box-shadow: 0 15px 40px rgba(231, 76, 60, 0.3);
    }

    .auth-card h3 {
        font-weight: 700;
        font-size: 1.8rem;
        margin-bottom: 15px;
        color: var(--dark);
    }

    .auth-card > p {
        color: #777;
        margin-bottom: 30px;
        line-height: 1.6;
    }

    .form-floating {
        margin-bottom: 25px;
        text-align: left;
    }

    .form-floating input {
        border: 2px solid #e8e8e8;
        border-radius: 15px;
        height: 60px;
        padding: 20px 20px 10px;
        font-size: 15px;
        transition: all 0.3s ease;
        background: white;
        width: 100%;
    }

    .form-floating input:focus {
        border-color: var(--rouge);
        box-shadow: 0 0 0 4px rgba(231, 76, 60, 0.2);
    }

    .form-floating label {
        padding-left: 20px;
        color: #999;
    }

    .btn-auth {
        width: 100%;
        padding: 15px;
        background: linear-gradient(135deg, var(--rouge), #c0392b);
        color: white;
        border: none;
        border-radius: 15px;
        font-weight: 600;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .btn-auth:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 40px rgba(231, 76, 60, 0.4);
    }

    .auth-links {
        margin-top: 30px;
        padding-top: 25px;
        border-top: 1px solid #eee;
    }

    .auth-links a {
        color: var(--bleu-ceil);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.3s ease;
    }

    .auth-links a:hover {
        color: var(--vert-pistache);
    }

    .success-message {
        background: linear-gradient(135deg, #d4edda, #c3e6cb);
        border: 1px solid var(--vert-pistache);
        color: #155724;
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 20px;
        display: none;
    }

    .success-message.show {
        display: block;
    }
</style>
{% endblock %}

{% block body %}
<section class="auth-section">
    <div class="auth-shape auth-shape-1"></div>
    <div class="auth-shape auth-shape-2"></div>
    
    <div class="auth-card" data-aos="zoom-in">
        <div class="auth-icon">
            <i class="fas fa-lock-open"></i>
        </div>
        
        <h3>Mot de passe oublié ?</h3>
        <p>Entrez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.</p>
        
        <div class="success-message" id="successMsg">
            <i class="fas fa-check-circle me-2"></i>
            Un email de réinitialisation a été envoyé !
        </div>
        
        <form method="post" action="#" id="forgotForm">
            <div class="form-floating">
                <input type="email" class="form-control" id="email" name="email" placeholder="email@example.com" required>
                <label for="email"><i class="fas fa-envelope me-2"></i>Adresse email</label>
            </div>
            
            <button type="submit" class="btn-auth">
                <i class="fas fa-paper-plane me-2"></i>Envoyer le lien
            </button>
        </form>
        
        <div class="auth-links">
            <p style="margin: 0;">
                <a href="{{ path('app_login') }}"><i class="fas fa-arrow-left me-2"></i>Retour à la connexion</a>
            </p>
            <p style="margin-top: 15px; margin-bottom: 0;">
                <a href="{{ path('app_home') }}"><i class="fas fa-home me-2"></i>Retour à l'accueil</a>
            </p>
        </div>
    </div>
</section>

<script>
document.getElementById('forgotForm').addEventListener('submit', function(e) {
    e.preventDefault();
    document.getElementById('successMsg').classList.add('show');
    setTimeout(function() {
        document.getElementById('successMsg').classList.remove('show');
    }, 5000);
});
</script>
{% endblock %}
