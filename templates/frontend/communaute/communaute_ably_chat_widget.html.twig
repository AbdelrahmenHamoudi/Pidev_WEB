<script src="https://cdn.ably.com/lib/ably.min-2.js"></script>

<script>
(function() {
    'use strict';
    
    // Configuration
    const STORAGE_KEY = 'ably_chat_data';
    const USER_STORAGE_KEY = 'ably_chat_user';
    
    // State
    let ably;
    let channel;
    let presence;
    let currentChannel = 'general';
    let channels = [];
    let messages = {};
    let unreadCounts = {};
    let onlineUsers = new Map();
    let seenBy = {}; // { channelName: { messageId: [{ userId, userName }] } }
    let typingTimeout;
    let lastTypingTime = 0;
    let isOpen = false;
    let connectionState = 'connecting';
    let currentUser = null;
    
    // DOM Elements
    const widget = document.getElementById('ablyChatWidget');
    const toggleBtn = document.getElementById('ablyChatToggle');
    const chatWindow = document.getElementById('ablyChatWindow');
    const closeBtn = document.getElementById('ablyCloseChat');
    const channelsPanel = document.getElementById('channelsPanel');
    const messagesPanel = document.getElementById('messagesPanel');
    const channelList = document.getElementById('channelList');
    const messagesContainer = document.getElementById('messagesContainer');
    const messageInput = document.getElementById('messageInput');
    const sendBtn = document.getElementById('sendMessageBtn');
    const currentChannelName = document.getElementById('currentChannelName');
    const onlineCount = document.getElementById('onlineCount');
    const typingIndicator = document.getElementById('typingIndicator');
    const connectionStatus = document.getElementById('connectionStatus');
    const unreadBadge = document.getElementById('ablyUnreadBadge');

    //Pass user data to JavaScript

    window.RE7LA_USER = {
        id: {{ app.user ? app.user.id : 'null' }},
        name: {{ app.user ? ("'" ~ app.user.prenom ~ " " ~ app.user.nom ~ "'")|raw : 'null' }},
        email: {{ app.user ? ("'" ~ app.user.e_mail ~ "'")|raw : 'null' }}
    };
    
    // Initialize user - FIXED VERSION
// Initialize user - USE REAL USER DATA FROM SYMFONY
function initUser() {
    try {
        // Check if we have real user data from Symfony
        if (window.RE7LA_USER && window.RE7LA_USER.id && window.RE7LA_USER.name) {
            currentUser = {
                id: 'user_' + window.RE7LA_USER.id,
                name: window.RE7LA_USER.name,
                email: window.RE7LA_USER.email,
                color: '#' + Math.floor(Math.random()*16777215).toString(16)
            };
            console.log('👤 Using real user:', currentUser);
            return;
        }
        
        // Fallback: Check localStorage for existing user
        const stored = localStorage.getItem(USER_STORAGE_KEY);
        if (stored) {
            currentUser = JSON.parse(stored);
            console.log('👤 Loaded user from storage:', currentUser);
        } else {
            // Last resort: Generate random name but mark as guest
            const randomId = 'guest_' + Math.random().toString(36).substr(2, 9) + '_' + Date.now();
            currentUser = {
                id: randomId,
                name: 'Invité',
                color: '#94a3b8',
                isGuest: true
            };
            localStorage.setItem(USER_STORAGE_KEY, JSON.stringify(currentUser));
            console.log('👤 Created guest user:', currentUser);
        }
    } catch (e) {
        console.error('Failed to init user:', e);
        currentUser = { id: 'error_' + Date.now(), name: 'Invité', color: '#94a3b8' };
    }
}
    
    // Load data from localStorage
    function loadFromStorage() {
        try {
            const stored = localStorage.getItem(STORAGE_KEY);
            if (stored) {
                const data = JSON.parse(stored);
                channels = data.channels || ['general'];
                messages = data.messages || { general: [] };
                unreadCounts = data.unreadCounts || {};
            } else {
                channels = ['general'];
                messages = { general: [] };
                unreadCounts = {};
            }
            
            if (!channels.includes('general')) {
                channels.unshift('general');
            }
            if (!messages.general) {
                messages.general = [];
            }
        } catch (e) {
            console.error('Failed to load from storage:', e);
            channels = ['general'];
            messages = { general: [] };
            unreadCounts = {};
        }
    }
    
    // Save to localStorage
    function saveToStorage() {
        try {
            localStorage.setItem(STORAGE_KEY, JSON.stringify({
                channels: channels,
                messages: messages,
                unreadCounts: unreadCounts
            }));
        } catch (e) {
            console.error('Failed to save to storage:', e);
        }
    }
    
    // Initialize Ably
    async function initAbly() {
    try {
        console.log('🔵 Initializing Ably...');
        
        // Force a TRULY UNIQUE clientId for each browser session
        // This ensures presence works correctly across different browsers
        const browserFingerprint = navigator.userAgent.replace(/[^a-z0-9]/gi, '').substring(0, 10);
        const timestamp = Date.now();
        const uniqueClientId = currentUser.id + '_' + browserFingerprint + '_' + timestamp;
        
        console.log('📝 Original user ID:', currentUser.id);
        console.log('📝 Unique clientId for Ably:', uniqueClientId);
        
        const response = await fetch('/api/ably/token', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ clientId: uniqueClientId })
        });
        
        const data = await response.json();
        console.log('📝 Token response received:', data.tokenRequest ? 'Success' : 'Failed');
        
        if (data.error) {
            console.error('❌ Token error:', data.error);
            connectionState = 'disconnected';
            updateConnectionStatus();
            useOfflineMode();
            return;
        }
        
        // Store the unique clientId for later use
        currentUser.ablyClientId = uniqueClientId;
        
        ably = new Ably.Realtime({
            authCallback: (tokenParams, callback) => {
                console.log('🔑 Auth callback called');
                callback(null, data.tokenRequest);
            },
            clientId: uniqueClientId,
            log: { level: 1 } // Enable basic logging
        });
        
        ably.connection.on('connected', () => {
            console.log('✅ Ably connected successfully!');
            console.log('📝 Connection ID:', ably.connection.id);
            console.log('📝 Client ID:', ably.connection.clientId);
            connectionState = 'connected';
            updateConnectionStatus();
            subscribeToChannel(currentChannel);
            loadChannelList();
            
            // Force a presence refresh after connection
            setTimeout(() => {
                if (presence) {
                    console.log('🔄 Refreshing presence...');
                    presence.get((err, members) => {
                        if (!err && members) {
                            console.log('👥 Presence members after refresh:', members.length);
                            members.forEach(member => {
                                console.log('  -', member.clientId, member.data);
                            });
                        }
                    });
                }
            }, 1000);
        });
        
        ably.connection.on('connecting', () => {
            console.log('🔄 Ably connecting...');
            connectionState = 'connecting';
            updateConnectionStatus();
        });
        
        ably.connection.on('disconnected', () => {
            console.log('🔴 Ably disconnected');
            connectionState = 'disconnected';
            updateConnectionStatus();
        });
        
        ably.connection.on('failed', (error) => {
            console.error('❌ Ably connection failed:', error);
            connectionState = 'disconnected';
            updateConnectionStatus();
        });
        
        ably.connection.on('suspended', () => {
            console.warn('⚠️ Ably connection suspended');
            connectionState = 'disconnected';
            updateConnectionStatus();
        });
        
        ably.connection.on('closed', () => {
            console.log('🔒 Ably connection closed');
            connectionState = 'disconnected';
            updateConnectionStatus();
        });
        
    } catch (e) {
        console.error('❌ Failed to initialize Ably:', e);
        connectionState = 'disconnected';
        updateConnectionStatus();
        useOfflineMode();
    }
}
    
    // Update connection status display
    function updateConnectionStatus() {
        if (!connectionStatus) return;
        
        connectionStatus.className = 'ably-connection-status ' + connectionState;
        const statusText = connectionStatus.querySelector('span:last-child');
        
        switch (connectionState) {
            case 'connected':
                if (statusText) statusText.textContent = 'Connecté';
                break;
            case 'connecting':
                if (statusText) statusText.textContent = 'Connexion...';
                break;
            default:
                if (statusText) statusText.textContent = 'Déconnecté (mode hors-ligne)';
        }
    }
    
    // Offline mode fallback
    function useOfflineMode() {
        console.log('Using offline mode');
        renderChannelList();
        renderMessages();
    }
    
    // Subscribe to channel
    function subscribeToChannel(channelName) {
    console.log('📡 Subscribing to channel:', channelName);
    
    // Unsubscribe from previous channel
    if (channel) {
        channel.unsubscribe();
        if (presence) {
            presence.leave();
        }
    }
    
    channel = ably.channels.get('chat:' + channelName);
    presence = channel.presence;
    
    // Subscribe to messages
    channel.subscribe('message', (msg) => {
        handleIncomingMessage(msg);
    });
    
    channel.subscribe('typing', (msg) => {
        handleTypingEvent(msg);
    });
    
    channel.subscribe('message-deleted', (msg) => {
        handleMessageDeleted(msg);
    });
    
    // Subscribe to seen events
    channel.subscribe('seen', (msg) => {
        if (!msg.data || msg.data.userId === currentUser.id) return;
        const { messageId, userId, userName } = msg.data;
        if (!seenBy[currentChannel]) seenBy[currentChannel] = {};
        if (!seenBy[currentChannel][messageId]) seenBy[currentChannel][messageId] = [];
        const already = seenBy[currentChannel][messageId].some(u => u.userId === userId);
        if (!already) {
            seenBy[currentChannel][messageId].push({ userId, userName });
            if (currentChannel === channelName) renderMessages();
        }
    });
    
    // ============================================
    // CALL-RELATED SUBSCRIPTIONS - MAKE SURE THESE EXIST
    // ============================================
    channel.subscribe('call-invitation', (msg) => {
        console.log('📞 Call invitation received:', msg);
        handleCallInvitation(msg);
    });
    
    channel.subscribe('call-response', (msg) => {
        console.log('📞 Call response received:', msg);
        handleCallResponse(msg);
    });
    
    channel.subscribe('call-ice-candidate', (msg) => {
        console.log('📞 ICE candidate received:', msg);
        handleICECandidate(msg);
    });
    
    channel.subscribe('call-ended', (msg) => {
        console.log('📞 Call ended received:', msg);
        if (isCallActive) {
            endCall();
        }
    });
    
    // Presence events
    presence.subscribe('enter', (member) => {
        console.log('👤 User entered:', member.clientId, member.data);
        onlineUsers.set(member.clientId, member.data || { name: 'Anonyme' });
        updateOnlineCount();
        renderChannelList();
    });
    
    presence.subscribe('leave', (member) => {
        console.log('👋 User left:', member.clientId);
        onlineUsers.delete(member.clientId);
        updateOnlineCount();
        renderChannelList();
    });
    
    presence.subscribe('update', (member) => {
        console.log('🔄 User updated:', member.clientId, member.data);
        onlineUsers.set(member.clientId, member.data || { name: 'Anonyme' });
    });
    
    // Enter presence
    presence.enter({ 
        name: currentUser.name, 
        color: currentUser.color 
    }, (err) => {
        if (err) {
            console.error('❌ Failed to enter presence:', err);
        } else {
            console.log('✅ Entered presence as:', currentUser.name);
            
            // Get current presence
            presence.get((err, members) => {
                if (!err && members) {
                    console.log('👥 Presence members:', members.length);
                    onlineUsers.clear();
                    members.forEach(member => {
                        console.log('  - Member:', member.clientId, member.data);
                        onlineUsers.set(member.clientId, member.data || { name: 'Anonyme' });
                    });
                    updateOnlineCount();
                    renderChannelList();
                }
            });
        }
    });
    
    // Load history
    loadChannelHistory(channelName);
}
    
    // Load channel history
    async function loadChannelHistory(channelName) {
        try {
            const response = await fetch('/api/ably/history/' + channelName);
            const data = await response.json();
            
            if (data.messages && data.messages.length > 0) {
                const historyMessages = data.messages
                    .filter(msg => msg.data && msg.data.type === 'message')
                    .map(msg => ({
                        id: msg.id,
                        text: msg.data.text,
                        sender: msg.data.sender,
                        senderId: msg.clientId,
                        timestamp: msg.timestamp,
                        local: false
                    }));
                
                // Merge with local messages
                const localMessages = messages[channelName] || [];
                const allMessages = [...historyMessages, ...localMessages.filter(m => m.local)];
                
                // Deduplicate
                const uniqueMessages = [];
                const seenIds = new Set();
                allMessages.forEach(msg => {
                    if (!seenIds.has(msg.id)) {
                        seenIds.add(msg.id);
                        uniqueMessages.push(msg);
                    }
                });
                
                messages[channelName] = uniqueMessages.sort((a, b) => 
                    new Date(a.timestamp) - new Date(b.timestamp)
                );
                
                saveToStorage();
            }
        } catch (e) {
            console.error('Failed to load history:', e);
        }
        
        renderMessages();
    }
    
    // Handle incoming message
    function handleIncomingMessage(msg, channelName) {
        // Use passed channelName — msg.channel does not exist in Ably SDK v2
        channelName = channelName || currentChannel;

        // Skip own messages: already added locally in sendMessage()
        if (msg.clientId === currentUser.id) return;

        const messageData = {
            id: msg.id,
            text: msg.data.text,
            sender: msg.data.sender,
            senderId: msg.clientId,
            timestamp: msg.timestamp,
            local: false
        };
        
        if (!messages[channelName]) {
            messages[channelName] = [];
        }
        
        // Check for duplicate
        const exists = messages[channelName].some(m => m.id === msg.id);
        if (!exists) {
            messages[channelName].push(messageData);
            saveToStorage();
            
            // Increment unread if widget closed or different channel
            if (!isOpen || channelName !== currentChannel) {
                unreadCounts[channelName] = (unreadCounts[channelName] || 0) + 1;
                updateUnreadBadge();
                renderChannelList();
            }
            
            if (channelName === currentChannel) {
                renderMessages();
            }
        }
    }
    
    // Handle typing event
    function handleTypingEvent(msg, channelName) {
        channelName = channelName || currentChannel;
        // Only show indicator if the typing is for the channel currently viewed
        if (channelName !== currentChannel) return;
        if (!msg.data || msg.clientId === currentUser.id || msg.clientId === currentUser.ablyClientId) return;
        
        if (typingIndicator) {
            typingIndicator.textContent = msg.data.name + ' est en train d\'écrire...';
            
            clearTimeout(typingTimeout);
            typingTimeout = setTimeout(() => {
                typingIndicator.textContent = '';
            }, 2000);
        }
    }
    
    // Handle message deleted
    function handleMessageDeleted(msg, channelName) {
        channelName = channelName || currentChannel;
        
        if (messages[channelName]) {
            messages[channelName] = messages[channelName].filter(m => m.id !== msg.data.messageId);
            saveToStorage();
            
            if (channelName === currentChannel) {
                renderMessages();
            }
        }
    }
    
    // Send message
    function sendMessage() {
        const text = messageInput.value.trim();
        if (!text) return;
        
        const messageData = {
            type: 'message',
            text: text,
            sender: currentUser.name,
            timestamp: new Date().toISOString()
        };
        
        const localMessage = {
            id: 'local_' + Date.now(),
            text: text,
            sender: currentUser.name,
            senderId: currentUser.id,
            timestamp: new Date().toISOString(),
            local: true
        };
        
        // Add locally
        if (!messages[currentChannel]) {
            messages[currentChannel] = [];
        }
        messages[currentChannel].push(localMessage);
        saveToStorage();
        renderMessages();
        
        // Send via Ably
        if (channel && connectionState === 'connected') {
            channel.publish('message', messageData);
        }
        
        messageInput.value = '';
        messageInput.focus();
        lastTypingTime = 0; // Reset typing timer
    }
    
    // Send typing event with throttling
    function sendTypingEvent() {
        if (!channel || connectionState !== 'connected') return;

        const now = Date.now();
        if (now - lastTypingTime > 2000) { // Throttle: 2 seconds
            channel.publish('typing', { name: currentUser.name });
            lastTypingTime = now;
        }
    }
    
    // Delete message
    function deleteMessage(messageId) {
        if (!messages[currentChannel]) return;
        
        const message = messages[currentChannel].find(m => m.id === messageId);
        if (!message) return;
        
        // Only allow deleting own messages
        if (message.senderId !== currentUser.id && message.sender !== currentUser.name) return;
        
        messages[currentChannel] = messages[currentChannel].filter(m => m.id !== messageId);
        saveToStorage();
        renderMessages();
        
        // Notify others
        if (channel && connectionState === 'connected' && !message.local) {
            channel.publish('message-deleted', { messageId: messageId });
        }
    }
    
    // Create channel
    function createChannel(name) {
        name = name.trim().toLowerCase().replace(/[^a-z0-9-_]/g, '');
        if (!name || name.length < 3) {
            alert('Le nom du salon doit contenir au moins 3 caractères (lettres, chiffres, - ou _)');
            return false;
        }
        
        if (channels.includes(name)) {
            alert('Ce salon existe déjà');
            return false;
        }
        
        channels.push(name);
        messages[name] = [];
        saveToStorage();
        renderChannelList();
        
        return true;
    }
    
    // Publish seen event for the last message in a channel
    function publishSeen(channelName) {
        if (!channel || connectionState !== 'connected') return;
        const channelMessages = messages[channelName] || [];
        if (channelMessages.length === 0) return;
        const lastMsg = channelMessages[channelMessages.length - 1];
        // Don't send seen for own messages
        if (lastMsg.senderId === currentUser.id || lastMsg.sender === currentUser.name) return;
        channel.publish('seen', {
            messageId: lastMsg.id,
            userId: currentUser.id,
            userName: currentUser.name
        });
    }
    
    // Switch channel
    function switchChannel(channelName) {
        currentChannel = channelName;
        unreadCounts[channelName] = 0;
        updateUnreadBadge();
        
        if (currentChannelName) {
            currentChannelName.textContent = '#' + channelName;
        }
        
        subscribeToChannel(channelName);
        publishSeen(channelName);
        renderChannelList();
        
        // Show messages panel on mobile
        if (window.innerWidth <= 480) {
            channelsPanel.style.display = 'none';
            messagesPanel.style.display = 'flex';
        }
    }
    
    // Update online count
    function updateOnlineCount() {
        if (onlineCount) {
            onlineCount.textContent = onlineUsers.size;
        }
    }
    
    // Update unread badge
    function updateUnreadBadge() {
        const totalUnread = Object.values(unreadCounts).reduce((a, b) => a + b, 0);
        
        if (unreadBadge) {
            if (totalUnread > 0 && !isOpen) {
                unreadBadge.style.display = 'flex';
                unreadBadge.textContent = totalUnread > 99 ? '99+' : totalUnread;
            } else {
                unreadBadge.style.display = 'none';
            }
        }
    }
    
    // Render channel list
    function renderChannelList() {
        if (!channelList) return;
        
        channelList.innerHTML = '';
        
        channels.forEach(channelName => {
            const unread = unreadCounts[channelName] || 0;
            const isActive = channelName === currentChannel;
            
            const item = document.createElement('div');
            item.className = 'ably-channel-item' + (isActive ? ' active' : '');
            
            item.innerHTML = `
                <div class="ably-channel-info">
                    <div class="ably-channel-icon">
                        <i class="fas fa-hashtag"></i>
                    </div>
                    <div class="ably-channel-details">
                        <h5>${channelName}</h5>
                        <p>
                            <i class="fas fa-user"></i>
                            ${channelName === currentChannel ? onlineUsers.size : '-'} membres
                        </p>
                    </div>
                </div>
                ${unread > 0 ? `<span class="ably-channel-badge">${unread > 9 ? '9+' : unread}</span>` : ''}
            `;
            
            item.addEventListener('click', () => switchChannel(channelName));
            channelList.appendChild(item);
        });
    }
    
    // Render messages
    function renderMessages() {
        if (!messagesContainer) return;
        
        const channelMessages = messages[currentChannel] || [];
        
        if (channelMessages.length === 0) {
            messagesContainer.innerHTML = `
                <div class="ably-empty-state">
                    <i class="fas fa-comment-dots"></i>
                    <p>Aucun message dans ce salon</p>
                    <p style="font-size:12px;">Soyez le premier à écrire !</p>
                </div>
            `;
            return;
        }
        
        messagesContainer.innerHTML = '';
        
        channelMessages.forEach(msg => {
            const isOwn = msg.senderId === currentUser?.id || msg.sender === currentUser?.name;
            const date = new Date(msg.timestamp);
            const timeStr = date.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
            const seenList = isOwn ? (seenBy[currentChannel]?.[msg.id] || []) : [];
            
            const messageEl = document.createElement('div');
            messageEl.className = 'ably-message' + (isOwn ? ' own' : '');
            messageEl.dataset.messageId = msg.id;
            
            messageEl.innerHTML = `
                <div class="ably-message-avatar">
                    ${msg.sender ? msg.sender.charAt(0).toUpperCase() : '?'}
                </div>
                <div class="ably-message-content">
                    <div class="ably-message-header">
                        <span class="ably-message-name">${msg.sender || 'Anonyme'}</span>
                        <span class="ably-message-time">${timeStr}</span>
                    </div>
                    <div class="ably-message-bubble">
                        ${escapeHtml(msg.text)}
                    </div>
                    ${isOwn ? `
                        <div class="ably-message-seen">
                            ${seenList.length > 0 ? `
                                <i class="fas fa-check-double" style="color:#3b82f6;"></i>
                                <span class="seen-avatars">
                                    ${seenList.slice(0, 3).map(u =>
                                        `<div class="seen-avatar" title="${escapeHtml(u.userName)}">${u.userName.charAt(0).toUpperCase()}</div>`
                                    ).join('')}
                                </span>
                                <span>Vu</span>
                            ` : `
                                <i class="fas fa-check" style="color:#cbd5e1;"></i>
                                <span style="color:#cbd5e1;">Envoyé</span>
                            `}
                        </div>
                        <button class="ably-message-delete" onclick="deleteMessage('${msg.id}')">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    ` : ''}
                </div>
            `;
            
            messagesContainer.appendChild(messageEl);
        });
        
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }
    
    // Escape HTML
    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
    
    // Clear all local data
    function clearAllData() {
        if (confirm('Effacer toutes les données locales de chat ?')) {
            localStorage.removeItem(STORAGE_KEY);
            loadFromStorage();
            currentChannel = 'general';
            renderChannelList();
            renderMessages();
            if (channel) {
                subscribeToChannel(currentChannel);
            }
        }
    }
    
    // Toggle chat window
    function toggleChat() {
        isOpen = !isOpen;
        
        if (isOpen) {
            chatWindow.classList.add('open');
            unreadCounts[currentChannel] = 0;
            updateUnreadBadge();
            renderMessages();
            renderChannelList();
            publishSeen(currentChannel);
        } else {
            chatWindow.classList.remove('open');
        }
    }
    
    // Initialize everything
    // Initialize everything
async function init() {
    initUser();
    loadFromStorage();
    await initAbly();
    
    // Initialize video call AFTER Ably is ready
    initVideoCall();
    
    // Event listeners
    if (toggleBtn) {
        toggleBtn.addEventListener('click', toggleChat);
    }
    
    if (closeBtn) {
        closeBtn.addEventListener('click', () => {
            isOpen = false;
            chatWindow.classList.remove('open');
        });
    }
    
    if (sendBtn) {
        sendBtn.addEventListener('click', sendMessage);
    }
    
    if (messageInput) {
        messageInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });
        
        messageInput.addEventListener('input', () => {
            sendTypingEvent();
        });
    }
    
    // Tab switching
    document.querySelectorAll('.ably-chat-tab').forEach(tab => {
        tab.addEventListener('click', () => {
            const tabName = tab.dataset.tab;
            
            document.querySelectorAll('.ably-chat-tab').forEach(t => t.classList.remove('active'));
            tab.classList.add('active');
            
            if (tabName === 'channels') {
                channelsPanel.style.display = 'block';
                messagesPanel.style.display = 'none';
            } else {
                channelsPanel.style.display = 'none';
                messagesPanel.style.display = 'flex';
            }
        });
    });
    
    // Back button (mobile)
    const backBtn = document.getElementById('backToChannelsBtn');
    if (backBtn) {
        backBtn.addEventListener('click', () => {
            channelsPanel.style.display = 'block';
            messagesPanel.style.display = 'none';
        });
    }
    
    // Create channel
    const showCreateBtn = document.getElementById('showCreateChannelBtn');
    const createForm = document.getElementById('createChannelForm');
    const cancelBtn = document.getElementById('cancelCreateChannel');
    const submitBtn = document.getElementById('createChannelSubmit');
    const nameInput = document.getElementById('newChannelName');
    
    if (showCreateBtn) {
        showCreateBtn.addEventListener('click', () => {
            createForm.style.display = 'block';
            showCreateBtn.style.display = 'none';
        });
    }
    
    if (cancelBtn) {
        cancelBtn.addEventListener('click', () => {
            createForm.style.display = 'none';
            showCreateBtn.style.display = 'block';
            if (nameInput) nameInput.value = '';
        });
    }
    
    if (submitBtn && nameInput) {
        submitBtn.addEventListener('click', () => {
            if (createChannel(nameInput.value)) {
                createForm.style.display = 'none';
                showCreateBtn.style.display = 'block';
                nameInput.value = '';
                switchChannel(nameInput.value);
            }
        });
    }
    
    // Clear storage
    const clearBtn = document.getElementById('ablyClearStorageBtn');
    if (clearBtn) {
        clearBtn.addEventListener('click', clearAllData);
    }
    
    // Close on escape
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen) {
            isOpen = false;
            chatWindow.classList.remove('open');
        }
    });
    
    // Initial render
    renderChannelList();
    renderMessages();
    
    // Make delete function global
    window.deleteMessage = deleteMessage;
}

