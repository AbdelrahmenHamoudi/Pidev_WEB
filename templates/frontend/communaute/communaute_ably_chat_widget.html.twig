// Show list of online users to call
// Show list of online users to call
function showUserListForCall() {
    const onlineUsersList = Array.from(onlineUsers.entries())
        .filter(([clientId]) => clientId !== currentUser.ablyClientId);
    
    if (onlineUsersList.length === 0) {
        alert('Aucun utilisateur en ligne pour le moment.');
        return;
    }
    
    // Remove any existing modal first
    const existingModal = document.querySelector('.user-selection-modal');
    if (existingModal) existingModal.remove();
    
    // Create a simple user selection modal
    const modal = document.createElement('div');
    modal.className = 'user-selection-modal';
    modal.id = 'userSelectionModal';
    modal.innerHTML = `
        <div class="user-selection-content">
            <h4>Choisir un utilisateur</h4>
            <div class="user-list">
                ${onlineUsersList.map(([clientId, data]) => `
                    <div class="member-item">
                        <span>${data.name || 'Utilisateur'}</span>
                        <button class="member-call-btn" data-client-id="${clientId}">
                            <i class="fas fa-video"></i> Appeler
                        </button>
                    </div>
                `).join('')}
            </div>
            <button class="close-modal-btn" id="cancelUserSelection">Annuler</button>
        </div>
    `;
    
    document.body.appendChild(modal);
    
    // Function to close modal
    const closeModal = () => {
        if (modal && modal.parentNode) {
            modal.remove();
        }
    };
    
    // Handle call button clicks
    modal.querySelectorAll('.member-call-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const clientId = btn.dataset.clientId;
            closeModal(); // CLOSE MODAL IMMEDIATELY
            startCall(clientId);
        });
    });
    
    // Handle cancel button
    const cancelBtn = modal.querySelector('#cancelUserSelection');
    if (cancelBtn) {
        cancelBtn.addEventListener('click', closeModal);
    }
    
    // Close modal when clicking outside
    modal.addEventListener('click', (e) => {
        if (e.target === modal) {
            closeModal();
        }
    });
    
    // Close on escape key
    const escHandler = (e) => {
        if (e.key === 'Escape') {
            closeModal();
            document.removeEventListener('keydown', escHandler);
        }
    };
    document.addEventListener('keydown', escHandler);
}

// Start a call
// Start a call
// Start a call - FIXED VERSION
async function startCall(remoteClientId) {
    console.log('📞 Starting call to:', remoteClientId);
    
    const remoteUser = onlineUsers.get(remoteClientId);
    const remoteName = remoteUser?.name || 'Utilisateur';
    
    try {
        // Request media permissions
        console.log('📞 Requesting media permissions...');
        localStream = await navigator.mediaDevices.getUserMedia({ 
            video: { width: { ideal: 640 }, height: { ideal: 480 } }, 
            audio: true 
        });
        
        const localVideo = document.getElementById('localVideo');
        if (localVideo) {
            localVideo.srcObject = localStream;
            localVideo.muted = true;
        }
        
        const videoCallModal = document.getElementById('videoCallModal');
        if (videoCallModal) {
            videoCallModal.style.display = 'block';
        }
        
        // Create peer connection
        await createPeerConnection(remoteClientId);
        
        // Add local tracks
        localStream.getTracks().forEach(track => {
            peerConnection.addTrack(track, localStream);
        });
        
        // Create and send offer
        const offer = await peerConnection.createOffer({
            offerToReceiveAudio: true,
            offerToReceiveVideo: true
        });
        await peerConnection.setLocalDescription(offer);
        
        console.log('📞 Sending call invitation to:', remoteClientId);
        console.log('📞 My clientId:', currentUser.ablyClientId);
        
        // Send call invitation - USE ablyClientId
        channel.publish('call-invitation', {
            from: currentUser.ablyClientId,
            fromName: currentUser.name,
            to: remoteClientId,
            offer: offer
        });
        
        currentCall = remoteClientId;
        isCallActive = true;
        
        console.log('📞 Call invitation sent');
        
    } catch (error) {
        console.error('❌ Error starting call:', error);
        alert('Impossible de démarrer l\'appel. Vérifiez les permissions de caméra/micro.');
    }
}


// Create peer connection
async function createPeerConnection(remoteClientId) {
    console.log('📞 Creating peer connection for:', remoteClientId);
    
    // Close existing connection if any
    if (peerConnection) {
        peerConnection.close();
        peerConnection = null;
    }
    
    peerConnection = new RTCPeerConnection(rtcConfig);
    
    // ============================================
    // CRITICAL: Handle incoming tracks
    // ============================================
    peerConnection.addEventListener('track', (event) => {
        console.log('📞📞📞 TRACK EVENT FIRED! 📞📞📞');
        console.log('📞 Track kind:', event.track.kind);
        console.log('📞 Streams:', event.streams);
        
        const remoteVideo = document.getElementById('remoteVideo');
        if (!remoteVideo) {
            console.error('❌ Remote video element not found!');
            return;
        }
        
        // Check if we already have a stream
        if (remoteVideo.srcObject) {
            console.log('📞 Already have remote stream, adding track to existing stream');
            const stream = remoteVideo.srcObject;
            stream.addTrack(event.track);
        } else if (event.streams && event.streams.length > 0) {
            console.log('📞 Setting new remote stream');
            remoteVideo.srcObject = event.streams[0];
            
            // Force video to play
            remoteVideo.onloadedmetadata = () => {
                console.log('📞 Remote video metadata loaded');
                remoteVideo.play().then(() => {
                    console.log('✅ Remote video playing');
                }).catch(e => {
                    console.error('❌ Error playing remote video:', e);
                });
            };
        } else {
            console.log('📞 Creating new stream with track');
            const newStream = new MediaStream();
            newStream.addTrack(event.track);
            remoteVideo.srcObject = newStream;
            
            remoteVideo.onloadedmetadata = () => {
                console.log('📞 Remote video metadata loaded');
                remoteVideo.play().then(() => {
                    console.log('✅ Remote video playing');
                }).catch(e => {
                    console.error('❌ Error playing remote video:', e);
                });
            };
        }
        
        console.log('📞 Remote video srcObject set:', remoteVideo.srcObject);
    });
    
    // Handle ICE candidates
    peerConnection.addEventListener('icecandidate', (event) => {
        if (event.candidate) {
            console.log('📞 Sending ICE candidate:', event.candidate.type);
            channel.publish('call-ice-candidate', {
                to: remoteClientId,
                from: currentUser.ablyClientId,
                candidate: event.candidate
            });
        } else {
            console.log('📞 All ICE candidates sent');
        }
    });
    
    // Handle connection state changes
    peerConnection.addEventListener('connectionstatechange', () => {
        console.log('📞 Connection state:', peerConnection.connectionState);
        
        if (peerConnection.connectionState === 'connected') {
            console.log('✅✅✅ PEER CONNECTION ESTABLISHED! ✅✅✅');
            
            // Check receivers
            const receivers = peerConnection.getReceivers();
            console.log('📞 Receivers:', receivers.length);
            receivers.forEach((receiver, i) => {
                console.log(`  Receiver ${i}:`, receiver.track.kind, receiver.track.enabled);
            });
        }
    });
    
    peerConnection.addEventListener('iceconnectionstatechange', () => {
        console.log('📞 ICE connection state:', peerConnection.iceConnectionState);
        
        if (peerConnection.iceConnectionState === 'connected' || 
            peerConnection.iceConnectionState === 'completed') {
            console.log('✅ ICE connection established!');
        }
    });
    
    peerConnection.addEventListener('signalingstatechange', () => {
        console.log('📞 Signaling state:', peerConnection.signalingState);
    });
    
    console.log('📞 Peer connection created');
}

// Handle incoming call invitation
function handleCallInvitation(msg) {
    console.log('📞 Handling call invitation:', msg);
    console.log('📞 Message data:', msg.data);
    console.log('📞 Current user:', currentUser);
    console.log('📞 Is call active?', isCallActive);
    
    // Check if this call is for us
    if (msg.data.to !== currentUser.ablyClientId) {
        console.log('📞 Call not for us, ignoring. Expected:', currentUser.ablyClientId, 'Got:', msg.data.to);
        return;
    }
    
    if (isCallActive) {
        console.log('📞 Already in a call, sending busy response');
        // Busy - send rejection
        channel.publish('call-response', {
            to: msg.data.from,
            from: currentUser.ablyClientId,
            accepted: false,
            reason: 'busy'
        });
        return;
    }
    
    console.log('📞 Showing incoming call UI for:', msg.data.fromName);
    
    // Play incoming ringtone
    const ringtone = document.getElementById('incomingRingtone');
    if (ringtone) {
        ringtone.currentTime = 0;
        ringtone.play().catch(e => console.warn('🔇 Could not play ringtone:', e));
    }
    
    // Show the video call modal first
    const videoCallModal = document.getElementById('videoCallModal');
    if (videoCallModal) {
        videoCallModal.style.display = 'block';
    } else {
        console.error('❌ videoCallModal not found!');
    }
    
    // Show incoming call panel
    const incomingCallPanel = document.getElementById('incomingCallPanel');
    if (incomingCallPanel) {
        incomingCallPanel.style.display = 'flex';
    } else {
        console.error('❌ incomingCallPanel not found!');
    }
    
    // Set caller name
    const incomingCallerName = document.getElementById('incomingCallerName');
    if (incomingCallerName) {
        incomingCallerName.textContent = msg.data.fromName || 'Quelqu\'un';
    }
    
    // Store pending call info
    currentCall = {
        remoteId: msg.data.from,
        remoteName: msg.data.fromName,
        offer: msg.data.offer
    };
    
    console.log('📞 Current call stored:', currentCall);
}


// Accept incoming call
// Accept incoming call
// Accept incoming call
// Accept incoming call - FIXED VERSION
async function acceptCall() {
    console.log('📞 Accepting call...');
    console.log('📞 Current call:', currentCall);
    
    // Stop ringtone
    const ringtone = document.getElementById('incomingRingtone');
    if (ringtone) { 
        ringtone.pause(); 
        ringtone.currentTime = 0; 
    }
    
    try {
        const incomingCallPanel = document.getElementById('incomingCallPanel');
        if (incomingCallPanel) {
            incomingCallPanel.style.display = 'none';
        }
        
        // Request media permissions
        console.log('📞 Requesting media permissions...');
        localStream = await navigator.mediaDevices.getUserMedia({ 
            video: { width: { ideal: 640 }, height: { ideal: 480 } }, 
            audio: true 
        });
        
        const localVideo = document.getElementById('localVideo');
        if (localVideo) {
            localVideo.srcObject = localStream;
            localVideo.muted = true;
        }
        
        // Create peer connection
        await createPeerConnection(currentCall.remoteId);
        
        // Add local tracks
        localStream.getTracks().forEach(track => {
            peerConnection.addTrack(track, localStream);
        });
        
        // Set remote offer
        console.log('📞 Setting remote description...');
        console.log('📞 Remote offer:', currentCall.offer);
        await peerConnection.setRemoteDescription(currentCall.offer);
        console.log('✅ Remote description set');
        
        // Create answer
        const answer = await peerConnection.createAnswer();
        await peerConnection.setLocalDescription(answer);
        console.log('✅ Local description set');
        
        console.log('📞 Sending call acceptance to:', currentCall.remoteId);
        
        // Send answer back - USE ablyClientId
        channel.publish('call-response', {
            to: currentCall.remoteId,
            from: currentUser.ablyClientId,
            accepted: true,
            answer: answer
        });
        
        isCallActive = true;
        console.log('📞 Call accepted, waiting for ICE connection...');
        
    } catch (error) {
        console.error('❌ Error accepting call:', error);
        endCall();
    }
}

// Reject call
// Reject call - FIXED VERSION
function rejectCall() {
    console.log('📞 Rejecting call');
    
    // Stop ringtone
    const ringtone = document.getElementById('incomingRingtone');
    if (ringtone) { 
        ringtone.pause(); 
        ringtone.currentTime = 0; 
    }
    
    // IMPORTANT: Use ablyClientId, not id
    if (currentCall && currentCall.remoteId) {
        channel.publish('call-response', {
            to: currentCall.remoteId,
            from: currentUser.ablyClientId,  // Use ablyClientId here
            accepted: false,
            reason: 'rejected'
        });
    }
    
    document.getElementById('incomingCallPanel').style.display = 'none';
    document.getElementById('videoCallModal').style.display = 'none';
    currentCall = null;
}

// Handle call response
// Handle call response
// Handle call response - FIXED VERSION
async function handleCallResponse(msg) {
    console.log('📞 Handling call response');
    console.log('📞 Response data:', msg.data);
    console.log('📞 My clientId:', currentUser.ablyClientId);
    console.log('📞 Response target:', msg.data.to);
    
    // IMPORTANT: Check if this response is for us
    if (msg.data.to !== currentUser.ablyClientId) {
        console.log('📞 Response not for us, ignoring');
        return;
    }
    
    if (msg.data.accepted) {
        console.log('📞 Call accepted! Setting remote description...');
        
        if (!peerConnection) {
            console.error('❌ No peer connection!');
            return;
        }
        
        try {
            console.log('📞 Remote answer type:', msg.data.answer.type);
            await peerConnection.setRemoteDescription(msg.data.answer);
            console.log('✅ Remote description set successfully');
        } catch (error) {
            console.error('❌ Error setting remote description:', error);
            endCall();
        }
    } else {
        console.log('📞 Call rejected. Reason:', msg.data.reason);
        // Only show alert if it wasn't a busy response
        if (msg.data.reason !== 'busy') {
            alert('Appel refusé');
        }
        endCall();
    }
}

// Handle ICE candidates
function handleICECandidate(msg) {
    console.log('📞 Received ICE candidate');
    
    if (msg.data.to !== currentUser.ablyClientId) {
        console.log('📞 ICE candidate not for us');
        return;
    }
    
    if (!peerConnection) {
        console.error('❌ No peer connection for ICE candidate');
        return;
    }
    
    const candidate = new RTCIceCandidate(msg.data.candidate);
    
    peerConnection.addIceCandidate(candidate)
        .then(() => {
            console.log('✅ ICE candidate added successfully');
        })
        .catch(error => {
            console.error('❌ Error adding ICE candidate:', error);
        });
}

// End call
function endCall() {
    // Stop ringtone (in case call ends before being answered)
    const ringtone = document.getElementById('incomingRingtone');
    if (ringtone) { ringtone.pause(); ringtone.currentTime = 0; }
    
    if (localStream) {
        localStream.getTracks().forEach(track => track.stop());
        localStream = null;
    }
    
    if (peerConnection) {
        peerConnection.close();
        peerConnection = null;
    }
    
    document.getElementById('videoCallModal').style.display = 'none';
    document.getElementById('incomingCallPanel').style.display = 'none';
    document.getElementById('remoteVideo').srcObject = null;
    document.getElementById('localVideo').srcObject = null;
    
    isCallActive = false;
    currentCall = null;
    isAudioMuted = false;
    isVideoMuted = false;
}

// Toggle audio mute
function toggleAudioMute() {
    if (!localStream) return;
    
    const audioTracks = localStream.getAudioTracks();
    audioTracks.forEach(track => track.enabled = !track.enabled);
    isAudioMuted = !isAudioMuted;
    
    document.getElementById('muteAudioBtn').classList.toggle('muted', isAudioMuted);
    document.getElementById('muteAudioBtn').innerHTML = isAudioMuted ? 
        '<i class="fas fa-microphone-slash"></i>' : 
        '<i class="fas fa-microphone"></i>';
}

// Toggle video mute
function toggleVideoMute() {
    if (!localStream) return;
    
    const videoTracks = localStream.getVideoTracks();
    videoTracks.forEach(track => track.enabled = !track.enabled);
    isVideoMuted = !isVideoMuted;
    
    document.getElementById('muteVideoBtn').classList.toggle('muted', isVideoMuted);
    document.getElementById('muteVideoBtn').innerHTML = isVideoMuted ? 
        '<i class="fas fa-video-slash"></i>' : 
        '<i class="fas fa-video"></i>';
}

// Subscribe to call-related Ably events
function subscribeToCallEvents() {
    if (!channel) return;
    
    channel.subscribe('call-invitation', handleCallInvitation);
    channel.subscribe('call-response', handleCallResponse);
    channel.subscribe('call-ice-candidate', handleICECandidate);
}

