{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}Trajet {{ trajet.pointDepart }} → {{ trajet.pointArrivee }} - RE7LA{% endblock %}

{% block extra_styles %}
:root {
    --bleu-ceil: #87CEEB;
    --bleu-ceil-dark: #5dade2;
    --rouge: #e74c3c;
    --vert-pistache: #93C572;
    --vert-pistache-dark: #7cb342;
    --dark: #2c3e50;
}

.trajet-hero-show {
    background: linear-gradient(135deg, var(--dark) 0%, #1a2f42 100%);
    padding: 140px 0 60px;
    position: relative; overflow: hidden;
}
.trajet-hero-show::before {
    content: ''; position: absolute; inset: 0;
    background: url('https://images.unsplash.com/photo-1469854523086-cc02fe5d8800?w=1400') center/cover;
    opacity: 0.06;
}

.info-card-fe {
    background: white; border-radius: 25px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.08);
    overflow: hidden; margin-bottom: 24px;
    border: 1px solid rgba(135,206,235,0.1);
}
.ic-head {
    padding: 20px 28px; border-bottom: 1px solid #f0f4f8;
    display: flex; align-items: center; gap: 12px;
}
.ic-icon {
    width: 44px; height: 44px; border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
}
.ic-title { font-weight: 700; font-size: 16px; color: var(--dark); }

.info-row-fe {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 28px; border-bottom: 1px solid #f8fafc; font-size: 14px;
}
.info-row-fe:last-child { border-bottom: none; }
.ir-key { color: #94a3b8; display: flex; align-items: center; gap: 8px; }
.ir-val { font-weight: 600; color: var(--dark); }

.badge-fe { display: inline-block; padding: 6px 18px; border-radius: 50px; font-size: 12px; font-weight: 700; }
.badge-reserved  { background: rgba(135,206,235,0.15); color: #3b82f6; }
.badge-confirmed { background: rgba(147,197,114,0.15); color: #16a34a; }
.badge-cancelled { background: rgba(231,76,60,0.15);   color: #dc2626; }
.badge-completed { background: rgba(44,62,80,0.08);    color: #475569; }
{% endblock %}

{% block body %}

<!-- ===== HERO ===== -->
<section class="trajet-hero-show">
    <div class="container position-relative">
        <!-- Breadcrumb -->
        <nav class="mb-4">
            <ol class="breadcrumb" style="background: rgba(255,255,255,0.08); padding: 10px 20px; border-radius: 50px; display: inline-flex;">
                <li class="breadcrumb-item"><a href="{{ path('app_home') }}" style="color: rgba(255,255,255,0.6); text-decoration: none;">Accueil</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_trajet') }}" style="color: var(--bleu-ceil); text-decoration: none;">Trajets</a></li>
                <li class="breadcrumb-item active" style="color: white;">{{ trajet.pointDepart }} → {{ trajet.pointArrivee }}</li>
            </ol>
        </nav>

        <div class="row align-items-center">
            <div class="col-lg-8">
                <span style="background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache)); color: white; padding: 7px 18px; border-radius: 50px; font-size: 12px; font-weight: 600; display: inline-block; margin-bottom: 18px;">
                    <i class="fas fa-route me-2"></i>Fiche Trajet #{{ trajet.id }}
                </span>
                <h1 style="font-weight: 800; font-size: 2.5rem; color: white; margin-bottom: 10px;">
                    {{ trajet.pointDepart }}
                    <span style="color: rgba(255,255,255,0.3); font-size: 1.5rem; margin: 0 12px;"><i class="fas fa-arrow-right"></i></span>
                    <span style="background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">{{ trajet.pointArrivee }}</span>
                </h1>
                {% if trajet.dateReservation %}
                <p style="color: rgba(255,255,255,0.5); font-size: 14px;">
                    <i class="fas fa-calendar me-2"></i>Réservé le {{ trajet.dateReservation|date('d/m/Y à H:i') }}
                </p>
                {% endif %}
            </div>
            <div class="col-lg-4 d-flex gap-2 justify-content-lg-end mt-4 mt-lg-0">
                <a href="{{ path('app_trajet') }}" class="btn" style="background: rgba(255,255,255,0.1); color: white; border-radius: 50px; padding: 11px 24px; font-weight: 600; border: 1px solid rgba(255,255,255,0.2); backdrop-filter: blur(10px);">
                    <i class="fas fa-arrow-left me-2"></i>Liste
                </a>
                <a href="{{ path('app_trajet_edit', {id: trajet.id}) }}" class="btn" style="background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache)); color: white; border-radius: 50px; padding: 11px 24px; font-weight: 600; box-shadow: 0 8px 25px rgba(135,206,235,0.4);">
                    <i class="fas fa-pen me-2"></i>Modifier
                </a>
            </div>
        </div>
    </div>
</section>

<section class="py-5" style="background: #f8f9fa;">
    <div class="container">
        <div class="row g-4">

            <!-- ===== MAIN CONTENT ===== -->
            <div class="col-lg-8" data-aos="fade-up">

                <!-- Route visual card -->
                <div class="info-card-fe">
                    <div style="background: linear-gradient(135deg, var(--dark), #1a2f42); padding: 32px 28px; display: flex; align-items: center;">
                        <div style="flex: 1;">
                            <div style="font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 8px;">Départ</div>
                            <div style="font-size: 26px; font-weight: 800; color: white;">{{ trajet.pointDepart }}</div>
                            <div style="width: 40px; height: 3px; background: var(--bleu-ceil); border-radius: 2px; margin-top: 10px;"></div>
                        </div>
                        <div style="padding: 0 24px; text-align: center; flex-shrink: 0;">
                            <div style="width: 56px; height: 56px; background: rgba(255,255,255,0.08); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 8px;">
                                <i class="fas fa-bus" style="font-size: 22px; background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"></i>
                            </div>
                            {% if trajet.distanceKm %}
                            <div style="font-size: 13px; color: rgba(255,255,255,0.5); white-space: nowrap;">{{ trajet.distanceKm|number_format(1) }} km</div>
                            {% endif %}
                        </div>
                        <div style="flex: 1; text-align: right;">
                            <div style="font-size: 11px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 8px;">Arrivée</div>
                            <div style="font-size: 26px; font-weight: 800; color: white;">{{ trajet.pointArrivee }}</div>
                            <div style="width: 40px; height: 3px; background: var(--vert-pistache); border-radius: 2px; margin-top: 10px; margin-left: auto;"></div>
                        </div>
                    </div>
                </div>

                <!-- Détails du trajet -->
                <div class="info-card-fe" data-aos="fade-up" data-aos-delay="100">
                    <div class="ic-head">
                        <div class="ic-icon" style="background: linear-gradient(135deg, rgba(135,206,235,0.2), rgba(135,206,235,0.1));">
                            <i class="fas fa-list" style="color: var(--bleu-ceil);"></i>
                        </div>
                        <div class="ic-title">Détails du trajet</div>
                    </div>
                    <div class="info-row-fe">
                        <span class="ir-key"><i class="fas fa-info-circle"></i> Statut</span>
                        <span>
                            {% set s = trajet.statut %}
                            <span class="badge-fe
                                {% if s == 'Réservé' %}badge-reserved
                                {% elseif s == 'Confirmé' %}badge-confirmed
                                {% elseif s == 'Annulé' %}badge-cancelled
                                {% else %}badge-completed{% endif %}">
                                {{ s }}
                            </span>
                        </span>
                    </div>
                    <div class="info-row-fe">
                        <span class="ir-key"><i class="fas fa-calendar-alt"></i> Date de réservation</span>
                        <span class="ir-val">{% if trajet.dateReservation %}{{ trajet.dateReservation|date('d/m/Y à H:i') }}{% else %}—{% endif %}</span>
                    </div>
                    <div class="info-row-fe">
                        <span class="ir-key"><i class="fas fa-road"></i> Distance</span>
                        <span class="ir-val">{% if trajet.distanceKm %}{{ trajet.distanceKm|number_format(1) }} km{% else %}—{% endif %}</span>
                    </div>
                    <div class="info-row-fe">
                        <span class="ir-key"><i class="fas fa-users"></i> Passagers</span>
                        <span class="ir-val">{{ trajet.nbPersonnes }} personne{{ trajet.nbPersonnes > 1 ? 's' : '' }}</span>
                    </div>
                    <div class="info-row-fe">
                        <span class="ir-key"><i class="fas fa-hashtag"></i> Réf.</span>
                        <span class="ir-val">#{{ trajet.id }}</span>
                    </div>
                </div>

                <!-- Véhicule assigné -->
                {% if trajet.idVoiture %}
                <div class="info-card-fe" data-aos="fade-up" data-aos-delay="150">
                    <div class="ic-head">
                        <div class="ic-icon" style="background: linear-gradient(135deg, rgba(147,197,114,0.2), rgba(147,197,114,0.1));">
                            <i class="fas fa-car" style="color: var(--vert-pistache);"></i>
                        </div>
                        <div class="ic-title">Véhicule assigné</div>
                    </div>
                    <div class="info-row-fe">
                        <span class="ir-key"><i class="fas fa-tag"></i> Marque</span>
                        <span class="ir-val">{{ trajet.idVoiture.marque }}</span>
                    </div>
                    <div class="info-row-fe">
                        <span class="ir-key"><i class="fas fa-car-side"></i> Modèle</span>
                        <span class="ir-val">{{ trajet.idVoiture.modele }}</span>
                    </div>
                    {% if trajet.idVoiture.immatriculation is defined %}
                    <div class="info-row-fe">
                        <span class="ir-key"><i class="fas fa-id-card"></i> Immatriculation</span>
                        <span class="ir-val" style="font-family: monospace;">{{ trajet.idVoiture.immatriculation }}</span>
                    </div>
                    {% endif %}
                </div>
                {% endif %}

            </div>

            <!-- ===== SIDEBAR ===== -->
            <div class="col-lg-4">

                <!-- Quick summary -->
                <div class="info-card-fe" data-aos="fade-up">
                    <div class="ic-head">
                        <div class="ic-icon" style="background: linear-gradient(135deg, rgba(135,206,235,0.2), rgba(147,197,114,0.1));">
                            <i class="fas fa-bolt" style="color: var(--bleu-ceil);"></i>
                        </div>
                        <div class="ic-title">Résumé rapide</div>
                    </div>
                    <div style="padding: 10px 0;">
                        <div class="info-row-fe"><span class="ir-key">Départ</span><span class="ir-val">{{ trajet.pointDepart }}</span></div>
                        <div class="info-row-fe"><span class="ir-key">Arrivée</span><span class="ir-val">{{ trajet.pointArrivee }}</span></div>
                        <div class="info-row-fe"><span class="ir-key">Distance</span><span class="ir-val">{{ trajet.distanceKm ? trajet.distanceKm|number_format(1) ~ ' km' : '—' }}</span></div>
                        <div class="info-row-fe"><span class="ir-key">Passagers</span><span class="ir-val">{{ trajet.nbPersonnes }}</span></div>
                        <div class="info-row-fe"><span class="ir-key">Date</span><span class="ir-val">{{ trajet.dateReservation ? trajet.dateReservation|date('d/m/Y') : '—' }}</span></div>
                        <div class="info-row-fe"><span class="ir-key">Véhicule</span><span class="ir-val">{{ trajet.idVoiture ? trajet.idVoiture.marque ~ ' ' ~ trajet.idVoiture.modele : '—' }}</span></div>
                    </div>
                </div>

                <!-- Actions -->
                <div style="background: white; border-radius: 25px; box-shadow: 0 10px 40px rgba(0,0,0,0.08); padding: 24px; border: 1px solid rgba(135,206,235,0.1);" data-aos="fade-up" data-aos-delay="100">
                    <h6 style="font-weight: 700; color: var(--dark); margin-bottom: 16px;"><i class="fas fa-cogs me-2" style="color: var(--bleu-ceil);"></i>Actions</h6>

                    <div class="d-flex flex-column gap-2">
                        <a href="{{ path('app_trajet_edit', {id: trajet.id}) }}" class="btn w-100" style="background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache)); color: white; border-radius: 50px; padding: 12px; font-weight: 600;">
                            <i class="fas fa-pen me-2"></i>Modifier ce trajet
                        </a>
                        <a href="{{ path('app_trajet') }}" class="btn w-100" style="background: rgba(135,206,235,0.12); color: var(--bleu-ceil); border-radius: 50px; padding: 12px; font-weight: 600;">
                            <i class="fas fa-list me-2"></i>Retour à la liste
                        </a>
                        <a href="{{ path('app_trajet_create') }}" class="btn w-100" style="background: rgba(147,197,114,0.12); color: var(--vert-pistache-dark); border-radius: 50px; padding: 12px; font-weight: 600;">
                            <i class="fas fa-plus me-2"></i>Nouveau trajet
                        </a>
                        <hr style="border-color: #f0f4f8; margin: 6px 0;">
                        <form method="POST" action="{{ path('app_trajet_delete', {id: trajet.id}) }}" onsubmit="return confirm('Supprimer définitivement ce trajet ?');">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete' ~ trajet.id) }}">
                            <button type="submit" class="btn w-100" style="background: rgba(231,76,60,0.1); color: var(--rouge); border-radius: 50px; padding: 12px; font-weight: 600; border: none; font-family: 'Poppins', sans-serif;">
                                <i class="fas fa-trash me-2"></i>Supprimer
                            </button>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

{% endblock %}
