<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% block title %}RE7LA Admin — Dashboard{% endblock %}</title>
<link rel="icon" type="image/png" href="{{ asset('images/re7la-logo.png') }}">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Inter',sans-serif;background:#f4f6f9;color:#2C3E50;line-height:1.5;font-size:14px;}
.app{display:flex;height:100vh;overflow:hidden;}

/* ===== SIDEBAR ===== */
.sidebar{width:260px;background:#fff;border-right:1px solid #e8ecf0;display:flex;flex-direction:column;flex-shrink:0;overflow-y:auto;}
.sidebar-brand{padding:20px 24px;border-bottom:1px solid #f0f2f5;display:flex;align-items:center;gap:10px;}
.brand-logo{width:64px;height:64px;background:white;border-radius:12px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 8px rgba(0,0,0,0.1);}
.brand-logo img{width:40px;height:40px;object-fit:contain;}
.brand-name{font-size:18px;font-weight:700;color:#2C3E50;}
.brand-name span{color:#F7B731;}

.sidebar-nav{padding:16px 12px;flex:1;}
.nav-section-title{font-size:10px;font-weight:600;color:#94a3b8;text-transform:uppercase;letter-spacing:1px;padding:8px 12px 6px;margin-top:8px;}
.nav-item{display:flex;align-items:center;gap:12px;padding:10px 14px;border-radius:10px;color:#64748b;font-weight:500;font-size:13px;cursor:pointer;margin-bottom:2px;transition:all 0.15s;text-decoration:none;}
.nav-item i{width:20px;text-align:center;font-size:14px;}
.nav-item:hover{background:#f8fafc;color:#2C3E50;}
.nav-item.active{background:linear-gradient(135deg,#F7B731,#E6C050);color:#fff;box-shadow:0 4px 12px rgba(255,209,102,0.35);}
.nav-item.active i{color:#fff;}
.nav-badge{margin-left:auto;background:#F7B731;color:#fff;font-size:9px;font-weight:700;padding:2px 7px;border-radius:20px;}
.nav-badge.new{background:#ef4444;}

.sidebar-bottom{padding:16px 12px;border-top:1px solid #f0f2f5;}
.help-box{background:linear-gradient(135deg,#F7B731,#E6C050);border-radius:14px;padding:16px;color:#fff;text-align:center;}
.help-box .help-icon{font-size:28px;margin-bottom:8px;}
.help-box p{font-size:11px;opacity:0.9;margin:4px 0 10px;}
.help-btn{background:#fff;color:#F7B731;border:none;padding:6px 16px;border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;width:100%;}

/* ===== MAIN ===== */
.main{flex:1;display:flex;flex-direction:column;overflow-y:auto;overflow-x:hidden;}

/* ===== HEADER ===== */
.header{background:white;padding-bottom:20px;flex-shrink:0;}
.header-top{display:flex;align-items:center;justify-content:space-between;padding:16px 28px;}
.header-breadcrumb{color:#2C3E50;font-size:12px;margin-bottom:2px;}
.header-breadcrumb span{color:#2C3E50;font-weight:600;}
.header-title{color:#2C3E50;font-size:22px;font-weight:700;letter-spacing:-0.3px;}
.header-actions{display:flex;align-items:center;gap:20px;}
.search-box{background:#f0f2f5;border:1px solid #e8ecf0;border-radius:30px;padding:8px 16px;display:flex;align-items:center;gap:8px;}
.search-box input{background:transparent;border:none;outline:none;color:#2C3E50;font-size:13px;width:160px;}
.search-box input::placeholder{color:#6c757d;}
.search-box i{color:#6c757d;font-size:13px;}
.header-icon-btn{color:#6c757d;font-size:18px;cursor:pointer;position:relative;}
.notif-dot{position:absolute;top:-4px;right:-5px;background:#F7B731;width:16px;height:16px;border-radius:50%;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;color:#fff;border:2px solid white;}
.user-chip{display:flex;align-items:center;gap:10px;background:#f0f2f5;padding:6px 14px 6px 8px;border-radius:30px;cursor:pointer;}
.user-avatar{width:32px;height:32px;background:#F7B731;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:12px;}
.user-chip span{color:#2C3E50;font-size:13px;font-weight:500;}

/* ===== CONTENT ===== */
.content{padding:28px 28px 28px;}

.stat-cards-row{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:28px;position:relative;z-index:10;}
.stat-card{background:#fff;border-radius:14px;padding:18px 20px;box-shadow:0 4px 20px rgba(0,0,0,0.08);display:flex;align-items:center;justify-content:space-between;}
.stat-card-left .label{font-size:11px;font-weight:600;color:#94a3b8;text-transform:uppercase;letter-spacing:0.5px;}
.stat-card-left .value{font-size:22px;font-weight:700;color:#2C3E50;margin:4px 0 2px;}
.trend{font-size:12px;}
.trend.up{color:#1ABC9C;}
.trend.down{color:#ef4444;}
.stat-icon{width:48px;height:48px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px;color:#fff;}
.ic-orange{background:linear-gradient(135deg,#F39C12,#e67e22);}
.ic-teal{background:linear-gradient(135deg,#1ABC9C,#16a085);}
.ic-navy{background:linear-gradient(135deg,#2C3E50,#34495e);}
.ic-yellow{background:linear-gradient(135deg,#F7DC6F,#F39C12);}

.row{display:grid;gap:20px;margin-bottom:20px;}
.row-2{grid-template-columns:1fr 1fr;}
.row-3{grid-template-columns:2fr 1fr;}

.card{background:#fff;border-radius:16px;padding:22px;box-shadow:0 2px 12px rgba(0,0,0,0.05);}
.card-title{font-size:15px;font-weight:600;color:#2C3E50;margin-bottom:4px;}
.card-sub{font-size:12px;color:#94a3b8;margin-bottom:16px;}

.chart-area{height:180px;position:relative;margin-top:8px;}
.chart-line{width:100%;height:100%;}
.chart-label{display:flex;justify-content:space-between;font-size:11px;color:#94a3b8;margin-top:8px;}

.heberg-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.heberg-item{background:#f8fafc;border-radius:12px;padding:16px;}
.heberg-item .h-icon{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;margin-bottom:12px;font-size:18px;color:#fff;}
.h-icon.apt{background:linear-gradient(135deg,#1ABC9C,#16a085);}
.h-icon.htl{background:linear-gradient(135deg,#F39C12,#e67e22);}
.h-icon.res{background:linear-gradient(135deg,#2C3E50,#34495e);}
.h-icon.usr{background:linear-gradient(135deg,#F7DC6F,#F39C12);}
.heberg-item .h-num{font-size:26px;font-weight:700;color:#2C3E50;}
.heberg-item .h-lbl{font-size:12px;color:#64748b;margin-top:2px;}
.h-avail{font-size:11px;color:#1ABC9C;font-weight:600;margin-top:4px;}

.pie-area{display:flex;align-items:center;gap:20px;}
.pie-legend{flex:1;}
.legend-item{display:flex;align-items:center;gap:8px;margin-bottom:10px;}
.legend-dot{width:10px;height:10px;border-radius:50%;}
.legend-label{font-size:12px;color:#64748b;}
.legend-val{margin-left:auto;font-size:12px;font-weight:600;color:#2C3E50;}

.progress-bar{height:6px;background:rgba(255,255,255,0.15);border-radius:3px;margin:6px 0 12px;}
.progress-fill{height:100%;border-radius:3px;}

.table-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;}
th{font-size:11px;font-weight:600;color:#94a3b8;text-transform:uppercase;letter-spacing:0.5px;padding:8px 12px;text-align:left;border-bottom:1px solid #f0f2f5;}
td{padding:10px 12px;font-size:13px;color:#2C3E50;border-bottom:1px solid #f8fafc;}
tr:last-child td{border-bottom:none;}
.status-badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600;}
.s-ok{background:#d1fae5;color:#065f46;}
.s-pend{background:#fef3c7;color:#92400e;}
.s-cancel{background:#fee2e2;color:#991b1b;}

/* ===== RESPONSIVE ===== */
@media (max-width: 1100px) {
  .stat-cards-row{grid-template-columns:repeat(2,1fr);}
  .row-3{grid-template-columns:1fr;}
  .row-2{grid-template-columns:1fr;}
}
@media (max-width: 768px) {
  .sidebar{display:none;}
  .stat-cards-row{grid-template-columns:1fr 1fr;}
  .content{padding:0 16px 16px;}
  .header-top{padding:14px 16px;}
  .search-box{display:none;}
}
@media (max-width: 480px) {
  .stat-cards-row{grid-template-columns:1fr;}
  .user-chip span{display:none;}
}
</style>
{% block stylesheets %}{% endblock %}
</head>

<body>
<div class="app">

  <!-- ===== SIDEBAR ===== -->
  <aside class="sidebar">
    <div class="sidebar-brand">
      <img src="{{ asset('images/re7la-logo.png') }}" alt="RE7LA" style="width: 100%; max-width: 200px; height: auto; object-fit: contain;">
    </div>

    <div class="sidebar-nav">
      <div class="nav-section-title">Navigation</div>

      <a href="{{ path('app_admin_voiture_dashboard') }}" class="nav-item {{ app.request.attributes.get('_route') == 'app_admin_voiture_dashboard' ? 'active' : '' }}">
        <i class="fas fa-tachometer-alt"></i><span>Dashboard</span>
      </a>
      <a href="{{ path('app_home') }}" target="_blank" class="nav-item">
        <i class="fas fa-globe"></i><span>Aller au Front</span>
        <i class="fas fa-external-link-alt" style="margin-left:auto;font-size:10px;opacity:0.5;"></i>
      </a>
      <a href="{{ path('app_voiture') }}" class="nav-item {{ app.request.attributes.get('_route') starts with 'app_voiture' ? 'active' : '' }}">
        <i class="fas fa-car"></i><span>Voitures</span>
      </a>

      <div class="nav-section-title">Gestion</div>

      <div class="nav-item" onclick="setActive(this)">
        <i class="fas fa-users"></i><span>Utilisateurs</span>
      </div>
      <div class="nav-item" onclick="setActive(this)">
        <i class="fas fa-folder-open"></i><span>Projets</span>
      </div>
      <div class="nav-item" onclick="setActive(this)">
        <i class="fas fa-shopping-cart"></i><span>Commandes</span>
        <span class="nav-badge">12</span>
      </div>

      <div class="nav-section-title">Rapport</div>

      <div class="nav-item" onclick="setActive(this)">
        <i class="fas fa-chart-line"></i><span>Analytics</span>
        <span style="margin-left:auto;font-size:11px;color:#1ABC9C;font-weight:600;">+24%</span>
      </div>
      <div class="nav-item" onclick="setActive(this)">
        <i class="fas fa-sliders-h"></i><span>Configuration</span>
      </div>
    </div>

    <div class="sidebar-bottom">
      <div class="help-box">
        <div class="help-icon">🛟</div>
        <p style="font-weight:600;font-size:13px;">Besoin d'aide ?</p>
        <p>Consultez notre documentation</p>
        <button class="help-btn">Documentation</button>
      </div>
      <div style="text-align:center;font-size:10px;color:#94a3b8;margin-top:10px;">RE7LA Admin v1.0</div>
    </div>
  </aside>

  <!-- ===== MAIN ===== -->
  <div class="main">

    <!-- HEADER -->
    <header class="header">
      <div class="header-top">
        <div>
          <div class="header-breadcrumb">Pages / <span>{% block breadcrumb %}Dashboard{% endblock %}</span></div>
          <div class="header-title">{% block page_title %}Tableau de bord{% endblock %}</div>
        </div>
        <div class="header-actions">
          <div class="search-box">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Rechercher...">
          </div>
          <div class="header-icon-btn">
            <i class="far fa-bell"></i>
            <div class="notif-dot">3</div>
          </div>
          <div class="header-icon-btn">
            <i class="fas fa-cog"></i>
          </div>
          <div class="user-chip" onclick="toggleProfileMenu()" style="cursor:pointer;position:relative;">
            <div class="user-avatar">AD</div>
            <span>Alex Dupont</span>
            <i class="fas fa-chevron-down" style="color:rgba(255,255,255,0.7);font-size:10px;"></i>
            
            <!-- Profile Dropdown Menu -->
            <div id="profileMenu" style="position:absolute;top:100%;right:0;margin-top:8px;background:#fff;border-radius:12px;box-shadow:0 10px 40px rgba(0,0,0,0.15);min-width:220px;z-index:1000;display:none;">
              <div style="padding:8px;">
                
                <a href="{{ path('app_admin_profile') }}" style="display:flex;align-items:center;gap:12px;padding:12px;border-radius:8px;text-decoration:none;color:#2C3E50;transition:all 0.3s;background:#f8fafc;">
                  <i class="fas fa-user" style="color:#1ABC9C;width:16px;height:16px;display:flex;align-items:center;justify-content:center;"></i>
                  <span style="font-size:14px;font-weight:600;color:#2C3E50;white-space:nowrap;">Mon Profil</span>
                </a>
                
                <a href="{{ path('app_admin_profile_edit') }}" style="display:flex;align-items:center;gap:12px;padding:12px;border-radius:8px;text-decoration:none;color:#2C3E50;transition:all 0.3s;background:#f8fafc;">
                  <i class="fas fa-user-edit" style="color:#F39C12;width:16px;height:16px;display:flex;align-items:center;justify-content:center;"></i>
                  <span style="font-size:14px;font-weight:600;color:#2C3E50;white-space:nowrap;">Modifier Profil</span>
                </a>
                
                <div style="border-top:1px solid #f0f2f5;margin:4px 0;"></div>
                
                <a href="#" style="display:flex;align-items:center;gap:12px;padding:12px;border-radius:8px;text-decoration:none;color:#2C3E50;transition:all 0.3s;background:#f8fafc;">
                  <i class="fas fa-cog" style="color:#64748b;width:16px;height:16px;display:flex;align-items:center;justify-content:center;"></i>
                  <span style="font-size:14px;font-weight:600;color:#2C3E50;white-space:nowrap;">Paramètres</span>
                </a>
                
                <a href="{{ path('app_admin_login') }}" style="display:flex;align-items:center;gap:12px;padding:12px;border-radius:8px;text-decoration:none;color:#ef4444;transition:all 0.3s;background:#f8fafc;">
                  <i class="fas fa-sign-out-alt" style="color:#ef4444;width:16px;height:16px;display:flex;align-items:center;justify-content:center;"></i>
                  <span style="font-size:14px;font-weight:600;color:#ef4444;white-space:nowrap;">Déconnexion</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- CONTENT -->
    <div class="content">
      {% block body %}{% endblock %}
    </div><!-- end .content -->
  </div><!-- end .main -->
</div><!-- end .app -->

<script>
  function setActive(el) {
    document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
    el.classList.add('active');
  }
  
  function toggleProfileMenu() {
    const menu = document.getElementById('profileMenu');
    const isVisible = menu.style.display === 'block';
    menu.style.display = isVisible ? 'none' : 'block';
    
    // Debug
    console.log('Menu toggled:', !isVisible);
    console.log('Menu element:', menu);
    console.log('Menu display:', menu.style.display);
  }
  
  // Close menu when clicking outside
  document.addEventListener('click', function(event) {
    const userChip = document.querySelector('.user-chip');
    const menu = document.getElementById('profileMenu');
    
    if (!userChip.contains(event.target)) {
      menu.style.display = 'none';
    }
  });
  
    // Add hover effects
  document.addEventListener('DOMContentLoaded', function() {
    const menuLinks = document.querySelectorAll('#profileMenu a');
    menuLinks.forEach(link => {
      link.addEventListener('mouseenter', function() {
        this.style.background = 'rgba(26,188,156,0.1)';
        this.style.color = '#1ABC9C';
      });
      link.addEventListener('mouseleave', function() {
        this.style.background = '#f8fafc';
        this.style.color = (this.textContent.trim() === 'Déconnexion') ? '#ef4444' : '#2C3E50';
      });
    });
  });

  // --- GLOBAL REAL TIME NOTIFICATIONS (TRAJETS) ---
  document.addEventListener('DOMContentLoaded', function() {
      const url = "{{ mercure('https://re7la.com/admin/trajets')|escape('js') }}";
      const eventSource = new EventSource(url);
      
      eventSource.onmessage = event => {
          const data = JSON.parse(event.data);
          
          if(data.action === 'add_trajet') {
              // Notification globale SweetAlert2 Toast
              const Toast = Swal.mixin({
                toast: true,
                position: "top-end",
                showConfirmButton: false,
                timer: 6000,
                timerProgressBar: true,
                didOpen: (toast) => {
                  toast.onmouseenter = Swal.stopTimer;
                  toast.onmouseleave = Swal.resumeTimer;
                }
              });
              
              Toast.fire({
                icon: "success",
                title: "<span style='font-size:15px;font-weight:700;color:#2C3E50;'>Nouvelle Réservation !</span>",
                html: `<div style='font-size:13px;color:#64748b;margin-top:4px;'>${data.message}<br><b style='color:#2C3E50;'>Auto:</b> ${data.voiture_marque} ${data.voiture_modele}</div>`,
                background: '#ffffff',
                iconColor: '#1ABC9C',
                showCloseButton: true
              });
              
              // Met à jour la bulle de notification dans le header (point rouge)
              const notifDot = document.querySelector('.notif-dot');
              if(notifDot) {
                  let count = parseInt(notifDot.innerText) || 0;
                  notifDot.innerText = count + 1;
                  notifDot.style.animation = 'pulse 1s infinite alternate';
              }
          }
      };
  });
</script>
{% block javascripts %}{% endblock %}
</body>
</html>