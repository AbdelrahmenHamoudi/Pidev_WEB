{# ════════════════════════════════════════════════════════════
   templates/frontend/activite/show.html.twig
════════════════════════════════════════════════════════════ #}
{% extends 'base_frontend.html.twig' %}

{% block title %}RE7LA — {{ activite.nomA }}{% endblock %}

{% block extra_styles %}
.planning-card { background:#fff; border-radius:16px; padding:20px 24px;
    box-shadow:0 4px 20px rgba(0,0,0,0.06); border:2px solid transparent;
    transition:all 0.3s; margin-bottom:16px; }
.planning-card:hover { border-color:var(--bleu-ceil); transform:translateY(-3px); }
.btn-reserver { background:linear-gradient(135deg,var(--bleu-ceil),var(--vert-pistache));
    color:#fff; border:none; padding:12px 28px; border-radius:50px; font-weight:600;
    font-size:14px; cursor:pointer; transition:all 0.3s; }
.btn-reserver:hover { transform:translateY(-2px); box-shadow:0 8px 20px rgba(135,206,235,0.4); }
.btn-reserver:disabled { background:#ccc; cursor:not-allowed; transform:none; }
{% endblock %}

{% block body %}

{# Flash #}
<div style="padding-top:100px;">
{% for message in app.flashes('success') %}
    <div class="container" style="margin-bottom:-20px;">
        <div style="background:#d1fae5;color:#065f46;padding:14px 20px;border-radius:12px;font-weight:600;">
            <i class="fas fa-check-circle"></i> {{ message }}
        </div>
    </div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="container" style="margin-bottom:-20px;">
        <div style="background:#fee2e2;color:#991b1b;padding:14px 20px;border-radius:12px;font-weight:600;">
            <i class="fas fa-exclamation-circle"></i> {{ message }}
        </div>
    </div>
{% endfor %}
</div>

{# Hero image #}
<section style="padding-top:80px;">
    {% if activite.image %}
        <div style="height:420px;overflow:hidden;">
            <img src="{{ asset('uploads/activites/' ~ activite.image) }}"
                 alt="{{ activite.nomA }}"
                 style="width:100%;height:100%;object-fit:cover;">
        </div>
    {% else %}
        <div style="height:320px;background:linear-gradient(135deg,var(--bleu-ceil),var(--vert-pistache));
                    display:flex;align-items:center;justify-content:center;">
            <i class="fas fa-hiking" style="font-size:80px;color:rgba(255,255,255,0.6);"></i>
        </div>
    {% endif %}
</section>

{# Contenu principal #}
<section style="padding:50px 0 100px;">
    <div class="container">
        <div class="row g-5">

            {# ── Colonne gauche : infos ── #}
            <div class="col-lg-7">
                <div style="display:flex;gap:10px;margin-bottom:16px;" data-aos="fade-up">
                    <span style="background:rgba(135,206,235,0.15);color:var(--bleu-ceil-dark);
                                 padding:5px 14px;border-radius:20px;font-size:13px;font-weight:600;">
                        {{ activite.type }}
                    </span>
                    <span style="background:{{ activite.statut == 'Disponible' ? '#d1fae5' : '#fee2e2' }};
                                 color:{{ activite.statut == 'Disponible' ? '#065f46' : '#991b1b' }};
                                 padding:5px 14px;border-radius:20px;font-size:13px;font-weight:600;">
                        {{ activite.statut }}
                    </span>
                </div>

                <h1 style="font-size:2.2rem;font-weight:800;color:var(--dark);margin-bottom:12px;"
                    data-aos="fade-up" data-aos-delay="50">
                    {{ activite.nomA }}
                </h1>

                <div style="display:flex;gap:20px;margin-bottom:24px;color:#666;" data-aos="fade-up" data-aos-delay="100">
                    <span><i class="fas fa-map-marker-alt" style="color:var(--rouge);margin-right:5px;"></i>{{ activite.lieu }}</span>
                    <span><i class="fas fa-users" style="color:var(--vert-pistache);margin-right:5px;"></i>{{ activite.capaciteMax }} personnes max</span>
                    <span><i class="fas fa-tag" style="color:var(--bleu-ceil);margin-right:5px;"></i>{{ activite.prixParPersonne|number_format(0) }} DT/pers.</span>
                </div>

                <div style="background:#f8fafc;border-radius:16px;padding:24px;margin-bottom:30px;"
                     data-aos="fade-up" data-aos-delay="150">
                    <h5 style="font-weight:700;color:var(--dark);margin-bottom:12px;">
                        <i class="fas fa-info-circle" style="color:var(--bleu-ceil);margin-right:8px;"></i>
                        À propos
                    </h5>
                    <p style="color:#555;line-height:1.8;font-size:15px;">{{ activite.descriptionA }}</p>
                </div>

                <a href="{{ path('activite_index_front') }}"
                   style="color:var(--bleu-ceil-dark);font-weight:600;text-decoration:none;font-size:14px;">
                    <i class="fas fa-arrow-left"></i> Retour aux activités
                </a>
            </div>

            {# ── Colonne droite : plannings + réservation ── #}
            <div class="col-lg-5" data-aos="fade-left">
                <div style="background:#fff;border-radius:24px;padding:28px;
                            box-shadow:0 10px 40px rgba(0,0,0,0.08);position:sticky;top:100px;">
                    <h4 style="font-weight:700;color:var(--dark);margin-bottom:6px;">
                        <i class="fas fa-calendar-check" style="color:var(--bleu-ceil);margin-right:8px;"></i>
                        Plannings disponibles
                    </h4>
                    <p style="color:#888;font-size:13px;margin-bottom:20px;">
                        Choisissez une date pour réserver votre place
                    </p>

                    {% if activite.plannings|filter(p => p.etat == 'Disponible' and p.nbPlacesRestantes > 0)|length > 0 %}
                        {% for planning in activite.plannings %}
                            {% if planning.etat == 'Disponible' and planning.nbPlacesRestantes > 0 %}
                            <div class="planning-card">
                                <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                                    <div>
                                        <div style="font-weight:700;font-size:16px;color:var(--dark);">
                                            {{ planning.datePlanning|date('d/m/Y') }}
                                        </div>
                                        <div style="color:#888;font-size:13px;margin-top:2px;">
                                            <i class="fas fa-clock" style="color:var(--bleu-ceil);"></i>
                                            {{ planning.heureDebut|date('H:i') }} — {{ planning.heureFin|date('H:i') }}
                                        </div>
                                    </div>
                                    <span style="font-size:12px;font-weight:600;
                                        background:{{ planning.nbPlacesRestantes > 10 ? '#d1fae5' : (planning.nbPlacesRestantes > 3 ? '#fef3c7' : '#fee2e2') }};
                                        color:{{ planning.nbPlacesRestantes > 10 ? '#065f46' : (planning.nbPlacesRestantes > 3 ? '#92400e' : '#991b1b') }};
                                        padding:4px 10px;border-radius:20px;">
                                        {{ planning.nbPlacesRestantes }} place{% if planning.nbPlacesRestantes > 1 %}s{% endif %}
                                    </span>
                                </div>

                                <form method="post" action="{{ path('planning_reserver', {id: planning.idPlanning}) }}"
                                      onsubmit="return confirm('Confirmer la réservation pour le {{ planning.datePlanning|date('d/m/Y') }} ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('reserver_' ~ planning.idPlanning) }}">
                                    <button type="submit" class="btn-reserver" style="width:100%;">
                                        <i class="fas fa-check"></i> Réserver — {{ activite.prixParPersonne|number_format(0) }} DT
                                    </button>
                                </form>
                            </div>
                            {% endif %}
                        {% endfor %}
                    {% else %}
                        <div style="text-align:center;padding:40px 20px;color:#888;">
                            <i class="fas fa-calendar-times" style="font-size:40px;margin-bottom:12px;display:block;color:#ccc;"></i>
                            <p style="font-size:14px;">Aucun planning disponible pour le moment.</p>
                            <p style="font-size:12px;color:#aaa;">Revenez prochainement !</p>
                        </div>
                    {% endif %}
                </div>
            </div>

        </div>
    </div>
</section>

{% endblock %}
