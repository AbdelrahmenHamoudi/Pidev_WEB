{# ════════════════════════════════════════════════════════════
   templates/frontend/activite/show.html.twig — RE7LA v2 WOW
════════════════════════════════════════════════════════════ #}
{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}RE7LA — {{ activite.nomA }}{% endblock %}

{% block extra_styles %}
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --orange:   #F39C12;
    --yellow:   #F7DC6F;
    --dark:     #2C3E50;
    --teal:     #1ABC9C;
    --white:    #FAFAFA;
    --orange-d: #d4870a;
    --teal-d:   #15a085;
    --card-bg:  #ffffff;
    --text-muted: #7a8a99;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body { font-family: 'DM Sans', sans-serif; background: var(--white); color: var(--dark); overflow-x: hidden; }

  /* ─── Keyframes ─── */
  @keyframes fadeUp      { from { opacity:0; transform:translateY(28px) } to { opacity:1; transform:translateY(0) } }
  @keyframes fadeIn      { from { opacity:0 } to { opacity:1 } }
  @keyframes slideRight  { from { opacity:0; transform:translateX(-36px) } to { opacity:1; transform:translateX(0) } }
  @keyframes slideLeft   { from { opacity:0; transform:translateX(36px) } to { opacity:1; transform:translateX(0) } }
  @keyframes floatY      { 0%,100% { transform:translateY(0) } 50% { transform:translateY(-10px) } }
  @keyframes badgePop    { 0% { transform:scale(0) opacity:0 } 60% { transform:scale(1.15) } 100% { transform:scale(1) opacity:1 } }
  @keyframes shimmer     { 0% { background-position:200% center } 100% { background-position:-200% center } }
  @keyframes orbPulse    { 0%,100% { transform:scale(1);opacity:.6 } 50% { transform:scale(1.15);opacity:.9 } }
  @keyframes scanline    { 0% { transform:translateY(-100%) } 100% { transform:translateY(400px) } }
  @keyframes rippleOut   { 0% { transform:scale(0);opacity:1 } 100% { transform:scale(4.5);opacity:0 } }
  @keyframes rotateGlow  { from { transform:rotate(0deg) } to { transform:rotate(360deg) } }
  @keyframes countUp     { from { opacity:0;transform:translateY(12px) } to { opacity:1;transform:translateY(0) } }
  @keyframes progressFill { from { width:0 } to { width:var(--pct,60%) } }
  @keyframes tickerMove  { 0% { transform:translateX(0) } 100% { transform:translateX(-50%) } }
  @keyframes pulseDot    { 0%,100% { box-shadow:0 0 0 0 rgba(26,188,156,.6) } 70% { box-shadow:0 0 0 10px rgba(26,188,156,0) } }

  /* ─── Ticker bar ─── */
  .r7-ticker {
    position: fixed; top: 0; left: 0; width: 100%; z-index: 9999;
    background: var(--dark); color: var(--yellow); font-size: 11px; font-weight: 600;
    letter-spacing: 1.5px; height: 28px; display: flex; align-items: center;
    overflow: hidden; pointer-events: none;
  }
  .r7-ticker-inner { display: flex; gap: 0; white-space: nowrap; animation: tickerMove 28s linear infinite; }
  .r7-ticker-item { padding: 0 48px; }
  .r7-ticker-item::before { content: '✦ '; opacity: .6; }

  /* ─── Hero ─── */
  .r7-hero {
    position: relative; min-height: 100vh; overflow: hidden;
    display: flex; align-items: flex-end;
    margin-top: 28px;
  }
  .r7-hero-img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    transform: scale(1.06);
    transition: transform 8s ease;
  }
  .r7-hero:hover .r7-hero-img { transform: scale(1); }

  /* layered gradients */
  .r7-hero-grad {
    position: absolute; inset: 0;
    background:
      linear-gradient(to top, #2C3E50 0%, rgba(44,62,80,.85) 30%, rgba(44,62,80,.2) 70%, transparent 100%),
      linear-gradient(135deg, rgba(26,188,156,.15) 0%, transparent 60%);
  }

  /* animated orbs */
  .r7-orb {
    position: absolute; border-radius: 50%; pointer-events: none; mix-blend-mode: screen;
    animation: orbPulse 6s ease-in-out infinite;
  }
  .r7-orb-1 {
    width: 500px; height: 500px; top: -80px; right: -100px;
    background: radial-gradient(circle, rgba(26,188,156,.18) 0%, transparent 70%);
    animation-delay: 0s;
  }
  .r7-orb-2 {
    width: 350px; height: 350px; bottom: 100px; left: -60px;
    background: radial-gradient(circle, rgba(243,156,18,.14) 0%, transparent 70%);
    animation-delay: 2s;
  }
  .r7-orb-3 {
    width: 200px; height: 200px; top: 40%; left: 40%;
    background: radial-gradient(circle, rgba(247,220,111,.1) 0%, transparent 70%);
    animation-delay: 4s;
  }

  /* scanline */
  .r7-scanline {
    position: absolute; inset: 0; pointer-events: none; overflow: hidden; z-index: 1;
  }
  .r7-scanline::after {
    content: ''; position: absolute; left: 0; right: 0; height: 2px;
    background: linear-gradient(90deg, transparent, rgba(26,188,156,.35), transparent);
    animation: scanline 5s linear infinite;
  }

  /* hero content */
  .r7-hero-content {
    position: relative; z-index: 10;
    padding: 0 60px 72px;
    width: 100%;
  }
  .r7-hero-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(26,188,156,.15);
    border: 1px solid rgba(26,188,156,.4);
    color: var(--teal); font-size: 10px; font-weight: 700;
    letter-spacing: 3px; text-transform: uppercase;
    padding: 6px 16px; border-radius: 100px;
    margin-bottom: 20px;
    animation: badgePop .6s .3s cubic-bezier(.36,.07,.19,.97) both;
    backdrop-filter: blur(8px);
  }
  .r7-live-dot {
    width: 7px; height: 7px; border-radius: 50%; background: var(--teal);
    animation: pulseDot 1.8s infinite;
  }
  .r7-hero-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(2.6rem, 6vw, 5rem);
    font-weight: 800; line-height: 1.05;
    color: white; margin-bottom: 24px;
    animation: fadeUp .9s .5s ease both;
    text-shadow: 0 4px 40px rgba(0,0,0,.3);
  }
  .r7-hero-title span {
    background: linear-gradient(90deg, var(--orange), var(--yellow), var(--teal));
    background-size: 200%;
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    animation: shimmer 4s linear infinite;
  }
  .r7-hero-chips {
    display: flex; gap: 12px; flex-wrap: wrap;
    animation: fadeUp .9s .7s ease both;
  }
  .r7-chip {
    display: flex; align-items: center; gap: 7px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.15);
    backdrop-filter: blur(12px);
    color: rgba(255,255,255,.92); font-size: 12px; font-weight: 500;
    padding: 8px 18px; border-radius: 100px;
    transition: all .25s;
  }
  .r7-chip:hover { background: rgba(26,188,156,.2); border-color: var(--teal); }
  .r7-chip-icon { font-size: 14px; }

  /* floating price card */
  .r7-price-float {
    position: absolute; top: 100px; right: 60px; z-index: 20;
    animation: floatY 4s ease-in-out infinite, fadeIn .8s .4s ease both;
  }
  .r7-price-card {
    background: rgba(255,255,255,.1);
    border: 1px solid rgba(255,255,255,.25);
    backdrop-filter: blur(20px);
    border-radius: 24px; padding: 24px 28px;
    text-align: center; min-width: 150px;
    position: relative; overflow: hidden;
  }
  .r7-price-card::before {
    content: ''; position: absolute;
    width: 200px; height: 200px; border-radius: 50%;
    background: radial-gradient(circle, rgba(243,156,18,.25), transparent 70%);
    top: -60px; left: -40px; pointer-events: none;
  }
  .r7-price-amount { font-family: 'Syne', sans-serif; font-size: 2.2rem; font-weight: 800; color: var(--yellow); line-height: 1; }
  .r7-price-currency { font-size: 1rem; color: rgba(255,255,255,.7); font-weight: 500; }
  .r7-price-lbl { font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,.5); margin-top: 6px; }

  /* wave divider */
  .r7-wave { position: absolute; bottom: -2px; left: 0; width: 100%; z-index: 5; pointer-events: none; }

  /* scroll indicator */
  .r7-scroll-hint {
    position: absolute; bottom: 100px; left: 50%; transform: translateX(-50%);
    z-index: 10; display: flex; flex-direction: column; align-items: center; gap: 6px;
    animation: fadeIn 1s 1.2s ease both;
  }
  .r7-scroll-hint span { font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: rgba(255,255,255,.45); }
  .r7-scroll-arrow { width: 24px; height: 40px; border: 1.5px solid rgba(255,255,255,.3); border-radius: 12px; display: flex; justify-content: center; padding-top: 7px; }
  .r7-scroll-dot { width: 4px; height: 8px; background: var(--teal); border-radius: 2px; animation: floatY 1.5s ease-in-out infinite; }

  /* ─── Flash messages ─── */
  .r7-alerts { max-width: 1200px; margin: 0 auto; padding: 20px 60px 0; }
  .r7-alert {
    display: flex; align-items: center; gap: 10px;
    padding: 14px 20px; border-radius: 14px; font-size: 13px; font-weight: 600;
    animation: fadeUp .5s ease both; margin-bottom: 10px;
  }
  .r7-alert-ok  { background: #d1fae5; color: #065f46; border: 1px solid #a7f3d0; }
  .r7-alert-err { background: #fee2e2; color: #991b1b; border: 1px solid #fca5a5; }

  /* ─── Main layout ─── */
  .r7-layout {
    display: grid; grid-template-columns: 1fr 420px;
    gap: 48px; max-width: 1200px;
    margin: 0 auto; padding: 56px 60px 120px;
  }

  /* ─── Section labels ─── */
  .r7-eyebrow {
    font-size: 9px; font-weight: 700; letter-spacing: 3px;
    text-transform: uppercase; color: var(--teal);
    margin-bottom: 6px;
  }
  .r7-section-title {
    font-family: 'Syne', sans-serif; font-size: 1.9rem; font-weight: 800;
    color: var(--dark); margin-bottom: 28px; line-height: 1.15;
  }

  /* ─── About card ─── */
  .r7-about {
    position: relative; border-radius: 24px; overflow: hidden;
    background: var(--card-bg); margin-bottom: 32px;
    border: 1.5px solid rgba(26,188,156,.12);
    animation: slideRight .7s .1s ease both;
  }
  .r7-about-accent {
    position: absolute; top: 0; left: 0; width: 100%; height: 4px;
    background: linear-gradient(90deg, var(--teal), var(--orange), var(--yellow));
  }
  .r7-about-body { padding: 28px 28px 28px; }
  .r7-about p { color: #556672; line-height: 1.85; font-size: 15px; }
  .r7-about-deco {
    position: absolute; bottom: -20px; right: -20px;
    width: 120px; height: 120px; border-radius: 50%;
    background: radial-gradient(circle, rgba(26,188,156,.06), transparent 70%);
    pointer-events: none;
  }

  /* ─── Stats grid ─── */
  .r7-stats {
    display: grid; grid-template-columns: repeat(3,1fr);
    gap: 16px; margin-bottom: 36px;
    animation: fadeUp .7s .25s ease both;
  }
  .r7-stat {
    background: var(--card-bg);
    border: 1.5px solid rgba(44,62,80,.07);
    border-radius: 20px; padding: 20px 16px 18px;
    text-align: center; cursor: default;
    transition: transform .3s, box-shadow .3s, border-color .3s;
    position: relative; overflow: hidden;
  }
  .r7-stat::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
    background: var(--accent, var(--teal));
    transform: scaleX(0); transform-origin: center;
    transition: transform .3s;
  }
  .r7-stat:hover { transform: translateY(-6px); box-shadow: 0 16px 40px rgba(0,0,0,.08); border-color: transparent; }
  .r7-stat:hover::after { transform: scaleX(1); }
  .r7-stat-icon {
    width: 44px; height: 44px; border-radius: 14px;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 12px;
  }
  .r7-stat-num { font-family: 'Syne', sans-serif; font-size: 1.4rem; font-weight: 800; color: var(--dark); animation: countUp .5s ease both; }
  .r7-stat-lbl { font-size: 10px; font-weight: 600; letter-spacing: .5px; color: var(--text-muted); margin-top: 3px; text-transform: uppercase; }

  /* ─── Weather block ─── */
  .r7-weather {
    background: linear-gradient(135deg, var(--dark) 0%, #1e2e40 100%);
    border-radius: 24px; padding: 28px; margin-bottom: 32px;
    position: relative; overflow: hidden;
    animation: slideRight .7s .35s ease both;
  }
  .r7-weather::before {
    content: ''; position: absolute; top: -80px; right: -80px;
    width: 260px; height: 260px; border-radius: 50%;
    background: radial-gradient(circle, rgba(26,188,156,.15), transparent 70%);
    pointer-events: none;
  }
  .r7-weather-lbl { font-size: 9px; letter-spacing: 2.5px; text-transform: uppercase; color: rgba(255,255,255,.4); margin-bottom: 14px; }
  .r7-weather-main { display: flex; align-items: center; gap: 16px; margin-bottom: 20px; }
  .r7-weather-icon { width: 68px; height: 68px; }
  .r7-weather-temp { font-family: 'Syne', sans-serif; font-size: 3.2rem; font-weight: 800; color: white; line-height: 1; }
  .r7-weather-desc { font-size: 13px; color: rgba(255,255,255,.55); margin-top: 4px; text-transform: capitalize; }
  .r7-weather-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 0; }
  .r7-weather-item { text-align: center; padding: 12px 0; border-top: 1px solid rgba(255,255,255,.06); }
  .r7-weather-item:not(:last-child) { border-right: 1px solid rgba(255,255,255,.06); }
  .r7-weather-val { font-size: 15px; font-weight: 700; color: white; }
  .r7-weather-key { font-size: 9px; letter-spacing: 1px; text-transform: uppercase; color: rgba(255,255,255,.35); margin-top: 3px; }

  /* ─── Map ─── */
  #r7-map { height: 280px; border-radius: 20px; overflow: hidden; margin-bottom: 32px; }

  /* ─── Separator ─── */
  .r7-sep {
    height: 1px; margin: 36px 0;
    background: linear-gradient(90deg, transparent, rgba(26,188,156,.25), rgba(243,156,18,.25), transparent);
  }

  /* ─── Back btn ─── */
  .r7-back {
    display: inline-flex; align-items: center; gap: 10px;
    color: var(--dark); font-size: 13px; font-weight: 600;
    text-decoration: none; padding: 11px 22px;
    border: 1.5px solid rgba(44,62,80,.18); border-radius: 100px;
    transition: all .25s;
  }
  .r7-back:hover { background: var(--dark); color: white; border-color: var(--dark); transform: translateX(-4px); }

  /* ─── Sticky panel ─── */
  .r7-sticky { position: sticky; top: 90px; animation: slideLeft .7s .1s ease both; }

  /* Panel card */
  .r7-panel {
    background: var(--card-bg);
    border: 1.5px solid rgba(44,62,80,.07);
    border-radius: 28px; padding: 32px;
    box-shadow: 0 24px 80px rgba(0,0,0,.07);
    position: relative; overflow: hidden;
  }
  .r7-panel::before {
    content: ''; position: absolute; top: -100px; right: -100px;
    width: 280px; height: 280px; border-radius: 50%;
    background: radial-gradient(circle, rgba(26,188,156,.05), transparent 70%);
    pointer-events: none;
  }
  .r7-panel-glow {
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--orange), var(--yellow), var(--teal));
    border-radius: 28px 28px 0 0;
  }
  .r7-panel-h { font-family: 'Syne', sans-serif; font-size: 1.2rem; font-weight: 800; color: var(--dark); margin-bottom: 4px; }
  .r7-panel-sub { font-size: 12px; color: var(--text-muted); margin-bottom: 24px; }

  /* ─── Planning card ─── */
  .r7-pcard {
    background: #f8fbfa;
    border: 1.5px solid rgba(44,62,80,.07);
    border-radius: 20px; padding: 20px;
    margin-bottom: 16px; position: relative; overflow: hidden;
    transition: transform .3s cubic-bezier(.23,1,.32,1), box-shadow .3s, border-color .3s;
    animation: fadeUp .5s ease both;
  }
  .r7-pcard::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: linear-gradient(180deg, var(--teal), var(--orange));
    border-radius: 3px 0 0 3px;
  }
  .r7-pcard:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(26,188,156,.12); border-color: rgba(26,188,156,.25); }

  .r7-pcard-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16px; }
  .r7-pcard-date { font-family: 'Syne', sans-serif; font-size: 1.1rem; font-weight: 800; color: var(--dark); }
  .r7-pcard-time { font-size: 11px; color: var(--text-muted); margin-top: 3px; display: flex; align-items: center; gap: 5px; }

  /* seats badge */
  .r7-seats {
    font-size: 10px; font-weight: 700; padding: 5px 12px; border-radius: 100px;
    letter-spacing: .3px; white-space: nowrap;
  }
  .r7-seats-ok   { background: #d1fae5; color: #065f46; }
  .r7-seats-warn { background: #fef3c7; color: #92400e; }
  .r7-seats-low  { background: #fee2e2; color: #991b1b; }

  /* seats progress */
  .r7-progress { height: 4px; background: rgba(44,62,80,.07); border-radius: 4px; overflow: hidden; margin-bottom: 14px; }
  .r7-progress-bar {
    height: 100%; border-radius: 4px;
    background: linear-gradient(90deg, var(--teal), var(--orange));
    width: var(--pct, 60%);
    animation: progressFill .8s ease both;
  }

  /* Inputs */
  .r7-field {
    width: 100%; padding: 11px 15px;
    border: 1.5px solid rgba(44,62,80,.12);
    border-radius: 12px; font-family: inherit; font-size: 13px;
    color: var(--dark); background: white; outline: none;
    transition: border-color .2s, box-shadow .2s;
    margin-bottom: 10px; display: block;
  }
  .r7-field:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(26,188,156,.1); }

  /* Reserve button */
  .r7-btn {
    width: 100%; padding: 15px;
    background: linear-gradient(135deg, var(--orange) 0%, #e67e22 50%, var(--orange) 100%);
    background-size: 200% 200%;
    color: white; font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px;
    letter-spacing: .5px; border: none; border-radius: 100px; cursor: pointer;
    position: relative; overflow: hidden;
    transition: transform .25s, box-shadow .25s;
  }
  .r7-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 36px rgba(243,156,18,.45);
    animation: shimmer 2s linear infinite;
  }
  .r7-btn:active { transform: scale(.97); }
  .r7-btn:disabled { background: #c8d0d8; cursor: not-allowed; box-shadow: none; transform: none; animation: none; }
  .r7-btn-ripple { position: absolute; border-radius: 50%; background: rgba(255,255,255,.3); width: 16px; height: 16px; pointer-events: none; animation: rippleOut .6s linear; }

  /* Trust row */
  .r7-trust { display: flex; gap: 18px; flex-wrap: wrap; margin-top: 18px; padding-top: 18px; border-top: 1px solid rgba(44,62,80,.06); }
  .r7-trust-item { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--text-muted); }

  /* Total price calculator */
  .r7-total-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px dashed rgba(44,62,80,.08); font-size: 13px; color: var(--text-muted); }
  .r7-total-final { display: flex; justify-content: space-between; align-items: center; padding-top: 12px; }
  .r7-total-final .lbl { font-weight: 700; color: var(--dark); font-size: 14px; }
  .r7-total-final .val { font-family: 'Syne', sans-serif; font-size: 1.4rem; font-weight: 800; color: var(--orange); }

  /* ─── Empty state ─── */
  .r7-empty { text-align: center; padding: 44px 20px; }
  .r7-empty-icon { font-size: 2.8rem; display: block; margin-bottom: 14px; animation: floatY 3s ease-in-out infinite; }
  .r7-empty-title { font-family: 'Syne', sans-serif; font-size: 1rem; font-weight: 800; color: var(--dark); margin-bottom: 6px; }
  .r7-empty-sub { font-size: 12px; color: var(--text-muted); }

  /* ─── Responsive ─── */
  @media (max-width: 960px) {
    .r7-layout { grid-template-columns: 1fr; padding: 36px 24px 80px; gap: 36px; }
    .r7-hero-content { padding: 0 24px 60px; }
    .r7-price-float { display: none; }
    .r7-sticky { position: relative; top: auto; }
    .r7-alerts { padding: 16px 24px 0; }
    .r7-stats { grid-template-columns: repeat(3,1fr); }
  }
  @media (max-width: 600px) {
    .r7-hero-title { font-size: 2.2rem; }
    .r7-stats { grid-template-columns: 1fr 1fr; }
    .r7-weather-grid { grid-template-columns: repeat(3,1fr); }
  }
</style>
{% endblock %}

{% block body %}

{# ── Ticker bar ── #}
<div class="r7-ticker" aria-hidden="true">
  <div class="r7-ticker-inner">
    {% for i in 1..6 %}
    <span class="r7-ticker-item">{{ activite.nomA }}</span>
    <span class="r7-ticker-item">{{ activite.lieu }}</span>
    <span class="r7-ticker-item">{{ activite.prixParPersonne|number_format(0) }} DT / pers.</span>
    <span class="r7-ticker-item">{{ activite.capaciteMax }} places</span>
    {% endfor %}
  </div>
</div>

{# ── HERO ── #}
<section class="r7-hero">

  {% if activite.image %}
    <img class="r7-hero-img"
         src="{{ asset('uploads/activites/' ~ activite.image) }}"
         alt="{{ activite.nomA }}">
  {% else %}
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,#1e2e40,#2C3E50 50%,#0f1f2e);"></div>
  {% endif %}

  <div class="r7-hero-grad"></div>
  <div class="r7-scanline"></div>
  <div class="r7-orb r7-orb-1"></div>
  <div class="r7-orb r7-orb-2"></div>
  <div class="r7-orb r7-orb-3"></div>

  {# Floating price #}
  <div class="r7-price-float">
    <div class="r7-price-card">
      <div class="r7-price-amount">{{ activite.prixParPersonne|number_format(0) }}</div>
      <div class="r7-price-currency">DT</div>
      <div class="r7-price-lbl">par personne</div>
    </div>
  </div>

  <div class="r7-hero-content">
    <div class="r7-hero-eyebrow">
      <span class="r7-live-dot"></span>
      Activité disponible
    </div>
    <h1 class="r7-hero-title">
      {{ activite.nomA|split(' ')|first }}
      <span>{% for w in activite.nomA|split(' ')|slice(1) %}{{ w }} {% endfor %}</span>
    </h1>
    <div class="r7-hero-chips">
      <div class="r7-chip"><span class="r7-chip-icon">📍</span> {{ activite.lieu }}</div>
      <div class="r7-chip"><span class="r7-chip-icon">👥</span> {{ activite.capaciteMax }} pers. max</div>
      <div class="r7-chip"><span class="r7-chip-icon">💰</span> {{ activite.prixParPersonne|number_format(0) }} DT / pers.</div>
    </div>
  </div>

  <div class="r7-scroll-hint">
    <div class="r7-scroll-arrow"><div class="r7-scroll-dot"></div></div>
    <span>Découvrir</span>
  </div>

  <svg class="r7-wave" viewBox="0 0 1440 90" preserveAspectRatio="none" style="height:60px;">
    <path d="M0,45 C360,90 720,0 1080,45 C1260,68 1360,50 1440,45 L1440,90 L0,90 Z" fill="#FAFAFA"/>
    <path d="M0,60 C320,20 640,80 960,50 C1120,35 1300,65 1440,55 L1440,90 L0,90 Z" fill="rgba(26,188,156,0.08)"/>
  </svg>
</section>

{# ── Alerts ── #}
<div class="r7-alerts">
  {% for msg in app.flashes('success') %}
    <div class="r7-alert r7-alert-ok">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#065f46" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-5"/></svg>
      {{ msg }}
    </div>
  {% endfor %}
  {% for msg in app.flashes('error') %}
    <div class="r7-alert r7-alert-err">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#991b1b" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/></svg>
      {{ msg }}
    </div>
  {% endfor %}
</div>

{# ── Layout ── #}
<div class="r7-layout">

  {# ═══════════════ LEFT COLUMN ═══════════════ #}
  <div>

    <div class="r7-eyebrow">L'activité</div>
    <h2 class="r7-section-title">À propos</h2>

    {# About #}
    <div class="r7-about">
      <div class="r7-about-accent"></div>
      <div class="r7-about-body">
        <p>{{ activite.descriptionA }}</p>
      </div>
      <div class="r7-about-deco"></div>
    </div>

    {# Stats #}
    <div class="r7-stats">
      <div class="r7-stat" style="--accent:var(--teal)">
        <div class="r7-stat-icon" style="background:rgba(26,188,156,.1);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1ABC9C" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <div class="r7-stat-num">{{ activite.capaciteMax }}</div>
        <div class="r7-stat-lbl">Places max</div>
      </div>
      <div class="r7-stat" style="--accent:var(--orange)">
        <div class="r7-stat-icon" style="background:rgba(243,156,18,.1);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F39C12" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <div class="r7-stat-num">{{ activite.prixParPersonne|number_format(0) }}</div>
        <div class="r7-stat-lbl">DT / pers.</div>
      </div>
      <div class="r7-stat" style="--accent:var(--dark)">
        <div class="r7-stat-icon" style="background:rgba(44,62,80,.07);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2C3E50" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div class="r7-stat-num" style="font-size:.9rem;">{{ activite.lieu|slice(0,8) }}</div>
        <div class="r7-stat-lbl">Lieu</div>
      </div>
    </div>

    {# Weather #}
    {% if meteo %}
    <div class="r7-weather">
      <div class="r7-weather-lbl">☁ Météo à {{ meteo.ville }}</div>
      <div class="r7-weather-main">
        <img class="r7-weather-icon" src="{{ meteo.icone_url }}" alt="météo">
        <div>
          <div class="r7-weather-temp">{{ meteo.temperature }}°</div>
          <div class="r7-weather-desc">{{ meteo.description }}</div>
        </div>
      </div>
      <div class="r7-weather-grid">
        <div class="r7-weather-item">
          <div class="r7-weather-val" style="color:#e74c3c;">{{ meteo.ressenti }}°C</div>
          <div class="r7-weather-key">Ressenti</div>
        </div>
        <div class="r7-weather-item">
          <div class="r7-weather-val" style="color:#1ABC9C;">{{ meteo.humidite }}%</div>
          <div class="r7-weather-key">Humidité</div>
        </div>
        <div class="r7-weather-item">
          <div class="r7-weather-val">{{ meteo.vent }} <small style="font-size:10px;">km/h</small></div>
          <div class="r7-weather-key">Vent</div>
        </div>
      </div>
    </div>
    {% endif %}

    {# Map #}
    {% if coords %}
    <div id="r7-map"></div>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        var map = L.map('r7-map', { zoomControl: false }).setView([{{ coords.lat }}, {{ coords.lon }}], 13);
        L.control.zoom({ position: 'bottomright' }).addTo(map);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '© OpenStreetMap' }).addTo(map);
        var icon = L.divIcon({
          html: '<div style="background:linear-gradient(135deg,#F39C12,#1ABC9C);width:36px;height:36px;border-radius:50% 50% 50% 0;transform:rotate(-45deg);border:3px solid white;box-shadow:0 4px 16px rgba(0,0,0,.3);"></div>',
          iconSize:[36,36], iconAnchor:[18,36], className:''
        });
        L.marker([{{ coords.lat }}, {{ coords.lon }}], { icon: icon })
          .addTo(map).bindPopup('<strong>{{ activite.nomA }}</strong><br>{{ activite.lieu }}').openPopup();
      });
    </script>
    {% endif %}

    <div class="r7-sep"></div>
    <a href="{{ path('activite_index_front') }}" class="r7-back">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Retour aux activités
    </a>

  </div>

  {# ═══════════════ RIGHT PANEL ═══════════════ #}
  <div class="r7-sticky">
    <div class="r7-panel">
      <div class="r7-panel-glow"></div>

      <div style="display:flex;align-items:center;gap:10px;margin-bottom:4px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1ABC9C" stroke-width="2.5"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        <div class="r7-panel-h">Plannings disponibles</div>
      </div>
      <div class="r7-panel-sub">Choisissez une date et réservez votre place</div>

      {% set plannings_dispo = activite.plannings|filter(p => p.etat == 'Disponible' and p.nbPlacesRestantes > 0) %}

      {% if plannings_dispo|length > 0 %}
        {% for planning in plannings_dispo %}
          {% set pct = ((activite.capaciteMax - planning.nbPlacesRestantes) / activite.capaciteMax * 100)|round %}
          <div class="r7-pcard" style="animation-delay:{{ loop.index * 0.08 }}s;">

            <div class="r7-pcard-top">
              <div>
                <div class="r7-pcard-date">{{ planning.datePlanning|date('d MMM Y') }}</div>
                <div class="r7-pcard-time">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                  {{ planning.heureDebut }} — {{ planning.heureFin }}
                </div>
              </div>
              <span class="r7-seats {% if planning.nbPlacesRestantes > 10 %}r7-seats-ok{% elseif planning.nbPlacesRestantes > 3 %}r7-seats-warn{% else %}r7-seats-low{% endif %}">
                {{ planning.nbPlacesRestantes }} place{% if planning.nbPlacesRestantes > 1 %}s{% endif %}
              </span>
            </div>

            <div class="r7-progress">
              <div class="r7-progress-bar" style="--pct:{{ pct }}%;"></div>
            </div>

            {# Price summary #}
            <div style="margin-bottom:14px;">
              <div class="r7-total-row">
                <span>Prix unitaire</span><span>{{ activite.prixParPersonne|number_format(0) }} DT</span>
              </div>
              <div class="r7-total-final">
                <span class="lbl">Total (1 pers.)</span>
                <span class="val">{{ activite.prixParPersonne|number_format(0) }} DT</span>
              </div>
            </div>

            <form method="post" action="{{ path('planning_reserver', {id: planning.id}) }}"
                  onsubmit="return confirm('Confirmer la réservation pour le {{ planning.datePlanning|date('d/m/Y') }} ?');">
              <input type="hidden" name="_token" value="{{ csrf_token('reserver_' ~ planning.id) }}">
              <input type="hidden" name="id_activite" value="{{ activite.idActivite }}">

              {% if not app.user %}
              <input type="text"  name="nom_client"   placeholder="Votre nom complet *" required class="r7-field">
              <input type="email" name="email_client"  placeholder="Votre adresse email *" required class="r7-field">
              {% endif %}

              <button type="submit" class="r7-btn">
                ✓ &nbsp;Réserver — {{ activite.prixParPersonne|number_format(0) }} DT
              </button>
            </form>

          </div>
        {% endfor %}

      {% else %}
        <div class="r7-empty">
          <span class="r7-empty-icon">📅</span>
          <div class="r7-empty-title">Aucun planning pour l'instant</div>
          <div class="r7-empty-sub">Revenez prochainement, de nouvelles dates arrivent !</div>
        </div>
      {% endif %}

      {# Trust signals #}
      <div class="r7-trust">
        <div class="r7-trust-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#1ABC9C" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Paiement sécurisé
        </div>
        <div class="r7-trust-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#1ABC9C" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
          Annulation gratuite
        </div>
        <div class="r7-trust-item">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#1ABC9C" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
          Confirmation rapide
        </div>
      </div>

    </div>
  </div>

</div>

{# ── Ripple JS ── #}
<script>
  document.querySelectorAll('.r7-btn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      var rect = this.getBoundingClientRect();
      var rip = document.createElement('span');
      rip.className = 'r7-btn-ripple';
      rip.style.left = (e.clientX - rect.left - 8) + 'px';
      rip.style.top  = (e.clientY - rect.top  - 8) + 'px';
      this.appendChild(rip);
      setTimeout(function() { rip.remove(); }, 600);
    });
  });

  // Parallax hero image
  var heroImg = document.querySelector('.r7-hero-img');
  if (heroImg) {
    window.addEventListener('scroll', function() {
      heroImg.style.transform = 'scale(1.06) translateY(' + (window.scrollY * 0.15) + 'px)';
    }, { passive: true });
  }
</script>

{% endblock %}
