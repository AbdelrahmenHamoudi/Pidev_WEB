{% extends 'base.html.twig' %}
{% block title %}RE7LA — Visite Virtuelle {{ lieu }}{% endblock %}

{% block body %}

{# ── Variables langue ── #}
{% set isAr = langue == 'arabe' %}
{% set dir  = isAr ? 'rtl' : 'ltr' %}

{# ══════════════════════════════════════════════
   ÉCRAN DE CHARGEMENT
══════════════════════════════════════════════ #}
<div id="loading" style="min-height:100vh;display:flex;align-items:center;
     justify-content:center;flex-direction:column;gap:20px;direction:{{ dir }};">
    <div style="font-size:60px;">🎬</div>
    <h2 style="font-weight:800;color:var(--dark);">
        {{ isAr ? 'جارٍ التحضير...' : 'Génération en cours...' }}
    </h2>
    <p style="color:#888;">
        {% if isAr %}
            ذكاؤنا الاصطناعي يُعدّ جولتك في <strong>{{ lieu }}</strong>
        {% else %}
            Notre IA prépare votre visite de <strong>{{ lieu }}</strong>
        {% endif %}
    </p>
    <div class="spinner-border" style="color:var(--bleu-ceil);width:48px;height:48px;" role="status"></div>
</div>

{# ══════════════════════════════════════════════
   CONTENU DE LA VISITE
══════════════════════════════════════════════ #}
<div id="tour" style="display:none;direction:{{ dir }};">

    {# ── Sélecteur de langue ── #}
    <div style="position:fixed;top:80px;{{ isAr ? 'left' : 'right' }}:20px;z-index:999;
                display:flex;gap:8px;background:rgba(255,255,255,0.95);
                padding:8px;border-radius:50px;box-shadow:0 4px 20px rgba(0,0,0,0.1);">
        <a href="{{ path('virtual_tour_generer', {lieu: lieu}) }}?langue=français"
           style="padding:6px 14px;border-radius:50px;text-decoration:none;font-size:13px;font-weight:600;
                  background:{{ not isAr ? 'var(--bleu-ceil)' : 'transparent' }};
                  color:{{ not isAr ? '#fff' : '#888' }};">
            FR
        </a>
        <a href="{{ path('virtual_tour_generer', {lieu: lieu}) }}?langue=arabe"
           style="padding:6px 14px;border-radius:50px;text-decoration:none;font-size:13px;font-weight:600;
                  background:{{ isAr ? 'var(--bleu-ceil)' : 'transparent' }};
                  color:{{ isAr ? '#fff' : '#888' }};">
            ع
        </a>
    </div>

    {# ── Diaporama photos ── #}
    <section style="padding:80px 0 40px;">
        <div class="container">
            <h1 style="text-align:center;font-size:2.2rem;font-weight:800;
                       margin-bottom:24px;color:var(--dark);">
                {{ isAr ? '🗺 جولة افتراضية في' : '🗺 Visite virtuelle —' }}
                <span style="color:var(--bleu-ceil);">{{ lieu }}</span>
            </h1>

            <div id="slideshow" style="position:relative;border-radius:24px;overflow:hidden;
                 height:480px;background:#000;box-shadow:0 20px 60px rgba(0,0,0,0.2);">

                <div id="slides" style="display:flex;transition:transform 0.6s ease;height:100%;"></div>

                <button onclick="changerSlide(-1)"
                    style="position:absolute;{{ isAr ? 'right' : 'left' }}:20px;top:50%;
                           transform:translateY(-50%);background:rgba(0,0,0,0.6);color:#fff;
                           border:none;width:50px;height:50px;border-radius:50%;
                           font-size:20px;cursor:pointer;z-index:10;">
                    {{ isAr ? '▶' : '◀' }}
                </button>
                <button onclick="changerSlide(1)"
                    style="position:absolute;{{ isAr ? 'left' : 'right' }}:20px;top:50%;
                           transform:translateY(-50%);background:rgba(0,0,0,0.6);color:#fff;
                           border:none;width:50px;height:50px;border-radius:50%;
                           font-size:20px;cursor:pointer;z-index:10;">
                    {{ isAr ? '◀' : '▶' }}
                </button>

                <div id="counter"
                    style="position:absolute;top:16px;{{ isAr ? 'left' : 'right' }}:16px;
                           background:rgba(0,0,0,0.7);color:#fff;
                           padding:6px 14px;border-radius:20px;font-size:14px;font-weight:600;">
                    1/6
                </div>
            </div>
        </div>
    </section>

    {# ── Narration + Audio ── #}
    <section style="padding:0 0 40px;">
        <div class="container" style="max-width:800px;">

            {# Lecteur audio #}
            <div id="audioWrapper" style="background:linear-gradient(135deg,var(--bleu-ceil),var(--vert-pistache));
                        border-radius:20px;padding:24px;margin-bottom:24px;color:#fff;">
                <h5 style="font-weight:700;margin-bottom:16px;">
                    🎧 {{ isAr ? 'التعليق الصوتي' : 'Narration Audio' }}
                </h5>

                {# Spinner pendant la génération audio #}
                <div id="audioLoading" style="display:flex;align-items:center;gap:12px;padding:10px 0;">
                    <div class="spinner-border spinner-border-sm" style="color:#fff;" role="status"></div>
                    <span style="font-size:14px;opacity:0.85;">
                        {{ isAr ? 'جارٍ تحضير الصوت...' : 'Audio en cours de génération…' }}
                    </span>
                </div>

                {# Lecteur audio (caché jusqu'à ce que l'audio soit prêt) #}
                <audio id="audioPlayer" controls style="width:100%;border-radius:10px;display:none;">
                    {{ isAr ? 'متصفحك لا يدعم الصوت.' : 'Votre navigateur ne supporte pas l\'audio.' }}
                </audio>
            </div>

            {# Texte narration #}
            <div style="background:#fff;border-radius:20px;padding:28px;
                        box-shadow:0 4px 20px rgba(0,0,0,0.07);
                        border-{{ isAr ? 'right' : 'left' }}:4px solid var(--bleu-ceil);
                        {{ isAr ? 'border-radius:20px 0 0 20px;' : '' }}">
                <h5 style="font-weight:700;color:var(--dark);margin-bottom:12px;
                           {{ isAr ? 'text-align:right;' : '' }}">
                    {{ isAr ? 'التعليق السياحي' : 'Narration' }}
                </h5>
                <p id="narration"
                   style="color:#555;line-height:2;font-size:15px;
                          {{ isAr ? 'text-align:right;font-family:\"Amiri\",serif;font-size:17px;' : '' }}">
                </p>
            </div>
        </div>
    </section>

    {# ── Quiz culturel ── #}
    <section style="padding:0 0 40px;">
        <div class="container" style="max-width:800px;">
            <div style="background:#fff;border-radius:20px;padding:28px;
                        box-shadow:0 4px 20px rgba(0,0,0,0.07);">
                <h5 style="font-weight:700;color:var(--dark);margin-bottom:20px;
                           {{ isAr ? 'text-align:right;' : '' }}">
                    🧠 {{ isAr ? 'اختبر معلوماتك' : 'Quiz culturel' }}
                </h5>

                <div id="quizContainer">
                    <div style="text-align:center;color:#aaa;padding:20px;">
                        {{ isAr ? 'جارٍ تحميل الأسئلة...' : 'Chargement des questions...' }}
                    </div>
                </div>

                <div id="quizScore" style="display:none;text-align:center;margin-top:16px;
                     padding:16px;background:#f0fff8;border-radius:12px;
                     color:#1D9E75;font-weight:700;font-size:18px;">
                </div>
            </div>
        </div>
    </section>

    {# ── Partage social ── #}
    <section style="padding:0 0 80px;">
        <div class="container" style="max-width:800px;">
            <div style="background:#fff;border-radius:20px;padding:24px;
                        box-shadow:0 4px 20px rgba(0,0,0,0.07);text-align:center;">
                <h5 style="font-weight:700;color:var(--dark);margin-bottom:16px;">
                    📤 {{ isAr ? 'شارك الجولة' : 'Partager cette visite' }}
                </h5>
                <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">

                    {# WhatsApp #}
                    <a id="shareWhatsapp" href="#" target="_blank"
                       style="display:inline-flex;align-items:center;gap:8px;
                              padding:10px 20px;border-radius:50px;text-decoration:none;
                              background:#25D366;color:#fff;font-weight:600;font-size:14px;">
                        📱 WhatsApp
                    </a>

                    {# Facebook #}
                    <a id="shareFacebook" href="#" target="_blank"
                       style="display:inline-flex;align-items:center;gap:8px;
                              padding:10px 20px;border-radius:50px;text-decoration:none;
                              background:#1877F2;color:#fff;font-weight:600;font-size:14px;">
                        📘 Facebook
                    </a>

                    {# Copier le lien #}
                    <button onclick="copierLien()"
                       style="display:inline-flex;align-items:center;gap:8px;
                              padding:10px 20px;border-radius:50px;border:2px solid #ddd;
                              background:#fff;color:#555;font-weight:600;font-size:14px;cursor:pointer;">
                        🔗 <span id="copyLabel">{{ isAr ? 'نسخ الرابط' : 'Copier le lien' }}</span>
                    </button>

                </div>
            </div>
        </div>
    </section>

</div>{# fin #tour #}

{# ── Police arabe (chargée uniquement si nécessaire) ── #}
{% if isAr %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&display=swap" rel="stylesheet">
{% endif %}

<script>
const LIEU   = "{{ lieu|e('js') }}";
const LANGUE = "{{ langue|e('js') }}";
const IS_AR  = {{ isAr ? 'true' : 'false' }};

let indexActuel = 0;
let photos = [];
let quizData = [];
let reponsesUtilisateur = [];

// ── 1. Charger la visite (photos + narration) ─────────────────────────────
fetch(`/visite-virtuelle/api/${encodeURIComponent(LIEU)}?langue=${LANGUE}`)
    .then(r => r.json())
    .then(data => {
        if (!data.success) throw new Error('Erreur API');

        photos = data.photos;

        // Construire les slides
        const slidesEl = document.getElementById('slides');
        photos.forEach((url, i) => {
            const slide = document.createElement('div');
            slide.style.cssText = 'min-width:100%;height:100%;';
            slide.innerHTML = `<img src="${url}"
                style="width:100%;height:100%;object-fit:cover;"
                onerror="this.src='https://via.placeholder.com/1200x480?text=Photo+${i+1}'">`;
            slidesEl.appendChild(slide);
        });

        majCompteur();

        // Narration
        document.getElementById('narration').textContent = data.narration;

        // Partage
        const pageUrl      = encodeURIComponent(window.location.href);
        const textePartage = IS_AR
            ? encodeURIComponent(`اكتشف ${LIEU} مع RE7LA — جولة افتراضية`)
            : encodeURIComponent(`Découvrez ${LIEU} avec RE7LA — Visite Virtuelle`);

        document.getElementById('shareWhatsapp').href =
            `https://wa.me/?text=${textePartage}%20${pageUrl}`;
        document.getElementById('shareFacebook').href =
            `https://www.facebook.com/sharer/sharer.php?u=${pageUrl}`;

        // Afficher la page
        document.getElementById('loading').style.display = 'none';
        document.getElementById('tour').style.display    = 'block';

        // Auto-play diaporama toutes les 5s
        setInterval(() => changerSlide(1), 5000);

        // Lancer l'audio et le quiz en parallèle (asynchrones)
        chargerAudio();
        chargerQuiz();
    })
    .catch(() => {
        document.getElementById('loading').innerHTML =
            `<p style="color:red;font-size:18px;padding:20px;">
                ${IS_AR ? 'خطأ في التحميل. أعد المحاولة.' : 'Erreur de génération. Veuillez réessayer.'}
             </p>`;
    });

// ── 2. Charger l'audio séparément (évite le timeout 30s) ─────────────────
function chargerAudio() {
    fetch(`/visite-virtuelle/api/audio/${encodeURIComponent(LIEU)}?langue=${LANGUE}`)
        .then(r => r.json())
        .then(data => {
            const loadingEl = document.getElementById('audioLoading');
            const playerEl  = document.getElementById('audioPlayer');

            if (data.success && data.audio) {
                playerEl.src = data.audio;
                playerEl.style.display = 'block';
                if (loadingEl) loadingEl.style.display = 'none';
            } else {
                // Audio indisponible — afficher un message discret
                if (loadingEl) {
                    loadingEl.innerHTML = `<span style="font-size:13px;opacity:0.7;">
                        ${IS_AR ? 'الصوت غير متاح حالياً.' : 'Audio temporairement indisponible.'}
                    </span>`;
                }
            }
        })
        .catch(() => {
            const loadingEl = document.getElementById('audioLoading');
            if (loadingEl) {
                loadingEl.innerHTML = `<span style="font-size:13px;opacity:0.7;">
                    ${IS_AR ? 'تعذّر تحميل الصوت.' : 'Impossible de charger l\'audio.'}
                </span>`;
            }
        });
}

// ── 3. Navigation diaporama ───────────────────────────────────────────────
function changerSlide(direction) {
    if (photos.length === 0) return;
    indexActuel = (indexActuel + direction + photos.length) % photos.length;
    document.getElementById('slides').style.transform =
        `translateX(-${indexActuel * 100}%)`;
    majCompteur();
}

function majCompteur() {
    document.getElementById('counter').textContent =
        `${indexActuel + 1}/${Math.max(photos.length, 1)}`;
}

// ── 4. Quiz culturel ──────────────────────────────────────────────────────
function chargerQuiz() {
    fetch(`/visite-virtuelle/api/quiz/${encodeURIComponent(LIEU)}?langue=${LANGUE}`)
        .then(r => r.json())
        .then(data => {
            if (!data.success || !data.quiz.length) return;
            quizData = data.quiz;
            reponsesUtilisateur = new Array(quizData.length).fill(null);
            afficherQuiz();
        })
        .catch(() => {
            document.getElementById('quizContainer').innerHTML =
                `<p style="color:#aaa;text-align:center;padding:20px;">
                    ${IS_AR ? 'تعذّر تحميل الأسئلة.' : 'Quiz indisponible.'}
                 </p>`;
        });
}

function afficherQuiz() {
    const container = document.getElementById('quizContainer');
    container.innerHTML = '';

    quizData.forEach((q, qi) => {
        const div = document.createElement('div');
        div.style.cssText = 'margin-bottom:20px;padding:16px;background:#f8f9fa;border-radius:12px;';

        const questionDiv = document.createElement('p');
        questionDiv.style.cssText = `font-weight:700;margin-bottom:12px;color:#333;
            ${IS_AR ? 'text-align:right;font-family:Amiri,serif;font-size:17px;' : ''}`;
        questionDiv.textContent = `${qi + 1}. ${q.question}`;
        div.appendChild(questionDiv);

        const optsGrid = document.createElement('div');
        optsGrid.style.cssText = 'display:grid;grid-template-columns:1fr 1fr;gap:8px;';

        q.options.forEach((opt, oi) => {
            const btn = document.createElement('button');
            btn.style.cssText = `padding:10px 14px;border-radius:10px;border:2px solid #dee2e6;
                background:#fff;cursor:pointer;font-size:14px;text-align:${IS_AR ? 'right' : 'left'};
                ${IS_AR ? 'font-family:Amiri,serif;' : ''}transition:all 0.2s;`;
            btn.textContent    = opt;
            btn.dataset.qi     = qi;
            btn.dataset.oi     = oi;
            btn.onclick        = () => repondre(qi, oi);
            optsGrid.appendChild(btn);
        });

        div.appendChild(optsGrid);
        container.appendChild(div);
    });

    // Bouton valider
    const btnValider = document.createElement('button');
    btnValider.id        = 'btnValider';
    btnValider.textContent = IS_AR ? 'تحقق من إجاباتي ✓' : 'Valider mes réponses ✓';
    btnValider.style.cssText = `display:block;margin:16px auto 0;padding:12px 32px;
        border-radius:50px;border:none;background:var(--bleu-ceil);color:#fff;
        font-weight:700;font-size:15px;cursor:pointer;`;
    btnValider.onclick = validerQuiz;
    container.appendChild(btnValider);
}

function repondre(qi, oi) {
    reponsesUtilisateur[qi] = oi;

    const allBtns = document.querySelectorAll(`[data-qi="${qi}"]`);
    allBtns.forEach(b => {
        b.style.borderColor = '#dee2e6';
        b.style.background  = '#fff';
        b.style.color       = '#333';
    });

    const selected = document.querySelector(`[data-qi="${qi}"][data-oi="${oi}"]`);
    if (selected) {
        selected.style.borderColor = 'var(--bleu-ceil)';
        selected.style.background  = '#e8f4fd';
        selected.style.color       = '#185FA5';
    }
}

function validerQuiz() {
    let score = 0;

    quizData.forEach((q, qi) => {
        const reponseUser = reponsesUtilisateur[qi];
        const allBtns     = document.querySelectorAll(`[data-qi="${qi}"]`);

        allBtns.forEach(b => {
            b.onclick = null; // Désactiver les clics
            const oi  = parseInt(b.dataset.oi);

            if (oi === q.correct) {
                b.style.borderColor = '#1D9E75';
                b.style.background  = '#d4edda';
                b.style.color       = '#0F6E56';
            } else if (oi === reponseUser) {
                b.style.borderColor = '#dc3545';
                b.style.background  = '#f8d7da';
                b.style.color       = '#721c24';
            }
        });

        if (reponseUser === q.correct) score++;
    });

    const btn = document.getElementById('btnValider');
    if (btn) btn.style.display = 'none';

    const scoreEl = document.getElementById('quizScore');
    const total   = quizData.length;
    const emoji   = score === total ? '🏆' : score >= total / 2 ? '⭐' : '💪';

    scoreEl.innerHTML = IS_AR
        ? `${emoji} نتيجتك: <strong>${score} / ${total}</strong>`
        : `${emoji} Score : <strong>${score} / ${total}</strong>`;
    scoreEl.style.display = 'block';
}

// ── 5. Copier le lien ─────────────────────────────────────────────────────
function copierLien() {
    navigator.clipboard.writeText(window.location.href).then(() => {
        const label = document.getElementById('copyLabel');
        label.textContent = IS_AR ? 'تم النسخ ✓' : 'Copié ✓';
        setTimeout(() => {
            label.textContent = IS_AR ? 'نسخ الرابط' : 'Copier le lien';
        }, 2000);
    });
}
</script>
{% endblock %}