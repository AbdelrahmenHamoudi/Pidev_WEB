{% extends 'base.html.twig' %}

{% block title %}RE7LA — Activités{% endblock %}

{% block extra_styles %}
.activite-card { border-radius:20px; overflow:hidden; box-shadow:0 8px 30px rgba(0,0,0,0.1);
    transition:all 0.3s ease; background:#fff; }
.activite-card:hover { transform:translateY(-8px); box-shadow:0 20px 50px rgba(0,0,0,0.15); }
.activite-card img { width:100%; height:220px; object-fit:cover; }
.activite-card .card-body { padding:20px; }
.badge-type { padding:5px 14px; border-radius:20px; font-size:12px; font-weight:600;
    background:rgba(135,206,235,0.15); color:var(--bleu-ceil-dark); }
.btn-voir { background:linear-gradient(135deg,var(--bleu-ceil),var(--vert-pistache));
    color:#fff; border:none; padding:10px 24px; border-radius:50px; font-weight:600;
    font-size:14px; text-decoration:none; display:inline-block; transition:all 0.3s; }
.btn-voir:hover { transform:translateY(-2px); color:#fff;
    box-shadow:0 8px 20px rgba(135,206,235,0.4); }
{% endblock %}

{% block body %}

<section style="padding:140px 0 80px;background:linear-gradient(135deg,rgba(135,206,235,0.08),rgba(147,197,114,0.08));">
    <div class="container text-center">
        <h1 class="hero-title" data-aos="fade-up">
            Nos <span class="gradient-text">Activités</span>
        </h1>
        <p class="hero-subtitle" data-aos="fade-up" data-aos-delay="100">
            Découvrez des expériences uniques en Tunisie
        </p>
    </div>
</section>

<section style="padding:60px 0 100px;">
    <div class="container">
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for activite in activites %}
            <div class="col" data-aos="fade-up" data-aos-delay="{{ loop.index0 * 80 }}">
                <div class="activite-card h-100">
                    {% if activite.image %}
                        <img src="{{ asset('uploads/activites/' ~ activite.image) }}" alt="{{ activite.nomA }}">
                    {% else %}
                        <div style="height:220px;background:linear-gradient(135deg,var(--bleu-ceil),var(--vert-pistache));
                                    display:flex;align-items:center;justify-content:center;">
                            <i class="fas fa-hiking" style="font-size:60px;color:rgba(255,255,255,0.8);"></i>
                        </div>
                    {% endif %}

                    <div class="card-body">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
                            <span class="badge-type">{{ activite.lieu }}</span>
                            <span style="font-weight:700;font-size:18px;color:var(--bleu-ceil-dark);">
                                {{ activite.prixParPersonne|number_format(0) }} DT
                            </span>
                        </div>

                        <h5 style="font-weight:700;color:var(--dark);margin-bottom:8px;">{{ activite.nomA }}</h5>

                        <p style="color:#666;font-size:13px;line-height:1.6;margin-bottom:12px;">
                            {{ activite.descriptionA|slice(0,100) }}{% if activite.descriptionA|length > 100 %}...{% endif %}
                        </p>

                        <div style="display:flex;align-items:center;gap:6px;margin-bottom:16px;font-size:13px;color:#888;">
                            <i class="fas fa-map-marker-alt" style="color:var(--rouge);"></i>
                            {{ activite.lieu }}
                            <span style="margin-left:auto;font-size:12px;">
                                <i class="fas fa-users" style="color:var(--vert-pistache);"></i>
                                {{ activite.capaciteMax }} pers.
                            </span>
                        </div>

                        <div style="display:flex;justify-content:space-between;align-items:center;">
                            <span style="font-size:12px;font-weight:600;color:#065f46;background:#d1fae5;padding:3px 10px;border-radius:20px;">
                                Disponible
                            </span>
                            <a href="{{ path('activite_show_front', {id: activite.idActivite}) }}"
                               class="btn-voir">
                                Voir <i class="fas fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="col-12 text-center" style="padding:60px 0;">
                <i class="fas fa-search" style="font-size:50px;color:#ccc;margin-bottom:16px;display:block;"></i>
                <p style="color:#888;font-size:16px;">Aucune activité disponible pour le moment.</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{% endblock %}