{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}RE7LA — Activités{% endblock %}

{% block extra_styles %}
/* ── Activités card styles ──────────────────────────────── */
.activite-card { border-radius:20px; overflow:hidden; box-shadow:0 8px 30px rgba(0,0,0,0.1);
    transition:all 0.3s ease; background:#fff; }
.activite-card:hover { transform:translateY(-8px); box-shadow:0 20px 50px rgba(0,0,0,0.15); }
.activite-card img { width:100%; height:220px; object-fit:cover; }
.activite-card .card-body { padding:20px; }
.badge-type { padding:5px 14px; border-radius:20px; font-size:12px; font-weight:600;
    background:rgba(26,188,156,0.15); color:#1ABC9C; }
.btn-voir { background: var(--rouge);
    color:#fff; border:none; padding:10px 24px; border-radius:50px; font-weight: 700;
    font-size:14px; text-decoration:none; display:inline-block; transition:all 0.3s;
    box-shadow: 0 4px 15px rgba(243, 156, 18, 0.2); }
.btn-voir:hover { transform:translateY(-2px); color:#fff;
    box-shadow:0 8px 20px rgba(26,188,156,0.4); }

/* ── Hero (mirror of Trajets hero) ──────────────────────── */
.activites-hero {
    background: linear-gradient(135deg, #0f172a 0%, var(--dark) 100%);
    padding: 60px 0 40px; /* Taille réduite comme Hebergement */
    position: relative;
    overflow: hidden;
    color: white;
}
.activites-hero::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; bottom: 0;
    background: url('https://images.unsplash.com/photo-1501854140801-50d01698950b?w=1600') center/cover;
    opacity: 0.12; /* Plus discret comme Hebergement */
    mix-blend-mode: overlay;
}

/* Floating shapes */
.act-shape {
    position: absolute; border-radius: 50%; opacity: 0.10;
    animation: actFloat 18s infinite ease-in-out;
}
.act-shape-1 { width: 300px; height: 300px; background: #1ABC9C; top: -100px; right: -80px; }
.act-shape-2 { width: 180px; height: 180px; background: #F39C12; bottom: -50px; left: -40px; animation-delay: -8s; }

@keyframes actFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    33%       { transform: translateY(-20px) rotate(5deg); }
    66%       { transform: translateY(10px) rotate(-5deg); }
}

/* Moving hikers animation */
.hiker-container {
    position: absolute; bottom: 10px; left: 0;
    width: 100%; height: 50px;
    pointer-events: none; z-index: 1;
}
.hero-hiker {
    position: absolute;
    color: rgba(255,255,255,0.25);
    font-size: 18px;
    animation: hikeRight linear infinite;
}
.hiker-1 { bottom: 5px;  animation-duration: 18s; animation-delay: 0s; }
.hiker-2 { bottom: 25px; animation-duration: 24s; animation-delay: -6s; font-size: 14px; opacity: 0.15; }
.hiker-3 { bottom: 40px; animation-duration: 20s; animation-delay: -12s; font-size: 22px; }

@keyframes hikeRight {
    from { transform: translateX(-100px); }
    to   { transform: translateX(calc(100vw + 100px)); }
}
{% endblock %}

{% block body %}

<section class="activites-hero">
    {# Animated walking hikers at the bottom #}
    <div class="hiker-container">
        <div class="hero-hiker hiker-1"><i class="fas fa-hiking"></i></div>
        <div class="hero-hiker hiker-2"><i class="fas fa-person-walking"></i></div>
        <div class="hero-hiker hiker-3"><i class="fas fa-person-biking"></i></div>
        <div class="hero-hiker hiker-1" style="animation-delay:-9s;"><i class="fas fa-swimmer"></i></div>
    </div>
    {# Floating glowing circles #}
    <div class="act-shape act-shape-1"></div>
    <div class="act-shape act-shape-2"></div>

    <div class="container position-relative" style="z-index:2;">
        <div class="row align-items-center">
            {# Left: text + CTA #}
            <div class="col-lg-7" data-aos="fade-right">
                <span style="background: var(--rouge); color:white; padding:8px 20px; border-radius:50px; font-size:13px; font-weight:600; display:inline-block; margin-bottom:20px;">
                    <i class="fas fa-hiking me-2"></i>Activités &amp; Expériences
                </span>
                <h1 style="font-weight:800;font-size:3rem;color:white;line-height:1.2;margin-bottom:16px;">
                    Nos <span style="color: var(--bleu-ceil);">Activités</span>
                </h1>
                <p style="color:rgba(255,255,255,0.7);font-size:1.1rem;margin-bottom:32px;">
                    Découvrez des expériences uniques en Tunisie
                </p>

            </div>
            {# Right: big hiking icon #}
            <div class="col-lg-5 d-none d-lg-flex justify-content-center" data-aos="fade-left">
                <div style="width:200px;height:200px;background:linear-gradient(135deg,rgba(26,188,156,0.2),rgba(243,156,18,0.2));border-radius:50%;display:flex;align-items:center;justify-content:center;">
                    <i class="fas fa-hiking" style="font-size:5.5rem;background:linear-gradient(135deg,#1ABC9C,#F39C12);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;"></i>
                </div>
            </div>
        </div>
    </div>
</section>

<section style="padding:60px 0 100px;">
    <div class="container">
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for activite in activites %}
            <div class="col" data-aos="fade-up" data-aos-delay="{{ loop.index0 * 80 }}">
                <div class="activite-card h-100">
                    {% if activite.image %}
                        <img src="{{ asset('uploads/activites/' ~ activite.image) }}" alt="{{ activite.nomA }}">
                    {% else %}
                        <div style="height:220px;background:linear-gradient(135deg,var(--bleu-ceil),var(--vert-pistache));
                                    display:flex;align-items:center;justify-content:center;">
                            <i class="fas fa-hiking" style="font-size:60px;color:rgba(255,255,255,0.8);"></i>
                        </div>
                    {% endif %}

                    <div class="card-body">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
                            <span class="badge-type">{{ activite.lieu }}</span>
                            <span style="font-weight:700;font-size:18px;color:var(--bleu-ceil-dark);">
                                {{ activite.prixParPersonne|number_format(0) }} DT
                            </span>
                        </div>

                        <h5 style="font-weight:700;color:var(--dark);margin-bottom:8px;">{{ activite.nomA }}</h5>

                        <p style="color:#666;font-size:13px;line-height:1.6;margin-bottom:12px;">
                            {{ activite.descriptionA|slice(0,100) }}{% if activite.descriptionA|length > 100 %}...{% endif %}
                        </p>

                        <div style="display:flex;align-items:center;gap:6px;margin-bottom:16px;font-size:13px;color:#888;">
                            <i class="fas fa-map-marker-alt" style="color:var(--rouge);"></i>
                            {{ activite.lieu }}
                            <span style="margin-left:auto;font-size:12px;">
                                <i class="fas fa-users" style="color:var(--vert-pistache);"></i>
                                {{ activite.capaciteMax }} pers.
                            </span>
                        </div>

                        <div style="display:flex;justify-content:space-between;align-items:center;">
                            <span style="font-size:12px;font-weight:600;color:#065f46;background:#d1fae5;padding:3px 10px;border-radius:20px;">
                                Disponible
                            </span>
                            <a href="{{ path('activite_show_front', {id: activite.idActivite}) }}"
                               class="btn-voir">
                                Voir <i class="fas fa-arrow-right"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="col-12 text-center" style="padding:60px 0;">
                <i class="fas fa-search" style="font-size:50px;color:#ccc;margin-bottom:16px;display:block;"></i>
                <p style="color:#888;font-size:16px;">Aucune activité disponible pour le moment.</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{% endblock %}