{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}RE7LA — Activités{% endblock %}

{% block extra_styles %}
.activite-card { border-radius:20px; overflow:hidden; box-shadow:0 8px 30px rgba(0,0,0,0.1);
    transition:all 0.3s ease; background:#fff; }
.activite-card:hover { transform:translateY(-8px); box-shadow:0 20px 50px rgba(0,0,0,0.15); }
.activite-card img { width:100%; height:220px; object-fit:cover; }
.activite-card .card-body { padding:20px; }
.badge-type { padding:5px 14px; border-radius:20px; font-size:12px; font-weight:600;
    background:rgba(135,206,235,0.15); color:var(--bleu-ceil-dark); }
.btn-voir { background:linear-gradient(135deg,var(--bleu-ceil),var(--vert-pistache));
    color:#fff; border:none; padding:10px 24px; border-radius:50px; font-weight:600;
    font-size:14px; text-decoration:none; display:inline-block; transition:all 0.3s; }
.btn-voir:hover { transform:translateY(-2px); color:#fff;
    box-shadow:0 8px 20px rgba(135,206,235,0.4); }

/* Design Premium & Glassmorphism */
@keyframes blob-bounce {
    0% { transform: translate(0, 0) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0, 0) scale(1); }
}
@keyframes shimmer-premium {
    0% { background-position: -200% center; }
    100% { background-position: 200% center; }
}

.hero-section-premium {
    position: relative;
    overflow: hidden;
    padding: 180px 0 140px;
    background-color: #f8fafc;
}

.blob {
    position: absolute;
    filter: blur(80px);
    z-index: 0;
    opacity: 0.6;
    border-radius: 50%;
    animation: blob-bounce 15s infinite alternate cubic-bezier(0.4, 0, 0.2, 1);
}
.blob-1 { top: -10%; left: -10%; width: 500px; height: 500px; background: #00bcd4; animation-delay: 0s; }
.blob-2 { top: 10%; right: -10%; width: 550px; height: 550px; background: #e91e63; animation-delay: -5s; }
.blob-3 { bottom: -20%; left: 20%; width: 600px; height: 600px; background: #ffeb3b; animation-delay: -10s; }

.relative-container {
    position: relative;
    z-index: 10;
}

.hero-content-glass {
    position: relative;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 40px;
    padding: 70px 40px;
    max-width: 850px;
    margin: 0 auto;
    box-shadow: 0 30px 60px rgba(0,0,0,0.08), inset 0 0 0 1px rgba(255,255,255,0.5);
}

.hero-title-premium {
    font-size: 4.5rem;
    font-weight: 900;
    margin-bottom: 25px;
    color: #1e293b;
    letter-spacing: -1.5px;
}

.gradient-text-premium {
    background: linear-gradient(135deg, #00bcd4, #4caf50, #e91e63, #ff9800);
    background-size: 300% 300%;
    color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
    animation: shimmer-premium 6s ease infinite;
    display: inline-block;
}

.hero-subtitle-premium {
    font-size: 1.3rem;
    color: #475569;
    font-weight: 500;
    max-width: 650px;
    margin: 0 auto;
    line-height: 1.6;
}

.glass-icon {
    position: absolute;
    background: rgba(255,255,255,0.7);
    backdrop-filter: blur(8px);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 15px 35px rgba(0,0,0,0.1);
    border: 1px solid rgba(255,255,255,0.8);
}
.g-icon-1 { top: -30px; left: -30px; width: 100px; height: 100px; font-size: 40px; color: #00bcd4; animation: blob-bounce 8s infinite alternate; }
.g-icon-2 { bottom: -40px; right: -20px; width: 120px; height: 120px; font-size: 50px; color: #ff9800; animation: blob-bounce 10s infinite alternate-reverse; }
.g-icon-3 { top: 40%; right: -50px; width: 80px; height: 80px; font-size: 30px; color: #e91e63; animation: blob-bounce 12s infinite alternate; }
{% endblock %}

{% block body %}

<section class="hero-section-premium">
    <!-- Formes floues colorées en arrière-plan (Mesh Gradient) -->
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>

    <div class="container relative-container text-center">
        <div class="hero-content-glass" data-aos="zoom-in" data-aos-duration="1000">
            <!-- Icônes en verre flottantes aux coins -->
            <div class="glass-icon g-icon-1"><i class="fas fa-hiking"></i></div>
            <div class="glass-icon g-icon-2"><i class="fas fa-sun"></i></div>
            <div class="glass-icon g-icon-3"><i class="fas fa-camera"></i></div>
            
            <h1 class="hero-title-premium">
                Nos <span class="gradient-text-premium">Activités</span>
            </h1>
            <p class="hero-subtitle-premium" data-aos="fade-up" data-aos-delay="200">
                Découvrez des expériences uniques en Tunisie, prêtes à vous faire voyager !
            </p>
        </div>
    </div>
</section>

<section style="padding:60px 0 100px;">
    <div class="container">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-lg-3 mb-4">
                <div class="sidebar p-4 sticky-top" style="background: #fff; border-radius: 20px; box-shadow: 0 8px 30px rgba(0,0,0,0.05); top: 100px; z-index: 10;">
                    <h4 style="font-weight: 700; color: var(--dark); margin-bottom: 20px; font-size: 1.2rem;">Filtres de recherche</h4>
                    
                    <form action="{{ path('activite_index_front') }}" method="GET" class="mb-4">
                        <div class="mb-3">
                            <label for="search_nom" class="form-label" style="font-size: 13px; font-weight: 600; color: #555;">Nom de l'activité</label>
                            <div class="input-group" style="box-shadow: 0 4px 10px rgba(0,0,0,0.03); border-radius: 10px; overflow: hidden;">
                                <span class="input-group-text" style="background: #f8f9fa; border: 1px solid #e9ecef; border-right: none;"><i class="fas fa-search" style="color: #aaa;"></i></span>
                                <input type="text" name="nom" id="search_nom" class="form-control" placeholder="Ex: Randonnée..." style="background: #f8f9fa; border: 1px solid #e9ecef; border-left: none; box-shadow: none;" value="{{ app.request.query.get('nom') }}">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="search_lieu" class="form-label" style="font-size: 13px; font-weight: 600; color: #555;">Lieu</label>
                            <div class="input-group" style="box-shadow: 0 4px 10px rgba(0,0,0,0.03); border-radius: 10px; overflow: hidden;">
                                <span class="input-group-text" style="background: #f8f9fa; border: 1px solid #e9ecef; border-right: none;"><i class="fas fa-map-marker-alt" style="color: #aaa;"></i></span>
                                <input type="text" name="lieu" id="search_lieu" class="form-control" placeholder="Où aller ?" style="background: #f8f9fa; border: 1px solid #e9ecef; border-left: none; box-shadow: none;" value="{{ app.request.query.get('lieu') }}">
                            </div>
                        </div>

                        <button type="submit" class="btn w-100" style="background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache)); color: #fff; border-radius: 50px; font-weight: 600; padding: 10px 15px; border: none; box-shadow: 0 4px 15px rgba(135,206,235,0.3); transition: transform 0.3s;">
                            <i class="fas fa-filter me-1"></i> Filtrer
                        </button>
                    </form>

                    <hr style="border-color: #eee; margin: 25px 0;">

                    <a href="{{ path('mes_reservations_activite') }}" class="btn w-100 d-flex align-items-center justify-content-center btn-mes-reservations" style="background: rgba(135,206,235,0.1); color: var(--bleu-ceil-dark); border-radius: 50px; font-weight: 600; padding: 12px; text-decoration: none; transition: all 0.3s; border: 1px solid rgba(135,206,235,0.2);">
                        <i class="fas fa-calendar-check me-2" style="font-size: 1.1rem;"></i> Mes réservations
                    </a>
                </div>
            </div>

            <!-- Activités Grid -->
            <div class="col-lg-9">
                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    {% for activite in activites %}
                    <div class="col" data-aos="fade-up" data-aos-delay="{{ loop.index0 * 80 }}">
                        <div class="activite-card h-100">
                            {% if activite.image %}
                                <img src="{{ asset('uploads/activites/' ~ activite.image) }}" alt="{{ activite.nomA }}">
                            {% else %}
                                <div style="height:220px;background:linear-gradient(135deg,var(--bleu-ceil),var(--vert-pistache));
                                            display:flex;align-items:center;justify-content:center;">
                                    <i class="fas fa-hiking" style="font-size:60px;color:rgba(255,255,255,0.8);"></i>
                                </div>
                            {% endif %}

                            <div class="card-body">
                                <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;">
                                    <span class="badge-type">{{ activite.lieu }}</span>
                                    <span style="font-weight:700;font-size:18px;color:var(--bleu-ceil-dark);">
                                        {{ activite.prixParPersonne|number_format(0) }} DT
                                    </span>
                                </div>

                                <h5 style="font-weight:700;color:var(--dark);margin-bottom:8px;">{{ activite.nomA }}</h5>

                                <p style="color:#666;font-size:13px;line-height:1.6;margin-bottom:12px;">
                                    {{ activite.descriptionA|slice(0,100) }}{% if activite.descriptionA|length > 100 %}...{% endif %}
                                </p>

                                <div style="display:flex;align-items:center;gap:6px;margin-bottom:16px;font-size:13px;color:#888;">
                                    <i class="fas fa-map-marker-alt" style="color:var(--rouge);"></i>
                                    {{ activite.lieu }}
                                    <span style="margin-left:auto;font-size:12px;">
                                        <i class="fas fa-users" style="color:var(--vert-pistache);"></i>
                                        {{ activite.capaciteMax }} pers.
                                    </span>
                                </div>

                                <div style="display:flex;justify-content:space-between;align-items:center;">
                                    <span style="font-size:12px;font-weight:600;color:#065f46;background:#d1fae5;padding:3px 10px;border-radius:20px;">
                                        Disponible
                                    </span>
                                    <a href="{{ path('activite_show_front', {id: activite.idActivite}) }}"
                                       class="btn-voir">
                                        Voir <i class="fas fa-arrow-right"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% else %}
                    <div class="col-12 text-center" style="padding:60px 0;">
                        <i class="fas fa-search" style="font-size:50px;color:#ccc;margin-bottom:16px;display:block;"></i>
                        <p style="color:#888;font-size:16px;">Aucune activité disponible pour le moment.</p>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>

<style>
.btn-mes-reservations:hover {
    background: rgba(135,206,235,0.25) !important;
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(135,206,235,0.2);
}
</style>

{% endblock %}