{% extends 'base.html.twig' %}

{% block title %}RE7LA — Mes Réservations{% endblock %}

{% block extra_styles %}
.reservation-card {
    background: #fff;
    border-radius: 16px;
    padding: 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    border-left: 4px solid var(--bleu-ceil);
    margin-bottom: 16px;
    transition: all 0.3s;
}
.reservation-card:hover { transform: translateY(-3px); box-shadow: 0 8px 30px rgba(0,0,0,0.1); }
.reservation-card.annulee { border-left-color: #ccc; opacity: 0.7; }
.badge-statut {
    padding: 4px 14px; border-radius: 20px;
    font-size: 12px; font-weight: 600;
}
.badge-confirmee { background: #d1fae5; color: #065f46; }
.badge-annulee   { background: #fee2e2; color: #991b1b; }
.badge-attente   { background: #fef3c7; color: #92400e; }
{% endblock %}

{% block body %}
<section style="padding: 60px 0 100px;">
    <div class="container">

        <div style="margin-bottom: 36px;" data-aos="fade-up">
            <h2 style="font-weight: 800; color: var(--dark); font-size: 2rem;">
                <i class="fas fa-calendar-check" style="color: var(--bleu-ceil); margin-right: 10px;"></i>
                Mes Réservations
            </h2>
            <p style="color: #888; margin-top: 6px;">
                {{ reservations|length }} réservation(s) trouvée(s)
            </p>
        </div>

        {% if reservations|length == 0 %}
            <div style="text-align: center; padding: 80px 20px; background: #fff;
                        border-radius: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.06);">
                <i class="fas fa-calendar-times" style="font-size: 60px; color: #ccc; display: block; margin-bottom: 16px;"></i>
                <h4 style="color: #888; font-weight: 600;">Aucune réservation pour le moment</h4>
                <a href="{{ path('activite_index_front') }}"
                   style="display: inline-block; margin-top: 20px; background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache));
                          color: #fff; padding: 12px 28px; border-radius: 50px; text-decoration: none; font-weight: 600;">
                    Découvrir les activités
                </a>
            </div>
        {% else %}
            {% for reservation in reservations %}
            <div class="reservation-card {{ reservation.statut == 'Annulee' ? 'annulee' : '' }}"
                 data-aos="fade-up" data-aos-delay="{{ loop.index0 * 80 }}">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 16px;">

                    {# ── Infos activité ── #}
                    <div style="flex: 1;">
                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 10px;">
                            <span class="badge-statut badge-{{ reservation.statut|lower|replace({'é': 'e', 'è': 'e'}) }}">
                                {{ reservation.statut }}
                            </span>
                            <span style="font-size: 12px; color: #888;">
                                Réservé le {{ reservation.dateReservation|date('d/m/Y à H:i') }}
                            </span>
                        </div>

                        <h5 style="font-weight: 700; color: var(--dark); margin-bottom: 8px; font-size: 1.1rem;">
                            {{ reservation.planning.activite.nomA }}
                        </h5>

                        <div style="display: flex; gap: 20px; flex-wrap: wrap; font-size: 13px; color: #666;">
                            <span>
                                <i class="fas fa-calendar" style="color: var(--bleu-ceil); margin-right: 5px;"></i>
                                {{ reservation.planning.datePlanning|date('d/m/Y') }}
                            </span>
                            <span>
                                <i class="fas fa-clock" style="color: var(--vert-pistache); margin-right: 5px;"></i>
                                {{ reservation.planning.heureDebut }} — {{ reservation.planning.heureFin }}
                            </span>
                            <span>
                                <i class="fas fa-map-marker-alt" style="color: var(--rouge); margin-right: 5px;"></i>
                                {{ reservation.planning.activite.lieu }}
                            </span>
                            <span>
                                <i class="fas fa-tag" style="color: var(--bleu-ceil); margin-right: 5px;"></i>
                                {{ reservation.planning.activite.prixParPersonne|number_format(0) }} DT
                            </span>
                        </div>
                    </div>

                    {# ── Actions ── #}
                    <div style="display: flex; flex-direction: column; gap: 8px; align-items: flex-end;">
                        <a href="{{ path('activite_show_front', {id: reservation.planning.activite.idActivite}) }}"
                           style="background: #f0f2f5; color: var(--dark); padding: 8px 16px;
                                  border-radius: 10px; font-size: 13px; font-weight: 600;
                                  text-decoration: none;">
                            <i class="fas fa-eye"></i> Voir l'activité
                        </a>

                        {% if reservation.statut != 'Annulee' %}
                        <form method="post"
                              action="{{ path('reservation_activite_annuler', {id: reservation.id}) }}"
                              onsubmit="return confirm('Annuler cette réservation ?');">
                            <input type="hidden" name="_token"
                                   value="{{ csrf_token('annuler_reservation_' ~ reservation.id) }}">
                            <button type="submit"
                                    style="background: #fee2e2; color: #991b1b; padding: 8px 16px;
                                           border-radius: 10px; font-size: 13px; font-weight: 600;
                                           border: none; cursor: pointer; width: 100%;">
                                <i class="fas fa-times"></i> Annuler
                            </button>
                        </form>
                        {% endif %}
                    </div>

                </div>
            </div>
            {% endfor %}
        {% endif %}

    </div>
</section>
{% endblock %}
