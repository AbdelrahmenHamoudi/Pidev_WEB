{% extends 'backend/baseend.html.twig' %}

{% block title %}Publication #{{ publication.idPublication }} — RE7LA{% endblock %}

{% block body %}
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap');
.show-wrap { font-family: 'DM Sans', sans-serif; }
.show-topbar { display:flex; align-items:center; gap:12px; margin-bottom:24px; flex-wrap:wrap; }
.btn-back { display:inline-flex; align-items:center; gap:6px; background:#fff; border:1.5px solid #edf0f7; border-radius:10px; padding:8px 16px; font-size:13px; font-weight:600; color:#64748b; text-decoration:none; transition:all .2s; }
.btn-back:hover { background:#f8f9fc; color:#1a1d23; border-color:#F7B731; }
.show-title { font-family:'Peter Bold',sans-serif; font-size:22px; font-weight:800; color:#1a1d23; margin:0; }
.show-grid { display:grid; grid-template-columns:1fr 340px; gap:20px; align-items:start; }
.show-card { background:#fff; border-radius:18px; border:1.5px solid #edf0f7; box-shadow:0 4px 20px rgba(0,0,0,0.06); overflow:hidden; }
.show-card-header { padding:16px 22px; border-bottom:1.5px solid #f0f4fb; font-family:'Peter Bold',sans-serif; font-size:13px; font-weight:700; color:#1a1d23; display:flex; align-items:center; gap:8px; background:#fafbfc; }
.show-card-body { padding:22px; }

.pub-cover { width:100%; max-height:300px; object-fit:cover; border-radius:14px; margin-bottom:22px; box-shadow:0 4px 20px rgba(0,0,0,0.1); display:block; }
.pub-cover-ph { width:100%; height:180px; border-radius:14px; background:linear-gradient(135deg,#f8f9fc,#edf0f7); display:flex; align-items:center; justify-content:center; font-size:48px; margin-bottom:22px; color:#c8d0e0; }

.info-grid { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
.info-item label { font-size:10px; font-weight:700; letter-spacing:1px; text-transform:uppercase; color:#94a3b8; display:block; margin-bottom:4px; }
.info-item .info-val { font-size:14px; font-weight:500; color:#1a1d23; }
.info-desc { grid-column:1 / -1; }

.type-badge { display:inline-flex; align-items:center; gap:4px; padding:5px 12px; border-radius:9px; font-size:12px; font-weight:700; }
.type-HEBERGEMENT{background:#d1fae5;color:#065f46;} .type-ACTIVITE{background:#dbeafe;color:#1e40af;} .type-TRANSPORT{background:#fef3c7;color:#92400e;}
.statut-badge { display:inline-flex; align-items:center; gap:5px; padding:5px 13px; border-radius:20px; font-size:12px; font-weight:700; }
.statut-badge::before{content:'';width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.s-VALIDE{background:#d1fae5;color:#065f46;} .s-VALIDE::before{background:#10b981;}
.s-EN_ATTENTE{background:#fef3c7;color:#92400e;} .s-EN_ATTENTE::before{background:#f59e0b;}
.s-REFUSE{background:#fee2e2;color:#991b1b;} .s-REFUSE::before{background:#ef4444;}
.verifie-yes{display:inline-flex;align-items:center;gap:4px;background:#d1fae5;color:#065f46;padding:5px 12px;border-radius:20px;font-size:12px;font-weight:700;}
.verifie-no {display:inline-flex;align-items:center;gap:4px;background:#f1f5f9;color:#64748b;padding:5px 12px;border-radius:20px;font-size:12px;font-weight:700;}

.show-actions { display:flex; gap:10px; margin-top:22px; flex-wrap:wrap; }
.btn-edit-pub { display:inline-flex; align-items:center; gap:7px; background:linear-gradient(135deg,#F7B731,#e09d10); color:#1a1d23; border:none; border-radius:12px; padding:11px 22px; font-weight:700; font-size:13px; text-decoration:none; transition:all .2s; box-shadow:0 4px 14px rgba(247,183,49,.35); }
.btn-edit-pub:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(247,183,49,.45); color:#1a1d23; }
.btn-comments-pub { display:inline-flex; align-items:center; gap:7px; background:#eff6ff; color:#1d4ed8; border:1.5px solid #bfdbfe; border-radius:12px; padding:11px 22px; font-weight:600; font-size:13px; text-decoration:none; transition:all .2s; }
.btn-comments-pub:hover { background:#dbeafe; color:#1d4ed8; }

.comment-item { padding:14px 0; border-bottom:1px solid #f0f4fb; }
.comment-item:last-child { border-bottom:none; }
.comment-author { display:flex; align-items:center; gap:8px; margin-bottom:6px; }
.comment-avatar { width:28px; height:28px; border-radius:50%; background:linear-gradient(135deg,#F7B731,#e09d10); display:flex; align-items:center; justify-content:center; font-size:10px; font-weight:700; color:#1a1d23; flex-shrink:0; }
.comment-author-name { font-size:12px; font-weight:600; color:#1a1d23; }
.comment-date { font-size:11px; color:#94a3b8; margin-left:auto; }
.comment-text { font-size:13px; color:#64748b; line-height:1.5; }
.comment-status { display:inline-block; font-size:10px; font-weight:700; padding:2px 8px; border-radius:6px; margin-top:5px; }
.cs-active{background:#d1fae5;color:#065f46;} .cs-inactive{background:#f1f5f9;color:#64748b;}
.no-comments { text-align:center; padding:30px 16px; color:#94a3b8; font-size:13px; }

@media(max-width:900px){ .show-grid{grid-template-columns:1fr;} .info-grid{grid-template-columns:1fr;} }
</style>

<div class="show-wrap">

  <div class="show-topbar">
    <a href="{{ path('app_admin_publication_index') }}" class="btn-back">← Retour</a>
    <h1 class="show-title">📄 Publication #{{ publication.idPublication }}</h1>
  </div>

  <div class="show-grid">

    <div class="show-card">
      <div class="show-card-header">📋 Détails de la publication</div>
      <div class="show-card-body">

        {% if publication.imgURL %}
          <img src="{{ asset('uploads/publications/' ~ publication.imgURL) }}" alt="image" class="pub-cover">
        {% else %}
          <div class="pub-cover-ph">🖼</div>
        {% endif %}

        <div class="info-grid">
          <div class="info-item info-desc">
            <label>Description</label>
            <div class="info-val" style="line-height:1.6">{{ publication.descriptionP }}</div>
          </div>
          <div class="info-item">
            <label>Type cible</label>
            <div><span class="type-badge type-{{ publication.typeCible }}">{{ publication.typeCible }}</span></div>
          </div>
          <div class="info-item">
            <label>Statut</label>
            <div><span class="statut-badge s-{{ publication.statutP }}">{{ publication.statutP }}</span></div>
          </div>
          <div class="info-item">
            <label>Vérification</label>
            <div>
              {% if publication.estVerifie %}<span class="verifie-yes">✔ Vérifiée</span>
              {% else %}<span class="verifie-no">✗ Non vérifiée</span>{% endif %}
            </div>
          </div>
          <div class="info-item">
            <label>Auteur</label>
            <div class="info-val">
              {% if publication.id_utilisateur %}{{ publication.id_utilisateur.nom }} {{ publication.id_utilisateur.prenom }}
              {% else %}—{% endif %}
            </div>
          </div>
          <div class="info-item">
            <label>Créée le</label>
            <div class="info-val">{{ publication.dateCreation }}</div>
          </div>
          <div class="info-item">
            <label>Modifiée le</label>
            <div class="info-val">{{ publication.dateModif }}</div>
          </div>
        </div>

        <div class="show-actions">
          <a href="{{ path('app_admin_publication_edit', {idPublication: publication.idPublication}) }}" class="btn-edit-pub">✏️ Modifier</a>
          <a href="{{ path('app_admin_publication_commentaires', {idPublication: publication.idPublication}) }}" class="btn-comments-pub">💬 Voir les commentaires</a>
        </div>

      </div>
    </div>

    <div class="show-card">
      <div class="show-card-header">
        💬 Commentaires
        <span style="margin-left:auto;background:#eff6ff;color:#1d4ed8;font-size:11px;padding:2px 9px;border-radius:10px;font-weight:700;">
          {{ publication.commentaires|length }}
        </span>
      </div>
      <div class="show-card-body" style="padding:0 16px;">
        {% if publication.commentaires is empty %}
          <div class="no-comments">💬 Aucun commentaire pour cette publication.</div>
        {% else %}
          {% for c in publication.commentaires %}
            <div class="comment-item">
              <div class="comment-author">
                <div class="comment-avatar">
                  {% if c.id_utilisateur %}{{ c.id_utilisateur.nom|slice(0,1)|upper }}{{ c.id_utilisateur.prenom|slice(0,1)|upper }}{% else %}?{% endif %}
                </div>
                <span class="comment-author-name">
                  {% if c.id_utilisateur %}{{ c.id_utilisateur.nom }} {{ c.id_utilisateur.prenom }}{% else %}Inconnu{% endif %}
                </span>
                <span class="comment-date">{{ c.dateCreationC }}</span>
              </div>
              <div class="comment-text">{{ c.contenuC }}</div>
              <span class="comment-status {{ c.statutC ? 'cs-active' : 'cs-inactive' }}">
                {{ c.statutC ? 'Actif' : 'Inactif' }}
              </span>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>

  </div>
</div>
{% endblock %}
