{% extends 'backend/baseend.html.twig' %}

{% block title %}Publications — RE7LA Admin{% endblock %}

{% block body %}
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap');

.pub-wrap { font-family: 'DM Sans', sans-serif; }

/* ── BANNER ── */
.pub-banner {
  background: linear-gradient(120deg, #1a1d23 60%, #2e3340 100%);
  border-radius: 20px; padding: 32px 36px; margin-bottom: 24px;
  position: relative; overflow: hidden;
  display: flex; align-items: center; justify-content: space-between; gap: 20px;
}
.pub-banner::before {
  content: ''; position: absolute; width: 280px; height: 280px; border-radius: 50%;
  background: radial-gradient(circle, rgba(247,183,49,0.22) 0%, transparent 70%);
  top: -80px; right: -40px; pointer-events: none;
}
.pub-banner::after {
  content: ''; position: absolute; width: 180px; height: 180px; border-radius: 50%;
  background: radial-gradient(circle, rgba(247,183,49,0.08) 0%, transparent 70%);
  bottom: -60px; left: 38%; pointer-events: none;
}
.pub-banner-left { position: relative; z-index: 1; }
.pub-eyebrow { font-size: 10px; font-weight: 700; letter-spacing: 2.5px; text-transform: uppercase; color: #F7B731; margin-bottom: 6px; }
.pub-banner-title { font-family: 'Peter Bold', sans-serif; font-size: 28px; font-weight: 800; color: #fff; margin: 0 0 5px; letter-spacing: -0.5px; }
.pub-banner-sub { color: rgba(255,255,255,0.42); font-size: 13px; margin: 0; }
.pub-banner-right { position: relative; z-index: 1; flex-shrink: 0; }
.btn-create {
  display: inline-flex; align-items: center; gap: 8px;
  background: linear-gradient(135deg, #F7B731, #e09d10); color: #1a1d23;
  font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 14px;
  padding: 13px 26px; border-radius: 14px; text-decoration: none; border: none;
  box-shadow: 0 4px 20px rgba(247,183,49,0.45); transition: all 0.25s; white-space: nowrap;
}
.btn-create:hover { transform: translateY(-3px); box-shadow: 0 8px 28px rgba(247,183,49,0.55); color: #1a1d23; }

/* ── STATS ── */
.stat-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; margin-bottom: 20px; }
.stat-c {
  background: #fff; border-radius: 16px; padding: 20px 22px;
  border: 1px solid #edf0f7; box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  display: flex; align-items: center; gap: 16px; transition: all 0.2s;
}
.stat-c:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.08); transform: translateY(-2px); }
.stat-icon { width: 50px; height: 50px; border-radius: 13px; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; }
.si-total { background: linear-gradient(135deg,#fff8e1,#ffe082); }
.si-ok    { background: linear-gradient(135deg,#e8fdf5,#a7f3d0); }
.si-pend  { background: linear-gradient(135deg,#fef9e7,#fde68a); }
.stat-val { font-family: 'Peter Bold ', sans-serif; font-size: 26px; font-weight: 800; color: #1a1d23; line-height: 1; }
.stat-lbl { font-size: 12px; color: #94a3b8; margin-top: 3px; }

/* ── FILTER ── */
.filter-card {
  background: #fff; border-radius: 16px; border: 1px solid #edf0f7;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04); padding: 18px 22px; margin-bottom: 18px;
}
.filter-card .form-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #94a3b8; margin-bottom: 5px; }
.filter-card .form-control,
.filter-card .form-select {
  border: 1.5px solid #edf0f7; border-radius: 10px;
  font-size: 13px; padding: 9px 13px; color: #1a1d23;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.filter-card .form-control:focus,
.filter-card .form-select:focus { border-color: #F7B731; box-shadow: 0 0 0 3px rgba(247,183,49,0.12); outline: none; }
.btn-filter {
  background: linear-gradient(135deg,#F7B731,#e09d10); color: #1a1d23;
  border: none; border-radius: 10px; font-weight: 700; font-size: 13px; padding: 9px 20px;
  transition: all 0.2s; cursor: pointer;
}
.btn-filter:hover { box-shadow: 0 4px 12px rgba(247,183,49,0.4); transform: translateY(-1px); }
.btn-reset {
  background: #f8f9fc; color: #64748b; border: 1.5px solid #edf0f7; border-radius: 10px;
  font-weight: 600; font-size: 13px; padding: 9px 15px;
  text-decoration: none; transition: all 0.2s; display: inline-block;
}
.btn-reset:hover { background: #edf0f7; color: #1a1d23; }

/* ── TABLE CARD ── */
.table-card { background: #fff; border-radius: 16px; border: 1px solid #edf0f7; box-shadow: 0 2px 8px rgba(0,0,0,0.04); overflow: hidden; }
.table-card-hd { padding: 16px 22px; border-bottom: 1px solid #f0f4fb; display: flex; align-items: center; justify-content: space-between; }
.table-card-hd-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px; color: #1a1d23; }
.count-pill { background: #fff8e1; color: #92650a; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; }

/* ── Flash ── */
.flash-ok  { background:#d1fae5; color:#065f46; border:none; border-radius:12px; padding:13px 16px; font-size:13px; }
.flash-err { background:#fee2e2; color:#991b1b; border:none; border-radius:12px; padding:13px 16px; font-size:13px; }

/* ── Delete Modal ── */
.del-overlay { display:none; position:fixed; inset:0; background:rgba(10,12,18,0.55); backdrop-filter:blur(5px); z-index:9999; align-items:center; justify-content:center; }
.del-overlay.open { display:flex; }
.del-box { background:#fff; border-radius:22px; padding:36px 32px; max-width:390px; width:92%; box-shadow:0 32px 80px rgba(0,0,0,0.22); animation:popIn .22s ease; }
@keyframes popIn { from{transform:scale(.9);opacity:0} to{transform:scale(1);opacity:1} }
.del-icon { width:58px; height:58px; background:#fee2e2; border-radius:16px; display:flex; align-items:center; justify-content:center; font-size:28px; margin:0 auto 16px; }
.del-title { font-family:'Syne',sans-serif; font-size:18px; font-weight:800; color:#1a1d23; text-align:center; margin-bottom:8px; }
.del-sub { font-size:13px; color:#64748b; text-align:center; margin-bottom:26px; line-height:1.5; }
.del-actions { display:flex; gap:10px; }
.del-cancel { flex:1; padding:12px; border:1.5px solid #edf0f7; background:#f8f9fc; border-radius:12px; font-weight:600; font-size:13px; cursor:pointer; color:#64748b; transition:.2s; }
.del-cancel:hover { background:#edf0f7; }
.del-confirm { flex:1; padding:12px; border:none; background:linear-gradient(135deg,#ef4444,#dc2626); border-radius:12px; font-weight:700; font-size:13px; cursor:pointer; color:#fff; transition:.2s; }
.del-confirm:hover { box-shadow:0 4px 14px rgba(239,68,68,.4); }

@media(max-width:768px){ .stat-row{grid-template-columns:1fr;} .pub-banner{flex-direction:column;align-items:flex-start;} }
</style>

<div class="pub-wrap">

  {% for label, messages in app.flashes %}
    {% for message in messages %}
      <div class="alert flash-{{ label == 'error' ? 'err' : 'ok' }} alert-dismissible mb-3">
        {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    {% endfor %}
  {% endfor %}

  <div class="pub-banner">
    <div class="pub-banner-left">
      <div class="pub-eyebrow">Gestion du contenu</div>
      <h1 class="pub-banner-title">Publications</h1>
      <p class="pub-banner-sub">Modérez les publications de la communauté RE7LA</p>
    </div>
    <div class="pub-banner-right">
      <a href="{{ path('app_admin_publication_new') }}" class="btn-create">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nouvelle publication
      </a>
    </div>
  </div>

  <div class="stat-row">
    <div class="stat-c">
      <div class="stat-icon si-total">📄</div>
      <div><div class="stat-val">{{ totalPublications }}</div><div class="stat-lbl">Total publications</div></div>
    </div>
    <div class="stat-c">
      <div class="stat-icon si-ok">✅</div>
      <div><div class="stat-val" style="color:#10b981">{{ totalVerifiees }}</div><div class="stat-lbl">Vérifiées</div></div>
    </div>
    <div class="stat-c">
      <div class="stat-icon si-pend">⏳</div>
      <div><div class="stat-val" style="color:#f59e0b">{{ totalNonVerifiees }}</div><div class="stat-lbl">Non vérifiées</div></div>
    </div>
  </div>

  <div class="filter-card">
    <form method="get" class="row g-2 align-items-end">
      <div class="col-md-5">
        <label class="form-label">Recherche</label>
        <input type="text" name="search" class="form-control" placeholder="Description, auteur…" value="{{ search }}">
      </div>
      <div class="col-md-3">
        <label class="form-label">Type cible</label>
        <select name="typeCible" class="form-select">
          <option value="">Tous les types</option>
          {% for type in ['HEBERGEMENT','ACTIVITE','TRANSPORT'] %}
            <option value="{{ type }}" {{ typeCible == type ? 'selected' : '' }}>{{ type }}</option>
          {% endfor %}
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Statut</label>
        <select name="statutP" class="form-select">
          <option value="">Tous</option>
          {% for s in ['VALIDE','EN_ATTENTE','REFUSE'] %}
            <option value="{{ s }}" {{ statutP == s ? 'selected' : '' }}>{{ s }}</option>
          {% endfor %}
        </select>
      </div>
      <div class="col-md-2 d-flex gap-2">
        <button type="submit" class="btn-filter flex-grow-1">Filtrer</button>
        <a href="{{ path('app_admin_publication_index') }}" class="btn-reset">↺</a>
      </div>
    </form>
  </div>

  <div class="table-card">
    <div class="table-card-hd">
      <span class="table-card-hd-title">Liste des publications</span>
      <span class="count-pill">{{ publications|length }} résultat{{ publications|length != 1 ? 's' : '' }}</span>
    </div>
    {% include 'backendCommunaute/publication/_table.html.twig' %}
  </div>

</div>

<div class="del-overlay" id="delModal">
  <div class="del-box">
    <div class="del-icon">🗑️</div>
    <div class="del-title">Supprimer la publication ?</div>
    <div class="del-sub">Cette action est irréversible. La publication et tous ses commentaires seront définitivement supprimés.</div>
    <div class="del-actions">
      <button class="del-cancel" onclick="closeDel()">Annuler</button>
      <button class="del-confirm" id="delConfirm">Supprimer</button>
    </div>
  </div>
</div>

<script>
let _delUrl=null, _delRow=null;
function openDel(url,row){ _delUrl=url; _delRow=row; document.getElementById('delModal').classList.add('open'); }
function closeDel(){ document.getElementById('delModal').classList.remove('open'); _delUrl=null; _delRow=null; }
document.getElementById('delModal').addEventListener('click', e=>{ if(e.target===document.getElementById('delModal')) closeDel(); });
document.getElementById('delConfirm').addEventListener('click', ()=>{
  if(!_delUrl) return;
  fetch(_delUrl,{method:'POST'}).then(r=>r.json()).then(d=>{ if(d.success&&_delRow){ _delRow.style.transition='opacity .3s,transform .3s'; _delRow.style.opacity='0'; _delRow.style.transform='translateX(20px)'; setTimeout(()=>{ _delRow.remove(); closeDel(); },300); } else closeDel(); });
});
document.addEventListener('DOMContentLoaded', ()=>{
  document.querySelectorAll('.btn-delete').forEach(btn=>btn.addEventListener('click',()=>openDel(btn.dataset.url,btn.closest('tr'))));
  document.querySelectorAll('.toggle-verifie').forEach(btn=>{
    btn.addEventListener('click',()=>{
      fetch(btn.dataset.url,{method:'POST'}).then(r=>r.json()).then(d=>{
        if(d.success) btn.innerHTML = d.verifie
          ? '<span class="verifie-yes">✔ Vérifié</span>'
          : '<span class="verifie-no">✗ Non vérifié</span>';
      });
    });
  });
});
</script>
{% endblock %}
