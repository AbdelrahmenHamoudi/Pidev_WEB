{% extends 'backend/baseend.html.twig' %}

{% block title %}Nouvelle publication — RE7LA{% endblock %}

{% block body %}
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap');
.form-wrap { font-family: 'DM Sans', sans-serif; max-width: 760px; }
.form-topbar { display:flex; align-items:center; gap:12px; margin-bottom:24px; flex-wrap:wrap; }
.btn-back { display:inline-flex; align-items:center; gap:6px; background:#fff; border:1.5px solid #edf0f7; border-radius:10px; padding:8px 16px; font-size:13px; font-weight:600; color:#64748b; text-decoration:none; transition:all .2s; }
.btn-back:hover { background:#f8f9fc; color:#1a1d23; border-color:#F7B731; }
.form-page-title { font-family:'Peter Bold',sans-serif; font-size:22px; font-weight:800; color:#1a1d23; margin:0; }
.form-card { background:#fff; border-radius:18px; border:1.5px solid #edf0f7; box-shadow:0 4px 20px rgba(0,0,0,0.06); overflow:hidden; }
.form-card-header { padding:16px 24px; border-bottom:1.5px solid #f0f4fb; font-family:'Peter Bold',sans-serif; font-size:13px; font-weight:700; color:#1a1d23; display:flex; align-items:center; gap:8px; background:#fafbfc; }
.form-card-body { padding:28px 24px; }
.form-footer { display:flex; gap:10px; padding:20px 24px; border-top:1.5px solid #f0f4fb; background:#fafbfc; margin:0 -24px -28px; }
.btn-submit { display:inline-flex; align-items:center; gap:8px; background:linear-gradient(135deg,#F7B731,#e09d10); color:#1a1d23; border:none; border-radius:12px; padding:13px 28px; font-weight:700; font-size:14px; cursor:pointer; box-shadow:0 4px 16px rgba(247,183,49,.38); transition:all .2s; }
.btn-submit:hover { transform:translateY(-2px); box-shadow:0 6px 22px rgba(247,183,49,.48); }
.btn-cancel-form { display:inline-flex; align-items:center; gap:8px; background:#f8f9fc; color:#64748b; border:1.5px solid #edf0f7; border-radius:12px; padding:13px 22px; font-weight:600; font-size:14px; text-decoration:none; transition:all .2s; }
.btn-cancel-form:hover { background:#edf0f7; color:#1a1d23; }
.flash-ok  { background:#d1fae5; color:#065f46; border:none; border-radius:12px; padding:13px 16px; font-size:13px; margin-bottom:16px; }
.flash-err { background:#fee2e2; color:#991b1b; border:none; border-radius:12px; padding:13px 16px; font-size:13px; margin-bottom:16px; }
@media(max-width:640px){ .form-wrap{max-width:100%;} }
</style>

<div class="form-wrap">

  {% for label, messages in app.flashes %}
    {% for message in messages %}
      <div class="alert flash-{{ label == 'error' ? 'err' : 'ok' }} alert-dismissible">
        {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    {% endfor %}
  {% endfor %}

  <div class="form-topbar">
    <a href="{{ path('app_admin_publication_index') }}" class="btn-back">← Retour</a>
    <h1 class="form-page-title">➕ Nouvelle publication</h1>
  </div>

  <div class="form-card">
    <div class="form-card-header">📝 Informations de la publication</div>
    <div class="form-card-body">
      <form method="post" enctype="multipart/form-data" action="{{ path('app_admin_publication_new') }}" novalidate>

        {% include 'backendCommunaute/publication/_form.html.twig' with {
          typeCibles: typeCibles, statuts: statuts, users: users, pub: null
        } %}

        <div class="form-footer">
          <button type="submit" class="btn-submit">✅ Créer la publication</button>
          <a href="{{ path('app_admin_publication_index') }}" class="btn-cancel-form">Annuler</a>
        </div>
      </form>
    </div>
  </div>

</div>
{% endblock %}
