{% extends 'backend/baseend.html.twig' %}

{% block title %}Commentaire #{{ commentaire.idCommentaire }}{% endblock %}

{% block body %}
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500;600&display=swap');
:root{ --orange:#F7B731; --orange-deep:#e09d10; --orange-soft:rgba(247,183,49,.10); --orange-glow:rgba(247,183,49,.25); --border:#edf0f7; --surface:#fafbfc; --text-primary:#1a1d23; --text-secondary:#64748b; --text-muted:#94a3b8; }
.show-wrap { font-family:'DM Sans',sans-serif; max-width:680px; }
.show-topbar { display:flex; align-items:center; gap:12px; margin-bottom:28px; flex-wrap:wrap; }
.btn-back { display:inline-flex; align-items:center; gap:6px; background:#fff; border:1.5px solid var(--border); border-radius:10px; padding:8px 16px; font-size:12px; font-weight:600; color:var(--text-secondary); text-decoration:none; transition:all .2s; }
.btn-back:hover { border-color:var(--orange); color:var(--text-primary); background:var(--orange-soft); }
.show-title { font-family:'Peter Bold',sans-serif; font-size:22px; font-weight:800; color:var(--text-primary); margin:0; }
.show-card { background:#fff; border:1.5px solid var(--border); border-radius:20px; overflow:hidden; box-shadow:0 4px 20px rgba(0,0,0,.06); }
.show-card-header { padding:18px 24px; border-bottom:1.5px solid var(--border); background:var(--surface); display:flex; align-items:center; justify-content:space-between; }
.show-card-header-left { display:flex; align-items:center; gap:10px; }
.show-card-icon { width:38px; height:38px; background:var(--orange-soft); border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:17px; }
.show-card-label { font-family:'Peter Bold',sans-serif; font-size:13px; font-weight:700; color:var(--text-primary); }
.show-card-sub   { font-size:11px; color:var(--text-muted); margin-top:1px; }
.show-card-body  { padding:28px 24px; display:flex; flex-direction:column; gap:0; }
.field-row { display:grid; grid-template-columns:140px 1fr; gap:12px; align-items:start; padding:16px 0; border-bottom:1px solid #f0f4fb; }
.field-row:first-child { padding-top:0; }
.field-row:last-child  { border-bottom:none; padding-bottom:0; }
.field-key { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1.2px; color:var(--text-muted); padding-top:3px; }
.field-val { font-size:13px; color:var(--text-primary); line-height:1.6; }
.content-bubble { background:var(--orange-soft); border:1.5px solid rgba(247,183,49,.2); border-radius:14px; padding:14px 16px; font-size:14px; color:var(--text-primary); line-height:1.6; }
.author-pill { display:inline-flex; align-items:center; gap:8px; }
.author-avatar { width:32px; height:32px; border-radius:50%; background:linear-gradient(135deg,var(--orange),var(--orange-deep)); display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:700; color:var(--text-primary); flex-shrink:0; }
.author-name { font-size:13px; font-weight:600; color:var(--text-primary); }
.pub-link { display:inline-flex; align-items:center; gap:5px; background:var(--orange-soft); color:#b07800; border:1px solid rgba(247,183,49,.25); border-radius:8px; padding:5px 12px; font-size:12px; font-weight:600; text-decoration:none; transition:all .2s; }
.pub-link:hover { background:rgba(247,183,49,.20); }
.badge-active   { display:inline-flex; align-items:center; gap:5px; background:rgba(16,185,129,.10); color:#059669; border:1px solid rgba(16,185,129,.2); border-radius:20px; padding:5px 12px; font-size:12px; font-weight:700; }
.badge-inactive { display:inline-flex; align-items:center; gap:5px; background:rgba(239,68,68,.08); color:#dc2626; border:1px solid rgba(239,68,68,.18); border-radius:20px; padding:5px 12px; font-size:12px; font-weight:700; }
.show-footer { padding:20px 24px; border-top:1.5px solid var(--border); background:var(--surface); display:flex; gap:10px; }
.btn-edit { display:inline-flex; align-items:center; gap:8px; background:linear-gradient(135deg,var(--orange),var(--orange-deep)); color:var(--text-primary); border:none; border-radius:12px; padding:11px 22px; font-weight:700; font-size:13px; text-decoration:none; box-shadow:0 3px 12px var(--orange-glow); transition:all .2s; }
.btn-edit:hover { transform:translateY(-2px); box-shadow:0 5px 18px var(--orange-glow); color:var(--text-primary); }
.btn-cancel { display:inline-flex; align-items:center; gap:8px; background:#fff; border:1.5px solid var(--border); border-radius:12px; padding:11px 18px; font-weight:600; font-size:13px; color:var(--text-secondary); text-decoration:none; transition:all .2s; }
.btn-cancel:hover { border-color:var(--orange); color:var(--text-primary); }
</style>

<div class="show-wrap">

  <div class="show-topbar">
    <a href="{{ path('app_admin_commentaire_index') }}" class="btn-back">← Retour</a>
    <h1 class="show-title">💬 Commentaire #{{ commentaire.idCommentaire }}</h1>
  </div>

  <div class="show-card">
    <div class="show-card-header">
      <div class="show-card-header-left">
        <div class="show-card-icon">💬</div>
        <div>
          <div class="show-card-label">Détail du commentaire</div>
          <div class="show-card-sub">ID #{{ commentaire.idCommentaire }}</div>
        </div>
      </div>
      {% if commentaire.statutC %}<span class="badge-active">● Actif</span>
      {% else %}<span class="badge-inactive">● Inactif</span>{% endif %}
    </div>

    <div class="show-card-body">
      <div class="field-row">
        <span class="field-key">Contenu</span>
        <div class="content-bubble">{{ commentaire.contenuC }}</div>
      </div>
      <div class="field-row">
        <span class="field-key">Auteur</span>
        <div class="field-val">
          {% if commentaire.id_utilisateur %}
            <div class="author-pill">
              <div class="author-avatar">{{ commentaire.id_utilisateur.nom|slice(0,1)|upper }}{{ commentaire.id_utilisateur.prenom|slice(0,1)|upper }}</div>
              <span class="author-name">{{ commentaire.id_utilisateur.nom }} {{ commentaire.id_utilisateur.prenom }}</span>
            </div>
          {% else %}<span style="color:#94a3b8">—</span>{% endif %}
        </div>
      </div>
      <div class="field-row">
        <span class="field-key">Publication</span>
        <div class="field-val">
          {% if commentaire.idPublication %}
            <a href="{{ path('app_admin_publication_show', {idPublication: commentaire.idPublication.idPublication}) }}" class="pub-link">
              📄 Publication #{{ commentaire.idPublication.idPublication }}
            </a>
          {% else %}<span style="color:#94a3b8">—</span>{% endif %}
        </div>
      </div>
      <div class="field-row">
        <span class="field-key">Statut</span>
        <div class="field-val">
          {% if commentaire.statutC %}<span class="badge-active">● Actif</span>
          {% else %}<span class="badge-inactive">● Inactif</span>{% endif %}
        </div>
      </div>
      <div class="field-row">
        <span class="field-key">Date création</span>
        <div class="field-val" style="color:#64748b">{{ commentaire.dateCreationC }}</div>
      </div>
    </div>

    <div class="show-footer">
      <a href="{{ path('app_admin_commentaire_edit', {idCommentaire: commentaire.idCommentaire}) }}" class="btn-edit">✏️ Modifier</a>
      <a href="{{ path('app_admin_commentaire_index') }}" class="btn-cancel">Retour à la liste</a>
    </div>
  </div>

</div>
{% endblock %}
