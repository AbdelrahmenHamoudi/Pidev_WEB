<style>
.cmnt-empty { display:flex; flex-direction:column; align-items:center; justify-content:center; padding:64px 24px; gap:12px; }
.cmnt-empty-icon { width:64px; height:64px; background:rgba(247,183,49,.10); border-radius:20px; display:flex; align-items:center; justify-content:center; font-size:28px; }
.cmnt-empty p { font-size:14px; color:#94a3b8; margin:0; font-weight:500; }

.cmnt-table { width:100%; border-collapse:collapse; }
.cmnt-table thead tr { background:#fafbfc; border-bottom:2px solid #edf0f7; }
.cmnt-table thead th { padding:13px 16px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1.2px; color:#94a3b8; white-space:nowrap; }
.cmnt-table tbody tr { border-bottom:1px solid #f0f4fb; transition:background .15s; }
.cmnt-table tbody tr:last-child { border-bottom:none; }
.cmnt-table tbody tr:hover { background:#fffdf5; }
.cmnt-table td { padding:14px 16px; vertical-align:middle; }

.id-chip { display:inline-flex; align-items:center; justify-content:center; background:#f0f4fb; color:#64748b; border-radius:8px; padding:3px 9px; font-size:11px; font-weight:700; }
.cmnt-content-text { font-size:13px; color:#1a1d23; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; max-width:220px; line-height:1.45; }
.author-wrap { display:flex; align-items:center; gap:8px; }
.author-avatar { width:30px; height:30px; border-radius:50%; background:linear-gradient(135deg,#F7B731,#e09d10); display:flex; align-items:center; justify-content:center; font-size:11px; font-weight:700; color:#1a1d23; flex-shrink:0; }
.author-name { font-size:13px; font-weight:500; color:#1a1d23; }
.pub-link { display:inline-flex; align-items:center; gap:5px; background:rgba(247,183,49,.10); color:#b07800; border:1px solid rgba(247,183,49,.25); border-radius:8px; padding:4px 10px; font-size:12px; font-weight:600; text-decoration:none; transition:all .2s; }
.pub-link:hover { background:rgba(247,183,49,.20); color:#7a5200; }
.status-btn { background:none; border:none; padding:0; cursor:pointer; display:inline-flex; }
.badge-active { display:inline-flex; align-items:center; gap:5px; background:rgba(16,185,129,.10); color:#059669; border:1px solid rgba(16,185,129,.2); border-radius:20px; padding:4px 10px; font-size:11px; font-weight:700; transition:all .2s; }
.badge-active:hover { background:rgba(16,185,129,.18); }
.badge-inactive { display:inline-flex; align-items:center; gap:5px; background:rgba(239,68,68,.08); color:#dc2626; border:1px solid rgba(239,68,68,.18); border-radius:20px; padding:4px 10px; font-size:11px; font-weight:700; transition:all .2s; }
.badge-inactive:hover { background:rgba(239,68,68,.15); }
.date-text { font-size:12px; color:#94a3b8; white-space:nowrap; }
.action-group { display:flex; gap:6px; justify-content:flex-end; align-items:center; }
.act-btn { width:32px; height:32px; border-radius:9px; display:inline-flex; align-items:center; justify-content:center; font-size:14px; text-decoration:none; border:1.5px solid transparent; transition:all .18s; cursor:pointer; background:none; }
.act-btn-view { border-color:#edf0f7; color:#64748b; background:#f8f9fc; }
.act-btn-view:hover  { border-color:#F7B731; background:rgba(247,183,49,.12); color:#1a1d23; }
.act-btn-edit { border-color:#edf0f7; color:#64748b; background:#f8f9fc; }
.act-btn-edit:hover  { border-color:#3b82f6; background:rgba(59,130,246,.08); color:#2563eb; }
.act-btn-del  { border-color:#edf0f7; color:#64748b; background:#f8f9fc; }
.act-btn-del:hover   { border-color:#ef4444; background:rgba(239,68,68,.08); color:#ef4444; }
</style>

{% if commentaires is empty %}
  <div class="cmnt-empty">
    <div class="cmnt-empty-icon">💬</div>
    <p>Aucun commentaire trouvé.</p>
  </div>
{% else %}
<div style="overflow-x:auto;">
  <table class="cmnt-table">
    <thead>
      <tr>
        <th>#</th>
        <th>Contenu</th>
        <th>Auteur</th>
        <th>Publication</th>
        <th>Statut</th>
        <th>Date</th>
        <th style="text-align:right">Actions</th>
      </tr>
    </thead>
    <tbody>
    {% for c in commentaires %}
      <tr>
        <td><span class="id-chip">{{ c.idCommentaire }}</span></td>
        <td><span class="cmnt-content-text" title="{{ c.contenuC }}">{{ c.contenuC }}</span></td>
        <td>
          {% if c.id_utilisateur %}
            <div class="author-wrap">
              <div class="author-avatar">{{ c.id_utilisateur.nom|slice(0,1)|upper }}{{ c.id_utilisateur.prenom|slice(0,1)|upper }}</div>
              <span class="author-name">{{ c.id_utilisateur.nom }} {{ c.id_utilisateur.prenom }}</span>
            </div>
          {% else %}<span class="date-text">—</span>{% endif %}
        </td>
        <td>
          {% if c.idPublication %}
            <a href="{{ path('app_admin_publication_show', {idPublication: c.idPublication.idPublication}) }}" class="pub-link">
              📄 #{{ c.idPublication.idPublication }}
            </a>
          {% else %}<span class="date-text">—</span>{% endif %}
        </td>
        <td>
          <button class="status-btn toggle-statut" data-id="{{ c.idCommentaire }}"
                  data-url="{{ path('app_admin_commentaire_toggle_statut', {idCommentaire: c.idCommentaire}) }}">
            {% if c.statutC %}<span class="badge-active">● Actif</span>
            {% else %}<span class="badge-inactive">● Inactif</span>{% endif %}
          </button>
        </td>
        <td><span class="date-text">{{ c.dateCreationC }}</span></td>
        <td>
          <div class="action-group">
            <a href="{{ path('app_admin_commentaire_show', {idCommentaire: c.idCommentaire}) }}" class="act-btn act-btn-view" title="Voir">👁</a>
            <a href="{{ path('app_admin_commentaire_edit', {idCommentaire: c.idCommentaire}) }}" class="act-btn act-btn-edit" title="Modifier">✏️</a>
            <button class="act-btn act-btn-del btn-delete"
                    data-url="{{ path('app_admin_commentaire_delete', {idCommentaire: c.idCommentaire}) }}" title="Supprimer">🗑</button>
          </div>
        </td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
</div>
{% endif %}

<script>
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.btn-delete').forEach(btn => {
    btn.addEventListener('click', () => {
      if(!confirm('Supprimer ce commentaire ?')) return;
      fetch(btn.dataset.url,{method:'POST'}).then(r=>r.json()).then(d=>{
        if(d.success){
          const tr=btn.closest('tr');
          tr.style.transition='opacity .3s,transform .3s';
          tr.style.opacity='0'; tr.style.transform='translateX(20px)';
          setTimeout(()=>tr.remove(),300);
        } else alert(d.message);
      });
    });
  });
  document.querySelectorAll('.toggle-statut').forEach(btn => {
    btn.addEventListener('click', ()=>{
      fetch(btn.dataset.url,{method:'POST'}).then(r=>r.json()).then(d=>{
        if(d.success) btn.innerHTML=d.statut
          ?'<span class="badge-active">● Actif</span>'
          :'<span class="badge-inactive">● Inactif</span>';
      });
    });
  });
});
</script>
