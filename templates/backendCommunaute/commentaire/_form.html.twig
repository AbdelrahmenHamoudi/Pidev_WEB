{#
  Variables expected:
    publications — array of Publication entities
    users        — array of Users entities
    com          — Commentaire entity or null (new)
#}
<style>
.cf-section { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1.5px; color:#94a3b8; padding-bottom:8px; border-bottom:1px solid #f0f4fb; margin:4px 0 18px; }
.cf-group { margin-bottom:20px; }
.cf-label { display:flex; align-items:center; gap:5px; font-size:12px; font-weight:700; color:#374151; margin-bottom:7px; text-transform:uppercase; letter-spacing:.5px; }
.cf-label .req { color:#ef4444; font-size:15px; line-height:1; }

.cf-input, .cf-select, .cf-textarea {
  width:100%; border:1.5px solid #edf0f7; border-radius:11px;
  padding:11px 14px; font-size:13px; color:#1a1d23;
  font-family:'DM Sans',sans-serif; background:#fff;
  transition:border-color .2s, box-shadow .2s; appearance:none;
}
.cf-input:focus, .cf-select:focus, .cf-textarea:focus { border-color:#F7B731; box-shadow:0 0 0 3px rgba(247,183,49,.12); outline:none; }
.cf-textarea { resize:vertical; min-height:110px; line-height:1.6; }

.cf-input.valid, .cf-select.valid, .cf-textarea.valid   { border-color:#10b981 !important; box-shadow:0 0 0 3px rgba(16,185,129,.10) !important; }
.cf-input.invalid, .cf-select.invalid, .cf-textarea.invalid { border-color:#ef4444 !important; box-shadow:0 0 0 3px rgba(239,68,68,.10) !important; }

.cf-feedback { font-size:11px; margin-top:5px; font-weight:600; display:none; }
.cf-feedback.err { color:#ef4444; display:block; }
.cf-feedback.ok  { color:#10b981; display:block; }

.cf-counter-row { display:flex; justify-content:space-between; margin-top:5px; }
.cf-hint    { font-size:11px; color:#94a3b8; }
.cf-counter { font-size:11px; font-weight:700; color:#94a3b8; font-variant-numeric:tabular-nums; }
.cf-counter.warn { color:#F7B731; }
.cf-counter.over { color:#ef4444; }

.cf-sel-wrap { position:relative; }
.cf-sel-wrap::after { content:'▾'; position:absolute; right:14px; top:50%; transform:translateY(-50%); color:#94a3b8; pointer-events:none; }
.cf-select { padding-right:36px; cursor:pointer; }

.cf-toggle-wrap { display:inline-flex; align-items:center; gap:12px; padding:13px 16px; border:1.5px solid #edf0f7; border-radius:11px; cursor:pointer; transition:all .2s; background:#fff; }
.cf-toggle-wrap:hover { border-color:#F7B731; background:rgba(247,183,49,.05); }
.cf-toggle { position:relative; width:40px; height:22px; flex-shrink:0; }
.cf-toggle input { opacity:0; width:0; height:0; position:absolute; }
.cf-slider { position:absolute; inset:0; background:#edf0f7; border-radius:22px; transition:.2s; }
.cf-slider::before { content:''; position:absolute; width:16px; height:16px; background:#fff; border-radius:50%; left:3px; top:3px; transition:.2s; box-shadow:0 1px 4px rgba(0,0,0,.15); }
.cf-toggle input:checked ~ .cf-slider { background:#F7B731; }
.cf-toggle input:checked ~ .cf-slider::before { transform:translateX(18px); }
.cf-toggle-lbl { font-size:13px; font-weight:500; color:#374151; }
</style>

{# ── Contenu ── #}
<div class="cf-section">💬 Contenu</div>

<div class="cf-group">
  <label for="contenuC" class="cf-label">Contenu du commentaire <span class="req">*</span></label>
  <textarea id="contenuC" name="contenuC"
            class="cf-textarea" rows="4"
            minlength="2" maxlength="200" required
            placeholder="Rédigez votre commentaire…"
            oninput="cfCounterUpdate(this,'contenu-ctr'); cfValidTA(this,2,200)">{{ com ? com.contenuC : '' }}</textarea>
  <div class="cf-counter-row">
    <span class="cf-hint">Entre 2 et 200 caractères. Mots interdits : bhim, kalb, couchon</span>
    <span class="cf-counter" id="contenu-ctr">0 / 200</span>
  </div>
  <div style="font-size:11px; margin-top:4px;" id="forbidden-words-hint"></div>
  <span class="cf-feedback" id="contenuC-fb"></span>
</div>

{# ── Associations ── #}
<div class="cf-section">🔗 Associations</div>

<div class="cf-group">
  <label for="idPublication" class="cf-label">Publication liée <span class="req">*</span></label>
  <div class="cf-sel-wrap">
    <select id="idPublication" name="idPublication" class="cf-select" required onchange="cfValidSel(this)">
      <option value="">— Sélectionner une publication —</option>
      {% for pub in publications %}
        <option value="{{ pub.idPublication }}"
          {{ com and com.idPublication and com.idPublication.idPublication == pub.idPublication ? 'selected' : '' }}>
          #{{ pub.idPublication }} — {{ pub.descriptionP|slice(0,60) }}
        </option>
      {% endfor %}
    </select>
  </div>
  <span class="cf-feedback" id="idPublication-fb"></span>
</div>

<div class="cf-group">
  <label for="id_utilisateur" class="cf-label">Auteur <span class="req">*</span></label>
  <div class="cf-sel-wrap">
    <select id="id_utilisateur" name="id_utilisateur" class="cf-select" required onchange="cfValidSel(this)">
      <option value="">— Sélectionner un utilisateur —</option>
      {% for user in users %}
        <option value="{{ user.id }}"
          {{ com and com.id_utilisateur and com.id_utilisateur.id == user.id ? 'selected' : '' }}>
          {{ user.nom }} {{ user.prenom }} — {{ user.e_mail }}
        </option>
      {% endfor %}
    </select>
  </div>
  <span class="cf-feedback" id="id_utilisateur-fb"></span>
</div>

{# ── Options ── #}
<div class="cf-section">⚙️ Options</div>

<div class="cf-group">
  <label class="cf-toggle-wrap" for="statutC">
    <span class="cf-toggle">
      <input type="checkbox" id="statutC" name="statutC" value="1"
             {{ com and com.statutC ? 'checked' : '' }}>
      <span class="cf-slider"></span>
    </span>
    <span class="cf-toggle-lbl">Commentaire actif</span>
  </label>
</div>

<script>
(function(){
  /* ── Forbidden words list ── */
  const FORBIDDEN_WORDS = ['bhim', 'kalb', 'couchon'];
  
  function containsForbiddenWords(text) {
    const lowerText = text.toLowerCase();
    return FORBIDDEN_WORDS.filter(word => lowerText.includes(word));
  }

  function cfCounterUpdate(el, cid) {
    const len=el.value.length, max=+el.getAttribute('maxlength')||200;
    const c=document.getElementById(cid); if(!c) return;
    c.textContent=len+' / '+max;
    c.className='cf-counter'+(len>=max?' over':len>max*.85?' warn':'');
  }
  window.cfCounterUpdate = cfCounterUpdate;

  function cfValidTA(el, min, max) {
    const v=el.value.trim(), fb=document.getElementById(el.id+'-fb');
    const hintEl = document.getElementById('forbidden-words-hint');
    el.classList.remove('valid','invalid');
    if(fb){fb.textContent='';fb.className='cf-feedback';}
    if(hintEl){ hintEl.textContent = ''; }
    
    // Check for forbidden words FIRST
    const forbiddenFound = containsForbiddenWords(v);
    if (forbiddenFound.length > 0) {
      el.classList.add('invalid');
      set(fb, `⚠️ Le commentaire contient des mots interdits : ${forbiddenFound.join(', ')}`, 'err');
      if(hintEl){ 
        hintEl.innerHTML = `🚫 Mots interdits détectés : <strong>${forbiddenFound.join(', ')}</strong>`;
        hintEl.style.color = '#ef4444';
      }
      return;
    }
    
    if(!v)           { el.classList.add('invalid'); set(fb,'⚠ Ce champ est requis.','err'); }
    else if(v.length<min){ el.classList.add('invalid'); set(fb,`⚠ Minimum ${min} caractères (actuel : ${v.length}).`,'err'); }
    else if(v.length>max){ el.classList.add('invalid'); set(fb,`⚠ Maximum ${max} caractères dépassé.`,'err'); }
    else             { el.classList.add('valid');   set(fb,'✓ Valide','ok'); }
  }
  window.cfValidTA = cfValidTA;

  function cfValidSel(el) {
    const fb=document.getElementById(el.id+'-fb');
    el.classList.remove('valid','invalid');
    if(fb){fb.textContent='';fb.className='cf-feedback';}
    if(!el.value){ el.classList.add('invalid'); set(fb,'⚠ Veuillez sélectionner une option.','err'); }
    else         { el.classList.add('valid');   set(fb,'✓ Valide','ok'); }
  }
  window.cfValidSel = cfValidSel;

  function set(el,msg,cls){ if(!el) return; el.textContent=msg; el.className='cf-feedback '+cls; }

  document.addEventListener('DOMContentLoaded', function(){
    const contenu=document.getElementById('contenuC');
    if(contenu){ cfCounterUpdate(contenu,'contenu-ctr'); if(contenu.value.trim()) cfValidTA(contenu,2,200); }
    ['idPublication','id_utilisateur'].forEach(id=>{
      const el=document.getElementById(id); if(el&&el.value) cfValidSel(el);
    });

    const form=contenu?contenu.closest('form'):null;
    if(!form) return;
    form.addEventListener('submit', function(e){
      let ok=true;
      if(contenu){ cfValidTA(contenu,2,200); if(contenu.classList.contains('invalid')) ok=false; }
      ['idPublication','id_utilisateur'].forEach(id=>{
        const el=document.getElementById(id);
        if(el){ cfValidSel(el); if(el.classList.contains('invalid')) ok=false; }
      });
      if(!ok){ e.preventDefault(); const first=form.querySelector('.invalid'); if(first) first.scrollIntoView({behavior:'smooth',block:'center'}); }
    });
  });
})();
</script>
