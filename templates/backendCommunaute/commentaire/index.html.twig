{% extends 'backend/baseend.html.twig' %}

{% block title %}
  {% if publication %}Commentaires — Publication #{{ publication.idPublication }}
  {% else %}Gestion des Commentaires{% endif %}
{% endblock %}

{% block body %}
<style>
@import url('https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap');
:root {
  --orange:#F7B731; --orange-deep:#e09d10; --orange-soft:rgba(247,183,49,.10);
  --orange-glow:rgba(247,183,49,.25); --border:#edf0f7; --surface:#fafbfc;
  --text-primary:#1a1d23; --text-secondary:#64748b; --text-muted:#94a3b8;
}
.cmnt-wrap { font-family:'DM Sans',sans-serif; }
.cmnt-topbar { display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:16px; margin-bottom:28px; }
.cmnt-topbar-left { display:flex; flex-direction:column; gap:6px; }
.btn-back { display:inline-flex; align-items:center; gap:6px; background:#fff; border:1.5px solid var(--border); border-radius:10px; padding:7px 14px; font-size:12px; font-weight:600; color:var(--text-secondary); text-decoration:none; transition:all .2s; width:fit-content; }
.btn-back:hover { border-color:var(--orange); color:var(--text-primary); background:var(--orange-soft); }
.cmnt-page-title { font-family:'Peter Bold',sans-serif; font-size:26px; font-weight:800; color:var(--text-primary); margin:0; line-height:1.2; }
.cmnt-subtitle { font-size:13px; color:var(--text-secondary); margin:0; }
.btn-new { display:inline-flex; align-items:center; gap:8px; background:linear-gradient(135deg,var(--orange),var(--orange-deep)); color:var(--text-primary); border:none; border-radius:14px; padding:12px 22px; font-weight:700; font-size:13px; text-decoration:none; box-shadow:0 4px 14px var(--orange-glow); transition:all .2s; white-space:nowrap; }
.btn-new:hover { transform:translateY(-2px); box-shadow:0 6px 20px var(--orange-glow); color:var(--text-primary); }

.flash-ok  { background:#d1fae5; color:#065f46; border:none; border-radius:12px; padding:13px 16px; font-size:13px; margin-bottom:16px; }
.flash-err { background:#fee2e2; color:#991b1b; border:none; border-radius:12px; padding:13px 16px; font-size:13px; margin-bottom:16px; }

.stat-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:24px; }
.stat-card { background:#fff; border:1.5px solid var(--border); border-radius:20px; padding:22px 20px; display:flex; align-items:center; gap:16px; box-shadow:0 2px 8px rgba(0,0,0,.04); transition:all .25s; position:relative; overflow:hidden; }
.stat-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; border-radius:20px 20px 0 0; }
.stat-card:hover { box-shadow:0 6px 20px rgba(0,0,0,.08); transform:translateY(-2px); }
.stat-card.orange::before { background:linear-gradient(90deg,var(--orange),var(--orange-deep)); }
.stat-card.green::before  { background:linear-gradient(90deg,#10b981,#059669); }
.stat-card.red::before    { background:linear-gradient(90deg,#ef4444,#dc2626); }
.stat-icon { width:48px; height:48px; border-radius:14px; display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; }
.stat-card.orange .stat-icon { background:var(--orange-soft); }
.stat-card.green  .stat-icon { background:rgba(16,185,129,.10); }
.stat-card.red    .stat-icon { background:rgba(239,68,68,.10); }
.stat-val { font-family:'Peter Bold',sans-serif; font-size:28px; font-weight:800; line-height:1; color:var(--text-primary); }
.stat-label { font-size:12px; color:var(--text-secondary); margin-top:4px; font-weight:500; }

.filter-card { background:#fff; border:1.5px solid var(--border); border-radius:16px; padding:20px 22px; box-shadow:0 2px 8px rgba(0,0,0,.04); margin-bottom:20px; }
.filter-label { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:1.2px; color:var(--text-muted); display:block; margin-bottom:7px; }
.f-input, .f-select { width:100%; border:1.5px solid var(--border); border-radius:10px; padding:10px 13px; font-size:13px; color:var(--text-primary); font-family:'DM Sans',sans-serif; background:#fff; transition:border-color .2s, box-shadow .2s; }
.f-input:focus, .f-select:focus { border-color:var(--orange); box-shadow:0 0 0 3px var(--orange-soft); outline:none; }
.filter-row { display:flex; gap:12px; align-items:flex-end; flex-wrap:wrap; }
.filter-row .fg { flex:1; min-width:180px; }
.filter-row .fg-sm { width:160px; flex-shrink:0; }
.filter-row .fg-xs { display:flex; gap:8px; flex-shrink:0; }
.btn-filter { background:linear-gradient(135deg,var(--orange),var(--orange-deep)); color:var(--text-primary); border:none; border-radius:10px; padding:10px 20px; font-weight:700; font-size:13px; cursor:pointer; transition:all .2s; box-shadow:0 2px 8px var(--orange-glow); }
.btn-filter:hover { transform:translateY(-1px); }
.btn-reset { background:var(--surface); border:1.5px solid var(--border); color:var(--text-secondary); border-radius:10px; padding:10px 14px; font-size:13px; font-weight:600; text-decoration:none; transition:all .2s; display:inline-flex; align-items:center; }
.btn-reset:hover { border-color:var(--orange); color:var(--text-primary); }

.table-card { background:#fff; border:1.5px solid var(--border); border-radius:16px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,.04); }

@media(max-width:768px){ .stat-grid{grid-template-columns:1fr;} .filter-row{flex-direction:column;} .filter-row .fg-sm,.filter-row .fg-xs{width:100%;} }
</style>

<div class="cmnt-wrap">

  <div class="cmnt-topbar">
    <div class="cmnt-topbar-left">
      {% if publication %}
        <a href="{{ path('app_admin_publication_show', {idPublication: publication.idPublication}) }}" class="btn-back">← Retour à la publication</a>
      {% endif %}
      <h1 class="cmnt-page-title">
        {% if publication %}Commentaires — #{{ publication.idPublication }}
        {% else %}Gestion des Commentaires{% endif %}
      </h1>
      <p class="cmnt-subtitle">
        {% if publication %}{{ publication.descriptionP|slice(0,80) }}…
        {% else %}Vue d'ensemble de tous les commentaires{% endif %}
      </p>
    </div>
    <a href="{{ path('app_admin_commentaire_new') }}" class="btn-new">➕ Nouveau commentaire</a>
  </div>

  {% for label, messages in app.flashes %}
    {% for message in messages %}
      <div class="alert flash-{{ label == 'error' ? 'err' : 'ok' }} alert-dismissible">
        {{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    {% endfor %}
  {% endfor %}

  {% if not publication %}
  <div class="stat-grid">
    <div class="stat-card orange">
      <div class="stat-icon">💬</div>
      <div><div class="stat-val">{{ totalCommentaires }}</div><div class="stat-label">Total commentaires</div></div>
    </div>
    <div class="stat-card green">
      <div class="stat-icon">✅</div>
      <div><div class="stat-val">{{ totalActifs }}</div><div class="stat-label">Actifs</div></div>
    </div>
    <div class="stat-card red">
      <div class="stat-icon">🚫</div>
      <div><div class="stat-val">{{ totalInactifs }}</div><div class="stat-label">Inactifs</div></div>
    </div>
  </div>

  <div class="filter-card">
    <form method="get" class="filter-row">
      <div class="fg">
        <label class="filter-label">🔍 Recherche</label>
        <input type="text" name="search" class="f-input" placeholder="Contenu, auteur…" value="{{ search ?? '' }}">
      </div>
      <div class="fg-sm">
        <label class="filter-label">📌 Statut</label>
        <select name="statut" class="f-select">
          <option value="">Tous les statuts</option>
          <option value="1" {{ (statut ?? '') == '1' ? 'selected' : '' }}>✅ Actif</option>
          <option value="0" {{ (statut ?? '') == '0' ? 'selected' : '' }}>🚫 Inactif</option>
        </select>
      </div>
      <div class="fg-xs" style="margin-top:auto;">
        <button type="submit" class="btn-filter">Filtrer</button>
        <a href="{{ path('app_admin_commentaire_index') }}" class="btn-reset">↺</a>
      </div>
    </form>
  </div>
  {% endif %}

  <div class="table-card">
    {% include 'backendCommunaute/commentaire/_table.html.twig' %}
  </div>

</div>
{% endblock %}
