{% extends 'backend/baseend.html.twig' %}

{% block title %}Gestion des utilisateurs - RE7LA Admin{% endblock %}
{% block breadcrumb %}Utilisateurs{% endblock %}
{% block page_title %}Gestion des utilisateurs{% endblock %}

{% block body %}
<div id="usersToast" style="display:none;padding:14px 16px;border-radius:12px;margin-bottom:16px;font-weight:600;"></div>

{% for message in app.flashes('success') %}
    <div style="background:#dcfce7;color:#166534;padding:14px 16px;border-radius:12px;margin-bottom:16px;">
        {{ message }}
    </div>
{% endfor %}

{% for message in app.flashes('error') %}
    <div style="background:#fee2e2;color:#b91c1c;padding:14px 16px;border-radius:12px;margin-bottom:16px;">
        {{ message }}
    </div>
{% endfor %}

<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-bottom:24px;">
    <div class="card" style="padding:20px;border-radius:18px;text-align:center;">
        <h3 style="margin:0;font-size:30px;color:#1ABC9C;">{{ totalUsers }}</h3>
        <p style="margin:8px 0 0;color:#64748b;">Total utilisateurs</p>
    </div>
    <div class="card" style="padding:20px;border-radius:18px;text-align:center;">
        <h3 style="margin:0;font-size:30px;color:#2C3E50;">{{ totalAdmins }}</h3>
        <p style="margin:8px 0 0;color:#64748b;">Admins</p>
    </div>
    <div class="card" style="padding:20px;border-radius:18px;text-align:center;">
        <h3 style="margin:0;font-size:30px;color:#F39C12;">{{ totalSimpleUsers }}</h3>
        <p style="margin:8px 0 0;color:#64748b;">Utilisateurs simples</p>
    </div>
    <div class="card" style="padding:20px;border-radius:18px;text-align:center;">
        <h3 style="margin:0;font-size:30px;color:#e74c3c;">{{ totalBanned }}</h3>
        <p style="margin:8px 0 0;color:#64748b;">Bannis</p>
    </div>
</div>

<div style="display:flex;justify-content:flex-end;margin-bottom:16px;">
    <a href="#" id="exportPdfBtn"
       style="background:#e74c3c;color:white;padding:12px 22px;border-radius:12px;text-decoration:none;font-weight:600;display:inline-flex;align-items:center;gap:8px;box-shadow:0 4px 12px rgba(231,76,60,0.25);transition:transform 0.2s;"
       onmouseover="this.style.transform='translateY(-2px)'"
       onmouseout="this.style.transform='translateY(0)'">
        📄 Exporter en PDF
    </a>
</div>

<div class="card" style="padding:20px;border-radius:20px;margin-bottom:24px;">
    <div style="display:grid;grid-template-columns:2fr 1fr 1fr;gap:16px;">
        <div>
            <label style="display:block;margin-bottom:8px;font-weight:600;">Recherche</label>
            <input
                type="text"
                id="searchInput"
                value="{{ search }}"
                placeholder="Nom, prénom, email, téléphone"
                style="width:100%;padding:12px 14px;border:1px solid #dbe2ea;border-radius:12px;"
            >
        </div>

        <div>
            <label style="display:block;margin-bottom:8px;font-weight:600;">Rôle</label>
            <select id="roleFilter" style="width:100%;padding:12px 14px;border:1px solid #dbe2ea;border-radius:12px;">
                <option value="">Tous</option>
                <option value="admin" {% if role == 'admin' %}selected{% endif %}>admin</option>
                <option value="user" {% if role == 'user' %}selected{% endif %}>user</option>
            </select>
        </div>

        <div>
            <label style="display:block;margin-bottom:8px;font-weight:600;">Statut</label>
            <select id="statusFilter" style="width:100%;padding:12px 14px;border:1px solid #dbe2ea;border-radius:12px;">
                <option value="">Tous</option>
                <option value="Unbanned" {% if status == 'Unbanned' %}selected{% endif %}>Unbanned</option>
                <option value="Banned" {% if status == 'Banned' %}selected{% endif %}>Banned</option>
            </select>
        </div>
    </div>
</div>

<div id="usersTableContainer">
    {% include 'backend/users/_table.html.twig' with { users: users } %}
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const searchInput = document.getElementById('searchInput');
    const roleFilter = document.getElementById('roleFilter');
    const statusFilter = document.getElementById('statusFilter');
    const usersTableContainer = document.getElementById('usersTableContainer');
    const toast = document.getElementById('usersToast');
    const exportPdfBtn = document.getElementById('exportPdfBtn');

    let debounceTimer = null;

    function showToast(message, success = true) {
        toast.style.display = 'block';
        toast.textContent = message;
        toast.style.background = success ? '#dcfce7' : '#fee2e2';
        toast.style.color = success ? '#166534' : '#b91c1c';

        setTimeout(() => {
            toast.style.display = 'none';
        }, 2500);
    }

    function loadUsers() {
        const params = new URLSearchParams({
            search: searchInput.value,
            role: roleFilter.value,
            status: statusFilter.value
        });

        fetch('/admin/users/ajax/list?' + params.toString(), {
            headers: {
                'X-Requested-With': 'XMLHttpRequest'
            }
        })
        .then(response => response.text())
        .then(html => {
            usersTableContainer.innerHTML = html;
            bindActionButtons();
        });
    }

    function bindActionButtons() {
        document.querySelectorAll('.ban-toggle-btn').forEach(button => {
            button.addEventListener('click', function () {
                const userId = this.dataset.id;

                fetch('/admin/users/' + userId + '/ban-toggle', {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    showToast(data.message, data.success);

                    if (data.success) {
                        loadUsers();
                    }
                });
            });
        });

        document.querySelectorAll('.delete-user-btn').forEach(button => {
            button.addEventListener('click', function () {
                const userId = this.dataset.id;

                if (!confirm('Supprimer cet utilisateur ?')) {
                    return;
                }

                fetch('/admin/users/' + userId + '/delete', {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    showToast(data.message, data.success);

                    if (data.success) {
                        loadUsers();
                    }
                });
            });
        });
    }

    // Export PDF avec les filtres actifs
    exportPdfBtn.addEventListener('click', function (e) {
        e.preventDefault();
        const params = new URLSearchParams({
            search: searchInput.value,
            role: roleFilter.value,
            status: statusFilter.value
        });
        window.location.href = '/admin/users/export/pdf?' + params.toString();
    });

    searchInput.addEventListener('input', function () {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(loadUsers, 300);
    });

    roleFilter.addEventListener('change', loadUsers);
    statusFilter.addEventListener('change', loadUsers);

    bindActionButtons();
});
</script>
{% endblock %}