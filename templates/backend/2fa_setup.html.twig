{% extends 'backend/baseend.html.twig' %}

{% block title %}Activer la 2FA - Admin RE7LA{% endblock %}

{% block breadcrumb %}2FA{% endblock %}
{% block page_title %}Activer la Double Authentification{% endblock %}

{% block body %}
<div style="max-width:560px;margin:0 auto;">
    <div style="background:#fff;border-radius:20px;padding:40px;box-shadow:0 4px 20px rgba(0,0,0,0.08);text-align:center;">
        <h2 style="font-size:22px;font-weight:700;color:#2C3E50;margin-bottom:8px;">
            <i class="fas fa-shield-alt" style="color:#1ABC9C;"></i> Activer la 2FA
        </h2>
        <p style="color:#6b7280;font-size:14px;margin-bottom:24px;">Scannez le QR code avec Google Authenticator</p>

        <div style="background:#fff;border-radius:16px;padding:20px;display:inline-block;box-shadow:0 6px 18px rgba(0,0,0,0.08);margin-bottom:16px;">
            <img src="{{ qrCodeDataUri }}" alt="QR Code 2FA" style="border-radius:8px;">
        </div>

        <div style="background:#f8fafc;border:2px dashed #e8ecf0;border-radius:12px;padding:12px;margin-bottom:24px;word-break:break-all;">
            <small style="color:#6b7280;font-size:11px;">Cle manuelle :</small><br>
            <code style="font-size:14px;font-weight:800;letter-spacing:2px;color:#2C3E50;word-break:break-all;">{{ secret }}</code>
        </div>

        {% if error %}
            <div style="background:#fee2e2;border:1px solid rgba(239,68,68,0.2);color:#991b1b;padding:12px;border-radius:12px;margin-bottom:16px;font-size:14px;font-weight:600;">
                <i class="fas fa-exclamation-circle"></i> {{ error }}
            </div>
        {% endif %}

        <form method="post">
            <input type="hidden" name="secret" value="{{ secret }}">
            <input type="text" name="code" placeholder="000000" maxlength="6" inputmode="numeric" autocomplete="off" autofocus required
                style="width:100%;height:56px;border:2px solid #e8ecf0;border-radius:14px;text-align:center;font-size:22px;font-weight:800;letter-spacing:6px;color:#2C3E50;background:#f8fafc;outline:none;margin-bottom:16px;">

            <button type="submit" style="width:100%;height:50px;border:none;border-radius:14px;background:linear-gradient(135deg,#1ABC9C,#16a085);color:#fff;font-size:15px;font-weight:700;cursor:pointer;">
                <i class="fas fa-check-circle"></i> Activer la 2FA
            </button>
        </form>

        <a href="{{ path('app_admin_profile') }}" style="display:block;margin-top:16px;color:#6b7280;font-size:13px;text-decoration:none;">
            <i class="fas fa-arrow-left"></i> Retour au profil
        </a>
    </div>
</div>
{% endblock %}