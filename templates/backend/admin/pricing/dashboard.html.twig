{% extends 'backend/baseend.html.twig' %}

{% block title %}Pricing Intelligence Center - RE7LA Admin{% endblock %}

{% block breadcrumb %}IA & Intelligence{% endblock %}
{% block page_title %}Pricing Intelligence Center ("Le Cerveau"){% endblock %}

{% block stylesheets %}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    .market-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-bottom: 32px; }
    .market-card { background: white; border-radius: 20px; padding: 24px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: 1px solid #f0f2f5; transition: all 0.3s ease; }
    .market-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(0,0,0,0.1); }
    .city-badge { font-size: 10px; font-weight: 800; text-transform: uppercase; color: #94a3b8; letter-spacing: 1px; margin-bottom: 12px; display: block; }
    .market-val { font-size: 24px; font-weight: 800; color: #2C3E50; display: flex; align-items: center; gap: 8px; }
    .trend-indicator { font-size: 12px; font-weight: 700; padding: 4px 8px; border-radius: 20px; }
    .trend-up { background: #d1fae5; color: #065f46; }
    .trend-down { background: #fee2e2; color: #991b1b; }

    .pricing-table { background: white; border-radius: 24px; padding: 32px; box-shadow: 0 10px 40px rgba(0,0,0,0.03); border: 1px solid #f0f2f5; }
    .h-row { transition: all 0.2s; border-radius: 12px; }
    .h-row:hover { background: #f8fafc; }
    
    .status-pill { padding: 6px 12px; border-radius: 12px; font-size: 11px; font-weight: 700; text-transform: uppercase; }
    .status-UP { background: rgba(52, 152, 219, 0.1); color: #3498DB; }
    .status-UP_MAX { background: rgba(231, 76, 60, 0.1); color: #E74C3C; }
    .status-DOWN { background: rgba(26, 188, 156, 0.1); color: #1ABC9C; }
    .status-STABLE { background: rgba(148, 163, 184, 0.1); color: #64748b; }

    /* Toggle Switch */
    .switch { position: relative; display: inline-block; width: 44px; height: 24px; }
    .switch input { opacity: 0; width: 0; height: 0; }
    .slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #e2e8f0; transition: .4s; border-radius: 34px; }
    .slider:before { position: absolute; content: ""; height: 18px; width: 18px; left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%; }
    input:checked + .slider { background-color: #1ABC9C; }
    input:checked + .slider:before { transform: translateX(20px); }

    .action-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; cursor: pointer; transition: 0.2s; }
    .action-icon:hover { transform: scale(1.1); }
</style>
{% endblock %}

{% block body %}
<!-- 1. Market Overview Row -->
<div class="market-grid">
    <!-- Section A: Vols -->
    <div class="market-card">
        <span class="city-badge">Trafic Aérien Global</span>
        <div style="display:flex; justify-content:space-between; align-items:flex-end;">
            <div>
                <div class="market-val"><i class="fas fa-plane" style="color:#3498DB;"></i> 142</div>
                <div style="font-size:11px; color:#64748b; margin-top:4px;">Vols suivis aujourd'hui</div>
            </div>
            <span class="trend-indicator trend-up"><i class="fas fa-caret-up"></i> +12%</span>
        </div>
        <div style="margin-top:20px; display:flex; gap:4px;">
            {% for city, s in stats %}
            <div style="flex:1; height:4px; background:{{ s.flights > 60 ? '#3498DB' : '#e2e8f0' }}; border-radius:4px;" title="{{ city }}: {{ s.flights }}%"></div>
            {% endfor %}
        </div>
    </div>

    <!-- Section B: Météo -->
    <div class="market-card">
        <span class="city-badge">Conditions Météo</span>
        <div style="display:flex; justify-content:space-between; align-items:flex-end;">
            <div>
                <div class="market-val"><i class="fas fa-sun" style="color:#F1C40F;"></i> 24°C</div>
                <div style="font-size:11px; color:#64748b; margin-top:4px;">Moyenne côtière optimale</div>
            </div>
            <span class="trend-indicator trend-up"><i class="fas fa-thumbs-up"></i> Favorable</span>
        </div>
        <div style="margin-top:20px; display:flex; justify-content:space-between; font-size:14px;">
            {% for city, s in stats %}
            <i class="fas {{ s.weather > 60 ? 'fa-sun text-warning' : 'fa-cloud text-muted' }}" title="{{ city }}"></i>
            {% endfor %}
        </div>
    </div>

    <!-- Section C: Evénements -->
    <div class="market-card">
        <span class="city-badge">Calendrier Événements</span>
        <div style="display:flex; justify-content:space-between; align-items:flex-end;">
            <div>
                <div class="market-val"><i class="fas fa-calendar-star" style="color:#9B59B6;"></i> 2</div>
                <div style="font-size:11px; color:#64748b; margin-top:4px;">Festivals actifs cette semaine</div>
            </div>
            <span class="trend-indicator trend-up" style="background:rgba(155, 89, 182, 0.1); color:#9B59B6;">Haute</span>
        </div>
    </div>

    <!-- Section D: Taux d'occupation -->
    <div class="market-card">
        <span class="city-badge">Occupation Interne</span>
        <div style="display:flex; justify-content:space-between; align-items:flex-end;">
            <div>
                <div class="market-val"><i class="fas fa-bed" style="color:#1ABC9C;"></i> 64%</div>
                <div style="font-size:11px; color:#64748b; margin-top:4px;">Taux de remplissage global</div>
            </div>
            <span class="trend-indicator trend-up"><i class="fas fa-fire"></i> +5%</span>
        </div>
    </div>
</div>

<!-- 2. Main Intelligence Table -->
<div class="pricing-table">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:30px;">
        <div>
            <h2 style="font-size:20px; font-weight:800; color:#2C3E50;">Console de Pilotage IA</h2>
            <p style="color:#94a3b8; font-size:13px;">Gérez l'automatisation et surveillez les ajustements conseillés.</p>
        </div>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Hébergement</th>
                <th>Mode IA</th>
                <th>Score Demande</th>
                <th>Prix Actuel</th>
                <th>Recommandation</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for item in pricingList %}
            {% set h = item.hebergement %}
            {% set p = item.pricing %}
            <tr class="h-row" id="row-{{ h.id }}">
                <td style="font-weight:700; color:#2C3E50;">
                    {{ h.titre }}
                    <div style="font-size:10px; color:#94a3b8; font-weight:400;">{{ h.typeHebergement }} • {{ h.capacite }} Voyageurs</div>
                </td>
                <td>
                    <label class="switch">
                        <input type="checkbox" class="toggle-pricing" data-id="{{ h.id }}" {{ p.isEnabled ? 'checked' : '' }}>
                        <span class="slider"></span>
                    </label>
                </td>
                <td>
                    <div style="display:flex; align-items:center; gap:10px;">
                        <div style="flex:1; height:6px; background:#eee; border-radius:10px; width:60px; overflow:hidden;">
                            <div style="width:{{ p.score }}%; height:100%; background:{{ p.score > 80 ? '#E74C3C' : (p.score > 60 ? '#F39C12' : '#1ABC9C') }};"></div>
                        </div>
                        <span style="font-weight:800;">{{ p.score }}</span>
                    </div>
                </td>
                <td style="font-weight:600; color:#94a3b8;" class="current-price">{{ h.prixParNuit }} DT</td>
                <td style="font-weight:800; color:#2C3E50; font-size:15px;">
                    {{ p.recommendedPrice }} DT
                    <span style="font-size:10px; color:{{ p.adjustment_pct >= 0 ? '#1ABC9C' : '#E74C3C' }}; margin-left:4px;">
                        {{ p.adjustment_pct >= 0 ? '+' : '' }}{{ p.adjustment_pct }}%
                    </span>
                </td>
                <td>
                    <span class="status-pill status-{{ p.status }}">
                        {{ p.status == 'UP' or p.status == 'UP_MAX' ? '🔼 HAUSSE' : (p.status == 'DOWN' ? '🔽 BAISSE' : '⚖️ STABLE') }}
                    </span>
                </td>
                <td>
                    <div style="display:flex; gap:8px;">
                        <div class="action-icon" style="background:#f1f5f9; color:#64748b;" onclick="showExplanation({{ h.id }}, '{{ p.explanation|escape('js') }}')" title="Explication">
                            <i class="fas fa-info-circle"></i>
                        </div>
                        {% if not p.isEnabled %}
                        <div class="action-icon" style="background:rgba(26,188,156,0.1); color:#1ABC9C;" title="Appliquer manuellement" onclick="applyManually({{ h.id }})">
                            <i class="fas fa-check"></i>
                        </div>
                        {% endif %}
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

<!-- Explanation Modal -->
<div class="modal fade" id="infoModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content" style="border-radius:24px; border:none; box-shadow:0 20px 60px rgba(0,0,0,0.2);">
      <div class="modal-header" style="border:none; padding:30px 30px 10px;">
        <h5 class="modal-title" style="font-weight:800; color:#2C3E50;">Explication IA</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" style="padding:30px;">
        <div id="infoContent" style="background:#f8fafc; border-radius:16px; padding:20px; line-height:1.6; color:#64748b; font-style:italic;">
        </div>
      </div>
    </div>
  </div>
</div>

</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function showExplanation(id, text) {
        console.log("Showing explanation for ID:", id, "Text:", text);
        const modalEl = document.getElementById('infoModal');
        const contentEl = document.getElementById('infoContent');
        
        if (!modalEl || !contentEl) {
            console.error("Modal elements not found!");
            return;
        }

        contentEl.innerText = text || "Aucune explication disponible.";
        
        try {
            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
            modal.show();
        } catch (e) {
            console.error("Bootstrap Modal error:", e);
            // Fallback for older BS or load issues
            modalEl.classList.add('show');
            modalEl.style.display = 'block';
            document.body.classList.add('modal-open');
        }
    }

    // Toggle logic
    document.querySelectorAll('.toggle-pricing').forEach(toggle => {
        toggle.addEventListener('change', async function() {
            const id = this.dataset.id;
            try {
                const response = await fetch(`/admin/api/pricing/toggle/${id}`, { method: 'POST' });
                const data = await response.json();
                
                const row = document.getElementById(`row-${id}`);
                const priceCell = row.querySelector('.current-price');

                if (data.success && data.enabled && data.newPrice) {
                    // Update the current price cell in the UI
                    priceCell.innerText = data.newPrice + ' DT';
                    priceCell.style.color = '#1ABC9C'; // Highlight green
                } else if (data.success && !data.enabled) {
                    priceCell.style.color = '#E74C3C'; // Highlight red
                }
                
                setTimeout(() => { priceCell.style.color = '#94a3b8'; }, 2000);
            } catch (e) {
                console.error("Toggle failed", e);
                alert("Erreur lors de la communication avec le serveur.");
                this.checked = !this.checked; // Revert
            }
        });
    });

    async function applyManually(id) {
        if (!confirm("Voulez-vous appliquer le prix recommandé manuellement ?")) return;
        
        try {
            // Turning ON triggers price application in our controller
            const response = await fetch(`/admin/api/pricing/toggle/${id}`, { method: 'POST' });
            const data = await response.json();
            
            if (data.success && data.newPrice) {
                const row = document.getElementById(`row-${id}`);
                row.querySelector('.current-price').innerText = data.newPrice + ' DT';
                
                // Immediately turn OFF to simulate manual one-time apply if it was OFF
                if (data.enabled) {
                    await fetch(`/admin/api/pricing/toggle/${id}`, { method: 'POST' });
                    row.querySelector('.toggle-pricing').checked = false;
                }
                
                alert("Prix mis à jour avec succès !");
            }
        } catch (e) {
            console.error("Apply failed", e);
        }
    }
</script>
{% endblock %}
