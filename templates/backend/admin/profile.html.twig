{% extends 'backend/baseend.html.twig' %}

{% block title %}Profil Admin - RE7LA Admin{% endblock %}

{% block breadcrumb %}Profil{% endblock %}
{% block page_title %}Mon Profil{% endblock %}

{% block body %}
<div style="max-width:1200px;margin:0 auto;">
  {% for message in app.flashes('success') %}
    <div style="background:#d1fae5;color:#065f46;padding:14px 18px;border-radius:12px;margin-bottom:20px;font-weight:600;">
      {{ message }}
    </div>
  {% endfor %}

  {% for message in app.flashes('error') %}
    <div style="background:#fee2e2;color:#991b1b;padding:14px 18px;border-radius:12px;margin-bottom:20px;font-weight:600;">
      {{ message }}
    </div>
  {% endfor %}

  <div style="background:linear-gradient(135deg,#1ABC9C 0%,#16a085 50%,#2C3E50 100%);border-radius:20px;padding:40px;color:#fff;position:relative;overflow:hidden;margin-bottom:30px;">
    <div style="position:absolute;top:-50px;right:-50px;width:200px;height:200px;background:rgba(255,255,255,0.1);border-radius:50%;"></div>
    <div style="position:absolute;bottom:-30px;left:-30px;width:150px;height:150px;background:rgba(255,255,255,0.05);border-radius:50%;"></div>
    
    <div style="display:flex;align-items:center;justify-content:space-between;position:relative;z-index:1;gap:20px;flex-wrap:wrap;">
      <div style="display:flex;align-items:center;gap:24px;flex-wrap:wrap;">
        <div style="width:120px;height:120px;background:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 10px 30px rgba(0,0,0,0.2);border:4px solid rgba(255,255,255,0.2);overflow:hidden;font-size:36px;font-weight:700;color:#1ABC9C;">
          {% if app.user.image %}
            <img src="{{ asset('uploads/profiles/' ~ app.user.image) }}" alt="Photo de profil" style="width:100%;height:100%;object-fit:cover;">
          {% else %}
            {{ app.user.prenom|slice(0,1)|upper }}{{ app.user.nom|slice(0,1)|upper }}
          {% endif %}
        </div>

        <div>
          <h1 style="font-size:28px;font-weight:700;margin-bottom:8px;">{{ app.user.prenom }} {{ app.user.nom }}</h1>
          <p style="font-size:16px;opacity:0.92;margin-bottom:6px;">
            <i class="fas fa-envelope" style="margin-right:8px;"></i>{{ app.user.e_mail }}
          </p>
          <p style="font-size:14px;opacity:0.85;margin-bottom:4px;">
            <i class="fas fa-phone" style="margin-right:8px;"></i>{{ app.user.num_tel ?: 'Non renseigné' }}
          </p>
          <p style="font-size:14px;opacity:0.85;">
            <i class="fas fa-shield-alt" style="margin-right:8px;"></i>
            {% if app.user.role == 'admin' %}Super Administrateur{% else %}Utilisateur{% endif %}
          </p>
        </div>
      </div>

      <a href="{{ path('app_admin_profile_edit') }}" style="background:#fff;color:#1ABC9C;border:none;padding:12px 24px;border-radius:12px;font-weight:600;cursor:pointer;transition:all 0.3s;display:inline-flex;align-items:center;gap:8px;text-decoration:none;">
        <i class="fas fa-edit"></i>
        Modifier le profil
      </a>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:1fr 2fr;gap:24px;">
    <div style="display:flex;flex-direction:column;gap:24px;">
      <div style="background:#fff;border-radius:20px;padding:24px;box-shadow:0 4px 20px rgba(0,0,0,0.08);border:1px solid #f0f2f5;">
        <h3 style="font-size:18px;font-weight:700;color:#2C3E50;margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid #f0f2f5;display:flex;align-items:center;gap:8px;">
          <i class="fas fa-user" style="color:#1ABC9C;"></i>
          Informations Personnelles
        </h3>
        
        <div style="display:flex;flex-direction:column;gap:16px;">
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:40px;height:40px;background:rgba(26,188,156,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-id-card" style="color:#1ABC9C;font-size:16px;"></i>
            </div>
            <div>
              <div style="font-size:12px;color:#64748b;">Nom complet</div>
              <div style="font-weight:600;color:#2C3E50;">{{ app.user.prenom }} {{ app.user.nom }}</div>
            </div>
          </div>
          
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:40px;height:40px;background:rgba(243,156,18,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-envelope" style="color:#F39C12;font-size:16px;"></i>
            </div>
            <div>
              <div style="font-size:12px;color:#64748b;">Email</div>
              <div style="font-weight:600;color:#2C3E50;">{{ app.user.e_mail }}</div>
            </div>
          </div>
          
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:40px;height:40px;background:rgba(239,68,68,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-phone" style="color:#ef4444;font-size:16px;"></i>
            </div>
            <div>
              <div style="font-size:12px;color:#64748b;">Téléphone</div>
              <div style="font-weight:600;color:#2C3E50;">{{ app.user.num_tel ?: 'Non renseigné' }}</div>
            </div>
          </div>
          
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:40px;height:40px;background:rgba(139,92,246,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-calendar" style="color:#8b5cf6;font-size:16px;"></i>
            </div>
            <div>
              <div style="font-size:12px;color:#64748b;">Date de naissance</div>
              <div style="font-weight:600;color:#2C3E50;">{{ app.user.date_naiss ?: 'Non renseignée' }}</div>
            </div>
          </div>
        </div>
      </div>

      <div style="background:#fff;border-radius:20px;padding:24px;box-shadow:0 4px 20px rgba(0,0,0,0.08);border:1px solid #f0f2f5;">
        <h3 style="font-size:18px;font-weight:700;color:#2C3E50;margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid #f0f2f5;display:flex;align-items:center;gap:8px;">
          <i class="fas fa-shield-alt" style="color:#1ABC9C;"></i>
          Sécurité
        </h3>
        
        <div style="display:flex;flex-direction:column;gap:16px;">
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:40px;height:40px;background:rgba(34,197,94,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-check-circle" style="color:#22c55e;font-size:16px;"></i>
            </div>
            <div style="flex:1;">
              <div style="font-size:12px;color:#64748b;">Statut du compte</div>
              <div style="font-weight:600;color:#2C3E50;">{{ app.user.status }}</div>
            </div>
            <span style="background:rgba(34,197,94,0.15);color:#22c55e;padding:4px 12px;border-radius:20px;font-size:11px;font-weight:600;">
              {{ app.user.email_verified ? 'Vérifié' : 'Non vérifié' }}
            </span>
          </div>
          
          <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:40px;height:40px;background:rgba(59,130,246,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-user-tag" style="color:#3b82f6;font-size:16px;"></i>
            </div>
            <div>
              <div style="font-size:12px;color:#64748b;">Rôle</div>
              <div style="font-weight:600;color:#2C3E50;">
                {% if app.user.role == 'admin' %}Administrateur{% else %}Utilisateur{% endif %}
              </div>
            </div>
          </div>

          <div style="display:flex;align-items:center;gap:12px;">
            <div style="width:40px;height:40px;background:rgba(168,85,247,0.15);border-radius:10px;display:flex;align-items:center;justify-content:center;">
              <i class="fas fa-fingerprint" style="color:#a855f7;font-size:16px;"></i>
            </div>
            <div>
              <div style="font-size:12px;color:#64748b;">Accès</div>
              <div style="font-weight:600;color:#2C3E50;">Compte connecté</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div>
      <div style="background:#fff;border-radius:20px;padding:32px;box-shadow:0 4px 20px rgba(0,0,0,0.08);border:1px solid #f0f2f5;">
        <h3 style="font-size:20px;font-weight:700;color:#2C3E50;margin-bottom:24px;display:flex;align-items:center;gap:8px;">
          <i class="fas fa-user-circle" style="color:#1ABC9C;"></i>
          Résumé du compte
        </h3>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;">
          <div class="card" style="padding:20px;border-radius:16px;background:#f8fafc;">
            <strong>ID :</strong> {{ app.user.id }}
          </div>

          <div class="card" style="padding:20px;border-radius:16px;background:#f8fafc;">
            <strong>Email :</strong> {{ app.user.e_mail }}
          </div>

          <div class="card" style="padding:20px;border-radius:16px;background:#f8fafc;">
            <strong>Rôle :</strong>
            {% if app.user.role == 'admin' %}Administrateur{% else %}Utilisateur{% endif %}
          </div>

          <div class="card" style="padding:20px;border-radius:16px;background:#f8fafc;">
            <strong>Statut :</strong> {{ app.user.status }}
          </div>

          <div class="card" style="padding:20px;border-radius:16px;background:#f8fafc;">
            <strong>Téléphone :</strong> {{ app.user.num_tel ?: 'Non renseigné' }}
          </div>

          <div class="card" style="padding:20px;border-radius:16px;background:#f8fafc;">
            <strong>Date de naissance :</strong> {{ app.user.date_naiss ?: 'Non renseignée' }}
          </div>
        </div>

        <div style="margin-top:28px;padding-top:22px;border-top:1px solid #f0f2f5;display:flex;gap:12px;flex-wrap:wrap;">
          <a href="{{ path('app_admin_profile_edit') }}" style="background:linear-gradient(135deg,#1ABC9C,#16a085);color:#fff;border:none;padding:12px 20px;border-radius:12px;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:8px;">
            <i class="fas fa-user-edit"></i>
            Modifier mes informations
          </a>

          <a href="{{ path('app_logout') }}" style="background:#fff;color:#ef4444;border:2px solid #fee2e2;padding:12px 20px;border-radius:12px;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:8px;">
            <i class="fas fa-sign-out-alt"></i>
            Déconnexion
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
{% endblock %}