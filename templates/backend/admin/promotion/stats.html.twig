{% extends 'backend/baseend.html.twig' %}

{% block title %}Statistiques Promotions - RE7LA Admin{% endblock %}
{% block breadcrumb %}Promotions / Statistiques{% endblock %}
{% block page_title %}Analyse des Performances{% endblock %}

{% block stylesheets %}
<style>
    /* Animated Background */
    #stats-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    }

    .stat-card {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 20px;
        padding: 20px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.03);
        height: 100%;
        transition: transform 0.3s ease;
    }
    .stat-card:hover {
        transform: translateY(-5px);
    }

    .kpi-card {
        padding: 20px;
        border-radius: 20px;
        color: #fff;
        display: flex;
        flex-direction: column;
        justify-content: center;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

    .chart-container {
        position: relative;
        margin: auto;
        height: 250px; /* Reduced height */
        width: 100%;
    }
</style>
{% endblock %}

{% block body %}
<canvas id="stats-canvas"></canvas>

<div class="row mb-4" data-aos="fade-down">
    <div class="col-12" style="display:flex;justify-content:space-between;align-items:center;">
        <a href="{{ path('app_admin_promotion_list') }}" class="btn btn-sm" style="background:rgba(255,255,255,0.7);backdrop-filter:blur(5px);color:#64748b;border:1px solid #e2e8f0;border-radius:10px;padding:8px 16px;text-decoration:none;font-weight:600;display:flex;align-items:center;gap:8px;">
            <i class="fas fa-arrow-left"></i> Retour
        </a>
        <a href="{{ path('app_admin_promotion_stats_pdf') }}" class="btn btn-sm" 
           style="background:linear-gradient(135deg,#e74c3c,#c0392b);color:#fff;border-radius:10px;padding:8px 16px;text-decoration:none;display:inline-flex;align-items:center;gap:6px;font-weight:600;"
           data-aos="fade-left" data-aos-delay="200">
            <i class="fas fa-file-pdf"></i> Exporter PDF
        </a>
    </div>
</div>

<!-- KPIs -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="kpi-card" style="background: linear-gradient(135deg, #3498db, #2980b9);">
            <div style="font-size: 11px; font-weight: 700; opacity: 0.8; text-transform: uppercase;">Promotions Actives</div>
            <div style="font-size: 28px; font-weight: 800;">{{ totalPromos }}</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="kpi-card" style="background: linear-gradient(135deg, #1abc9c, #16a085);">
            <div style="font-size: 11px; font-weight: 700; opacity: 0.8; text-transform: uppercase;">Réservations</div>
            <div style="font-size: 28px; font-weight: 800;">{{ totalReservations }}</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="kpi-card" style="background: linear-gradient(135deg, #f1c40f, #f39c12);">
            <div style="font-size: 11px; font-weight: 700; opacity: 0.8; text-transform: uppercase;">Engagement Client</div>
            <div style="font-size: 28px; font-weight: 800;">{{ topUsers|length }} VIPs</div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Bar Chart -->
    <div class="col-lg-7 mb-4">
        <div class="stat-card" data-aos="fade-right">
            <h5 style="font-weight: 700; margin-bottom: 20px; color: #2d3748; font-size: 15px;">Performance des Promotions</h5>
            <div class="chart-container">
                <canvas id="topPromosChart"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Doughnut Chart -->
    <div class="col-lg-5 mb-4">
        <div class="stat-card" data-aos="fade-left">
            <h5 style="font-weight: 700; margin-bottom: 20px; color: #2d3748; font-size: 15px;">Répartition par Type</h5>
            <div class="chart-container">
                <canvas id="typeDistChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Users Lists -->
    <div class="col-lg-4 mb-4">
        <div class="stat-card" data-aos="fade-up">
            <h5 style="font-weight: 700; margin-bottom: 20px; color: #2d3748; font-size: 14px;">
                <i class="fas fa-crown text-warning"></i> Meilleurs Clients
            </h5>
            <div style="display: flex; flex-direction: column; gap: 10px;">
                {% for email, count in topUsers %}
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 15px; background: rgba(26,188,156,0.05); border-radius: 12px; border: 1px solid rgba(26,188,156,0.1);">
                    <div style="font-size: 12px; font-weight: 600; color: #2d3748; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;">{{ email }}</div>
                    <span class="badge rounded-pill" style="background: #1abc9c;">{{ count }}</span>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-4">
        <div class="stat-card" data-aos="fade-up" data-aos-delay="100">
            <h5 style="font-weight: 700; margin-bottom: 20px; color: #2d3748; font-size: 14px;">
                <i class="fas fa-arrow-down text-danger"></i> Moins Actifs
            </h5>
            <div style="display: flex; flex-direction: column; gap: 10px;">
                {% for email, count in leastUsers %}
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 15px; background: rgba(231,76,60,0.05); border-radius: 12px; border: 1px solid rgba(231,76,60,0.1);">
                    <div style="font-size: 12px; font-weight: 600; color: #2d3748; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 150px;">{{ email }}</div>
                    <span class="badge rounded-pill" style="background: #e74c3c;">{{ count }}</span>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-4">
        <div class="stat-card" data-aos="fade-up" data-aos-delay="200">
            <h5 style="font-weight: 700; margin-bottom: 20px; color: #2d3748; font-size: 14px;">
                <i class="fas fa-box-open text-primary"></i> Top Packs Combo
            </h5>
            <div style="display: flex; flex-direction: column; gap: 10px;">
                {% for pack in bestPacks %}
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 10px 15px; background: rgba(52,152,219,0.05); border-radius: 12px; border: 1px solid rgba(52,152,219,0.1);">
                    <div style="font-size: 12px; font-weight: 600; color: #2d3748;">{{ pack.name }}</div>
                    <span style="font-size: 11px; font-weight: 700; color: #3498db;">{{ pack.count }} v.</span>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // 1. Top Promotions Chart
    new Chart(document.getElementById('topPromosChart'), {
        type: 'bar',
        data: {
            labels: {{ topPromosLabels|json_encode|raw }},
            datasets: [{
                label: 'Réservations',
                data: {{ topPromosData|json_encode|raw }},
                backgroundColor: 'rgba(52, 152, 219, 0.7)',
                borderColor: '#3498db',
                borderWidth: 1,
                borderRadius: 5
            }]
        },
        options: {
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { font: { size: 10 } } },
                x: { ticks: { font: { size: 9 } } }
            }
        }
    });

    // 2. Type Distribution Chart
    new Chart(document.getElementById('typeDistChart'), {
        type: 'doughnut',
        data: {
            labels: {{ typeDistLabels|json_encode|raw }},
            datasets: [{
                data: {{ typeDistData|json_encode|raw }},
                backgroundColor: ['#667eea', '#1abc9c', '#f7b731', '#e74c3c'],
                hoverOffset: 10
            }]
        },
        options: {
            maintainAspectRatio: false,
            plugins: { 
                legend: { 
                    position: 'right',
                    labels: { boxWidth: 12, font: { size: 10 } }
                } 
            }
        }
    });

    // --- Background Animation ---
    const canvas = document.getElementById('stats-canvas');
    const ctx = canvas.getContext('2d');
    let particles = [];

    window.addEventListener('resize', () => {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    });
    window.dispatchEvent(new Event('resize'));

    class Particle {
        constructor() {
            this.x = Math.random() * canvas.width;
            this.y = Math.random() * canvas.height;
            this.size = Math.random() * 3 + 1;
            this.speedX = Math.random() * 0.5 - 0.25;
            this.speedY = Math.random() * 0.5 - 0.25;
            this.color = `rgba(${Math.random() * 100 + 150}, ${Math.random() * 100 + 150}, 255, 0.2)`;
        }
        update() {
            this.x += this.speedX;
            this.y += this.speedY;
            if (this.x > canvas.width) this.x = 0;
            if (this.x < 0) this.x = canvas.width;
            if (this.y > canvas.height) this.y = 0;
            if (this.y < 0) this.y = canvas.height;
        }
        draw() {
            ctx.fillStyle = this.color;
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
            ctx.fill();
        }
    }

    for (let i = 0; i < 50; i++) particles.push(new Particle());

    function animate() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        particles.forEach(p => {
            p.update();
            p.draw();
        });
        requestAnimationFrame(animate);
    }
    animate();
});
</script>
{% endblock %}
