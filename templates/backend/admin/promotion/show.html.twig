{% extends 'backend/baseend.html.twig' %}

{% block title %}Détails Promotion - RE7LA Admin{% endblock %}
{% block breadcrumb %}Promotions / Détails{% endblock %}
{% block page_title %}Détails de la Promotion{% endblock %}

{% block body %}

{% set status       = promotion.status %}
{% set statusColors = promotion.statusColors %}

<div class="row">
 <div class="col-md-9 mx-auto">

  {# ── Header avec boutons ── #}
  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;" data-aos="fade-down">
    <a href="{{ path('app_admin_promotion_list') }}"
       style="color:#64748b; text-decoration:none; font-size:13px; font-weight:600; display:flex; align-items:center; gap:8px; transition: color 0.2s;"
       onmouseover="this.style.color='#2C3E50';" onmouseout="this.style.color='#64748b';">
      <i class="fas fa-arrow-left"></i> Retour à la liste
    </a>
    <div style="display:flex; gap:12px;">
      <a href="{{ path('app_admin_promotion_pdf', {id: promotion.id}) }}" target="_blank"
         style="background:linear-gradient(135deg,#3498DB,#2980B9); color:#fff; padding:10px 22px; border-radius:12px; font-weight:700; font-size:13px; text-decoration:none; display:flex; align-items:center; gap:8px; box-shadow:0 4px 12px rgba(52,152,219,0.3);">
        <i class="fas fa-file-pdf"></i> Exporter PDF
      </a>
      <a href="{{ path('app_admin_promotion_edit', {id: promotion.id}) }}"
         style="background:linear-gradient(135deg,#F7B731,#E67E22); color:#fff; padding:10px 22px; border-radius:12px; font-weight:700; font-size:13px; text-decoration:none; display:flex; align-items:center; gap:8px; box-shadow:0 4px 12px rgba(247,183,49,0.3);">
        <i class="fas fa-edit"></i> Modifier
      </a>
    </div>
  </div>

  {# ── Card principale ── #}
  <div class="card" style="border-radius:32px; border:none; box-shadow:0 25px 80px rgba(0,0,0,0.12); overflow:hidden; background:#fff; margin-bottom: 30px;" data-aos="fade-up">
    <div style="display:grid; grid-template-columns: 1fr 1.4fr; min-height:650px;">
        
        {# Image Section with Premium Overlay #}
        <div style="position:relative; overflow:hidden; background:#0f172a;">
            {% if promotion.image %}
                <img src="{{ asset(promotion.image) }}" alt="{{ promotion.name }}" style="width:100%; height:100%; object-fit:cover; opacity:0.85; transition: transform 0.5s ease;">
            {% else %}
                <div style="width:100%; height:100%; background:linear-gradient(135deg,#6366f1,#8b5cf6); display:flex; align-items:center; justify-content:center;">
                    <i class="fas fa-tags" style="font-size:100px; color:rgba(255,255,255,0.15);"></i>
                </div>
            {% endif %}
            
            <div style="position:absolute; inset:0; background:linear-gradient(to top, rgba(15,23,42,0.95) 0%, rgba(15,23,42,0.4) 50%, transparent 100%);"></div>
            
            <div style="position:absolute; bottom:0; left:0; right:0; padding:45px;">
                <div style="display:flex; gap:8px; margin-bottom:20px;">
                    <span style="background:rgba(255,255,255,0.15); color:#fff; padding:6px 16px; border-radius:30px; font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:1px; backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.2);">
                        {{ promotion.isPack() ? '📦 Pack' : '🎫 Individuelle' }}
                    </span>
                    <span style="background:rgba(255,255,255,0.15); color:#fff; padding:6px 16px; border-radius:30px; font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:1px; backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,0.2);">
                        {{ promotion.offerTypeLabel|default('Offre') }}
                    </span>
                </div>
                <h1 style="color:#fff; font-size:36px; font-weight:900; margin:0; line-height:1.1; letter-spacing:-1px;">{{ promotion.name }}</h1>
                <p style="color:rgba(255,255,255,0.6); font-size:15px; margin-top:15px; max-width:90%;">{{ promotion.description|slice(0, 150) ~ (promotion.description|length > 150 ? '...' : '') }}</p>
            </div>
        </div>

        {# Information Section #}
        <div style="padding:60px; background:#fff; display:flex; flex-direction:column; justify-content:center; border-left:1px solid #f1f5f9;">
            {# ── State Badges ── #}
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:40px;">
                <div style="display:flex; flex-wrap:wrap; gap:10px;">
                    {# Statut Badge #}
                    <span style="background:{{ statusColors.bg }}; color:{{ statusColors.color }}; padding:8px 18px; border-radius:12px; font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:1px; border:1px solid {{ statusColors.color }}33; display:flex; align-items:center; gap:6px;">
                        <i class="fas fa-circle" style="font-size:8px;"></i> {{ promotion.statusLabel }}
                    </span>

                    {# Trend Badge #}
                    {% if isTrending %}
                        <span style="background:linear-gradient(135deg, #FFF5F5, #FED7D7); color:#E53E3E; padding:8px 18px; border-radius:12px; font-size:11px; font-weight:800; border:1px solid #FEB2B2; display:flex; align-items:center; gap:8px;" class="animate__animated animate__pulse animate__infinite">
                            <i class="fas fa-fire"></i> TENDANCE
                        </span>
                    {% endif %}

                    {# AI Badge #}
                    {% if promotion.isAiGenerated %}
                        <span style="background:linear-gradient(135deg, #EEF2FF, #E0E7FF); color:#4F46E5; padding:8px 18px; border-radius:12px; font-size:11px; font-weight:800; border:1px solid #C7D2FE; display:flex; align-items:center; gap:8px;">
                            <i class="fas fa-robot"></i> IA GÉNÉRÉE
                        </span>
                    {% endif %}

                    {# Locked Badge #}
                    {% if promotion.isVerrouille() %}
                        <span style="background:linear-gradient(135deg, #F8FAFC, #F1F5F9); color:#475569; padding:8px 18px; border-radius:12px; font-size:11px; font-weight:800; border:1px solid #E2E8F0; display:flex; align-items:center; gap:8px;">
                            <i class="fas fa-lock"></i> VERROUILLÉE
                        </span>
                    {% endif %}
                </div>
                <div style="text-align:right;">
                    <div style="font-size:11px; font-weight:700; color:#94a3b8; text-transform:uppercase;">Identifiant</div>
                    <div style="font-size:14px; font-weight:800; color:#1e293b;">#{{ promotion.id }}</div>
                </div>
            </div>

            <div style="margin-bottom:40px;">
                <h3 style="font-size:12px; color:#64748b; font-weight:800; text-transform:uppercase; letter-spacing:2px; margin-bottom:15px; display:flex; align-items:center; gap:10px;">
                    <i class="fas fa-align-left" style="color:#cbd5e1;"></i> À propos de cette offre
                </h3>
                <p style="color:#334155; font-size:16px; line-height:1.8;">
                    {{ promotion.description ?: 'Aucune description détaillée disponible.' }}
                </p>
            </div>

            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:25px; margin-bottom:40px;">
                <div style="background:#f8fafc; border:1px solid #f1f5f9; padding:25px; border-radius:24px; position:relative; overflow:hidden;">
                    <i class="fas fa-percentage" style="position:absolute; right:-10px; top:-10px; font-size:60px; color:rgba(0,0,0,0.03);"></i>
                    <div style="font-size:11px; color:#64748b; font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-bottom:10px;">Réduction</div>
                    <div style="font-size:36px; font-weight:900; color:#0f172a;">-{{ promotion.reductionLabel }}</div>
                </div>
                <div style="background:#f8fafc; border:1px solid #f1f5f9; padding:25px; border-radius:24px; position:relative; overflow:hidden;">
                    <i class="fas fa-chart-line" style="position:absolute; right:-10px; top:-10px; font-size:60px; color:rgba(0,0,0,0.03);"></i>
                    <div style="font-size:11px; color:#64748b; font-weight:700; text-transform:uppercase; letter-spacing:1px; margin-bottom:10px;">Engagement</div>
                    <div style="display:flex; gap:25px; align-items:center; margin-top:5px;">
                        <div>
                            <div style="font-size:24px; font-weight:900; color:#334155;">{{ nbVues }}</div>
                            <div style="font-size:10px; color:#94a3b8; font-weight:700;">VUES</div>
                        </div>
                        <div style="width:1px; height:35px; background:#e2e8f0;"></div>
                        <div>
                            <div style="font-size:24px; font-weight:900; color:#334155;">{{ nbReservations }}</div>
                            <div style="font-size:10px; color:#94a3b8; font-weight:700;">VENTES</div>
                        </div>
                    </div>
                </div>
            </div>

            {# Smart Engine Discount Section #}
            {% if promotion.autoDiscountReason %}
            <div style="background:linear-gradient(135deg, #fffbeb, #fff7ed); border:2px solid #fed7aa; border-radius:28px; padding:30px; box-shadow: 0 10px 30px rgba(234,88,12,0.05);">
                <div style="display:flex; align-items:center; gap:18px; margin-bottom:20px;">
                    <div style="background:#ea580c; color:#fff; width:48px; height:48px; border-radius:16px; display:flex; align-items:center; justify-content:center; font-size:20px; box-shadow:0 8px 16px rgba(234,88,12,0.25);">
                        <i class="fas fa-magic"></i>
                    </div>
                    <div>
                        <h4 style="font-size:16px; font-weight:800; color:#9a3412; margin:0;">Optimisation Smart Engine</h4>
                        <p style="font-size:12px; color:#c2410c; margin:0; opacity:0.8;">Ajustement dynamique de la performance</p>
                    </div>
                </div>
                <div style="display:flex; justify-content:space-between; align-items:center; background:#fff; padding:18px; border-radius:20px; border:1px solid #ffedd5;">
                    <div style="text-align:center; flex:1;">
                        <div style="font-size:10px; color:#94a3b8; font-weight:800; margin-bottom:5px; text-transform:uppercase;">Initial</div>
                        <div style="font-size:18px; font-weight:700; color:#94a3b8; text-decoration:line-through;">{{ promotion.originalDiscountPercentage|default('?') }}%</div>
                    </div>
                    <div style="color:#fdba74; font-size:20px;"><i class="fas fa-chevron-right"></i></div>
                    <div style="text-align:center; flex:1;">
                        <div style="font-size:10px; color:#ea580c; font-weight:800; margin-bottom:5px; text-transform:uppercase;">Optimisé</div>
                        <div style="font-size:26px; font-weight:900; color:#ea580c;">{{ promotion.discountPercentage }}%</div>
                    </div>
                </div>
                <div style="margin-top:15px; display:flex; align-items:center; gap:8px; font-size:12px; color:#9a3412; font-weight:600; background:rgba(254,215,170,0.3); padding:8px 15px; border-radius:10px;">
                    <i class="fas fa-info-circle"></i>
                    {{ promotion.autoDiscountReason == 'low_engagement' ? 'Boost activé suite à une faible interaction.' : 'Régulation suite à une forte demande.' }}
                </div>
            </div>
            {% endif %}
        </div>
    </div>
  </div>

  {# ── Détails techniques & Offres ── #}
  <div class="row mt-4">
    <div class="col-md-6" data-aos="fade-right" data-aos-delay="200">
        <div class="card" style="height:100%; border-radius:20px;">
            <h5 style="font-size:15px; font-weight:700; color:#2C3E50; margin-bottom:20px; display:flex; align-items:center; gap:10px;">
                <i class="fas fa-calendar-alt" style="color:#3498DB;"></i> Période de Campagne
            </h5>
            <div style="display:flex; align-items:center; gap:15px; background:#f8fafc; padding:15px; border-radius:12px; margin-bottom:10px;">
                <div style="width:8px; height:8px; border-radius:50%; background:#3498DB;"></div>
                <div style="flex:1;">
                    <div style="font-size:11px; color:#94a3b8; font-weight:600;">DATE DÉBUT</div>
                    <div style="font-size:14px; font-weight:700; color:#2C3E50;">{{ promotion.startDate|date('d F Y') }}</div>
                </div>
            </div>
            <div style="display:flex; align-items:center; gap:15px; background:#f8fafc; padding:15px; border-radius:12px;">
                <div style="width:8px; height:8px; border-radius:50%; background:#e74c3c;"></div>
                <div style="flex:1;">
                    <div style="font-size:11px; color:#94a3b8; font-weight:600;">DATE FIN</div>
                    <div style="font-size:14px; font-weight:700; color:#2C3E50;">{{ promotion.endDate|date('d F Y') }}</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6" data-aos="fade-left" data-aos-delay="300">
        <div class="card" style="height:100%; border-radius:20px;">
            <h5 style="font-size:15px; font-weight:700; color:#2C3E50; margin-bottom:20px; display:flex; align-items:center; gap:10px;">
                <i class="fas fa-bullseye" style="color:#F7B731;"></i> Offres Concernées
            </h5>
            
            {% if promotion.isPack() %}
                {% set packItems = promotion.packItemsDecoded %}
                <div style="display:flex; flex-direction:column; gap:8px;">
                    {% for item in packItems %}
                        <div style="display:flex; align-items:center; gap:10px; background:#f8fafc; padding:10px 14px; border-radius:10px; border:1px solid #eef2f6;">
                            <i class="fas {{ item.type == 'hebergement' ? 'fa-home' : (item.type == 'activite' ? 'fa-hiking' : 'fa-car') }}" style="color:#64748b; font-size:0.9rem;"></i>
                            <span style="font-size:12px; font-weight:600; color:#2C3E50;">{{ item.label|default(item.name|default(item.type|capitalize ~ ' #' ~ item.id)) }}</span>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div style="background:#f8fafc; padding:20px; border-radius:16px; border:1px solid #eef2f6; text-align:center;">
                    <i class="fas {{ promotion.offerType == 'hebergement' ? 'fa-home' : (promotion.offerType == 'activite' ? 'fa-hiking' : 'fa-car') }}" style="font-size:2rem; color:#3498DB; margin-bottom:12px; opacity:0.8;"></i>
                    <div style="font-size:14px; font-weight:700; color:#2C3E50;">{{ promotion.offerTypeLabel }}</div>
                    <div style="font-size:11px; color:#94a3b8;">Référence ID: #{{ promotion.referenceId }}</div>
                </div>
            {% endif %}
        </div>
    </div>
  </div>

  {# ── Code Promo & Sécurité ── #}
  {% if promotion.isVerrouille() %}
  <div class="card mt-4" style="border-radius:20px; background:linear-gradient(135deg, #2C3E50, #1A252F); border:none;" data-aos="flip-up">
    <div style="display:grid; grid-template-columns: 1fr 1fr; align-items:center; padding:10px;">
        <div style="color:#fff;">
            <h5 style="font-size:15px; font-weight:700; color:#F7B731; margin-bottom:10px;">Accès Privé (Code Promo)</h5>
            <p style="font-size:13px; color:#94a3b8; margin-bottom:20px;">Cette promotion est protégée par un code unique requis lors de la réservation.</p>
            {% if promoCode %}
                <div style="background:rgba(255,255,255,0.05); padding:15px; border-radius:12px; display:inline-block;">
                    <div style="font-size:9px; color:#94a3b8; letter-spacing:1px; margin-bottom:4px;">CODE ACTIF</div>
                    <div style="font-size:24px; font-weight:800; color:#fff; letter-spacing:4px; font-family:monospace;">{{ promoCode.code }}</div>
                </div>
            {% else %}
                <a href="{{ path('app_admin_promotion_generate_qr', {id: promotion.id}) }}" onclick="event.preventDefault(); generateQrFromShow({{ promotion.id }})" style="background:#F7B731; color:#2C3E50; padding:10px 20px; border-radius:10px; font-weight:700; text-decoration:none; font-size:13px;">Générer un Code</a>
            {% endif %}
        </div>
        {% if qrUrl %}
        <div style="text-align:right;">
            <img src="{{ qrUrl }}" alt="QR Code" style="width:140px; height:140px; border-radius:15px; padding:10px; background:#fff;">
        </div>
        {% endif %}
    </div>
  </div>
  {% endif %}

  {# ── Actions de fin ── #}
  <div style="margin-top:40px; text-align:center;" data-aos="fade-up">
    <form method="post" action="{{ path('app_admin_promotion_delete', {id: promotion.id}) }}" style="display:inline;">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ promotion.id) }}">
        <button type="submit" style="background:none; border:none; color:#e63946; font-size:13px; font-weight:700; cursor:pointer; text-decoration:underline;" onclick="return confirm('Confirmer la suppression ? Cette action est irréversible.')">
            <i class="fas fa-trash-alt me-1"></i> Supprimer définitivement cette promotion
        </button>
    </form>
  </div>

 </div>
</div>

<script>
function generateQrFromShow(promoId) {
    fetch(`/admin/promotion/${promoId}/generate-qr`, {
        method: "POST",
        headers: { "X-Requested-With": "XMLHttpRequest" }
    })
    .then(r => r.json())
    .then(data => {
        if (data.success) { location.reload(); }
        else { alert("Erreur: " + (data.message || "Impossible de generer le QR")); }
    });
}
</script>
{% endblock %}
