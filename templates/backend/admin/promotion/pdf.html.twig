<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>RE7LA - Official Promotion Document</title>
    <style>
        @page { margin: 0; }
        body { font-family: 'Helvetica', sans-serif; color: #1e293b; margin: 0; padding: 0; background: #fff; }
        .container { padding: 50px; }
        
        /* Header */
        .pdf-header { display: table; width: 100%; border-bottom: 2px solid #f1f5f9; padding-bottom: 20px; margin-bottom: 40px; }
        .header-logo { display: table-cell; width: 50%; vertical-align: middle; }
        .header-info { display: table-cell; width: 50%; text-align: right; vertical-align: middle; }
        .logo-text { font-size: 24px; font-weight: 900; color: #2C3E50; }
        .logo-text span { color: #F7B731; }
        .doc-type { font-size: 10px; font-weight: 700; color: #94a3b8; text-transform: uppercase; letter-spacing: 2px; }
        
        /* Banner */
        .promo-banner { position: relative; margin-bottom: 40px; border-radius: 20px; overflow: hidden; height: 250px; background: #1e293b; }
        .promo-banner img { width: 100%; height: 100%; object-fit: cover; opacity: 0.8; }
        .banner-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 30px; background: linear-gradient(to top, rgba(0,0,0,0.8), transparent); }
        .banner-title { color: #fff; font-size: 28px; font-weight: 800; margin: 0; }
        
        /* Content */
        .details-table { width: 100%; border-collapse: separate; border-spacing: 0 10px; margin-bottom: 30px; }
        .details-table td { padding: 15px; background: #f8fafc; border: 1px solid #f1f5f9; }
        .label { font-size: 10px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
        .value { font-size: 14px; font-weight: 700; color: #1e293b; }
        
        /* Smart Engine Box */
        .smart-engine { background: #fffbeb; border: 2px dashed #fed7aa; border-radius: 16px; padding: 20px; margin-bottom: 30px; position: relative; }
        .smart-badge { position: absolute; top: -10px; right: 20px; background: #ea580c; color: #fff; padding: 4px 12px; border-radius: 20px; font-size: 9px; font-weight: 800; }
        
        /* Stamp & Signature */
        .official-footer { display: table; width: 100%; margin-top: 60px; }
        .signature-block { display: table-cell; width: 60%; vertical-align: bottom; }
        .stamp-block { display: table-cell; width: 40%; text-align: center; vertical-align: middle; }
        
        .stamp { width: 120px; height: 120px; border: 3px double #e11d48; border-radius: 50%; display: inline-block; position: relative; transform: rotate(-15deg); opacity: 0.7; }
        .stamp-inner { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); color: #e11d48; font-weight: 900; font-size: 10px; text-align: center; line-height: 1; }
        
        .signature { border-bottom: 1px solid #2C3E50; width: 200px; padding-bottom: 5px; margin-top: 30px; font-family: 'Cursive', serif; font-size: 20px; color: #2C3E50; }
        .footer-note { font-size: 9px; color: #94a3b8; margin-top: 40px; text-align: center; border-top: 1px solid #f1f5f9; padding-top: 20px; }
    </style>
</head>
<body>

<div class="container">
    <div class="pdf-header">
        <div class="header-logo">
            <div class="logo-text">RE7<span>LA</span></div>
            <div style="font-size: 10px; color: #64748b; font-weight: 600;">Tunisian Travel Experience</div>
        </div>
        <div class="header-info">
            <div class="doc-type">Attestation Officielle de Promotion</div>
            <div style="font-size: 12px; color: #1e293b; font-weight: 700; margin-top: 5px;">Document N&deg; PRM-{{ promotion.id }}-{{ "now"|date("Y") }}</div>
            <div style="font-size: 11px; color: #94a3b8;">Émis le {{ "now"|date("d/m/Y") }}</div>
        </div>
    </div>

    <div class="promo-banner">
        {% if promotion.image %}
            <img src="{{ app.request.schemeAndHttpHost ~ asset(promotion.image) }}" alt="Promotion">
        {% endif %}
        <div class="banner-overlay">
            <h1 class="banner-title">{{ promotion.name }}</h1>
        </div>
    </div>

    <table class="details-table">
        <tr>
            <td style="border-radius: 12px 0 0 12px; width: 33%;">
                <div class="label">Catégorie</div>
                <div class="value">{{ promotion.isPack() ? 'Pack Touristique' : 'Offre ' ~ promotion.offerTypeLabel }}</div>
            </td>
            <td style="width: 33%;">
                <div class="label">Réduction</div>
                <div style="font-size: 20px; font-weight: 900; color: #ea580c;">-{{ promotion.reductionLabel }}</div>
            </td>
            <td style="border-radius: 0 12px 12px 0; width: 34%;">
                <div class="label">Validité</div>
                <div class="value">Jusqu'au {{ promotion.endDate|date('d/m/Y') }}</div>
            </td>
        </tr>
    </table>

    <div class="section-content" style="padding: 0 10px;">
        <div class="label">Description Officielle</div>
        <p style="font-size: 13px; line-height: 1.6; color: #475569; margin-bottom: 30px;">
            {{ promotion.description ?: 'Cette promotion exclusive permet aux clients de RE7LA de bénéficier de tarifs préférentiels sur nos services de voyage. Offre soumise à conditions.' }}
        </p>
    </div>

    {% if promotion.autoDiscountReason %}
    <div class="smart-engine">
        <div class="smart-badge">OPTIMISÉ PAR SMART ENGINE</div>
        <div style="font-size: 12px; color: #92400e; font-weight: 700;">ANALYSE DYNAMIQUE DE PERFORMANCE</div>
        <p style="font-size: 11px; color: #b45309; margin: 10px 0 0;">
            Ce document atteste que l'offre a été ajustée dynamiquement pour garantir la meilleure visibilité possible. 
            La réduction initiale de {{ promotion.originalDiscountPercentage|default('?') }}% a été portée à {{ promotion.discountPercentage }}% 
            pour cause de {{ promotion.autoDiscountReason == 'low_engagement' ? 'faible engagement utilisateur' : 'forte demande' }}.
        </p>
    </div>
    {% endif %}

    <div class="official-footer">
        <div class="signature-block">
            <div style="font-size: 11px; font-weight: 800; color: #1e293b; margin-bottom: 40px;">SIGNATURE DE LA DIRECTION</div>
            <div class="signature">Management RE7LA</div>
            <div style="font-size: 10px; color: #94a3b8; margin-top: 5px;">Département Marketing & Promos</div>
        </div>
        <div class="stamp-block">
            <div class="stamp">
                <div class="stamp-inner">
                    APPROUVÉ<br>
                    RE7LA TUNISIA<br>
                    {{ "now"|date("Y") }}
                </div>
            </div>
        </div>
    </div>

    <div class="footer-note">
        RE7LA - Siège Social, Tunis, Tunisie | www.re7la.tn<br>
        Ce document est généré électroniquement et est valide sans signature manuscrite.
    </div>
</div>

</body>
</html>
