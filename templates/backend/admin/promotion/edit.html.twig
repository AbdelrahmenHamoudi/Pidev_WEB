{% extends 'backend/baseend.html.twig' %}

{% block title %}Modifier Promotion - RE7LA Admin{% endblock %}
{% block breadcrumb %}Promotions{% endblock %}
{% block page_title %}Modifier la Promotion{% endblock %}

{% block body %}
<!-- Header -->
<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:30px;">
  <div>
    <a href="{{ path('app_admin_promotion_list') }}" style="color:#1ABC9C;text-decoration:none;font-weight:500;font-size:14px;display:flex;align-items:center;gap:8px;margin-bottom:8px;">
      <i class="fas fa-arrow-left"></i>
      Retour aux promotions
    </a>
    <h1 style="font-size:24px;font-weight:700;color:#2C3E50;margin:0;">Modifier la promotion</h1>
  </div>
</div>

{% for message in app.flashes('error') %}
  <div style="background:#fee2e2;color:#991b1b;padding:16px 20px;border-radius:12px;margin-bottom:24px;display:flex;align-items:center;gap:12px;font-size:14px;font-weight:500;">
    <i class="fas fa-exclamation-circle" style="color:#ef4444;"></i>
    <span>{{ message }}</span>
  </div>
{% endfor %}

{# Préparer les données existantes pour JS #}
{% set existingOfferType  = promotion.offerType ?? '' %}
{% set existingRefId      = promotion.referenceId ?? 0 %}
{% set existingPackItems  = promotion.packItems ?? '[]' %}
{% set existingPromoType  = promotion.promoType %}

<div style="background:#fff;border-radius:20px;padding:32px;box-shadow:0 10px 40px rgba(0,0,0,0.04);border:1px solid #f0f2f5;">
    {{ form_start(form, {'attr': {'novalidate':'novalidate','enctype':'multipart/form-data','id':'promoForm'}}) }}

      <input type="hidden" name="offer_type"      id="hiddenOfferType"  value="{{ existingOfferType }}">
      <input type="hidden" name="reference_id"    id="hiddenReferenceId" value="{{ existingRefId }}">
      <input type="hidden" name="pack_items_json" id="hiddenPackItems"  value="{{ existingPackItems }}">

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px;">

        {# ── Colonne gauche : Infos générales ── #}
        <div style="display:flex;flex-direction:column;gap:24px;">
          
          <div style="background:#f8fafc;padding:24px;border-radius:16px;border:1px solid #e8ecf0;">
             <h3 style="font-size:16px;font-weight:700;color:#2C3E50;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
                <i class="fas fa-edit" style="color:#3498DB;"></i>
                Modification : {{ promotion.name }}
             </h3>

             <div style="display:flex;flex-direction:column;gap:16px;">
                <div>
                  <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:13px;">Titre de la promotion <span style="color:#ef4444;">*</span></label>
                  {{ form_widget(form.name, {'attr': {'style': 'width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#fff;'}}) }}
                  {{ form_errors(form.name) }}
                </div>

                <div>
                  <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:13px;">Description détaillée</label>
                  {{ form_widget(form.description, {'attr': {'style': 'width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#fff;min-height:100px;resize:vertical;'}}) }}
                  {{ form_errors(form.description) }}
                </div>
             </div>
          </div>

          <div style="background:#f8fafc;padding:24px;border-radius:16px;border:1px solid #e8ecf0;">
             <h3 style="font-size:16px;font-weight:700;color:#2C3E50;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
                <i class="fas fa-percent" style="color:#1ABC9C;"></i>
                Détails de l'offre
             </h3>

             <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div style="grid-column: 1 / -1;">
                  <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:13px;">Type de promotion <span style="color:#ef4444;">*</span></label>
                  {{ form_widget(form.promoType, {'attr': {'id':'promoTypeSelect', 'style': 'width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#fff;'}}) }}
                </div>

                <div>
                  <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:13px;">Réduction (%)</label>
                  {{ form_widget(form.discountPercentage, {'attr': {'style': 'width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#fff;'}}) }}
                  {{ form_errors(form.discountPercentage) }}
                </div>

                <div>
                  <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:13px;">Réduction (DT fixe)</label>
                  {{ form_widget(form.discountFixed, {'attr': {'style': 'width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#fff;'}}) }}
                  {{ form_errors(form.discountFixed) }}
                </div>

                <div>
                  <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:13px;">Date début <span style="color:#ef4444;">*</span></label>
                  {{ form_widget(form.startDate, {'attr': {'style': 'width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#fff;'}}) }}
                  {{ form_errors(form.startDate) }}
                </div>

                <div>
                  <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:13px;">Date fin <span style="color:#ef4444;">*</span></label>
                  {{ form_widget(form.endDate, {'attr': {'style': 'width:100%;padding:12px 16px;border:2px solid #e8ecf0;border-radius:12px;font-size:14px;transition:all 0.3s;background:#fff;'}}) }}
                  {{ form_errors(form.endDate) }}
                </div>

                <div style="grid-column: 1 / -1;">
                  <label style="display:block;font-weight:600;color:#2C3E50;margin-bottom:8px;font-size:13px;">Image bannière</label>
                   
                   {% if promotion.image %}
                    <div style="margin-bottom:12px;border-radius:10px;overflow:hidden;height:80px;border:1px solid #e2e8f0;display:flex;align-items:center;background:#fff;padding:8px;gap:12px;">
                        <img src="{{ asset(promotion.image) }}" style="height:100%;width:80px;object-fit:cover;border-radius:6px;">
                        <span style="font-size:12px;color:#94a3b8;font-weight:600;">IMAGE ACTUELLE</span>
                    </div>
                   {% endif %}

                   <div style="border:2px dashed #e8ecf0;border-radius:12px;padding:16px;text-align:center;background:#fff;">
                      <i class="fas fa-cloud-upload-alt" style="font-size:24px;color:#cbd5e1;margin-bottom:10px;display:block;"></i>
                      <input type="file" name="promo_image" accept=".jpg,.jpeg,.png,.webp,.gif" style="font-size:12px;color:#64748b;">
                   </div>
                </div>
             </div>
          </div>
        </div>

        {# ── Colonne droite : Sélecteur d'offres ── #}
        <div style="background:#f8fafc;padding:24px;border-radius:20px;border:1px solid #e8ecf0;display:flex;flex-direction:column;">
            <h3 style="font-size:16px;font-weight:700;color:#2C3E50;margin-bottom:20px;display:flex;align-items:center;gap:10px;">
                <i class="fas fa-bullseye" style="color:#3498DB;"></i>
                <span id="offerSelectorTitle">Ciblage de la promotion</span>
            </h3>

            <div style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;">
              <button type="button" class="offer-type-btn" data-type="hebergement" style="flex:1;background:#fff;border:2px solid #e8ecf0;border-radius:10px;padding:10px;font-size:12px;font-weight:700;color:#64748b;cursor:pointer;transition:0.2s;display:flex;flex-direction:column;align-items:center;gap:6px;">
                <i class="fas fa-hotel" style="font-size:18px;"></i> Hébergements
              </button>
              <button type="button" class="offer-type-btn" data-type="activite" style="flex:1;background:#fff;border:2px solid #e8ecf0;border-radius:10px;padding:10px;font-size:12px;font-weight:700;color:#64748b;cursor:pointer;transition:0.2s;display:flex;flex-direction:column;align-items:center;gap:6px;">
                <i class="fas fa-skating" style="font-size:18px;"></i> Activités
              </button>
              <button type="button" class="offer-type-btn" data-type="voiture" style="flex:1;background:#fff;border:2px solid #e8ecf0;border-radius:10px;padding:10px;font-size:12px;font-weight:700;color:#64748b;cursor:pointer;transition:0.2s;display:flex;flex-direction:column;align-items:center;gap:6px;">
                <i class="fas fa-car" style="font-size:18px;"></i> Voitures
              </button>
            </div>

            <div id="offerListContainer" style="flex:1;max-height:450px;overflow-y:auto;padding-right:10px;">
              <div id="offerPlaceholder" style="text-align:center;padding:60px 20px;color:#94a3b8;">
                <i class="fas fa-mouse-pointer" style="font-size:32px;opacity:0.2;margin-bottom:16px;display:block;"></i>
                <p style="font-size:14px;">Sélectionnez un type d'offre pour voir la liste</p>
              </div>

              {# Lists #}
              <div id="list-hebergement" class="offer-list" style="display:none;">
                {% for h in hebergements %}
                <div class="offer-item" data-id="{{ h.idHebergement }}" data-type="hebergement" data-label="{{ h.titre }}" style="background:#fff;padding:12px 16px;border-radius:12px;border:2px solid transparent;margin-bottom:10px;cursor:pointer;display:flex;align-items:center;gap:12px;transition:0.2s;box-shadow:0 2px 8px rgba(0,0,0,0.02);">
                  <div style="width:40px;height:40px;background:rgba(52,152,219,0.1);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#3498DB;">
                    <i class="fas fa-hotel"></i>
                  </div>
                  <div style="flex:1;">
                    <div style="font-weight:700;color:#2C3E50;font-size:14px;">{{ h.titre }}</div>
                    <div style="font-size:11px;color:#94a3b8;">{{ h.typeHebergement }} — {{ h.prixParNuit }} DT</div>
                  </div>
                  <i class="fas fa-check-circle check-icon" style="display:none;color:#1ABC9C;font-size:18px;"></i>
                </div>
                {% endfor %}
              </div>

              <div id="list-activite" class="offer-list" style="display:none;">
                {% for a in activites %}
                <div class="offer-item" data-id="{{ a.idActivite }}" data-type="activite" data-label="{{ a.nomA }}" style="background:#fff;padding:12px 16px;border-radius:12px;border:2px solid transparent;margin-bottom:10px;cursor:pointer;display:flex;align-items:center;gap:12px;transition:0.2s;box-shadow:0 2px 8px rgba(0,0,0,0.02);">
                  <div style="width:40px;height:40px;background:rgba(26,188,156,0.1);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#1ABC9C;">
                    <i class="fas fa-skating"></i>
                  </div>
                  <div style="flex:1;">
                    <div style="font-weight:700;color:#2C3E50;font-size:14px;">{{ a.nomA }}</div>
                    <div style="font-size:11px;color:#94a3b8;">{{ a.lieu }} — {{ a.prixParPersonne }} DT</div>
                  </div>
                  <i class="fas fa-check-circle check-icon" style="display:none;color:#1ABC9C;font-size:18px;"></i>
                </div>
                {% endfor %}
              </div>

              <div id="list-voiture" class="offer-list" style="display:none;">
                {% for v in voitures %}
                <div class="offer-item" data-id="{{ v.id_voiture }}" data-type="voiture" data-label="{{ v.marque }} {{ v.modele }}" style="background:#fff;padding:12px 16px;border-radius:12px;border:2px solid transparent;margin-bottom:10px;cursor:pointer;display:flex;align-items:center;gap:12px;transition:0.2s;box-shadow:0 2px 8px rgba(0,0,0,0.02);">
                  <div style="width:40px;height:40px;background:rgba(243,156,18,0.1);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#F39C12;">
                    <i class="fas fa-car"></i>
                  </div>
                  <div style="flex:1;">
                    <div style="font-weight:700;color:#2C3E50;font-size:14px;">{{ v.marque }} {{ v.modele }}</div>
                    <div style="font-size:11px;color:#94a3b8;">{{ v.immatriculation }} — {{ v.prix_KM }} DT/km</div>
                  </div>
                  <i class="fas fa-check-circle check-icon" style="display:none;color:#1ABC9C;font-size:18px;"></i>
                </div>
                {% endfor %}
              </div>
            </div>

            {# Summary boxes #}
            <div id="indivSummary" style="display:none;margin-top:20px;padding:16px;background:#fff;border-radius:12px;border:2px solid #1ABC9C;box-shadow:0 10px 25px rgba(26,188,156,0.1);">
                <div style="color:#1ABC9C;font-weight:700;font-size:13px;margin-bottom:4px;display:flex;align-items:center;gap:8px;">
                   <i class="fas fa-check-circle"></i> Offre sélectionnée
                </div>
                <div id="indivLabel" style="font-weight:700;color:#2C3E50;font-size:15px;"></div>
            </div>

            <div id="packSummary" style="display:none;margin-top:20px;padding:16px;background:#fff;border-radius:12px;border:2px solid #F7B731;box-shadow:0 10px 25px rgba(247,183,49,0.1);">
                <div style="color:#F7B731;font-weight:700;font-size:13px;margin-bottom:8px;display:flex;align-items:center;gap:8px;">
                   <i class="fas fa-box-open"></i> Contenu du pack
                </div>
                <div id="packItemsList" style="display:flex;flex-direction:column;gap:8px;"></div>
            </div>
        </div>
      </div>

      <div style="display:flex;gap:12px;justify-content:flex-end;margin-top:32px;padding-top:24px;border-top:1px solid #f0f2f5;">
        <a href="{{ path('app_admin_promotion_list') }}" style="background:#fff;color:#64748b;border:2px solid #e8ecf0;padding:12px 24px;border-radius:12px;font-weight:600;text-decoration:none;transition:all 0.3s;display:inline-flex;align-items:center;gap:8px;font-size:14px;">
          <i class="fas fa-times"></i> Annuler
        </a>
        <button type="submit" id="submitBtn" style="background:linear-gradient(135deg,#3498DB,#2980B9);color:#fff;border:none;padding:12px 32px;border-radius:12px;font-weight:700;cursor:pointer;transition:all 0.3s;display:inline-flex;align-items:center;gap:8px;font-size:14px;box-shadow:0 4px 15px rgba(52,152,219,0.3);">
          <i class="fas fa-save"></i> Enregistrer
        </button>
      </div>

    {{ form_end(form) }}
</div>

<style>
  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: #3498DB !important;
    background: #fff !important;
    box-shadow: 0 0 0 4px rgba(52,152,219,0.1) !important;
  }
  
  .offer-type-btn:hover {
    border-color: #3498DB !important;
    color: #3498DB !important;
    transform: translateY(-2px);
  }
  .offer-type-btn.active {
    background: linear-gradient(135deg,#3498DB,#2980B9) !important;
    border-color: #3498DB !important;
    color: #fff !important;
  }

  .offer-item:hover {
    border-color: #3498DB !important;
    background: #fff !important;
    transform: translateX(5px);
  }
  
  #offerListContainer::-webkit-scrollbar { width: 4px; }
  #offerListContainer::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }

  button:hover, a:hover {
    transform: translateY(-2px);
  }
</style>

{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
const EXISTING_PROMO_TYPE  = {{ existingPromoType|json_encode|raw }};
const EXISTING_OFFER_TYPE  = {{ existingOfferType|json_encode|raw }};
const EXISTING_REF_ID      = {{ existingRefId|default(0) }};
const EXISTING_PACK_ITEMS  = {{ existingPackItems|raw }};
</script>

<script>
(function() {
    let promoMode      = EXISTING_PROMO_TYPE || 'individuelle';
    let selectedIndiv  = (EXISTING_OFFER_TYPE && EXISTING_REF_ID)
        ? { type: EXISTING_OFFER_TYPE, id: EXISTING_REF_ID, label: '' }
        : null;
    let packItems = Array.isArray(EXISTING_PACK_ITEMS) ? EXISTING_PACK_ITEMS : [];

    const promoTypeSelect  = document.getElementById('promoTypeSelect');
    const hiddenOfferType  = document.getElementById('hiddenOfferType');
    const hiddenRefId      = document.getElementById('hiddenReferenceId');
    const hiddenPackItems  = document.getElementById('hiddenPackItems');
    const offerTypeBtns    = document.querySelectorAll('.offer-type-btn');
    const offerLists       = document.querySelectorAll('.offer-list');
    const offerItems       = document.querySelectorAll('.offer-item');
    const offerPlaceholder = document.getElementById('offerPlaceholder');
    const packSummary      = document.getElementById('packSummary');
    const packItemsList    = document.getElementById('packItemsList');
    const indivSummary     = document.getElementById('indivSummary');
    const indivLabel       = document.getElementById('indivLabel');
    const selectorTitle    = document.getElementById('offerSelectorTitle');

    promoTypeSelect.addEventListener('change', function() {
        promoMode = this.value;
        resetSelection();
        updateSelectorTitle();
    });

    function updateSelectorTitle() {
        selectorTitle.textContent = promoMode === 'pack'
            ? 'Configuration du Pack (min. 2 offres)'
            : "Ciblage de l'offre (Sélection unique)";
    }

    offerTypeBtns.forEach(function(btn) {
        btn.addEventListener('click', function() {
            const type = this.dataset.type;
            offerTypeBtns.forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            offerLists.forEach(l => l.style.display = 'none');
            offerPlaceholder.style.display = 'none';
            document.getElementById('list-' + type).style.display = 'block';
            refreshItemVisuals();
        });
    });

    offerItems.forEach(function(item) {
        item.addEventListener('click', function() {
            const id    = parseInt(this.dataset.id);
            const type  = this.dataset.type;
            const label = this.dataset.label;

            if (promoMode === 'individuelle') {
                selectedIndiv = { type, id, label };
                hiddenOfferType.value = type;
                hiddenRefId.value     = id;
                indivLabel.textContent = label;
                indivSummary.style.display = 'block';
                packSummary.style.display  = 'none';
            } else {
                const idx = packItems.findIndex(p => p.type === type && p.id === id);
                if (idx >= 0) packItems.splice(idx, 1);
                else packItems.push({ type, id, label });
                hiddenPackItems.value = JSON.stringify(packItems);
                updatePackSummary();
            }
            refreshItemVisuals();
        });
    });

    function refreshItemVisuals() {
        offerItems.forEach(function(item) {
            const id = parseInt(item.dataset.id), type = item.dataset.type;
            let sel = promoMode === 'individuelle'
                ? (selectedIndiv && selectedIndiv.type === type && selectedIndiv.id === id)
                : packItems.some(p => p.type === type && p.id === id);
            item.style.borderColor = sel ? '#1ABC9C' : 'transparent';
            item.style.background  = sel ? 'rgba(26,188,156,0.06)' : '#fff';
            const chk = item.querySelector('.check-icon');
            if (chk) chk.style.display = sel ? 'inline' : 'none';
        });
    }

    function updatePackSummary() {
        packItemsList.innerHTML = '';
        packItems.forEach(function(p) {
            const div = document.createElement('div');
            div.style.cssText = 'display:flex;align-items:center;justify-content:space-between;padding:8px 12px;background:#f8fafc;border-radius:8px;font-size:12px;';
            div.innerHTML = `<span style="font-weight:600;"><i class="fas fa-caret-right" style="color:#F7B731;margin-right:6px;"></i>${p.label}</span>
                <button type="button" onclick="removePackItem('${p.type}',${p.id})"
                  style="background:none;border:none;color:#e63946;cursor:pointer;font-size:14px;padding:0;">✕</button>`;
            packItemsList.appendChild(div);
        });
        const ok = packItems.length >= 2;
        packSummary.style.display = packItems.length > 0 ? 'block' : 'none';
        packSummary.style.borderColor = ok ? '#1ABC9C' : '#F7B731';
    }

    window.removePackItem = function(type, id) {
        packItems = packItems.filter(p => !(p.type === type && p.id === id));
        hiddenPackItems.value = JSON.stringify(packItems);
        updatePackSummary(); refreshItemVisuals();
    };

    function resetSelection() {
        selectedIndiv = null; packItems = [];
        hiddenOfferType.value = ''; hiddenRefId.value = ''; hiddenPackItems.value = '[]';
        indivSummary.style.display = 'none'; packSummary.style.display = 'none';
        refreshItemVisuals();
    }

    document.getElementById('promoForm').addEventListener('submit', function(e) {
        const nameField = document.querySelector('input[name="promotion[name]"]');
        if (nameField && nameField.value.trim().length < 3) {
            e.preventDefault();
            nameField.style.borderColor = '#e63946';
            alert('Titre trop court.');
            return;
        }
        if (promoMode === 'individuelle') {
            if (!hiddenOfferType.value || !hiddenRefId.value) { e.preventDefault(); alert('Veuillez sélectionner une offre.'); }
        } else {
            const items = JSON.parse(hiddenPackItems.value || '[]');
            if (items.length < 2) { e.preventDefault(); alert('Un pack doit contenir au moins 2 offres.'); }
        }
    });

    updateSelectorTitle();
    if (promoMode === 'pack' && packItems.length > 0) updatePackSummary();
    if (promoMode === 'individuelle' && selectedIndiv) {
        const el = document.querySelector(`.offer-item[data-type="${selectedIndiv.type}"][data-id="${selectedIndiv.id}"]`);
        if (el) { selectedIndiv.label = el.dataset.label; indivLabel.textContent = el.dataset.label; indivSummary.style.display = 'block'; }
    }
    refreshItemVisuals();
})();
</script>
{% endblock %}