{% extends 'backend/baseend.html.twig' %}

{% block title %}RE7LA Admin — Dashboard{% endblock %}

{% block breadcrumb %}Dashboard{% endblock %}
{% block page_title %}Tableau de bord{% endblock %}

{% block body %}
<!-- Stats Cards -->
<div class="stat-cards-row">
  <div class="stat-card" style="background:#1ABC9C;color:#fff;">
    <div class="stat-card-left">
      <div class="label">Hébergements</div>
      <div class="value">{{ totalH|default(0) }}</div>
    </div>
    <div class="stat-icon" style="background:rgba(255,255,255,0.2);">
      <i class="fas fa-hotel"></i>
    </div>
  </div>

  <div class="stat-card" style="background:#F7B731;color:#fff;">
    <div class="stat-card-left">
      <div class="label">En Attente</div>
      <div class="value">{{ pendingR|default(0) }}</div>
    </div>
    <div class="stat-icon" style="background:rgba(255,255,255,0.2);">
      <i class="fas fa-clock"></i>
    </div>
  </div>

  <div class="stat-card" style="background:#3498DB;color:#fff;">
    <div class="stat-card-left">
      <div class="label">Total Réservations</div>
      <div class="value">{{ totalR|default(0) }}</div>
    </div>
    <div class="stat-icon" style="background:rgba(255,255,255,0.2);">
      <i class="fas fa-shopping-cart"></i>
    </div>
  </div>

  <div class="stat-card" style="background:#e63946;color:#fff;">
    <div class="stat-card-left">
      <div class="label">Utilisateurs</div>
      <div class="value">24</div>
    </div>
    <div class="stat-icon" style="background:rgba(255,255,255,0.2);">
      <i class="fas fa-users"></i>
    </div>
  </div>
</div>

<div class="row">
  <div class="card" style="width:100%;text-align:center;padding:80px 20px;">
    <div style="max-width:600px;margin:0 auto;">
      <div style="width:100px;height:100px;background:linear-gradient(135deg,#1ABC9C,#16a085);border-radius:30px;display:flex;align-items:center;justify-content:center;margin:0 auto 30px;box-shadow:0 10px 40px rgba(26,188,156,0.3);">
        <i class="fas fa-chart-line" style="font-size:40px;color:#fff;"></i>
      </div>
      <h1 style="font-size:28px;font-weight:700;color:#2C3E50;margin-bottom:15px;">Bienvenue sur RE7LA Admin</h1>
      <p style="font-size:15px;color:#64748b;margin-bottom:40px;line-height:1.6;">
        Gérez la flotte depuis la section Voitures. Les trajets sont réservés côté site public.
      </p>
      
      <div style="display:flex;justify-content:center;gap:20px;flex-wrap:wrap;margin-bottom:30px;">
        <a href="{{ path('app_voiture') }}" style="background:linear-gradient(135deg,#F7B731,#E6C050);color:#fff;padding:12px 24px;border-radius:12px;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:8px;border:none;transition:all 0.3s;box-shadow:0 4px 15px rgba(247,183,49,0.35);">
          <i class="fas fa-car"></i>
          Gérer les voitures
        </a>
        
        <a href="{{ path('app_home') }}" target="_blank" style="background:#f8fafc;color:#2C3E50;padding:12px 24px;border-radius:12px;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:8px;border:1px solid #e8ecf0;transition:all 0.3s;">
          <i class="fas fa-globe"></i>
          Voir le site public
        </a>
      </div>

      <!-- Test Notifications Section -->
      <div style="background:#f1f5f9;border-radius:16px;padding:24px;border:1px solid #e2e8f0;">
        <h3 style="font-size:14px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:1px;margin-bottom:15px;display:flex;align-items:center;justify-content:center;gap:8px;">
          <i class="fas fa-flask"></i> Zone de Test des Notifications
        </h3>
        <div style="display:flex;justify-content:center;gap:15px;flex-wrap:wrap;">
          <button onclick="testNotificationUI()" style="background:#fff;border:1px solid #cbd5e1;padding:10px 18px;border-radius:10px;font-size:13px;font-weight:600;color:#475569;cursor:pointer;display:flex;align-items:center;gap:8px;transition:0.3s;" onmouseover="this.style.background='#f8fafc'">
            <i class="fas fa-eye" style="color:#3b82f6;"></i> Tester UI (JS)
          </button>
          
          <button id="btn-test-server" style="background:#fff;border:1px solid #cbd5e1;padding:10px 18px;border-radius:10px;font-size:13px;font-weight:600;color:#475569;cursor:pointer;display:flex;align-items:center;gap:8px;transition:0.3s;" onmouseover="this.style.background='#f8fafc'">
            <i class="fas fa-server" style="color:#10b981;"></i> Tester Serveur (Mercure)
          </button>
          
        </div>
        <p id="test-status" style="font-size:11px;color:#94a3b8;margin-top:12px;display:none;">Envoi en cours...</p>
      </div>
    </div>
  </div>
</div>

<script>
  // --- EXISTING TEST SCRIPTS ---
  function testNotificationUI() {
    if (window.showGlobalNotification) {
      window.showGlobalNotification({
        action: 'add_trajet',
        message: '👋 Hello ! Le système de Toast fonctionne parfaitement.'
      });
    } else {
      alert('Système de notification non initialisé.');
    }
  }

  document.getElementById('btn-test-server').addEventListener('click', async function() {
    const btn = this;
    const status = document.getElementById('test-status');
    const originalContent = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Envoi...';
    status.style.display = 'block';
    status.innerText = 'Appel de l\'API Mercure...';

    try {
      const response = await fetch('{{ path("app_admin_test_notif") }}', { method: 'POST' });
      const data = await response.json();
      
      if (data.status === 'success') {
        status.style.color = '#10b981';
        status.innerText = '✅ ' + data.message;
      } else {
        throw new Error(data.message);
      }
    } catch (error) {
      status.style.color = '#ef4444';
      status.innerText = '❌ ' + error.message;
    } finally {
      setTimeout(() => {
        btn.disabled = false;
        btn.innerHTML = originalContent;
      }, 2000);
    }
  });
</script>
{% endblock %}
