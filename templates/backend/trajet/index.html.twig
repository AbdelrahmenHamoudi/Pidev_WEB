{% extends 'backend/baseend.html.twig' %}

{% block title %}Gestion des Trajets - RE7LA Admin{% endblock %}
{% block breadcrumb %}Trajets{% endblock %}
{% block page_title %}Liste globale des trajets{% endblock %}

{% block body %}
<div class="card">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;border-bottom:1px solid #f0f2f5;padding-bottom:20px;">
        <div>
            <h1 style="font-size:20px;font-weight:700;color:#2C3E50;margin-bottom:5px;">Tous les Trajets</h1>
            <p style="color:#94a3b8;font-size:13px;">{{ trajets|length }} trajet{{ trajets|length != 1 ? 's' : '' }} au total</p>
        </div>
    </div>

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Départ</th>
                    <th>Arrivée</th>
                    <th>Date</th>
                    <th>Passagers</th>
                    <th>Véhicule</th>
                    <th>Client (ID)</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                {% for trajet in trajets %}
                    <tr>
                        <td>#{{ trajet.id }}</td>
                        <td style="font-weight:600;">{{ trajet.pointDepart }}</td>
                        <td style="font-weight:600;">{{ trajet.pointArrivee }}</td>
                        <td>{{ trajet.dateReservation ? trajet.dateReservation|date('d/m/Y H:i') : '—' }}</td>
                        <td>{{ trajet.nbPersonnes }}</td>
                        <td>
                            {% if trajet.idVoiture %}
                                <span style="color:#3498db;">{{ trajet.idVoiture.marque }} {{ trajet.idVoiture.modele }}</span>
                            {% else %}
                                <span style="color:#94a3b8;">Aucun</span>
                            {% endif %}
                        </td>
                        <td>
                            <span class="status-badge s-ok" style="background:rgba(26,188,156,0.1);color:#16a085;">
                                <i class="fas fa-user"></i> {{ trajet.idUtilisateur }}
                            </span>
                        </td>
                        <td>
                            {% set s = trajet.statut %}
                            <span class="status-badge 
                                {% if s == 'Réservé' %}s-pend
                                {% elseif s == 'Confirmé' %}s-ok
                                {% elseif s == 'Annulé' %}s-cancel
                                {% else %}s-navy{% endif %}">
                                {{ s }}
                            </span>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" style="text-align:center;padding:40px;color:#94a3b8;">Aucun trajet trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
