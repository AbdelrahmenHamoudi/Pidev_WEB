{% extends 'backend/baseend.html.twig' %}

{% block title %}Codes de secours - Admin RE7LA{% endblock %}
{% block breadcrumb %}2FA{% endblock %}
{% block page_title %}Codes de Secours{% endblock %}

{% block body %}
<div style="max-width:560px;margin:0 auto;">
    <div style="background:#fff;border-radius:20px;padding:40px;box-shadow:0 4px 20px rgba(0,0,0,0.08);text-align:center;">
        <div style="width:70px;height:70px;background:rgba(34,197,94,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:32px;color:#22c55e;">
            <i class="fas fa-check"></i>
        </div>

        <h2 style="font-size:20px;font-weight:700;color:#2C3E50;margin-bottom:8px;">2FA Activee !</h2>
        <p style="color:#6b7280;font-size:14px;margin-bottom:20px;">Sauvegardez ces codes de secours :</p>

        <div style="background:#fffbeb;border:1px solid rgba(245,158,11,0.25);border-radius:12px;padding:14px;margin-bottom:20px;text-align:left;">
            <p style="color:#92400e;font-size:13px;font-weight:600;margin:0;">
                <i class="fas fa-exclamation-triangle" style="color:#f59e0b;"></i>
                Chaque code ne peut etre utilise qu'une seule fois.
            </p>
        </div>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:20px;">
            {% for code in backupCodes %}
                <div class="backup-code-item" style="background:#f8fafc;border:2px solid #e8ecf0;border-radius:10px;padding:10px;font-family:monospace;font-size:15px;font-weight:800;color:#2C3E50;letter-spacing:2px;">
                    {{ code }}
                </div>
            {% endfor %}
        </div>

        <button onclick="copyBackupCodes()" id="copyBtn" style="width:100%;height:46px;border:2px solid #e8ecf0;border-radius:12px;background:#fff;color:#2C3E50;font-weight:700;cursor:pointer;margin-bottom:10px;">
            <i class="fas fa-copy"></i> Copier les codes
        </button>

        <a href="{{ path('app_admin_profile') }}" style="display:flex;align-items:center;justify-content:center;width:100%;height:46px;border:none;border-radius:12px;background:linear-gradient(135deg,#1ABC9C,#16a085);color:#fff;font-weight:700;text-decoration:none;">
            <i class="fas fa-check-circle" style="margin-right:6px;"></i> J'ai sauvegarde mes codes
        </a>
    </div>
</div>

<script>
function copyBackupCodes() {
    const codes = [];
    document.querySelectorAll('.backup-code-item').forEach(el => codes.push(el.textContent.trim()));
    navigator.clipboard.writeText("RE7LA - Codes de secours 2FA\n\n" + codes.join('\n')).then(() => {
        const btn = document.getElementById('copyBtn');
        btn.innerHTML = '<i class="fas fa-check"></i> Copies !';
        btn.style.borderColor = '#22c55e';
        btn.style.color = '#22c55e';
        setTimeout(() => {
            btn.innerHTML = '<i class="fas fa-copy"></i> Copier les codes';
            btn.style.borderColor = '#e8ecf0';
            btn.style.color = '#2C3E50';
        }, 3000);
    });
}
</script>
{% endblock %}