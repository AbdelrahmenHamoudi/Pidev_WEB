<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}RE7LA - Voyagez Autrement{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">

    <style>
        :root {
            --bleu-ceil: #87CEEB;
            --bleu-ceil-dark: #5dade2;
            --rouge: #e74c3c;
            --vert-pistache: #93C572;
            --vert-pistache-dark: #7cb342;
            --dark: #2c3e50;
            --light: #f8f9fa;
            --navbar-height: 96px;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body { font-family: 'Poppins', sans-serif; overflow-x: hidden; background: var(--light); }

        .navbar-re7la {
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(20px);
            box-shadow: 0 4px 30px rgba(0,0,0,0.1);
            border-bottom: 1px solid rgba(255,255,255,0.3);
            padding: 15px 0;
            transition: all 0.3s ease;
            min-height: var(--navbar-height);
            display: flex;
            align-items: center;
            z-index: 1100;
        }
        .navbar-re7la.scrolled { background: rgba(255,255,255,0.95); padding: 10px 0; }

        .navbar-brand {
            font-weight: 800; font-size: 2rem;
            background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache));
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
        }
        .navbar-brand span { color: var(--rouge); -webkit-text-fill-color: var(--rouge); }

        .nav-link {
            font-weight: 500; color: var(--dark) !important;
            margin: 0 10px; position: relative; transition: all 0.3s ease;
        }
        .nav-link::after {
            content: ''; position: absolute; bottom: -5px; left: 0;
            width: 0; height: 3px;
            background: linear-gradient(90deg, var(--bleu-ceil), var(--vert-pistache));
            transition: width 0.3s ease; border-radius: 2px;
        }
        .nav-link:hover::after, .nav-link.active::after { width: 100%; }

        .btn-nav {
            background: linear-gradient(135deg, var(--bleu-ceil), var(--bleu-ceil-dark));
            color: white !important; padding: 10px 25px !important;
            border-radius: 50px; font-weight: 600; transition: all 0.3s ease;
            border: none; text-decoration: none; display: inline-flex; align-items: center;
        }
        .btn-nav:hover { transform: translateY(-3px); box-shadow: 0 10px 25px rgba(135,206,235,0.4); }

        main.site-main { padding-top: calc(var(--navbar-height) + 24px); }

        /* ── Activité cards ── */
        .activite-card {
            border-radius: 20px; overflow: hidden;
            box-shadow: 0 8px 30px rgba(0,0,0,0.1);
            transition: all 0.3s ease; background: #fff;
        }
        .activite-card:hover { transform: translateY(-8px); box-shadow: 0 20px 50px rgba(0,0,0,0.15); }
        .activite-card img { width: 100%; height: 220px; object-fit: cover; }
        .activite-card .card-body { padding: 20px; }
        .badge-type {
            padding: 5px 14px; border-radius: 20px; font-size: 12px; font-weight: 600;
            background: rgba(135,206,235,0.15); color: var(--bleu-ceil-dark);
        }
        .btn-voir {
            background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache));
            color: #fff; border: none; padding: 10px 24px; border-radius: 50px;
            font-weight: 600; font-size: 14px; text-decoration: none;
            display: inline-block; transition: all 0.3s;
        }
        .btn-voir:hover { transform: translateY(-2px); color: #fff; box-shadow: 0 8px 20px rgba(135,206,235,0.4); }

        /* ── Planning card ── */
        .planning-card {
            border-radius: 16px; padding: 20px 24px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.06);
            border: 2px solid transparent; transition: all 0.3s; margin-bottom: 16px;
            background: #fff;
        }
        .planning-card:hover { border-color: var(--bleu-ceil); transform: translateY(-3px); }
        .btn-reserver {
            background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache));
            color: #fff; border: none; padding: 12px 28px; border-radius: 50px;
            font-weight: 600; font-size: 14px; cursor: pointer; transition: all 0.3s; width: 100%;
        }
        .btn-reserver:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(135,206,235,0.4); }
        .btn-reserver:disabled { background: #ccc; cursor: not-allowed; transform: none; }

        {% block extra_styles %}{% endblock %}
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

    {# ══════════════ NAVBAR ══════════════ #}
    <nav class="navbar navbar-expand-lg navbar-re7la fixed-top">
        <div class="container">
            <a class="navbar-brand" href="{{ path('activite_index_front') }}">RE<span>7</span>LA</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">

                    <li class="nav-item">
                        <a class="nav-link {{ app.request.attributes.get('_route') == 'activite_index_front' ? 'active' : '' }}"
                           href="{{ path('activite_index_front') }}">
                            <i class="fas fa-hiking me-1"></i>Activités
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#contact">Contact</a>
                    </li>

                    {# Lien vers le backoffice #}
                    <li class="nav-item ms-lg-3">
                        <a class="btn-nav" href="{{ path('activite_index') }}">
                            <i class="fas fa-cog me-2"></i>Admin
                        </a>
                    </li>

                </ul>
            </div>
        </div>
    </nav>

    {# ══════════════ CONTENU ══════════════ #}
    <main class="site-main">

        {# Flash messages globaux #}
        <div class="container">
            {% for message in app.flashes('success') %}
                <div style="background:#d1fae5;color:#065f46;padding:14px 20px;border-radius:12px;
                            margin-bottom:16px;font-weight:600;">
                    <i class="fas fa-check-circle me-2"></i>{{ message }}
                </div>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <div style="background:#fee2e2;color:#991b1b;padding:14px 20px;border-radius:12px;
                            margin-bottom:16px;font-weight:600;">
                    <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
                </div>
            {% endfor %}
        </div>

        {% block body %}{% endblock %}
    </main>

    {# ══════════════ FOOTER ══════════════ #}
    <footer id="contact" style="background:var(--dark);color:white;padding:60px 0 30px;margin-top:100px;">
        <div class="container">
            <div class="row">
                <div class="col-lg-4 mb-4">
                    <h3 style="font-weight:800;margin-bottom:20px;">
                        RE<span style="color:var(--rouge);">7</span>LA
                    </h3>
                    <p style="color:#aaa;line-height:1.8;">
                        Votre partenaire de confiance pour des voyages inoubliables en Tunisie.
                        Découvrez des expériences uniques et authentiques.
                    </p>
                </div>
                <div class="col-lg-3 col-md-4 mb-4">
                    <h5 style="font-weight:600;margin-bottom:20px;color:var(--vert-pistache);">Liens rapides</h5>
                    <ul style="list-style:none;padding:0;">
                        <li style="margin-bottom:10px;">
                            <a href="{{ path('activite_index_front') }}" style="color:#aaa;text-decoration:none;">
                                Activités
                            </a>
                        </li>
                        <li style="margin-bottom:10px;">
                            <a href="#contact" style="color:#aaa;text-decoration:none;">Contact</a>
                        </li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4 mb-4">
                    <h5 style="font-weight:600;margin-bottom:20px;color:var(--vert-pistache);">Contact</h5>
                    <ul style="list-style:none;padding:0;color:#aaa;">
                        <li style="margin-bottom:10px;">
                            <i class="fas fa-map-marker-alt me-2" style="color:var(--rouge);"></i>Tunis, Tunisie
                        </li>
                        <li style="margin-bottom:10px;">
                            <i class="fas fa-envelope me-2" style="color:var(--rouge);"></i>contact@re7la.tn
                        </li>
                    </ul>
                </div>
            </div>
            <hr style="border-color:#444;margin:40px 0 20px;">
            <div class="text-center" style="color:#777;">
                <p>&copy; 2024 RE7LA. Tous droits réservés.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 1000, once: true });
        window.addEventListener('scroll', function() {
            const navbar = document.querySelector('.navbar-re7la');
            if (window.scrollY > 50) navbar.classList.add('scrolled');
            else navbar.classList.remove('scrolled');
        });
    </script>

    {% block javascripts %}{% endblock %}
</body>
</html>
