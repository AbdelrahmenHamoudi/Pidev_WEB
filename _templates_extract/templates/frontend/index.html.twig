        </div>
    </div>
</section>

<!-- CTA SECTION -->
<section class="cta-section" id="contact">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8" data-aos="zoom-in">
                <div class="cta-box">
                    <h2>Prêt à vivre l'aventure ?</h2>
                    <p>Rejoignez plus de 50 000 voyageurs satisfaits et réservez votre prochain voyage avec RE7LA.</p>
