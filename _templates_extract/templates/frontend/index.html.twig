{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}RE7LA - Réservez votre voyage au Maroc{% endblock %}

{% block extra_styles %}
<style>
    /* DESTINATIONS CARDS */
    .destinations-section {
        padding: 100px 0;
        background: linear-gradient(180deg, #fff 0%, rgba(135, 206, 235, 0.05) 100%);
    }

    .section-header {
        text-align: center;
        margin-bottom: 60px;
    }

    .section-header h2 {
        font-size: 2.8rem;
        font-weight: 800;
        color: var(--dark);
        margin-bottom: 15px;
    }

    .section-header p {
        color: #777;
        font-size: 1.1rem;
    }

    .destination-card {
        border-radius: 25px;
        overflow: hidden;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        transition: all 0.4s ease;
        background: white;
        margin-bottom: 30px;
    }

    .destination-card:hover {
        transform: translateY(-15px);
        box-shadow: 0 25px 60px rgba(0,0,0,0.15);
    }

    .destination-img {
        height: 250px;
        background-size: cover;
        background-position: center;
        position: relative;
    }

    .destination-badge {
        position: absolute;
        top: 20px;
        left: 20px;
        background: linear-gradient(135deg, var(--rouge), #c0392b);
        color: white;
        padding: 8px 20px;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .destination-content {
        padding: 30px;
    }

    .destination-content h4 {
        font-weight: 700;
        font-size: 1.4rem;
        margin-bottom: 10px;
    }

    .destination-content p {
        color: #777;
        font-size: 0.95rem;
        margin-bottom: 20px;
    }

    .destination-price {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--bleu-ceil);
    }

    .destination-price small {
        color: #999;
        font-size: 0.9rem;
        font-weight: 400;
    }

    .btn-reserver {
        background: linear-gradient(135deg, var(--vert-pistache), var(--vert-pistache-dark));
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
    }

    .btn-reserver:hover {
        transform: scale(1.05);
        box-shadow: 0 10px 30px rgba(147, 197, 114, 0.4);
        color: white;
    }

    /* SERVICES SECTION */
    .services-section {
        padding: 100px 0;
        background: white;
    }

    .service-box {
        text-align: center;
        padding: 40px 30px;
        border-radius: 25px;
        background: white;
        box-shadow: 0 10px 40px rgba(0,0,0,0.08);
        transition: all 0.4s ease;
        margin-bottom: 30px;
    }

    .service-box:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.12);
    }

    .service-icon {
        width: 90px;
        height: 90px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 25px;
        font-size: 2.2rem;
        color: white;
    }

    .service-icon.blue {
        background: linear-gradient(135deg, var(--bleu-ceil), var(--bleu-ceil-dark));
        box-shadow: 0 10px 30px rgba(135, 206, 235, 0.4);
    }

    .service-icon.green {
        background: linear-gradient(135deg, var(--vert-pistache), var(--vert-pistache-dark));
        box-shadow: 0 10px 30px rgba(147, 197, 114, 0.4);
    }

    .service-icon.red {
        background: linear-gradient(135deg, var(--rouge), #c0392b);
        box-shadow: 0 10px 30px rgba(231, 76, 60, 0.4);
    }

    .service-box h4 {
        font-weight: 700;
        margin-bottom: 15px;
        color: var(--dark);
    }

    .service-box p {
        color: #777;
        font-size: 0.95rem;
        line-height: 1.7;
    }

    /* STATS SECTION */
    .stats-section {
        padding: 80px 0;
        background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache));
        position: relative;
        overflow: hidden;
    }

    .stats-section::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        animation: slide 20s linear infinite;
    }

    @keyframes slide {
        0% { transform: translate(0, 0); }
        100% { transform: translate(60px, 60px); }
    }

    .stat-item {
        text-align: center;
        color: white;
        position: relative;
        z-index: 1;
    }

    .stat-number {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .stat-label {
        font-size: 1.1rem;
        opacity: 0.9;
    }

    /* TESTIMONIALS */
    .testimonials-section {
        padding: 100px 0;
        background: linear-gradient(180deg, rgba(147, 197, 114, 0.05) 0%, #fff 100%);
    }

    .testimonial-card {
        background: white;
        border-radius: 25px;
        padding: 40px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.08);
        text-align: center;
        margin-bottom: 30px;
    }

    .testimonial-avatar {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        margin: 0 auto 20px;
        border: 4px solid var(--bleu-ceil);
        overflow: hidden;
    }

    .testimonial-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .testimonial-text {
        font-style: italic;
        color: #555;
        margin-bottom: 20px;
        line-height: 1.8;
    }

    .testimonial-author {
        font-weight: 700;
        color: var(--dark);
    }

    .stars {
        color: #f1c40f;
        margin-bottom: 15px;
    }

    /* CTA SECTION */
    .cta-section {
        padding: 100px 0;
        background: linear-gradient(135deg, rgba(135, 206, 235, 0.1), rgba(147, 197, 114, 0.1));
        text-align: center;
    }

    .cta-box {
        background: white;
        border-radius: 30px;
        padding: 60px;
        box-shadow: 0 20px 60px rgba(0,0,0,0.1);
    }

    .cta-box h2 {
        font-size: 2.5rem;
        font-weight: 800;
        margin-bottom: 20px;
        color: var(--dark);
    }

    .cta-box p {
        color: #777;
        font-size: 1.1rem;
        margin-bottom: 30px;
    }

    .btn-cta {
        background: linear-gradient(135deg, var(--rouge), #c0392b);
        color: white;
        padding: 18px 50px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 1.1rem;
        text-decoration: none;
        display: inline-block;
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(231, 76, 60, 0.3);
    }

    .btn-cta:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(231, 76, 60, 0.4);
        color: white;
    }
</style>
{% endblock %}

{% block body %}
<!-- HERO SECTION -->
<section class="hero-section">
    <div class="hero-bg"></div>
    <div class="floating-shape shape-1"></div>
    <div class="floating-shape shape-2"></div>
    <div class="floating-shape shape-3"></div>
    
    <div class="container hero-content">
        <div class="row align-items-center" style="min-height: 90vh; padding-top: 100px;">
            <div class="col-lg-6" data-aos="fade-right">
                <h1 class="hero-title">
                    Découvrez le <span class="gradient-text">Maroc</span> autrement
                </h1>
                <p class="hero-subtitle">
                    Réservez vos voyages, hôtels et excursions en quelques clics. 
                    Des expériences uniques vous attendent.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="#destinations" class="btn btn-lg" style="background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache)); color: white; border-radius: 50px; padding: 15px 40px; font-weight: 600;">
                        <i class="fas fa-compass me-2"></i>Explorer
                    </a>
                    <a href="{{ path('app_login') }}" class="btn btn-lg btn-outline-dark" style="border-radius: 50px; padding: 15px 40px; font-weight: 600;">
                        <i class="fas fa-user me-2"></i>Mon compte
                    </a>
                </div>
            </div>
            
            <div class="col-lg-6" data-aos="fade-left">
                <div class="booking-card">
                    <h3><i class="fas fa-calendar-check me-2" style="color: var(--bleu-ceil);"></i>Réservez maintenant</h3>
                    <form>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" style="font-weight: 500; color: #555;">Destination</label>
                                <select class="form-control form-control-re7la">
                                    <option>Choisissez...</option>
                                    <option>Marrakech</option>
                                    <option>Casablanca</option>
                                    <option>Essaouira</option>
                                    <option>Chefchaouen</option>
                                    <option>Sahara</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" style="font-weight: 500; color: #555;">Type</label>
                                <select class="form-control form-control-re7la">
                                    <option>Choisissez...</option>
                                    <option>Hôtel</option>
                                    <option>Riad</option>
                                    <option>Excursion</option>
                                    <option>Vol + Hôtel</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" style="font-weight: 500; color: #555;">Arrivée</label>
                                <input type="date" class="form-control form-control-re7la">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" style="font-weight: 500; color: #555;">Départ</label>
                                <input type="date" class="form-control form-control-re7la">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" style="font-weight: 500; color: #555;">Adultes</label>
                                <select class="form-control form-control-re7la">
                                    <option>1</option>
                                    <option>2</option>
                                    <option>3</option>
                                    <option>4+</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" style="font-weight: 500; color: #555;">Enfants</label>
                                <select class="form-control form-control-re7la">
                                    <option>0</option>
                                    <option>1</option>
                                    <option>2</option>
                                    <option>3+</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-rechercher mt-3">
                                    <i class="fas fa-search me-2"></i>Rechercher
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- STATS SECTION -->
<section class="stats-section">
    <div class="container">
        <div class="row">
            <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="0">
                <div class="stat-item">
                    <div class="stat-number">500+</div>
                    <div class="stat-label">Hôtels partenaires</div>
                </div>
            </div>
            <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="100">
                <div class="stat-item">
                    <div class="stat-number">50k+</div>
                    <div class="stat-label">Voyageurs satisfaits</div>
                </div>
            </div>
            <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="200">
                <div class="stat-item">
                    <div class="stat-number">200+</div>
                    <div class="stat-label">Excursions</div>
                </div>
            </div>
            <div class="col-md-3 col-6" data-aos="fade-up" data-aos-delay="300">
                <div class="stat-item">
                    <div class="stat-number">4.9</div>
                    <div class="stat-label">Note moyenne</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- DESTINATIONS SECTION -->
<section class="destinations-section" id="destinations">
    <div class="container">
        <div class="section-header" data-aos="fade-up">
            <h2>Destinations populaires</h2>
            <p>Découvrez nos destinations les plus demandées par nos voyageurs</p>
        </div>
        
        <div class="row">
            <div class="col-lg-4 col-md-6" data-aos="fade-up" data-aos-delay="0">
                <div class="destination-card">
                    <div class="destination-img" style="background-image: url('https://images.unsplash.com/photo-1597212618440-806262de4f6b?w=500');">
                        <span class="destination-badge">Populaire</span>
                    </div>
                    <div class="destination-content">
                        <h4>Marrakech</h4>
                        <p>Ville rouge aux mille couleurs, découvrez ses jardins, palais et souks.</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="destination-price">
                                450€ <small>/personne</small>
                            </div>
