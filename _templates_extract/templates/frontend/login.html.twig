{% extends 'frontend/base_frontend.html.twig' %}

{% block title %}Connexion - RE7LA{% endblock %}

{% block extra_styles %}
<style>
    .auth-section {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, rgba(135, 206, 235, 0.1), rgba(147, 197, 114, 0.1));
        padding: 120px 20px 50px;
        position: relative;
        overflow: hidden;
    }

    .auth-shape {
        position: absolute;
        border-radius: 50%;
        opacity: 0.1;
    }

    .auth-shape-1 {
        width: 500px;
        height: 500px;
        background: var(--bleu-ceil);
        top: -250px;
        right: -250px;
    }

    .auth-shape-2 {
        width: 400px;
        height: 400px;
        background: var(--vert-pistache);
        bottom: -200px;
        left: -200px;
    }

    .auth-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(20px);
        border-radius: 30px;
        padding: 50px;
        box-shadow: 0 25px 80px rgba(0, 0, 0, 0.15);
        border: 1px solid rgba(255, 255, 255, 0.5);
        width: 100%;
        max-width: 450px;
        position: relative;
        z-index: 1;
    }

    .auth-logo {
        text-align: center;
        margin-bottom: 35px;
    }

    .auth-logo h2 {
        font-weight: 800;
        font-size: 2.5rem;
        background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .auth-logo h2 span {
        color: var(--rouge);
        -webkit-text-fill-color: var(--rouge);
    }

    .auth-logo p {
        color: #777;
        margin-top: 10px;
    }

    .form-floating {
        margin-bottom: 20px;
    }

    .form-floating input {
        border: 2px solid #e8e8e8;
        border-radius: 15px;
        height: 60px;
        padding: 20px 20px 10px;
        font-size: 15px;
        transition: all 0.3s ease;
        background: white;
    }

    .form-floating input:focus {
        border-color: var(--bleu-ceil);
        box-shadow: 0 0 0 4px rgba(135, 206, 235, 0.2);
    }

    .form-floating label {
        padding-left: 20px;
        color: #999;
    }

    .btn-auth {
        width: 100%;
        padding: 15px;
        background: linear-gradient(135deg, var(--bleu-ceil), var(--vert-pistache));
        color: white;
        border: none;
        border-radius: 15px;
        font-weight: 600;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 10px;
    }

    .btn-auth:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 40px rgba(135, 206, 235, 0.4);
    }

    .auth-links {
        text-align: center;
        margin-top: 25px;
    }

    .auth-links a {
        color: var(--bleu-ceil);
        text-decoration: none;
        font-weight: 500;
        transition: color 0.3s ease;
    }

    .auth-links a:hover {
        color: var(--vert-pistache);
    }

    .auth-divider {
        display: flex;
        align-items: center;
        margin: 30px 0;
        color: #999;
    }

    .auth-divider::before,
    .auth-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #e0e0e0;
    }

    .auth-divider span {
        padding: 0 15px;
        font-size: 14px;
    }

    .social-auth {
        display: flex;
        gap: 15px;
        justify-content: center;
    }

    .social-btn {
        flex: 1;
        padding: 12px;
        border-radius: 12px;
        border: 2px solid #e8e8e8;
        background: white;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        font-weight: 500;
    }

    .social-btn:hover {
        border-color: var(--bleu-ceil);
        background: rgba(135, 206, 235, 0.05);
    }

    .alert-danger {
        background: linear-gradient(135deg, #fee, #fcc);
        border: 1px solid var(--rouge);
        color: var(--rouge);
        padding: 15px;
        border-radius: 12px;
        margin-bottom: 20px;
        font-size: 14px;
    }
</style>
{% endblock %}

{% block body %}
<section class="auth-section">
    <div class="auth-shape auth-shape-1"></div>
    <div class="auth-shape auth-shape-2"></div>
    
    <div class="auth-card" data-aos="zoom-in">
        <div class="auth-logo">
            <h2>RE<span>7</span>LA</h2>
            <p>Connectez-vous à votre compte</p>
        </div>
        
        {% if error %}
            <div class="alert alert-danger">
                <i class="fas fa-exclamation-circle me-2"></i>
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}
        
        <form method="post" action="{{ path('app_login') }}">
            <div class="form-floating">
                <input type="email" class="form-control" id="email" name="_username" placeholder="email@example.com" required>
                <label for="email"><i class="fas fa-envelope me-2"></i>Adresse email</label>
            </div>
            
            <div class="form-floating">
                <input type="password" class="form-control" id="password" name="_password" placeholder="Mot de passe" required>
                <label for="password"><i class="fas fa-lock me-2"></i>Mot de passe</label>
            </div>
            
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="remember" name="_remember_me">
                    <label class="form-check-label" for="remember" style="color: #666; font-size: 14px;">
                        Se souvenir de moi
                    </label>
                </div>
                <a href="{{ path('app_forgot_password') }}" style="color: var(--bleu-ceil); font-size: 14px; text-decoration: none;">
                    Mot de passe oublié ?
                </a>
            </div>
            
            <button type="submit" class="btn-auth">
                <i class="fas fa-sign-in-alt me-2"></i>Se connecter
            </button>
        </form>
        
        <div class="auth-divider">
            <span>ou continuez avec</span>
        </div>
        
        <div class="social-auth">
            <button class="social-btn">
                <i class="fab fa-google" style="color: #DB4437;"></i>
                Google
            </button>
            <button class="social-btn">
                <i class="fab fa-facebook-f" style="color: #4267B2;"></i>
                Facebook
            </button>
        </div>
        
        <div class="auth-links">
            <p style="color: #777; margin: 0;">
                Pas encore de compte ? 
                <a href="#">Créer un compte</a>
            </p>
            <p style="margin-top: 15px;">
                <a href="{{ path('app_home') }}"><i class="fas fa-arrow-left me-2"></i>Retour à l'accueil</a>
            </p>
        </div>
    </div>
</section>
{% endblock %}
